<Window x:Class="ClassroomToolkit.App.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于"
        Height="Auto" Width="340"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        ShowInTaskbar="False"
        Topmost="True">

    <Border Background="{StaticResource Brush_Window_Atmosphere}" CornerRadius="16" Margin="10" BorderBrush="{StaticResource Brush_Border}" BorderThickness="1">
        <Border.Effect>
            <!-- 统一深邃浮层阴影 -->
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="12" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. 标题栏 - 紧凑精致版 -->
            <Grid Grid.Row="0" Height="40" Background="Transparent" MouseLeftButtonDown="OnTitleBarDrag">
                <TextBlock Text="关于" FontWeight="SemiBold" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}" FontSize="13"/>
                <Button Style="{StaticResource Style_IconButton}" Click="OnCloseClick" HorizontalAlignment="Right" Margin="0,0,8,0">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="10" Height="10"/>
                </Button>
            </Grid>
            <Border Grid.Row="0" VerticalAlignment="Bottom" Height="1" Background="{StaticResource Brush_Border}"/>

            <!-- 2. 内容 -->
            <Border Grid.Row="1" Margin="20" Background="{StaticResource Brush_Background_L2}" CornerRadius="8" Padding="16,16" BorderBrush="Transparent">
                <StackPanel>
                    <!-- App Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Width="40" Height="40" CornerRadius="8" Background="{StaticResource Brush_Primary}" Margin="0,0,12,0" BorderBrush="Transparent">
                            <Border.Effect>
                                <DropShadowEffect Color="{StaticResource Color_Primary_Main}" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/>
                            </Border.Effect>
                            <Path Data="{StaticResource Icon_RollCall}" Fill="#FAFAFA" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="课堂工具箱" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Brush_Text_Primary}"/>
                            <TextBlock Text="Version 6.0" FontSize="12" Foreground="{StaticResource Brush_Text_Tertiary}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Margin="0,0,0,6" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="12">作者：广州番禺王耀强</TextBlock>
                    <TextBlock Margin="0,0,0,6" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="12">公众号：sciman逸居</TextBlock>
                    <TextBlock Margin="0,0,0,6" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="12">"初中物理教研"Q群：323728546</TextBlock>

                    <WrapPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="知乎主页：" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="12"/>
                        <TextBlock>
                            <Hyperlink NavigateUri="https://www.zhihu.com/people/sciman/columns" RequestNavigate="OnRequestNavigate" Foreground="{StaticResource Brush_Primary}">sciman</Hyperlink>
                        </TextBlock>
                    </WrapPanel>

                    <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="GitHub：" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="12"/>
                        <TextBlock>
                            <Hyperlink NavigateUri="https://github.com/sciman-top/ClassroomTools" RequestNavigate="OnRequestNavigate" Foreground="{StaticResource Brush_Primary}">sciman-top/ClassroomTools</Hyperlink>
                        </TextBlock>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- 3. 底部按钮 -->
            <Button Grid.Row="2" Content="关闭"
                    Style="{StaticResource Style_PrimaryButton}"
                    HorizontalAlignment="Right"
                    Margin="0,0,16,16"
                    Width="72"
                    Padding="0"
                    Height="30"
                    Click="OnCloseClick"/>
        </Grid>
    </Border>
</Window>