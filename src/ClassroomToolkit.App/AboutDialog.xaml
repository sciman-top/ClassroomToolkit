<Window x:Class="ClassroomToolkit.App.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于"
        Height="Auto" Width="380"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        ShowInTaskbar="False"
        Topmost="True">
    
    <Border Background="White" CornerRadius="8" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="4" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. 标题栏 -->
            <Grid Grid.Row="0" Height="40" Background="Transparent" MouseLeftButtonDown="OnTitleBarDrag">
                <TextBlock Text="关于" FontWeight="Bold" Margin="16,0" VerticalAlignment="Center" Foreground="#333"/>
                <Button Style="{StaticResource Style_IconButton}" Click="OnCloseClick" HorizontalAlignment="Right" Margin="0,0,8,0">
                    <Path Data="{StaticResource Icon_Close}" Fill="#888" Stretch="Uniform" Width="10" Height="10"/>
                </Button>
            </Grid>
            <Border Grid.Row="0" VerticalAlignment="Bottom" Height="1" Background="#F0F0F0"/>

            <!-- 2. 内容 -->
            <StackPanel Grid.Row="1" Margin="24">
                <!-- App Header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Path Data="{StaticResource Icon_Apps}" Fill="{StaticResource Brush_Primary}" Width="32" Height="32" Stretch="Uniform" Margin="0,0,16,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="课堂工具箱" FontSize="18" FontWeight="Bold" Foreground="#333"/>
                        <TextBlock Text="Version 6.0" FontSize="12" Foreground="#888"/>
                    </StackPanel>
                </StackPanel>
                
                <TextBlock Margin="0,0,0,8" Foreground="#555">作者：广州番禺王耀强</TextBlock>
                <TextBlock Margin="0,0,0,8" Foreground="#555">公众号：sciman逸居</TextBlock>
                <TextBlock Margin="0,0,0,8" Foreground="#555">“初中物理教研”Q群：323728546</TextBlock>

                <WrapPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="知乎主页：" Foreground="#555"/>
                    <TextBlock>
                        <Hyperlink NavigateUri="https://www.zhihu.com/people/sciman/columns" RequestNavigate="OnRequestNavigate">sciman</Hyperlink>
                    </TextBlock>
                </WrapPanel>

                <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="GitHub：" Foreground="#555"/>
                    <TextBlock>
                        <Hyperlink NavigateUri="https://github.com/sciman-top/ClassroomTools" RequestNavigate="OnRequestNavigate">sciman-top/ClassroomTools</Hyperlink>
                    </TextBlock>
                </WrapPanel>
            </StackPanel>

            <!-- 3. 底部 -->
            <Button Grid.Row="2" Content="关闭" 
                    Style="{StaticResource Style_PrimaryButton}" 
                    HorizontalAlignment="Right" 
                    Margin="0,0,16,16" 
                    Width="80" 
                    Click="OnCloseClick"/>
        </Grid>
    </Border>
</Window>