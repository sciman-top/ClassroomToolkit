<Window x:Class="ClassroomToolkit.App.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于"
        Height="Auto" Width="360"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        ShowInTaskbar="False"
        Topmost="True">

    <Border Background="White" CornerRadius="10" Margin="8" BorderBrush="{StaticResource Brush_Border}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="18" ShadowDepth="4" Opacity="0.1"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. 标题栏 - 紧凑精致版 -->
            <Grid Grid.Row="0" Height="42" Background="Transparent" MouseLeftButtonDown="OnTitleBarDrag">
                <!-- 品牌色顶部条 -->
                <Border Height="2" VerticalAlignment="Top" CornerRadius="2,2,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{StaticResource Color_Primary_Light}" Offset="0"/>
                            <GradientStop Color="{StaticResource Color_Primary_Main}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <TextBlock Text="关于" FontWeight="SemiBold" Margin="14,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}" FontSize="14"/>
                <Button Style="{StaticResource Style_IconButton}" Click="OnCloseClick" HorizontalAlignment="Right" Margin="0,0,8,0">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="11" Height="11"/>
                </Button>
            </Grid>
            <Border Grid.Row="0" VerticalAlignment="Bottom" Height="1" Background="{StaticResource Brush_Border}"/>

            <!-- 2. 内容 - 紧凑精致版 -->
            <StackPanel Grid.Row="1" Margin="22">
                <!-- App Header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Width="42" Height="42" CornerRadius="9" Background="{StaticResource Gradient_Accent}" Margin="0,0,14,0">
                        <Border.Effect>
                            <DropShadowEffect Color="{StaticResource Color_Primary_Main}" BlurRadius="10" ShadowDepth="0" Opacity="0.22"/>
                        </Border.Effect>
                        <Path Data="{StaticResource Icon_Apps}" Fill="White" Width="23" Height="23" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="课堂工具箱" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Brush_Text_Primary}"/>
                        <TextBlock Text="Version 6.0" FontSize="12" Foreground="{StaticResource Brush_Text_Secondary}" Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Margin="0,0,0,8" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="12">作者：广州番禺王耀强</TextBlock>
                <TextBlock Margin="0,0,0,8" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="12">公众号：sciman逸居</TextBlock>
                <TextBlock Margin="0,0,0,8" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="12">"初中物理教研"Q群：323728546</TextBlock>

                <WrapPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="知乎主页：" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="12"/>
                    <TextBlock>
                        <Hyperlink NavigateUri="https://www.zhihu.com/people/sciman/columns" RequestNavigate="OnRequestNavigate">sciman</Hyperlink>
                    </TextBlock>
                </WrapPanel>

                <WrapPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <TextBlock Text="GitHub：" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="12"/>
                    <TextBlock>
                        <Hyperlink NavigateUri="https://github.com/sciman-top/ClassroomTools" RequestNavigate="OnRequestNavigate">sciman-top/ClassroomTools</Hyperlink>
                    </TextBlock>
                </WrapPanel>
            </StackPanel>

            <!-- 3. 底部按钮 - 紧凑精致版 -->
            <Button Grid.Row="2" Content="关闭"
                    Style="{StaticResource Style_PrimaryButton}"
                    HorizontalAlignment="Right"
                    Margin="0,0,16,16"
                    Width="80"
                    Padding="16,7"
                    Click="OnCloseClick"/>
        </Grid>
    </Border>
</Window>