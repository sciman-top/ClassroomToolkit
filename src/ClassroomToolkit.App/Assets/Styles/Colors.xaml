<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:PresentationOptions="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

    <!-- ========================================
         Designed by: Gemini Art Director
         Theme: Modern Dark (Cyberpunk Evolved)
         Concept: Matte Dark, Vibrant Accents, Clean
         ======================================== -->

    <!-- ========== 核心品牌色 (Brand Colors) ========== -->
    
    <!-- 主色 (Primary) - Electric Cyan -->
    <Color x:Key="Color_Primary_Light">#64FFDA</Color>
    <Color x:Key="Color_Primary_Main">#00E5FF</Color> 
    <Color x:Key="Color_Primary_Dark">#00B8D4</Color>

    <SolidColorBrush x:Key="Brush_Primary" Color="{StaticResource Color_Primary_Main}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Primary_Light" Color="{StaticResource Color_Primary_Light}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Primary_Dark" Color="{StaticResource Color_Primary_Dark}" PresentationOptions:Freeze="true"/>

    <!-- 辅助色 (Accent) - Neon Purple -->
    <Color x:Key="Color_Accent_Light">#E040FB</Color>
    <Color x:Key="Color_Accent_Main">#D500F9</Color>
    <Color x:Key="Color_Accent_Dark">#AA00FF</Color>

    <SolidColorBrush x:Key="Brush_Accent" Color="{StaticResource Color_Accent_Main}" PresentationOptions:Freeze="true"/>

    <!-- ========== 功能色 (Functional Colors) ========== -->

    <!-- 危险 (Danger) - Coral Red -->
    <Color x:Key="Color_Danger">#FF5252</Color>
    <SolidColorBrush x:Key="Brush_Danger" Color="{StaticResource Color_Danger}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Danger_Light" Color="#FF8A80" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Danger_Surface" Color="#3E1B1B" PresentationOptions:Freeze="true"/>

    <!-- 警告 (Warning) - Amber -->
    <Color x:Key="Color_Warning">#FFAB00</Color>
    <SolidColorBrush x:Key="Brush_Warning" Color="{StaticResource Color_Warning}" PresentationOptions:Freeze="true"/>

    <!-- 成功 (Success) - Light Green -->
    <Color x:Key="Color_Success">#69F0AE</Color>
    <SolidColorBrush x:Key="Brush_Success" Color="{StaticResource Color_Success}" PresentationOptions:Freeze="true"/>

    <!-- 信息 (Info) - Light Blue -->
    <Color x:Key="Color_Info">#40C4FF</Color>
    <SolidColorBrush x:Key="Brush_Info" Color="{StaticResource Color_Info}" PresentationOptions:Freeze="true"/>

    <!-- ========== 沉浸式背景体系 (Immersive Backgrounds) ========== -->

    <!-- 层级 1: 窗口底色 (Deep Matte Black/Gray) -->
    <Color x:Key="Color_Background_L1">#121212</Color>
    <SolidColorBrush x:Key="Brush_Background" Color="{StaticResource Color_Background_L1}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Window_Atmosphere" Color="#121212" PresentationOptions:Freeze="true"/>

    <!-- 层级 2: 卡片背景 (Elevation 1) -->
    <Color x:Key="Color_Background_L2">#1E1E1E</Color> 
    <SolidColorBrush x:Key="Brush_Background_L2" Color="{StaticResource Color_Background_L2}" PresentationOptions:Freeze="true"/>
    
    <!-- 层级 3: 浮层/输入框 (Elevation 2) -->
    <Color x:Key="Color_Background_L3">#2D2D2D</Color>
    <SolidColorBrush x:Key="Brush_Background_L3" Color="{StaticResource Color_Background_L3}" PresentationOptions:Freeze="true"/>
    
    <!-- 强调背景 (Selected) -->
    <Color x:Key="Color_Surface_Active">#37373D</Color> 
    <SolidColorBrush x:Key="Brush_Surface_Active" Color="{StaticResource Color_Surface_Active}" PresentationOptions:Freeze="true"/>

    <!-- 悬停色 (Hover) -->
    <Color x:Key="Color_Surface_Hover">#323232</Color>
    <SolidColorBrush x:Key="Brush_Surface_Hover" Color="{StaticResource Color_Surface_Hover}" PresentationOptions:Freeze="true"/>
    
    <!-- 兼容性映射 -->
    <SolidColorBrush x:Key="Brush_Surface_Tint" Color="{StaticResource Color_Surface_Hover}" PresentationOptions:Freeze="true"/>

    <!-- 遮罩 -->
    <SolidColorBrush x:Key="Brush_Overlay_Dark" Color="#CC000000" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Overlay_Light" Color="#1FFFFFFF" PresentationOptions:Freeze="true"/>
    
    <!-- 玻璃质感辅助色 -->
    <SolidColorBrush x:Key="Brush_White_Translucent" Color="#1FFFFFFF" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_White_Translucent_Low" Color="#0DFFFFFF" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Glass_Border" Color="#33FFFFFF" PresentationOptions:Freeze="true"/>

    <!-- ========== 现代文本系统 (High Contrast) ========== -->

    <!-- 主要文本 (High Emphasis) - Near White -->
    <Color x:Key="Color_Text_Primary">#F5F5F5</Color>
    <SolidColorBrush x:Key="Brush_Text_Primary" Color="{StaticResource Color_Text_Primary}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Foreground" Color="{StaticResource Color_Text_Primary}" PresentationOptions:Freeze="true"/>

    <!-- 次要文本 (Medium Emphasis) - Light Gray -->
    <Color x:Key="Color_Text_Secondary">#B0BEC5</Color>
    <SolidColorBrush x:Key="Brush_Text_Secondary" Color="{StaticResource Color_Text_Secondary}" PresentationOptions:Freeze="true"/>

    <!-- 提示文本 (Disabled/Hint) -->
    <Color x:Key="Color_Text_Tertiary">#78909C</Color>
    <SolidColorBrush x:Key="Brush_Text_Tertiary" Color="{StaticResource Color_Text_Tertiary}" PresentationOptions:Freeze="true"/>

    <!-- 禁用 -->
    <Color x:Key="Color_Disabled">#424242</Color>
    <SolidColorBrush x:Key="Brush_Disabled" Color="{StaticResource Color_Disabled}" PresentationOptions:Freeze="true"/>

    <!-- 边框 -->
    <Color x:Key="Color_Border">#333333</Color>
    <SolidColorBrush x:Key="Brush_Border" Color="{StaticResource Color_Border}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Border_Light" Color="#4D4D4D" PresentationOptions:Freeze="true"/>
    
    <!-- 聚焦光环色 -->
    <SolidColorBrush x:Key="Brush_Focus_Glow" Color="#6600E5FF" PresentationOptions:Freeze="true"/>

    <!-- 兼容性映射 (Legacy) -->
    <SolidColorBrush x:Key="Brush_Border_Subtle" Color="#262626" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Border_Medium" Color="{StaticResource Color_Border}" PresentationOptions:Freeze="true"/>

    <!-- ========== 动态渐变 (Gradients) ========== -->

    <!-- 主品牌渐变 -->
    <LinearGradientBrush x:Key="Gradient_Primary" StartPoint="0,0" EndPoint="1,1" PresentationOptions:Freeze="true">
        <GradientStop Color="#00B8D4" Offset="0"/>
        <GradientStop Color="#00E5FF" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- 悬停态渐变 -->
    <LinearGradientBrush x:Key="Gradient_Primary_Hover" StartPoint="0,0" EndPoint="1,1" PresentationOptions:Freeze="true">
        <GradientStop Color="#18FFFF" Offset="0"/>
        <GradientStop Color="#84FFFF" Offset="1"/>
    </LinearGradientBrush>

    <!-- 启动球渐变 -->
    <LinearGradientBrush x:Key="Gradient_Launcher" StartPoint="0,0" EndPoint="1,1" PresentationOptions:Freeze="true">
        <GradientStop Color="#D500F9" Offset="0"/>
        <GradientStop Color="#651FFF" Offset="1"/>
    </LinearGradientBrush>

    <!-- 计时器渐变 -->
    <Color x:Key="Color_Timer_Neon">#69F0AE</Color>
    <SolidColorBrush x:Key="Brush_Timer_Neon" Color="{StaticResource Color_Timer_Neon}" PresentationOptions:Freeze="true"/>

    <LinearGradientBrush x:Key="Gradient_Active" StartPoint="0,0" EndPoint="1,0" PresentationOptions:Freeze="true">
        <GradientStop Color="#00E5FF" Offset="0"/>
        <GradientStop Color="#69F0AE" Offset="1"/>
    </LinearGradientBrush>

    <!-- 点名卡片背景 -->
    <LinearGradientBrush x:Key="Gradient_RollCall_Card" StartPoint="0.5,0" EndPoint="0.5,1" PresentationOptions:Freeze="true">
        <GradientStop Color="#2C2C2C" Offset="0"/>
        <GradientStop Color="#1E1E1E" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="Gradient_RollCall_Name" StartPoint="0,0" EndPoint="1,0" PresentationOptions:Freeze="true">
        <GradientStop Color="#1E1E1E" Offset="0"/>
        <GradientStop Color="#2C2C2C" Offset="1"/>
    </LinearGradientBrush>

    <!-- 画笔色 -->
    <Color x:Key="Color_Pen_Red">#FF5252</Color>
    <SolidColorBrush x:Key="Brush_Pen_Red" Color="{StaticResource Color_Pen_Red}" PresentationOptions:Freeze="true"/>
    <Color x:Key="Color_Pen_Blue">#40C4FF</Color>
    <SolidColorBrush x:Key="Brush_Pen_Blue" Color="{StaticResource Color_Pen_Blue}" PresentationOptions:Freeze="true"/>

    <!-- ========== 高级阴影系统 (Subtle Depth) ========== -->
    
    <!-- 1. 弥散光影 -->
    <DropShadowEffect x:Key="Shadow_Primary_Glow" Color="#00E5FF" BlurRadius="20" ShadowDepth="0" Opacity="0.4" RenderingBias="Quality"/>
    
    <!-- 2. 危险光影 -->
    <DropShadowEffect x:Key="Shadow_Danger_Glow" Color="#FF5252" BlurRadius="20" ShadowDepth="0" Opacity="0.3" RenderingBias="Quality"/>

    <!-- 3. 浮层阴影 (Elevated) -->
    <DropShadowEffect x:Key="Shadow_Floating" Color="#000000" BlurRadius="30" ShadowDepth="8" Opacity="0.5" RenderingBias="Quality"/>
    
    <!-- 4. 紧凑卡片阴影 -->
    <DropShadowEffect x:Key="Shadow_Card" Color="#000000" BlurRadius="4" ShadowDepth="1" Opacity="0.25" RenderingBias="Quality"/>

    <!-- 5. 极简边框阴影 -->
    <DropShadowEffect x:Key="Shadow_Subtle" Color="#000000" BlurRadius="2" ShadowDepth="1" Opacity="0.2" RenderingBias="Quality"/>

</ResourceDictionary>
