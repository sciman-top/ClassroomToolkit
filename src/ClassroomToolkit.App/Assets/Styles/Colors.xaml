<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:PresentationOptions="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

    <!-- ========================================
         Designed by: Gemini Art Director
         Theme: Modern Blue (Tech Blue & Azure)
         Concept: Professional, Unified, Clean, Compact
         ======================================== -->

    <!-- ========== 核心品牌色 (Brand Colors) ========== -->
    
    <!-- 主色 (Primary) - Tech Blue / Microsoft Blue Style -->
    <Color x:Key="Color_Primary_Light">#63B2F6</Color>
    <Color x:Key="Color_Primary_Main">#0078D4</Color> 
    <Color x:Key="Color_Primary_Dark">#005A9E</Color>

    <SolidColorBrush x:Key="Brush_Primary" Color="{StaticResource Color_Primary_Main}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Primary_Light" Color="{StaticResource Color_Primary_Light}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Primary_Dark" Color="{StaticResource Color_Primary_Dark}" PresentationOptions:Freeze="true"/>

    <!-- 辅助色 (Accent) - Cyan / Teal -->
    <Color x:Key="Color_Accent_Light">#4DD0E1</Color>
    <Color x:Key="Color_Accent_Main">#00BCD4</Color>
    <Color x:Key="Color_Accent_Dark">#0097A7</Color>

    <SolidColorBrush x:Key="Brush_Accent" Color="{StaticResource Color_Accent_Main}" PresentationOptions:Freeze="true"/>

    <!-- ========== 功能色 (Functional Colors) ========== -->

    <!-- 危险 (Danger) - Vermilion -->
    <Color x:Key="Color_Danger">#D32F2F</Color>
    <SolidColorBrush x:Key="Brush_Danger" Color="{StaticResource Color_Danger}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Danger_Light" Color="#EF5350" PresentationOptions:Freeze="true"/>
    <!-- 危险色背景 (用于浅色块) -->
    <SolidColorBrush x:Key="Brush_Danger_Surface" Color="#FFEBEE" PresentationOptions:Freeze="true"/>

    <!-- 警告 (Warning) - Amber -->
    <Color x:Key="Color_Warning">#FFB300</Color>
    <SolidColorBrush x:Key="Brush_Warning" Color="{StaticResource Color_Warning}" PresentationOptions:Freeze="true"/>

    <!-- 成功 (Success) - Green -->
    <Color x:Key="Color_Success">#2E7D32</Color>
    <SolidColorBrush x:Key="Brush_Success" Color="{StaticResource Color_Success}" PresentationOptions:Freeze="true"/>

    <!-- 信息 (Info) - Light Blue -->
    <Color x:Key="Color_Info">#0288D1</Color>
    <SolidColorBrush x:Key="Brush_Info" Color="{StaticResource Color_Info}" PresentationOptions:Freeze="true"/>

    <!-- ========== 沉浸式背景体系 (Immersive Backgrounds) ========== -->

    <!-- 层级 1: 卡片/悬浮物 (纯白) -->
    <Color x:Key="Color_Background_L1">#FFFFFF</Color>
    <SolidColorBrush x:Key="Brush_Background" Color="{StaticResource Color_Background_L1}" PresentationOptions:Freeze="true"/>

    <!-- 层级 2: 窗口底色 - 冷灰/微蓝 -->
    <Color x:Key="Color_Background_L2">#F3F9FD</Color> 
    <!-- 主窗口使用的微妙渐变背景 (Blue tint) -->
    <LinearGradientBrush x:Key="Brush_Window_Atmosphere" StartPoint="0,0" EndPoint="1,1" PresentationOptions:Freeze="true">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#F0F8FF" Offset="0.7"/> <!-- AliceBlue -->
        <GradientStop Color="#E6F2FF" Offset="1"/>
    </LinearGradientBrush>

    <!-- 层级 3: 输入框/深色块 (Cool Gray) -->
    <Color x:Key="Color_Background_L3">#F3F5F8</Color>
    <SolidColorBrush x:Key="Brush_Background_L3" Color="{StaticResource Color_Background_L3}" PresentationOptions:Freeze="true"/>
    
    <!-- 强调背景 (用于选中项) -->
    <Color x:Key="Color_Surface_Active">#E1F0FF</Color> <!-- Very Light Blue -->
    <SolidColorBrush x:Key="Brush_Surface_Active" Color="{StaticResource Color_Surface_Active}" PresentationOptions:Freeze="true"/>

    <!-- 悬停色 (用于按钮Hover - Cool Gray) -->
    <Color x:Key="Color_Surface_Hover">#E8EAED</Color>
    <SolidColorBrush x:Key="Brush_Surface_Hover" Color="{StaticResource Color_Surface_Hover}" PresentationOptions:Freeze="true"/>

    <!-- 遮罩 -->
    <SolidColorBrush x:Key="Brush_Overlay_Dark" Color="#99000000" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Overlay_Light" Color="#99FFFFFF" PresentationOptions:Freeze="true"/>
    
    <!-- 玻璃质感辅助色 -->
    <SolidColorBrush x:Key="Brush_White_Translucent" Color="#CCFFFFFF" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_White_Translucent_Low" Color="#66FFFFFF" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Glass_Border" Color="#40FFFFFF" PresentationOptions:Freeze="true"/>

    <!-- ========== 现代文本系统 (Compact Typography Colors) ========== -->

    <!-- 主要文本 (Dark Slate) -->
    <Color x:Key="Color_Text_Primary">#202124</Color>
    <SolidColorBrush x:Key="Brush_Text_Primary" Color="{StaticResource Color_Text_Primary}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Foreground" Color="{StaticResource Color_Text_Primary}" PresentationOptions:Freeze="true"/>

    <!-- 次要文本 (Cool Gray) -->
    <Color x:Key="Color_Text_Secondary">#5F6368</Color>
    <SolidColorBrush x:Key="Brush_Text_Secondary" Color="{StaticResource Color_Text_Secondary}" PresentationOptions:Freeze="true"/>

    <!-- 提示文本 -->
    <Color x:Key="Color_Text_Tertiary">#9AA0A6</Color>
    <SolidColorBrush x:Key="Brush_Text_Tertiary" Color="{StaticResource Color_Text_Tertiary}" PresentationOptions:Freeze="true"/>

    <!-- 禁用 -->
    <Color x:Key="Color_Disabled">#DADCE0</Color>
    <SolidColorBrush x:Key="Brush_Disabled" Color="{StaticResource Color_Disabled}" PresentationOptions:Freeze="true"/>

    <!-- 边框 -->
    <Color x:Key="Color_Border">#DADCE0</Color>
    <SolidColorBrush x:Key="Brush_Border" Color="{StaticResource Color_Border}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Border_Light" Color="#E8EAED" PresentationOptions:Freeze="true"/>
    <!-- 聚焦光环色 -->
    <SolidColorBrush x:Key="Brush_Focus_Glow" Color="#400078D4" PresentationOptions:Freeze="true"/>

    <!-- ========== 兼容性映射 (Legacy Compatibility) ========== -->
    <SolidColorBrush x:Key="Brush_Border_Subtle" Color="#F1F3F4" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Border_Medium" Color="{StaticResource Color_Border}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Background_L2" Color="{StaticResource Color_Background_L2}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Surface_Tint" Color="{StaticResource Color_Surface_Hover}" PresentationOptions:Freeze="true"/>


    <!-- ========== 动态渐变 (Modern Blue Gradients) ========== -->

    <!-- 主品牌渐变: Windows Blue -> Deep Azure -->
    <LinearGradientBrush x:Key="Gradient_Primary" StartPoint="0,0" EndPoint="0,1" PresentationOptions:Freeze="true">
        <GradientStop Color="#0078D4" Offset="0"/>
        <GradientStop Color="#0063B1" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- 悬停态渐变 (Lighter) -->
    <LinearGradientBrush x:Key="Gradient_Primary_Hover" StartPoint="0,0" EndPoint="0,1" PresentationOptions:Freeze="true">
        <GradientStop Color="#2B88D8" Offset="0"/>
        <GradientStop Color="#0078D4" Offset="1"/>
    </LinearGradientBrush>

    <!-- 启动球渐变: Vivid Azure -> Blue -->
    <LinearGradientBrush x:Key="Gradient_Launcher" StartPoint="0,0" EndPoint="1,1" PresentationOptions:Freeze="true">
        <GradientStop Color="#00C6FF" Offset="0"/>
        <GradientStop Color="#0072FF" Offset="1"/>
    </LinearGradientBrush>

    <!-- 计时器渐变 (Blue -> Cyan) -->
    <Color x:Key="Color_Timer_Neon">#4FC3F7</Color>
    <SolidColorBrush x:Key="Brush_Timer_Neon" Color="{StaticResource Color_Timer_Neon}" PresentationOptions:Freeze="true"/>

    <LinearGradientBrush x:Key="Gradient_Active" StartPoint="0,0" EndPoint="1,0" PresentationOptions:Freeze="true">
        <GradientStop Color="#29B6F6" Offset="0"/>
        <GradientStop Color="#66BB6A" Offset="1"/>
    </LinearGradientBrush>

    <!-- 点名卡片背景 -->
    <LinearGradientBrush x:Key="Gradient_RollCall_Card" StartPoint="0.5,0" EndPoint="0.5,1" PresentationOptions:Freeze="true">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#F1F8FF" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="Gradient_RollCall_Name" StartPoint="0,0" EndPoint="1,0" PresentationOptions:Freeze="true">
        <GradientStop Color="#E6F7FF" Offset="0"/>
        <GradientStop Color="#E0F2F1" Offset="1"/>
    </LinearGradientBrush>

    <!-- 画笔色 -->
    <Color x:Key="Color_Pen_Red">#D32F2F</Color>
    <SolidColorBrush x:Key="Brush_Pen_Red" Color="{StaticResource Color_Pen_Red}" PresentationOptions:Freeze="true"/>
    <Color x:Key="Color_Pen_Blue">#1976D2</Color>
    <SolidColorBrush x:Key="Brush_Pen_Blue" Color="{StaticResource Color_Pen_Blue}" PresentationOptions:Freeze="true"/>

    <!-- ========== 高级阴影系统 (Clean & Crisp Shadows) ========== -->
    
    <!-- 1. 弥散光影 (主色) -->
    <DropShadowEffect x:Key="Shadow_Primary_Glow" Color="#0078D4" BlurRadius="12" ShadowDepth="2" Opacity="0.3" RenderingBias="Quality"/>
    
    <!-- 2. 危险光影 -->
    <DropShadowEffect x:Key="Shadow_Danger_Glow" Color="#D32F2F" BlurRadius="10" ShadowDepth="2" Opacity="0.25" RenderingBias="Quality"/>

    <!-- 3. 浮层阴影 (Crisp) -->
    <DropShadowEffect x:Key="Shadow_Floating" Color="#000000" BlurRadius="24" ShadowDepth="8" Opacity="0.12" RenderingBias="Quality"/>
    
    <!-- 4. 紧凑卡片阴影 -->
    <DropShadowEffect x:Key="Shadow_Card" Color="#000000" BlurRadius="4" ShadowDepth="1" Opacity="0.08" RenderingBias="Quality"/>

    <!-- 5. 极简边框阴影 -->
    <DropShadowEffect x:Key="Shadow_Subtle" Color="#000000" BlurRadius="2" ShadowDepth="1" Opacity="0.05" RenderingBias="Quality"/>

</ResourceDictionary>
