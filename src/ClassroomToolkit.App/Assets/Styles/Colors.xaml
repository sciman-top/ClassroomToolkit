<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:PresentationOptions="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

    <!-- ========================================
         Designed by: Gemini Art Director
         Theme: Soft Tech (Iris & Mint)
         ======================================== -->

    <!-- ========== 核心品牌色 (Brand Colors) ========== -->
    
    <!-- 主色 (Primary) - Iris Purple: 艺术、创造力、科技 -->
    <Color x:Key="Color_Primary_Light">#A29BFE</Color>
    <Color x:Key="Color_Primary_Main">#6C5CE7</Color>
    <Color x:Key="Color_Primary_Dark">#4834D4</Color>

    <SolidColorBrush x:Key="Brush_Primary" Color="{StaticResource Color_Primary_Main}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Primary_Light" Color="{StaticResource Color_Primary_Light}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Primary_Dark" Color="{StaticResource Color_Primary_Dark}" PresentationOptions:Freeze="true"/>

    <!-- 辅助色 (Accent) - Mint Teal: 清新、通过、活力 -->
    <Color x:Key="Color_Accent_Light">#55EFC4</Color>
    <Color x:Key="Color_Accent_Main">#00B894</Color>
    <Color x:Key="Color_Accent_Dark">#008E70</Color>

    <SolidColorBrush x:Key="Brush_Accent" Color="{StaticResource Color_Accent_Main}" PresentationOptions:Freeze="true"/>

    <!-- ========== 功能色 (Functional Colors) ========== -->

    <!-- 危险 (Danger) - Soft Red -->
    <Color x:Key="Color_Danger">#FF7675</Color>
    <SolidColorBrush x:Key="Brush_Danger" Color="{StaticResource Color_Danger}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Danger_Light" Color="#FFB4B4" PresentationOptions:Freeze="true"/>

    <!-- 警告 (Warning) - Sunflower -->
    <Color x:Key="Color_Warning">#FDCB6E</Color>
    <SolidColorBrush x:Key="Brush_Warning" Color="{StaticResource Color_Warning}" PresentationOptions:Freeze="true"/>

    <!-- 成功 (Success) - Green -->
    <Color x:Key="Color_Success">#00B894</Color>
    <SolidColorBrush x:Key="Brush_Success" Color="{StaticResource Color_Success}" PresentationOptions:Freeze="true"/>

    <!-- 信息 (Info) - Blue -->
    <Color x:Key="Color_Info">#0984E3</Color>
    <SolidColorBrush x:Key="Brush_Info" Color="{StaticResource Color_Info}" PresentationOptions:Freeze="true"/>

    <!-- ========== 背景与层级 (Backgrounds & Surfaces) ========== -->

    <!-- 层级 1: 卡片/浮窗 (纯白) -->
    <Color x:Key="Color_Background_L1">#FFFFFF</Color>
    <SolidColorBrush x:Key="Brush_Background" Color="{StaticResource Color_Background_L1}" PresentationOptions:Freeze="true"/>

    <!-- 层级 2: 窗口底色 (极淡蓝灰) -->
    <Color x:Key="Color_Background_L2">#F4F7FA</Color>
    <SolidColorBrush x:Key="Brush_Background_L2" Color="{StaticResource Color_Background_L2}" PresentationOptions:Freeze="true"/>

    <!-- 层级 3: 输入框/深色块 (淡灰) -->
    <Color x:Key="Color_Background_L3">#DFE6E9</Color>
    <SolidColorBrush x:Key="Brush_Background_L3" Color="{StaticResource Color_Background_L3}" PresentationOptions:Freeze="true"/>

    <!-- 暗色背景 (用于HUD/计时器) -->
    <SolidColorBrush x:Key="Brush_Background_Dark" Color="#2D3436" PresentationOptions:Freeze="true"/>

    <!-- 悬停色 (极浅的主色) -->
    <Color x:Key="Color_Surface_Tint">#F0F3FF</Color>
    <SolidColorBrush x:Key="Brush_Surface_Tint" Color="{StaticResource Color_Surface_Tint}" PresentationOptions:Freeze="true"/>

    <!-- 遮罩 -->
    <SolidColorBrush x:Key="Brush_Overlay_Dark" Color="#992D3436" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Overlay_Light" Color="#99FFFFFF" PresentationOptions:Freeze="true"/>

    <!-- ========== 文本与边框 (Text & Borders) ========== -->

    <!-- 主要文本 (Dracula Dark) -->
    <Color x:Key="Color_Text_Primary">#2D3436</Color>
    <SolidColorBrush x:Key="Brush_Text_Primary" Color="{StaticResource Color_Text_Primary}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Foreground" Color="{StaticResource Color_Text_Primary}" PresentationOptions:Freeze="true"/>

    <!-- 次要文本 (Slate) -->
    <Color x:Key="Color_Text_Secondary">#636E72</Color>
    <SolidColorBrush x:Key="Brush_Text_Secondary" Color="{StaticResource Color_Text_Secondary}" PresentationOptions:Freeze="true"/>

    <!-- 提示文本 -->
    <Color x:Key="Color_Text_Tertiary">#B2BEC3</Color>
    <SolidColorBrush x:Key="Brush_Text_Tertiary" Color="{StaticResource Color_Text_Tertiary}" PresentationOptions:Freeze="true"/>

    <!-- 禁用 -->
    <Color x:Key="Color_Disabled">#D1D8E0</Color>
    <SolidColorBrush x:Key="Brush_Disabled" Color="{StaticResource Color_Disabled}" PresentationOptions:Freeze="true"/>

    <!-- 边框 -->
    <Color x:Key="Color_Border">#E1E8EE</Color>
    <SolidColorBrush x:Key="Brush_Border" Color="{StaticResource Color_Border}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Border_Medium" Color="#CED6E0" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Border_Subtle" Color="#F5F6FA" PresentationOptions:Freeze="true"/>

    <!-- 玻璃态描边 -->
    <SolidColorBrush x:Key="Brush_White_Translucent" Color="#80FFFFFF" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_White_Translucent_Low" Color="#40FFFFFF" PresentationOptions:Freeze="true"/>

    <!-- ========== 渐变与特效 (Gradients & Effects) ========== -->

    <!-- 主品牌渐变: Iris -> Light Purple -->
    <LinearGradientBrush x:Key="Gradient_Primary" StartPoint="0,0" EndPoint="1,1" PresentationOptions:Freeze="true">
        <GradientStop Color="#6C5CE7" Offset="0"/>
        <GradientStop Color="#a29bfe" Offset="1"/>
    </LinearGradientBrush>

    <!-- 启动球渐变: Cyan -> Blue -->
    <LinearGradientBrush x:Key="Gradient_Launcher" StartPoint="0,0" EndPoint="1,1" PresentationOptions:Freeze="true">
        <GradientStop Color="#00CEC9" Offset="0"/>
        <GradientStop Color="#0984E3" Offset="1"/>
    </LinearGradientBrush>

    <!-- 计时器渐变 -->
    <LinearGradientBrush x:Key="Gradient_Active" StartPoint="0,0" EndPoint="1,0" PresentationOptions:Freeze="true">
        <GradientStop Color="#55EFC4" Offset="0"/>
        <GradientStop Color="#00B894" Offset="1"/>
    </LinearGradientBrush>

    <!-- 点名卡片姓名区: 极光微渐变 (Aurora) -->
    <LinearGradientBrush x:Key="Gradient_RollCall_Name" StartPoint="0,0" EndPoint="1,1" PresentationOptions:Freeze="true">
        <GradientStop Color="#E3FDF5" Offset="0"/>      <!-- 极淡薄荷 -->
        <GradientStop Color="#FFE6FA" Offset="1"/>      <!-- 极淡紫粉 -->
    </LinearGradientBrush>

    <!-- 点名卡片背景: 微光 -->
    <LinearGradientBrush x:Key="Gradient_RollCall_Card" StartPoint="0,0" EndPoint="1,1" PresentationOptions:Freeze="true">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#F4F7FA" Offset="1"/>
    </LinearGradientBrush>

    <!-- 霓虹色 -->
    <Color x:Key="Color_Timer_Neon">#55EFC4</Color>
    <SolidColorBrush x:Key="Brush_Timer_Neon" Color="{StaticResource Color_Timer_Neon}" PresentationOptions:Freeze="true"/>

    <!-- 画笔色 -->
    <Color x:Key="Color_Pen_Red">#FF7675</Color>
    <SolidColorBrush x:Key="Brush_Pen_Red" Color="{StaticResource Color_Pen_Red}" PresentationOptions:Freeze="true"/>
    <Color x:Key="Color_Pen_Blue">#0984E3</Color>
    <SolidColorBrush x:Key="Brush_Pen_Blue" Color="{StaticResource Color_Pen_Blue}" PresentationOptions:Freeze="true"/>

    <!-- 玻璃 -->
    <SolidColorBrush x:Key="Brush_Glass_White" Color="#E6FFFFFF" PresentationOptions:Freeze="true"/>

    <!-- ========== 阴影系统 (Shadows) ========== -->

    <!-- 浮层阴影: 深邃 -->
    <DropShadowEffect x:Key="Shadow_Floating" Color="#2D3436" BlurRadius="25" ShadowDepth="8" Opacity="0.15" RenderingBias="Quality"/>
    
    <!-- 卡片阴影: 轻柔 -->
    <DropShadowEffect x:Key="Shadow_Card" Color="#636E72" BlurRadius="12" ShadowDepth="3" Opacity="0.08" RenderingBias="Quality"/>

    <!-- 内部阴影 -->
    <DropShadowEffect x:Key="Shadow_Inset" Color="#000000" BlurRadius="4" ShadowDepth="-1" Opacity="0.05" RenderingBias="Quality"/>

</ResourceDictionary>