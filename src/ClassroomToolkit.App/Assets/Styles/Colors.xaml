<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:PresentationOptions="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

    <!-- ========================================
         Designed by: Gemini Art Director
         Theme: Modern Slate (Dark Blue)
         Concept: Professional, Deep, Calm
         ======================================== -->

    <!-- ========== 1. 核心色板 (Slate Palette) ========== -->
    
    <!-- Backgrounds (Slate 900-800) -->
    <Color x:Key="Color_Bg_Deep">#0F172A</Color>    <!-- Slate 900: Window Background -->
    <Color x:Key="Color_Bg_Surface">#1E293B</Color>  <!-- Slate 800: Cards/Dialogs -->
    <Color x:Key="Color_Bg_Input">#334155</Color>    <!-- Slate 700: Inputs/Hovers -->
    <Color x:Key="Color_Bg_Overlay">#020617</Color>  <!-- Slate 950: Overlay base -->

    <!-- Accents (Blue 600) -->
    <Color x:Key="Color_Primary">#2563EB</Color>     <!-- Blue 600: Primary Action -->
    <Color x:Key="Color_Primary_Hover">#3B82F6</Color> <!-- Blue 500: Hover -->
    <Color x:Key="Color_Primary_Active">#1D4ED8</Color> <!-- Blue 700: Pressed -->
    <Color x:Key="Color_Primary_Glow">#60A5FA</Color> <!-- Blue 400: Glows -->

    <!-- Functional -->
    <Color x:Key="Color_Danger">#EF4444</Color>      <!-- Red 500 -->
    <Color x:Key="Color_Success">#10B981</Color>     <!-- Emerald 500 -->
    <Color x:Key="Color_Warning">#F59E0B</Color>     <!-- Amber 500 -->
    
    <!-- Text -->
    <Color x:Key="Color_Text_Primary">#F1F5F9</Color>   <!-- Slate 100 -->
    <Color x:Key="Color_Text_Secondary">#94A3B8</Color> <!-- Slate 400 -->
    <Color x:Key="Color_Text_Disabled">#475569</Color>  <!-- Slate 600 -->

    <!-- Borders -->
    <Color x:Key="Color_Border_Subtle">#334155</Color>  <!-- Slate 700 -->
    <Color x:Key="Color_Border_Strong">#475569</Color>  <!-- Slate 600 -->

    <!-- ========== 2. 笔刷系统 (Brushes) ========== -->

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="Brush_Background" Color="{StaticResource Color_Bg_Deep}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Window_Atmosphere" Color="{StaticResource Color_Bg_Deep}" PresentationOptions:Freeze="true"/>
    
    <SolidColorBrush x:Key="Brush_Background_L2" Color="{StaticResource Color_Bg_Surface}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Background_L3" Color="{StaticResource Color_Bg_Input}" PresentationOptions:Freeze="true"/>

    <!-- States -->
    <SolidColorBrush x:Key="Brush_Surface_Hover" Color="#334155" PresentationOptions:Freeze="true"/> <!-- Slate 700 -->
    <SolidColorBrush x:Key="Brush_Surface_Active" Color="#475569" PresentationOptions:Freeze="true"/> <!-- Slate 600 -->
    <SolidColorBrush x:Key="Brush_Surface_Tint" Color="#1E293B" PresentationOptions:Freeze="true"/>

    <!-- Primary -->
    <SolidColorBrush x:Key="Brush_Primary" Color="{StaticResource Color_Primary}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Primary_Light" Color="{StaticResource Color_Primary_Hover}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Primary_Dark" Color="{StaticResource Color_Primary_Active}" PresentationOptions:Freeze="true"/>

    <!-- Text -->
    <SolidColorBrush x:Key="Brush_Text_Primary" Color="{StaticResource Color_Text_Primary}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Text_Secondary" Color="{StaticResource Color_Text_Secondary}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Text_Tertiary" Color="{StaticResource Color_Text_Disabled}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Disabled" Color="#20FFFFFF" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Foreground" Color="{StaticResource Color_Text_Primary}" PresentationOptions:Freeze="true"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="Brush_Border" Color="{StaticResource Color_Border_Subtle}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Border_Light" Color="{StaticResource Color_Border_Strong}" PresentationOptions:Freeze="true"/>

    <!-- Functional -->
    <SolidColorBrush x:Key="Brush_Danger" Color="{StaticResource Color_Danger}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Danger_Surface" Color="#2A1215" PresentationOptions:Freeze="true"/> <!-- Kept for compatibility -->
    <SolidColorBrush x:Key="Brush_Danger_Light" Color="#F87171" PresentationOptions:Freeze="true"/>
    
    <SolidColorBrush x:Key="Brush_Success" Color="{StaticResource Color_Success}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Warning" Color="{StaticResource Color_Warning}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Info" Color="#38BDF8" PresentationOptions:Freeze="true"/>

    <!-- Translucency / Glass -->
    <SolidColorBrush x:Key="Brush_White_Translucent" Color="#1AFFFFFF" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_White_Translucent_Low" Color="#08FFFFFF" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Glass_Border" Color="#26FFFFFF" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Overlay_Dark" Color="#CC020617" PresentationOptions:Freeze="true"/>

    <!-- ========== 3. 渐变与特效 (Gradients & Effects) ========== -->

    <!-- Subtle Primary Gradient (Vertical) -->
    <LinearGradientBrush x:Key="Gradient_Primary" StartPoint="0,0" EndPoint="0,1" PresentationOptions:Freeze="true">
        <GradientStop Color="#3B82F6" Offset="0"/>
        <GradientStop Color="#2563EB" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Gradient_Primary_Hover" StartPoint="0,0" EndPoint="0,1" PresentationOptions:Freeze="true">
        <GradientStop Color="#60A5FA" Offset="0"/>
        <GradientStop Color="#3B82F6" Offset="1"/>
    </LinearGradientBrush>

    <!-- Legacy Mappings for Compatibility -->
    <LinearGradientBrush x:Key="Gradient_RollCall_Card" StartPoint="0.5,0" EndPoint="0.5,1" PresentationOptions:Freeze="true">
        <GradientStop Color="{StaticResource Color_Bg_Input}" Offset="0"/>
        <GradientStop Color="{StaticResource Color_Bg_Surface}" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="Gradient_RollCall_Name" StartPoint="0,0" EndPoint="1,0" PresentationOptions:Freeze="true">
        <GradientStop Color="{StaticResource Color_Bg_Surface}" Offset="0"/>
        <GradientStop Color="{StaticResource Color_Bg_Input}" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="Gradient_Launcher" StartPoint="0,0" EndPoint="1,1" PresentationOptions:Freeze="true">
        <GradientStop Color="#2563EB" Offset="0"/>
        <GradientStop Color="#0F172A" Offset="1"/>
    </LinearGradientBrush>
    
    <Color x:Key="Color_Timer_Neon">#10B981</Color>
    <SolidColorBrush x:Key="Brush_Timer_Neon" Color="{StaticResource Color_Timer_Neon}" PresentationOptions:Freeze="true"/>

    <!-- Shadows (Optimized for performance) -->
    <!-- 1. Soft Glow (Primary) -->
    <DropShadowEffect x:Key="Shadow_Primary_Glow" Color="#3B82F6" BlurRadius="16" ShadowDepth="0" Opacity="0.2" RenderingBias="Performance"/>
    
    <!-- 2. Danger Glow -->
    <DropShadowEffect x:Key="Shadow_Danger_Glow" Color="#EF4444" BlurRadius="16" ShadowDepth="0" Opacity="0.2" RenderingBias="Performance"/>

    <!-- 3. Floating (Deep) -->
    <DropShadowEffect x:Key="Shadow_Floating" Color="#000000" BlurRadius="32" ShadowDepth="8" Opacity="0.5" RenderingBias="Performance"/>
    
    <!-- 4. Card (Crisp) -->
    <DropShadowEffect x:Key="Shadow_Card" Color="#000000" BlurRadius="4" ShadowDepth="1" Opacity="0.3" RenderingBias="Performance"/>

    <!-- 5. Subtle Border substitute -->
    <DropShadowEffect x:Key="Shadow_Subtle" Color="#000000" BlurRadius="2" ShadowDepth="1" Opacity="0.2" RenderingBias="Performance"/>

    <!-- Pen Colors -->
    <Color x:Key="Color_Pen_Red">#EF4444</Color>
    <SolidColorBrush x:Key="Brush_Pen_Red" Color="{StaticResource Color_Pen_Red}" PresentationOptions:Freeze="true"/>
    <Color x:Key="Color_Pen_Blue">#3B82F6</Color>
    <SolidColorBrush x:Key="Brush_Pen_Blue" Color="{StaticResource Color_Pen_Blue}" PresentationOptions:Freeze="true"/>

</ResourceDictionary>
