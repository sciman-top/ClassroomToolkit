<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:PresentationOptions="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

    <!-- ========================================
         现代化色彩系统 - Modern Color Palette
         教育科技 · 清新现代 · 温暖专业
         ======================================== -->

    <!-- ========== 主色调系统 ========== -->

    <!-- 核心主色 - 渐变蓝紫系 -->
    <Color x:Key="Color_Primary_Light">#6C5CE7</Color>      <!-- 优雅紫蓝 -->
    <Color x:Key="Color_Primary_Main">#4A90E2</Color>       <!-- 现代蓝 -->
    <Color x:Key="Color_Primary_Dark">#2E5BFF</Color>       <!-- 深海蓝 -->

    <SolidColorBrush x:Key="Brush_Primary" Color="{StaticResource Color_Primary_Main}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Primary_Light" Color="{StaticResource Color_Primary_Light}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Primary_Dark" Color="{StaticResource Color_Primary_Dark}" PresentationOptions:Freeze="true"/>

    <!-- 辅助色 - 清新绿系 -->
    <Color x:Key="Color_Accent_Light">#00E5AA</Color>       <!-- 薄荷绿 -->
    <Color x:Key="Color_Accent_Main">#00C896</Color>        <!-- 翡翠绿 -->
    <Color x:Key="Color_Accent_Dark">#00A67D</Color>        <!-- 森林绿 -->

    <SolidColorBrush x:Key="Brush_Accent" Color="{StaticResource Color_Accent_Main}" PresentationOptions:Freeze="true"/>

    <!-- ========== 功能色系 ========== -->

    <!-- 成功/完成 -->
    <Color x:Key="Color_Success">#10B981</Color>           <!-- 现代绿 -->
    <SolidColorBrush x:Key="Brush_Success" Color="{StaticResource Color_Success}" PresentationOptions:Freeze="true"/>

    <!-- 警告/注意 -->
    <Color x:Key="Color_Warning">#F59E0B</Color>           <!-- 琥珀橙 -->
    <SolidColorBrush x:Key="Brush_Warning" Color="{StaticResource Color_Warning}" PresentationOptions:Freeze="true"/>

    <!-- 危险/删除/退出 -->
    <Color x:Key="Color_Danger">#EF4444</Color>            <!-- 珊瑚红 -->
    <SolidColorBrush x:Key="Brush_Danger" Color="{StaticResource Color_Danger}" PresentationOptions:Freeze="true"/>

    <!-- 信息/提示 -->
    <Color x:Key="Color_Info">#3B82F6</Color>              <!-- 天空蓝 -->
    <SolidColorBrush x:Key="Brush_Info" Color="{StaticResource Color_Info}" PresentationOptions:Freeze="true"/>

    <!-- ========== 背景层次系统 ========== -->

    <Color x:Key="Color_Background_L1">#FFFFFF</Color>      <!-- 纯白 - 卡片/主要内容 -->
    <Color x:Key="Color_Background_L2">#F8FAFC</Color>      <!-- 浅灰白 - 次要区域 -->
    <Color x:Key="Color_Background_L3">#F1F5F9</Color>      <!-- 灰白 - 工具栏/侧边 -->
    <Color x:Key="Color_Background_L4">#E2E8F0</Color>      <!-- 浅灰 - 分割线 -->

    <SolidColorBrush x:Key="Brush_Background" Color="{StaticResource Color_Background_L1}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Background_L2" Color="{StaticResource Color_Background_L2}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Background_L3" Color="{StaticResource Color_Background_L3}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Background_L4" Color="{StaticResource Color_Background_L4}" PresentationOptions:Freeze="true"/>

    <!-- 半透明背景 -->
    <SolidColorBrush x:Key="Brush_Background_Translucent" Color="#F8FFFFFF" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Background_Glass" Color="#F0FFFFFF" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_White_Translucent" Color="#80FFFFFF" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_White_Translucent_Low" Color="#40FFFFFF" PresentationOptions:Freeze="true"/>

    <!-- 特殊背景 -->
    <SolidColorBrush x:Key="Brush_Background_Dark" Color="#1A1F2C" PresentationOptions:Freeze="true"/>

    <!-- ========== 文本层次系统 ========== -->

    <Color x:Key="Color_Text_Primary">#1E293B</Color>      <!-- 深石板灰 -->
    <Color x:Key="Color_Text_Secondary">#64748B</Color>    <!-- 中性灰 -->
    <Color x:Key="Color_Text_Tertiary">#94A3B8</Color>     <!-- 浅灰 -->
    <Color x:Key="Color_Text_Disabled">#CBD5E1</Color>     <!-- 禁用灰 -->

    <SolidColorBrush x:Key="Brush_Foreground" Color="{StaticResource Color_Text_Primary}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Text_Primary" Color="{StaticResource Color_Text_Primary}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Text_Secondary" Color="{StaticResource Color_Text_Secondary}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Text_Tertiary" Color="{StaticResource Color_Text_Tertiary}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Disabled" Color="{StaticResource Color_Text_Disabled}" PresentationOptions:Freeze="true"/>

    <!-- ========== 语义色系统 ========== -->

    <!-- 浅色背景（用于悬停等状态） -->
    <Color x:Key="Color_Surface_Tint">#EFF6FF</Color>      <!-- 浅蓝背景 -->
    <SolidColorBrush x:Key="Brush_Surface_Tint" Color="{StaticResource Color_Surface_Tint}" PresentationOptions:Freeze="true"/>

    <!-- 边框色 -->
    <Color x:Key="Color_Border_Subtle">#E2E8F0</Color>     <!-- 微妙边框 -->
    <Color x:Key="Color_Border_Medium">#CBD5E1</Color>     <!-- 中等边框 -->

    <SolidColorBrush x:Key="Brush_Border" Color="{StaticResource Color_Border_Subtle}" PresentationOptions:Freeze="true"/>
    <SolidColorBrush x:Key="Brush_Border_Medium" Color="{StaticResource Color_Border_Medium}" PresentationOptions:Freeze="true"/>

    <!-- ========== 渐变定义 ========== -->

    <!-- 主按钮渐变 -->
    <LinearGradientBrush x:Key="Gradient_Primary" StartPoint="0,0" EndPoint="1,0" PresentationOptions:Freeze="true">
        <GradientStop Color="#667eea" Offset="0"/>
        <GradientStop Color="#764ba2" Offset="1"/>
    </LinearGradientBrush>

    <!-- 强调渐变 -->
    <LinearGradientBrush x:Key="Gradient_Accent" StartPoint="0,0" EndPoint="1,1" PresentationOptions:Freeze="true">
        <GradientStop Color="{StaticResource Color_Primary_Light}" Offset="0"/>
        <GradientStop Color="{StaticResource Color_Primary_Main}" Offset="1"/>
    </LinearGradientBrush>

    <!-- 工具栏渐变 -->
    <LinearGradientBrush x:Key="Gradient_Toolbar" StartPoint="0,0" EndPoint="0,1" PresentationOptions:Freeze="true">
        <GradientStop Color="#F8FAFC" Offset="0"/>
        <GradientStop Color="#F1F5F9" Offset="1"/>
    </LinearGradientBrush>

    <!-- 启动球渐变 -->
    <LinearGradientBrush x:Key="Gradient_Launcher" StartPoint="0,0" EndPoint="1,1" PresentationOptions:Freeze="true">
        <GradientStop Color="#4FACFE" Offset="0"/>
        <GradientStop Color="#00F2FE" Offset="1"/>
    </LinearGradientBrush>

    <!-- 计时器霓虹色 -->
    <Color x:Key="Color_Timer_Neon">#00FFAA</Color>
    <SolidColorBrush x:Key="Brush_Timer_Neon" Color="{StaticResource Color_Timer_Neon}" PresentationOptions:Freeze="true"/>
    
    <!-- 画笔预设色 -->
    <Color x:Key="Color_Pen_Red">#FF3B30</Color>
    <SolidColorBrush x:Key="Brush_Pen_Red" Color="{StaticResource Color_Pen_Red}" PresentationOptions:Freeze="true"/>
    <Color x:Key="Color_Pen_Blue">#007ACC</Color>
    <SolidColorBrush x:Key="Brush_Pen_Blue" Color="{StaticResource Color_Pen_Blue}" PresentationOptions:Freeze="true"/>

    <!-- 玻璃态背景 -->
    <LinearGradientBrush x:Key="Gradient_Glass" StartPoint="0,0" EndPoint="0,1" PresentationOptions:Freeze="true">
        <GradientStop Color="#F8FFFFFF" Offset="0"/>
        <GradientStop Color="#F0FFFFFF" Offset="1"/>
    </LinearGradientBrush>

    <!-- ========== 阴影系统 ========== -->

    <!-- 柔和阴影（用于卡片、对话框） -->
    <DropShadowEffect x:Key="Shadow_Soft" Color="Black" BlurRadius="20" ShadowDepth="4" Opacity="0.08"/>

    <!-- 强阴影（用于浮动元素） -->
    <DropShadowEffect x:Key="Shadow_Strong" Color="Black" BlurRadius="30" ShadowDepth="8" Opacity="0.12"/>

    <!-- 内阴影（用于凹陷效果） -->
    <DropShadowEffect x:Key="Shadow_Inset" Color="Black" BlurRadius="8" ShadowDepth="-2" Opacity="0.06"/>

    <!-- 光晕效果（用于品牌色元素） -->
    <DropShadowEffect x:Key="Shadow_Glow" Color="#4A90E2" BlurRadius="20" ShadowDepth="0" Opacity="0.25"/>

</ResourceDictionary>