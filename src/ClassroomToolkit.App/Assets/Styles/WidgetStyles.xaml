<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ========================================
         Theme: Classroom Focus Widget Styles
         Concept: Professional, compact, touch-aware
         ======================================== -->

    <!-- ========== Density Tokens ========== -->
    <sys:Double x:Key="Size_Button_Icon_Compact">32</sys:Double>
    <sys:Double x:Key="Size_Button_Icon_Regular">36</sys:Double>
    <sys:Double x:Key="Size_Button_Icon_Large">40</sys:Double>
    <sys:Double x:Key="Size_Touch_Target_Min">44</sys:Double>
    <sys:Double x:Key="Size_Touch_Target_Primary">48</sys:Double>
    <sys:Double x:Key="Size_Touch_Target_Bubble_Hit">56</sys:Double>
    <sys:Double x:Key="Size_Touch_ScrollBar">16</sys:Double>
    <sys:Double x:Key="Size_Button_Action_Regular">96</sys:Double>
    <sys:Double x:Key="Size_Button_Action_Height_Compact">32</sys:Double>
    <sys:Double x:Key="Size_Shell_TitleBar_Dialog">42</sys:Double>
    <sys:Double x:Key="Size_Shell_TitleBar_Management">46</sys:Double>
    <sys:Double x:Key="Size_Shell_TitleBar_Work">40</sys:Double>
    <sys:Double x:Key="Size_Icon_Glyph_XS">10</sys:Double>
    <sys:Double x:Key="Size_Icon_Glyph_SM">12</sys:Double>
    <sys:Double x:Key="Size_Icon_Glyph_MD">14</sys:Double>
    <sys:Double x:Key="Size_Icon_Glyph_LG">18</sys:Double>
    <sys:Double x:Key="FontSize_Body_S">12</sys:Double>
    <sys:Double x:Key="FontSize_Body_M">13</sys:Double>
    <sys:Double x:Key="FontSize_Title_Dialog">14</sys:Double>
    <sys:Double x:Key="FontSize_Title_Management">15</sys:Double>
    <sys:Double x:Key="Opacity_State_Disabled">0.4</sys:Double>
    <sys:Double x:Key="Opacity_State_Disabled_Soft">0.5</sys:Double>
    <sys:Double x:Key="Opacity_State_Pressed">0.8</sys:Double>
    <sys:Double x:Key="Opacity_State_Hover_Subtle">0.9</sys:Double>
    <sys:Double x:Key="Opacity_State_Icon_Disabled">0.3</sys:Double>
    <sys:Double x:Key="Opacity_Effect_InnerShine">0.5</sys:Double>
    <sys:Double x:Key="Opacity_Overlay_CloseButton">0.85</sys:Double>
    <sys:Double x:Key="Opacity_Overlay_SideRail">0.8</sys:Double>
    <sys:Double x:Key="Opacity_Overlay_HintBadge">0.9</sys:Double>
    <Thickness x:Key="BorderThickness_Regular">1</Thickness>
    <Thickness x:Key="BorderThickness_Emphasis">1.5</Thickness>
    <Duration x:Key="Motion_Duration_Fast">0:0:0.2</Duration>
    <Thickness x:Key="Spacing_Shell_DialogMargin">10</Thickness>
    <Thickness x:Key="Spacing_Shell_TitleInset">18,0,0,0</Thickness>
    <Thickness x:Key="Spacing_Shell_ActionBar">18,0,18,18</Thickness>
    <Thickness x:Key="Spacing_Shell_ActionGap">0,0,8,0</Thickness>
    <Thickness x:Key="Spacing_Shell_CloseButton_Dialog">0,0,10,0</Thickness>
    <Thickness x:Key="Spacing_Shell_CloseButton_Management">0,0,12,0</Thickness>
    <Thickness x:Key="Spacing_Shell_WorkTitleBar">18,0,14,0</Thickness>
    <Thickness x:Key="Spacing_Shell_WorkContent">18,2,18,8</Thickness>
    <Thickness x:Key="Spacing_Shell_WorkBottomBar">18,0,18,14</Thickness>
    <Thickness x:Key="Spacing_Shell_ManagementContent">12,8,12,8</Thickness>
    <Thickness x:Key="Spacing_Control_Input">8,5</Thickness>
    <Thickness x:Key="Spacing_Control_Dropdown">10,5</Thickness>
    <Thickness x:Key="Spacing_Control_ButtonFamily">12,6</Thickness>
    <Thickness x:Key="Spacing_Control_ButtonFamily_Compact">12,5</Thickness>
    <Thickness x:Key="Spacing_Control_ActionButton">14,0</Thickness>
    <Thickness x:Key="Spacing_Control_MenuItem">10,6</Thickness>
    <Thickness x:Key="Spacing_Control_ListItem">8,6</Thickness>
    <Thickness x:Key="Spacing_Control_TreeItem">4,2</Thickness>
    <Thickness x:Key="Spacing_Control_Header">8,6</Thickness>
    <Thickness x:Key="Spacing_Control_TabItem">12,4</Thickness>
    <Thickness x:Key="Spacing_Control_WorkShellBottomBar">8,4</Thickness>
    <Thickness x:Key="Spacing_Control_ManagementFooter">14,0</Thickness>
    <Thickness x:Key="Spacing_Control_BubbleShellRoot">5,4</Thickness>
    <Thickness x:Key="Spacing_Control_BubbleShellItem">4</Thickness>
    <Thickness x:Key="Spacing_Control_OverlayHintBadge">10,4</Thickness>
    <Thickness x:Key="Size_DialogMargin_Standard">20</Thickness>
    <CornerRadius x:Key="Radius_Shell_Dialog">12</CornerRadius>
    <CornerRadius x:Key="Radius_Shell_Management">12</CornerRadius>
    <CornerRadius x:Key="Radius_Shell_Work">14</CornerRadius>
    <CornerRadius x:Key="Radius_Shell_WorkBottomBar">10</CornerRadius>
    <CornerRadius x:Key="Radius_Shell_OverlaySideRail">20</CornerRadius>
    <CornerRadius x:Key="Radius_Shell_OverlayHintBadge">10</CornerRadius>
    <CornerRadius x:Key="Radius_Control_Panel">7</CornerRadius>
    <CornerRadius x:Key="Radius_Control_BubbleShellRoot">10</CornerRadius>
    <CornerRadius x:Key="Radius_Control_BubbleShellItem">7</CornerRadius>
    <sys:Double x:Key="FontSize_Control_Label">13</sys:Double>
    <sys:Double x:Key="FontSize_Control_Helper">12</sys:Double>

    <Style x:Key="Style_FocusRing" TargetType="{x:Type Control}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Control}">
                    <Border Margin="-2"
                            BorderBrush="{StaticResource Brush_Border_Focus}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius_Control_Panel}"
                            Opacity="0.88"
                            SnapsToDevicePixels="True"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========== 0. 全局默认样式 (Global Defaults) - 修复文字可见性 ========== -->
    
    <!-- TextBlock Global Default - Fix Black on Black -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
        <Setter Property="TextWrapping" Value="NoWrap"/>
        <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
    </Style>

    <Style x:Key="Style_FieldLabelText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Brush_Text_Secondary}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize_Body_M}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="Style_HelperText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Brush_Text_Tertiary}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize_Body_S}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="Style_SectionHeaderText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Brush_Text_Secondary}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize_Body_M}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="Style_TitleIconBadge" TargetType="Border">
        <Setter Property="Width" Value="26"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="CornerRadius" Value="7"/>
        <Setter Property="Background" Value="{StaticResource Brush_InputBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush_Border_Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="5"/>
    </Style>

    <!-- ToolTip Style -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource Brush_Surface_Primary}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush_Border_Strong}"/>
        <Setter Property="BorderThickness" Value="{StaticResource BorderThickness_Regular}"/>
        <Setter Property="Padding" Value="{StaticResource Spacing_Control_MenuItem}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize_Control_Helper}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}"/>
                        <Border.Effect>
                            <StaticResource ResourceKey="Shadow_Floating"/>
                        </Border.Effect>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ContextMenu Style -->
    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="{StaticResource Brush_Surface_Primary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush_Border_Strong}"/>
        <Setter Property="BorderThickness" Value="{StaticResource BorderThickness_Regular}"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel IsItemsHost="True"/>
                        <Border.Effect>
                            <StaticResource ResourceKey="Shadow_Floating"/>
                        </Border.Effect>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- MenuItem Style -->
    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
        <Setter Property="Padding" Value="{StaticResource Spacing_Control_MenuItem}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="Icon"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="Shortcut"/>
                                <ColumnDefinition Width="13"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter x:Name="Icon" ContentSource="Icon" Margin="6,0,6,0" VerticalAlignment="Center"/>
                            <ContentPresenter ContentSource="Header" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="InputGestureText" Grid.Column="2" Text="{TemplateBinding InputGestureText}" Margin="5,2,0,2" DockPanel.Dock="Right" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="{StaticResource FontSize_Control_Helper}"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush_Surface_Hover}"/>
                        </Trigger>
                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush_Surface_Active}"/>
                            <Setter Property="Foreground" Value="{StaticResource Brush_Primary_Light}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Separator Style -->
    <Style TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource Brush_Border_Subtle}"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="0,4"/>
        <Setter Property="Opacity" Value="0.5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Background="{TemplateBinding Background}" Height="{TemplateBinding Height}" SnapsToDevicePixels="true"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========== 1. 输入控件 (Inputs) ========== -->

    <Style TargetType="TextBox">
        <Setter Property="Padding" Value="{StaticResource Spacing_Control_Input}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="{StaticResource Brush_InputBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush_Border_Subtle}"/>
        <Setter Property="BorderThickness" Value="{StaticResource BorderThickness_Regular}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize_Body_M}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
        <Setter Property="CaretBrush" Value="{StaticResource Brush_Primary}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="SelectionBrush" Value="{StaticResource Brush_Primary}"/>
        <Setter Property="SelectionOpacity" Value="0.3"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                            </Grid>
                        </Border>
                        <!-- Focus Indicator -->
                        <Border x:Name="FocusUnderline" VerticalAlignment="Bottom" Height="2" CornerRadius="0,0,6,6" 
                                Background="{StaticResource Brush_Primary}" 
                                RenderTransformOrigin="0.5,0.5" Opacity="0" Margin="1,0,1,1">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="0"/>
                            </Border.RenderTransform>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource Brush_Text_Tertiary}"/>
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Brush_Surface_Hover}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Brush_Surface_Secondary}"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource Brush_Border_Focus}"/>
                            <Setter TargetName="FocusUnderline" Property="Opacity" Value="1"/> 
                        </Trigger>
                        <EventTrigger RoutedEvent="GotKeyboardFocus">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="FocusUnderline" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="{StaticResource Motion_Duration_Fast}"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                         <EventTrigger RoutedEvent="LostKeyboardFocus">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="FocusUnderline" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0" Duration="{StaticResource Motion_Duration_Fast}"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
        <Setter Property="Padding" Value="{StaticResource Spacing_Control_MenuItem}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush_Surface_Hover}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush_Surface_Active}"/>
                            <Setter Property="Foreground" Value="{StaticResource Brush_Primary_Light}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Padding" Value="{StaticResource Spacing_Control_Dropdown}"/>
        <Setter Property="Background" Value="{StaticResource Brush_InputBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush_Border_Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize_Body_M}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                </Grid.ColumnDefinitions>
                                
                                <ToggleButton x:Name="PART_DropDownToggle"
                                              Grid.ColumnSpan="2"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                     <ToggleButton.Template>
                                         <ControlTemplate TargetType="ToggleButton">
                                             <Border Background="Transparent"/>
                                         </ControlTemplate>
                                     </ToggleButton.Template>
                                </ToggleButton>
                                
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  IsHitTestVisible="False"
                                                  VerticalAlignment="Center"/>
                                
                                <!-- Arrow -->
                                <Path Grid.Column="1" Data="M0,0 L4,4 L8,0" Stroke="{StaticResource Brush_Text_Secondary}" StrokeThickness="1.5"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" 
                                      IsHitTestVisible="False" SnapsToDevicePixels="False"/>
                            </Grid>
                        </Border>
                        
                         <Popup x:Name="PART_Popup" AllowsTransparency="True" 
                                Placement="Bottom" IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                PopupAnimation="Slide" VerticalOffset="4">
                             <Border x:Name="DropDownBorder" 
                                     Background="{StaticResource Brush_Surface_Primary}" 
                                     BorderBrush="{StaticResource Brush_Border_Strong}" 
                                     BorderThickness="1" 
                                     CornerRadius="6"
                                     MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                     MinWidth="{Binding ActualWidth, ElementName=border}">
                                  <Border.Effect>
                                      <StaticResource ResourceKey="Shadow_Floating"/>
                                  </Border.Effect>
                                 <ScrollViewer Margin="0,4">
                                     <StackPanel IsItemsHost="True" />
                                 </ScrollViewer>
                             </Border>
                         </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                             <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource Brush_Text_Tertiary}"/>
                             <Setter TargetName="border" Property="Background" Value="{StaticResource Brush_Surface_Hover}"/>
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                             <Setter TargetName="border" Property="Background" Value="{StaticResource Brush_Surface_Active}"/>
                             <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource Brush_Border_Focus}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            <Setter Property="Foreground" Value="{StaticResource Brush_Text_Tertiary}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="8,0,0,0"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize_Control_Label}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" Background="Transparent" SnapsToDevicePixels="True">
                        <Border x:Name="box" Width="18" Height="18" CornerRadius="4" BorderThickness="{StaticResource BorderThickness_Emphasis}" 
                                BorderBrush="{StaticResource Brush_Text_Tertiary}" Background="Transparent">
                            <Path x:Name="check" Data="M3,8 L6,11 L14,3" Stroke="White" StrokeThickness="2" Visibility="Collapsed" Margin="0"
                                  SnapsToDevicePixels="False" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ContentPresenter Margin="{TemplateBinding Padding}" TextElement.Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="box" Property="Background" Value="{StaticResource Brush_Primary}"/>
                            <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Brush_Primary}"/>
                            <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsChecked" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Brush_Primary}"/>
                            <Setter TargetName="box" Property="Background" Value="{StaticResource Brush_White_Translucent_Low}"/>
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="RadioButton">
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="8,0,0,0"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize_Control_Label}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <StackPanel Orientation="Horizontal" Background="Transparent" SnapsToDevicePixels="True">
                        <Border x:Name="box" Width="18" Height="18" CornerRadius="9" BorderThickness="{StaticResource BorderThickness_Emphasis}" 
                                BorderBrush="{StaticResource Brush_Text_Tertiary}" Background="Transparent">
                            <Ellipse x:Name="check" Width="8" Height="8" Fill="{StaticResource Brush_Primary}" Visibility="Collapsed"/>
                        </Border>
                        <ContentPresenter Margin="{TemplateBinding Padding}" TextElement.Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Brush_Primary}"/>
                            <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                             <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Brush_Primary}"/>
                             <Setter TargetName="box" Property="Background" Value="{StaticResource Brush_White_Translucent_Low}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========== 2. 按钮样式 (Buttons) ========== -->

    <!-- Shared Button Family Base -->
    <Style x:Key="Style_ButtonFamilyBase" TargetType="Button">
        <Setter Property="BorderThickness" Value="{StaticResource BorderThickness_Regular}"/>
        <Setter Property="Padding" Value="{StaticResource Spacing_Control_ButtonFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize_Body_M}"/>
        <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
        <Setter Property="MinHeight" Value="{StaticResource Size_Button_Action_Height_Compact}"/>
        <Setter Property="MinWidth" Value="64"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource Style_FocusRing}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
    </Style>

    <!-- [Style_PrimaryButton] - Radiant Gradient & Glass -->
    <Style x:Key="Style_PrimaryButton" TargetType="Button" BasedOn="{StaticResource Style_ButtonFamilyBase}">
        <Setter Property="Background" Value="{StaticResource Gradient_Primary_Subtle}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush_Text_Black}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush_Border_Strong}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7">
                        <Grid>
                            <!-- Inner Shine -->
                            <Border BorderBrush="#24FFFFFF" BorderThickness="1" CornerRadius="6" Opacity="{StaticResource Opacity_Effect_InnerShine}"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </Border>
