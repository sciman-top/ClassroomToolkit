                            <Setter TargetName="border" Property="RenderTransform">
                                <Setter.Value>
                                    <TranslateTransform Y="-0.5"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource Brush_Border_Focus}"/>
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Brush_Surface_Hover}"/>
                            <Setter TargetName="glow" Property="Opacity" Value="0.22"/>
                            <Setter TargetName="AccentLine" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="iconBg" Property="Background" Value="{StaticResource Brush_Primary}"/>
                            <Setter TargetName="iconBg" Property="BorderBrush" Value="{StaticResource Brush_Primary}"/>
                            <Setter TargetName="icon" Property="Fill" Value="{StaticResource Brush_Text_Primary}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource Brush_Border_Focus}"/>
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Brush_Surface_Hover}"/>
                            <Setter TargetName="glow" Property="Opacity" Value="0.18"/>
