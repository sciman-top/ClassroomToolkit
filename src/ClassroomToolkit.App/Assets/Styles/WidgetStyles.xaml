    <Style x:Key="Style_WorkShellHeroTileButton" TargetType="Button">
        <Setter Property="Width" Value="104"/>
        <Setter Property="Height" Value="84"/>
        <Setter Property="Margin" Value="4"/>
        <Setter Property="Background" Value="{StaticResource Brush_Surface_Primary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush_Border_Subtle}"/>
        <Setter Property="BorderThickness" Value="{StaticResource BorderThickness_Regular}"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource Style_FocusRing}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="glow"
                                Margin="10"
                                CornerRadius="10"
                                Background="{StaticResource Brush_Primary}"
                                Opacity="0"
                                Effect="{x:Null}"/>
                        <Border x:Name="border"
                                Margin="2"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                </Grid.RowDefinitions>

                                <Border x:Name="iconBg"
                                        Grid.Row="0"
                                        Width="34"
                                        Height="34"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        CornerRadius="8"
                                        Background="{StaticResource Brush_InputBackground}"
                                        BorderBrush="{StaticResource Brush_Border_Subtle}"
                                        BorderThickness="1">
                                    <Border Width="24"
                                            Height="24"
                                            CornerRadius="7"
                                            Background="{StaticResource Brush_Surface_Secondary}">
                                        <Path x:Name="icon"
                                              Width="{StaticResource Size_Icon_Glyph_LG}"
                                              Height="{StaticResource Size_Icon_Glyph_LG}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Data="{TemplateBinding Tag}"
                                              Fill="{StaticResource Brush_Primary}"
                                              Stretch="Uniform"/>
                                    </Border>
                                </Border>

                                <TextBlock Grid.Row="1"
                                           HorizontalAlignment="Center"
                                           Text="{TemplateBinding Content}"
                                           FontSize="{StaticResource FontSize_Control_Helper}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush_Text_Secondary}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="78"/>

                                <Border x:Name="AccentLine"
                                        Grid.RowSpan="3"
                                        Height="2"
                                        Margin="16,0"
                                        VerticalAlignment="Bottom"
                                        Background="{StaticResource Brush_Primary}"
                                        CornerRadius="1"
                                        Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
