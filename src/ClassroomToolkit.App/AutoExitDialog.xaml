<Window x:Class="ClassroomToolkit.App.AutoExitDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置自动关闭"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="软件自动关闭时间&#10;（分钟，0 表示不自动关闭）：" Margin="0,0,0,8" />
        <TextBox x:Name="MinutesBox" Grid.Row="1" Width="120" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="确定" Width="80" Height="28" Margin="0,0,8,0" Click="OnConfirm" />
            <Button Content="取消" Width="80" Height="28" Click="OnCancel" />
        </StackPanel>
    </Grid>
</Window>
