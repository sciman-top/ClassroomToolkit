<Window x:Class="ClassroomToolkit.App.AutoExitDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="自动关闭"
        Height="Auto" Width="408"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        ShowInTaskbar="False"
        Topmost="True">
    <Border Style="{StaticResource Style_DialogShellWindowBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Style="{StaticResource Style_DialogShellTitleBar}" MouseLeftButtonDown="OnTitleBarDrag">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                    <Border Style="{StaticResource Style_TitleIconBadge}" Margin="0,0,8,0">
                        <Path Data="{StaticResource Icon_Clock}" Fill="{StaticResource Brush_Warning}" Stretch="Uniform"/>
                    </Border>
                    <TextBlock Text="自动关闭" Style="{StaticResource Style_DialogShellTitleText}" Margin="0"/>
                </StackPanel>
                <Button Style="{StaticResource Style_DialogShellCloseButton}" Click="OnCancel" ToolTip="关闭">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform"
                          Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}"/>
                </Button>
            </Grid>
            <Border Grid.Row="0" Style="{StaticResource Style_DialogShellDivider}"/>

            <Border Grid.Row="1" Margin="20,16,20,8" Style="{StaticResource Style_SettingCardBorder}" Padding="14">
                <StackPanel>
                    <TextBlock Text="自动关闭（分钟）" Foreground="{StaticResource Brush_Text_Secondary}" Margin="0,0,0,6"/>
                    <TextBlock Text="0 = 不自动关闭" Style="{StaticResource Style_HelperText}" Margin="0,0,0,10"/>
                    <TextBox x:Name="MinutesBox" Padding="8,4"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2" Style="{StaticResource Style_DialogShellActionBar}">
                <Button Content="取消" Style="{StaticResource Style_DialogShellSecondaryActionButton}" Click="OnCancel"/>
                <Button Content="确定" Style="{StaticResource Style_DialogShellPrimaryActionButton}" Click="OnConfirm"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
