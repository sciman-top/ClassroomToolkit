<Window x:Class="ClassroomToolkit.App.AutoExitDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="启动器设置"
        Height="Auto" Width="400"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        ShowInTaskbar="False"
        Topmost="True">
    
    <Border Background="White" CornerRadius="8" Margin="10" BorderBrush="Transparent">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="4" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title -->
                <RowDefinition Height="Auto"/> <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- 1. 标题栏 -->
            <Grid Grid.Row="0" Height="40" Background="Transparent" MouseLeftButtonDown="OnTitleBarDrag">
                <TextBlock Text="启动器设置" FontWeight="Bold" Margin="16,0" VerticalAlignment="Center" Foreground="#333"/>
                <Button Style="{StaticResource Style_IconButton}" Click="OnCancel" HorizontalAlignment="Right" Margin="0,0,8,0">
                    <Path Data="{StaticResource Icon_Close}" Fill="#888" Stretch="Uniform" Width="10" Height="10"/>
                </Button>
            </Grid>
            <Border Grid.Row="0" VerticalAlignment="Bottom" Height="1" Background="#F0F0F0"/>

            <!-- 2. 内容 -->
            <StackPanel Grid.Row="1" Margin="24">
                <TextBlock Text="自动关闭时间 (分钟)" Foreground="#666" Margin="0,0,0,8"/>
                <TextBlock Text="设置为 0 则不自动关闭" FontSize="12" Foreground="#999" Margin="0,0,0,8"/>
                
                <TextBox x:Name="MinutesBox" Padding="8" BorderThickness="1" BorderBrush="#DDD" VerticalContentAlignment="Center"/>
                
                <Button x:Name="DiagnosticButton" Content="运行系统兼容性诊断" 
                        Style="{StaticResource Style_PrimaryButton}"
                        Click="OnDiagnosticClick"
                        Height="36"
                        Margin="0,20,0,0"/>
            </StackPanel>

            <!-- 3. 按钮 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,0,16,16">
                <Button Content="取消" Style="{StaticResource Style_SecondaryButton}" Margin="0,0,10,0" Width="80" Click="OnCancel"/>
                <Button Content="确定" Style="{StaticResource Style_PrimaryButton}" Width="80" Click="OnConfirm"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>