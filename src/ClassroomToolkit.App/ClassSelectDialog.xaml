<Window x:Class="ClassroomToolkit.App.ClassSelectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择班级"
        Height="Auto" Width="336"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}">

    <Border Style="{StaticResource Style_DialogShellWindowBorder}"
            TextElement.Foreground="{StaticResource Brush_Text_Primary}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Style="{StaticResource Style_DialogShellTitleBar}" MouseLeftButtonDown="OnTitleBarDrag">
                <TextBlock Text="选择班级" Style="{StaticResource Style_DialogShellTitleText}"/>
                <Button Style="{StaticResource Style_DialogShellCloseButton}" Click="OnCancel" ToolTip="关闭">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}"/>
                </Button>
            </Grid>
            <Border Grid.Row="0" Style="{StaticResource Style_DialogShellDivider}"/>

            <Border Grid.Row="1" Margin="16,14,16,6" Style="{StaticResource Style_SettingCardBorder}" Padding="8">
                <StackPanel>
                    <TextBlock Text="选择后应用到当前点名窗口。"
                               Margin="4,0,4,8"
                               Foreground="{StaticResource Brush_Text_Tertiary}"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                    <ListBox x:Name="ClassList"
                             MaxHeight="240" MinHeight="120"
                             Style="{StaticResource Style_CleanListBox}"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2" Style="{StaticResource Style_DialogShellActionBar}">
                <Button Content="取消" Style="{StaticResource Style_DialogShellSecondaryActionButton}" Click="OnCancel"/>
                <Button Content="确定" Style="{StaticResource Style_DialogShellPrimaryActionButton}" Click="OnConfirm"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
