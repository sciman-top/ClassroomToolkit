<Window x:Class="ClassroomToolkit.App.ClassSelectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择班级"
        SizeToContent="WidthAndHeight"
        MinWidth="240"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ListBox x:Name="ClassList" Grid.Row="0" MinHeight="180" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="确定" Width="80" Height="32" Margin="0,0,8,0" Click="OnConfirm" />
            <Button Content="取消" Width="80" Height="32" Click="OnCancel" />
        </StackPanel>
    </Grid>
</Window>
