<Window x:Class="ClassroomToolkit.App.Diagnostics.DiagnosticsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="系统兼容性诊断"
        Width="620" Height="420"
        MinWidth="520" MinHeight="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        Topmost="True">

    <Border Style="{StaticResource Style_ManagementShellWindowBorder}" TextElement.Foreground="{StaticResource Brush_Text_Primary}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- 1. 标题栏 -->
            <Grid Grid.Row="0" Style="{StaticResource Style_ManagementShellTitleBar}" MouseLeftButtonDown="OnTitleBarDrag">
                <TextBlock Text="系统兼容性诊断" Style="{StaticResource Style_ManagementShellTitleText}"/>
                <Button Style="{StaticResource Style_ManagementShellCloseButton}" Click="OnCloseClick" ToolTip="关闭诊断窗口">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform"
                          Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}"/>
                </Button>
            </Grid>
            <Border Grid.Row="0" Style="{StaticResource Style_ManagementShellDivider}"/>

            <!-- 2. 内容 -->
            <Border Grid.Row="1" Style="{StaticResource Style_ManagementShellContentBorder}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="SummaryText"
                               Grid.Row="0"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Foreground="{StaticResource Brush_Primary}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10" />

                    <TabControl Grid.Row="1" BorderThickness="0" Background="Transparent">
                        <!-- Global TabControl style applied automatically -->

                        <TabItem Header="详情">
                            <TextBox x:Name="DetailBox"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     Padding="8"
                                     Background="{StaticResource Brush_InputBackground}"
                                     Foreground="{StaticResource Brush_Text_Primary}"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Margin="0,8,0,0"
                                     BorderThickness="0"/>
                        </TabItem>
                        <TabItem Header="建议">
                            <TextBox x:Name="SuggestionBox"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     Padding="8"
                                     Background="{StaticResource Brush_InputBackground}"
                                     Foreground="{StaticResource Brush_Text_Primary}"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Margin="0,8,0,0"
                                     BorderThickness="0"/>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <!-- 3. 按钮 -->
            <Border Grid.Row="2" Style="{StaticResource Style_ManagementShellFooterBorder}" CornerRadius="0,0,14,14">
                <Grid>
                    <TextBlock Text="诊断详情仅用于本机兼容性排查。"
                               Style="{StaticResource Style_ManagementShellFooterText}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="导出诊断包" Style="{StaticResource Style_ManagementShellFooterActionButton}" Margin="0,0,8,0" Click="OnExportBundleClick" />
                        <Button Content="复制全部" Style="{StaticResource Style_ManagementShellFooterActionButton}" Margin="0,0,8,0" Click="OnCopyClick" />
                        <Button Content="关闭" Style="{StaticResource Style_PrimaryButton}" Width="88" Height="32" Click="OnCloseClick" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
