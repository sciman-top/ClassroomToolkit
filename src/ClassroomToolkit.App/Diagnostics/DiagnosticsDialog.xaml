<Window x:Class="ClassroomToolkit.App.Diagnostics.DiagnosticsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="系统兼容性诊断"
        Width="620" Height="420"
        MinWidth="520" MinHeight="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        Topmost="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Assets/Styles/Colors.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Assets/Styles/Icons.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Assets/Styles/WidgetStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <Border Background="White" CornerRadius="8" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="4" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- 1. 标题栏 -->
            <Grid Grid.Row="0" Height="40" Background="Transparent" MouseLeftButtonDown="OnTitleBarDrag">
                <TextBlock Text="系统兼容性诊断" FontWeight="Bold" Margin="16,0" VerticalAlignment="Center" Foreground="#333"/>
                <Button Style="{StaticResource Style_IconButton}" Click="OnCloseClick" HorizontalAlignment="Right" Margin="0,0,8,0">
                    <Path Data="{StaticResource Icon_Close}" Fill="#888" Stretch="Uniform" Width="10" Height="10"/>
                </Button>
            </Grid>
            <Border Grid.Row="0" VerticalAlignment="Bottom" Height="1" Background="#F0F0F0"/>

            <!-- 2. 内容 -->
            <Grid Grid.Row="1" Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="SummaryText"
                           Grid.Row="0"
                           FontWeight="Bold"
                           FontSize="14"
                           Foreground="{StaticResource Brush_Primary}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10" />

                <TabControl Grid.Row="1" BorderThickness="0" Background="Transparent">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Padding" Value="12,6"/>
                            <Setter Property="HeaderTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="13"/>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>

                    <TabItem Header="详情">
                        <TextBox x:Name="DetailBox"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Padding="8"
                                 Background="#F8F9FA"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Margin="0,8,0,0"/>
                    </TabItem>
                    <TabItem Header="建议">
                        <TextBox x:Name="SuggestionBox"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Padding="8"
                                 Background="#F8F9FA"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Margin="0,8,0,0"/>
                    </TabItem>
                </TabControl>
            </Grid>

            <!-- 3. 按钮 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,0,16,16">
                <Button Content="复制全部" Style="{StaticResource Style_SecondaryButton}" Width="90" Margin="0,0,8,0" Click="OnCopyClick" />
                <Button Content="关闭" Style="{StaticResource Style_PrimaryButton}" Width="80" Click="OnCloseClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>