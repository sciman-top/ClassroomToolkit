<Window x:Class="ClassroomToolkit.App.Diagnostics.DiagnosticsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="兼容诊断"
        Width="640" Height="440"
        MinWidth="540" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        Topmost="True">

    <Border Style="{StaticResource Style_ManagementShellWindowBorder}" TextElement.Foreground="{StaticResource Brush_Text_Primary}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Style="{StaticResource Style_ManagementShellTitleBar}" MouseLeftButtonDown="OnTitleBarDrag">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="兼容诊断" Style="{StaticResource Style_ManagementShellTitleText}" Margin="0"/>
                    <TextBlock Text="环境检查" Style="{StaticResource Style_ManagementShellSubtitleText}" Margin="10,2,0,0"/>
                </StackPanel>
                <Button Style="{StaticResource Style_ManagementShellCloseButton}" Click="OnCloseClick" ToolTip="关闭">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform"
                          Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}"/>
                </Button>
            </Grid>
            <Border Grid.Row="0" Style="{StaticResource Style_ManagementShellDivider}"/>

            <Border Grid.Row="1" Style="{StaticResource Style_ManagementShellContentBorder}">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource Brush_Surface_Secondary}" BorderBrush="{StaticResource Brush_Border_Subtle}" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                        <TextBlock x:Name="SummaryText"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Foreground="{StaticResource Brush_Primary}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <TabControl Grid.Row="1" BorderThickness="0" Background="Transparent">
                        <TabItem Header="详情">
                            <TextBox x:Name="DetailBox"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     Padding="10"
                                     Background="{StaticResource Brush_InputBackground}"
                                     Foreground="{StaticResource Brush_Text_Primary}"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Margin="0,8,0,0"
                                     BorderThickness="0"/>
                        </TabItem>
                        <TabItem Header="建议">
                            <TextBox x:Name="SuggestionBox"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     Padding="10"
                                     Background="{StaticResource Brush_InputBackground}"
                                     Foreground="{StaticResource Brush_Text_Primary}"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Margin="0,8,0,0"
                                     BorderThickness="0"/>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource Style_ManagementShellFooterBorder}" CornerRadius="0,0,14,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="仅供本机排查。"
                               Grid.Column="0"
                               Style="{StaticResource Style_ManagementShellFooterText}"
                               Margin="0,0,12,0"
                               TextTrimming="CharacterEllipsis"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="恢复提示" Style="{StaticResource Style_ManagementShellFooterActionButton}" Width="Auto" MinWidth="132" Margin="0,0,8,0" Click="OnResetStartupWarningsClick" />
                        <Button Content="导出包" Style="{StaticResource Style_ManagementShellFooterActionButton}" Width="104" Margin="0,0,8,0" Click="OnExportBundleClick" />
                        <Button Content="复制结果" Style="{StaticResource Style_ManagementShellFooterActionButton}" Width="88" Margin="0,0,8,0" Click="OnCopyClick" />
                        <Button Content="关闭" Style="{StaticResource Style_PrimaryButton}" Width="84" Height="30" Click="OnCloseClick" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
