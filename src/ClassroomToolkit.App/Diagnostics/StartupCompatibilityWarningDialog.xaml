<Window x:Class="ClassroomToolkit.App.Diagnostics.StartupCompatibilityWarningDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="兼容提示"
        Width="640" Height="448"
        MinWidth="540" MinHeight="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        Topmost="True">

    <Border Style="{StaticResource Style_ManagementShellWindowBorder}" TextElement.Foreground="{StaticResource Brush_Text_Primary}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Style="{StaticResource Style_ManagementShellTitleBar}" MouseLeftButtonDown="OnTitleBarDrag">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <Border Style="{StaticResource Style_TitleIconBadge}" Margin="0,0,8,0">
                        <Path Data="{StaticResource Icon_Info}" Fill="{StaticResource Brush_Warning}" Stretch="Uniform"/>
                    </Border>
                    <TextBlock Text="兼容提示" Style="{StaticResource Style_ManagementShellTitleText}" Margin="0"/>
                    <TextBlock Text="兼容优先" Style="{StaticResource Style_ManagementShellSubtitleText}" Margin="10,2,0,0"/>
                </StackPanel>
                <Button Style="{StaticResource Style_ManagementShellCloseButton}" Click="OnContinueClick" ToolTip="关闭">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform"
                          Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}"/>
                </Button>
            </Grid>
            <Border Grid.Row="0" Style="{StaticResource Style_ManagementShellDivider}"/>

            <Border Grid.Row="1" Style="{StaticResource Style_ManagementShellContentBorder}">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource Style_SurfaceSectionBorder_Danger}" Margin="0,0,0,10">
                        <TextBlock x:Name="SummaryText"
                                   FontWeight="SemiBold"
                                   FontSize="{StaticResource FontSize_Title_Dialog}"
                                   Foreground="{StaticResource Brush_Text_Primary}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <TabControl Grid.Row="1" BorderThickness="0" Background="Transparent">
                        <TabItem Header="详情">
                            <TextBox x:Name="DetailBox"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     Padding="10"
                                     Background="{StaticResource Brush_InputBackground}"
                                     Foreground="{StaticResource Brush_Text_Primary}"
                                     FontFamily="Consolas"
                                     FontSize="{StaticResource FontSize_Body_S}"
                                     Margin="0,8,0,0"
                                     BorderThickness="0"/>
                        </TabItem>
                        <TabItem Header="建议">
                            <TextBox x:Name="SuggestionBox"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     Padding="10"
                                     Background="{StaticResource Brush_InputBackground}"
                                     Foreground="{StaticResource Brush_Text_Primary}"
                                     FontFamily="Consolas"
                                     FontSize="{StaticResource FontSize_Body_S}"
                                     Margin="0,8,0,0"
                                     BorderThickness="0"/>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource Style_ManagementShellFooterBorder}" CornerRadius="0,0,14,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <CheckBox x:Name="SuppressCheckBox"
                              Grid.Row="0"
                              Content="本问题不再提示"
                              VerticalAlignment="Center"
                              Margin="0,0,0,8"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="已切到兼容优先；可在兼容诊断恢复提示。"
                                   Style="{StaticResource Style_ManagementShellFooterText}"
                                   Grid.Column="0"
                                   Margin="0,0,12,0"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button x:Name="OpenReportButton"
                                    Content="诊断报告"
                                    Style="{StaticResource Style_SecondaryButton}"
                                    Width="96"
                                    Height="{StaticResource Size_Button_Action_Height_Compact}"
                                    Margin="0,0,8,0"
                                    Click="OnOpenReportClick"/>
                            <Button x:Name="CopyDiagnosticsButton"
                                    Content="复制诊断"
                                    Style="{StaticResource Style_SecondaryButton}"
                                    Width="96"
                                    Height="{StaticResource Size_Button_Action_Height_Compact}"
                                    Margin="0,0,8,0"
                                    Click="OnCopyDiagnosticsClick"/>
                            <Button Content="继续启动"
                                    Style="{StaticResource Style_PrimaryButton}"
                                    Width="92"
                                    Height="{StaticResource Size_Button_Action_Height_Compact}"
                                    Click="OnContinueClick"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
