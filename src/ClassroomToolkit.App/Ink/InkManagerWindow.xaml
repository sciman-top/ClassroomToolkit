<Window x:Class="ClassroomToolkit.App.Ink.InkManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="历史记录"
        Width="860" Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        Topmost="True">

    <Border Background="White" CornerRadius="12" BorderBrush="{StaticResource Brush_Border_Subtle}" BorderThickness="1" Padding="16">
        <Border.Effect>
            <DropShadowEffect Color="#8899AA" Opacity="0.25" BlurRadius="28" ShadowDepth="8"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Height="40" Background="Transparent" MouseLeftButtonDown="OnTitleBarDrag">
                <TextBlock Text="历史记录" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}"/>
                <Button Style="{StaticResource Style_IconButton}" Click="OnCloseClick" HorizontalAlignment="Right" Width="32" Height="32">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="12" Height="12"/>
                </Button>
            </Grid>

            <Grid Grid.Row="1" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TabControl x:Name="CategoryTabs" SelectionChanged="OnCategoryChanged">
                        <TabItem Header="PPT课件"/>
                        <TabItem Header="图片"/>
                    </TabControl>
                    <TextBlock Text="课件列表" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="12" Margin="0,8,0,6"/>
                    <ListBox x:Name="DocumentList" SelectionChanged="OnDocumentChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4,4,4,6">
                                    <TextBlock Text="{Binding DocumentName}" Foreground="{StaticResource Brush_Text_Primary}" FontSize="13"/>
                                    <TextBlock Text="{Binding DateLabel}" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <Grid Grid.Column="1" Margin="16,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                        <TextBox x:Name="SearchBox" Width="200" Height="30" VerticalContentAlignment="Center" Margin="0,0,8,0" TextChanged="OnSearchChanged"/>
                        <ComboBox x:Name="SortCombo" Width="140" Height="30" SelectionChanged="OnSortChanged">
                            <ComboBoxItem Content="最近日期" Tag="recent"/>
                            <ComboBoxItem Content="课件名" Tag="name"/>
                        </ComboBox>
                    </StackPanel>
                    <TextBlock x:Name="DocumentTitle" Grid.Row="1" Text="请选择课件" FontWeight="SemiBold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,8"/>
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="PageList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" ItemWidth="160" ItemHeight="130"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource Style_SecondaryButton}" Padding="6" Margin="6" Click="OnPageClick" Tag="{Binding PageIndex}">
                                        <StackPanel>
                                            <Border BorderBrush="{StaticResource Brush_Border}" BorderThickness="1" CornerRadius="6" Background="#FFF6F6F6">
                                                <Image Source="{Binding ThumbnailPath}" Stretch="Uniform" Height="86"/>
                                            </Border>
                                            <TextBlock Text="{Binding PageLabel}" FontSize="12" Foreground="{StaticResource Brush_Text_Secondary}" Margin="4,6,0,0"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
