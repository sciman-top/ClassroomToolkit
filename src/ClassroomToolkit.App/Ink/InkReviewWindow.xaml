<Window x:Class="ClassroomToolkit.App.Ink.InkReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="课件回看"
        Width="960" Height="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        Topmost="True">

    <Border Background="White" CornerRadius="12" BorderBrush="{StaticResource Brush_Border_Subtle}" BorderThickness="1" Padding="12">
        <Border.Effect>
            <DropShadowEffect Color="#8899AA" Opacity="0.25" BlurRadius="28" ShadowDepth="8"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Height="40" Background="Transparent" MouseLeftButtonDown="OnTitleBarDrag">
                <TextBlock x:Name="TitleText" Text="课件回看" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}"/>
                <Button Style="{StaticResource Style_IconButton}" Click="OnCloseClick" HorizontalAlignment="Right" Width="32" Height="32">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="12" Height="12"/>
                </Button>
            </Grid>

            <Grid Grid.Row="1">
                <Viewbox Stretch="Uniform">
                    <Grid>
                        <Image x:Name="BackgroundImage" Stretch="Fill"/>
                        <Image x:Name="InkImage" Stretch="Fill"/>
                    </Grid>
                </Viewbox>
            </Grid>
        </Grid>
    </Border>
</Window>
