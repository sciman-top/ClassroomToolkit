<Window x:Class="ClassroomToolkit.App.Ink.InkSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="笔迹记录"
        Height="Auto" Width="432"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        Topmost="True">

    <Border Style="{StaticResource Style_DialogShellWindowBorder}"
            TextElement.Foreground="{StaticResource Brush_Text_Primary}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Style="{StaticResource Style_DialogShellTitleBar}" MouseLeftButtonDown="OnTitleBarDrag">
                <TextBlock Text="笔迹记录" Style="{StaticResource Style_DialogShellTitleText}"/>
                <Button Style="{StaticResource Style_DialogShellCloseButton}" Click="OnCancel" ToolTip="关闭">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform"
                          Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}"/>
                </Button>
            </Grid>
            <Border Grid.Row="0" Style="{StaticResource Style_DialogShellDivider}"/>

            <Border Grid.Row="1" Margin="16,14,16,8" Style="{StaticResource Style_SettingCardBorder}" Padding="14">
                <StackPanel>
                    <CheckBox x:Name="InkRecordCheck" Content="启用笔迹记录" Margin="0,0,0,10"/>
                    <CheckBox x:Name="InkReplayPreviousCheck" Content="显示上次笔迹" Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="自动清理（天）" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="{StaticResource FontSize_Body_S}" Margin="0,0,8,0"/>
                        <TextBox x:Name="InkRetentionDaysBox" Grid.Column="1" Height="{StaticResource Size_Button_Action_Height_Compact}" VerticalContentAlignment="Center" Padding="4,0"/>
                        <TextBlock Grid.Column="2" Text="0 表示不清理" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Tertiary}" FontSize="{StaticResource FontSize_Body_S}" Margin="8,0,0,0"/>
                    </Grid>
                    <TextBlock Text="笔迹保存路径" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="{StaticResource FontSize_Body_S}" Margin="0,6,0,4"/>
                    <TextBox x:Name="InkPhotoPathBox" Height="{StaticResource Size_Button_Action_Height_Compact}"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2" Style="{StaticResource Style_DialogShellActionBar}">
                <Button Content="取消" Style="{StaticResource Style_DialogShellSecondaryActionButton}" Click="OnCancel"/>
                <Button Content="确定" Style="{StaticResource Style_DialogShellPrimaryActionButton}" Click="OnConfirm"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
