<Window x:Class="ClassroomToolkit.App.Ink.InkSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="笔迹记录与回看"
        Height="Auto" Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        Topmost="True">

    <Border Background="{StaticResource Brush_Window_Atmosphere}" CornerRadius="16" Margin="8" BorderBrush="{StaticResource Brush_Border}" BorderThickness="1"
            TextElement.Foreground="{StaticResource Brush_Text_Primary}">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="12" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Height="44" Background="Transparent" MouseLeftButtonDown="OnTitleBarDrag">
                <TextBlock Text="笔迹记录与回看" FontWeight="SemiBold" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}" FontSize="15"/>
                <Button Style="{StaticResource Style_IconButton}" Click="OnCancel" HorizontalAlignment="Right" Margin="0,0,10,0" Width="30" Height="30">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="12" Height="12"/>
                </Button>
            </Grid>
            <Border Grid.Row="0" VerticalAlignment="Bottom" Height="1" Background="{StaticResource Brush_Border}"/>

            <StackPanel Grid.Row="1" Margin="16,14">
                <CheckBox x:Name="InkRecordCheck" Content="启用笔迹记录/回看" Margin="0,0,0,10"/>
                <CheckBox x:Name="InkAutoSaveCheck" Content="翻页自动保存（PPT/WPS 全屏放映时）" Margin="0,0,0,10"/>
                <CheckBox x:Name="InkReplayPreviousCheck" Content="显示同一个课件在上次课的笔迹" Margin="0,0,0,10"/>
                <Grid Margin="0,4,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="自动清理（天）" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="12" Margin="0,0,8,0"/>
                    <TextBox x:Name="InkRetentionDaysBox" Grid.Column="1" Height="30" VerticalContentAlignment="Center" Padding="4,0"/>
                    <TextBlock Grid.Column="2" Text="0 表示不清理" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="12" Margin="8,0,0,0"/>
                </Grid>
                <TextBlock Text="照片存储路径" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="12" Margin="0,8,0,4"/>
                <TextBox x:Name="InkPhotoPathBox" Height="28"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,0,16,16">
                <Button Content="取消" Style="{StaticResource Style_SecondaryButton}" Width="90" Margin="0,0,10,0" Click="OnCancel"/>
                <Button Content="确定" Style="{StaticResource Style_PrimaryButton}" Width="90" Click="OnConfirm"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
