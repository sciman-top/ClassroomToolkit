<Window x:Class="ClassroomToolkit.App.Ink.InkSidebarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="课堂回看"
        Width="64" Height="210"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        Topmost="True"
        ShowInTaskbar="False">

    <Border Background="White" CornerRadius="12" BorderBrush="{StaticResource Brush_Border_Subtle}" BorderThickness="1" Padding="8"
            MouseLeftButtonDown="OnTitleBarDrag">
        <Border.Effect>
            <DropShadowEffect Color="#8899AA" Opacity="0.25" BlurRadius="24" ShadowDepth="6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Height="16" Background="Transparent" MouseLeftButtonDown="OnTitleBarDrag">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.35">
                    <Ellipse Width="4" Height="4" Fill="{StaticResource Brush_Text_Primary}" Margin="2,0"/>
                    <Ellipse Width="4" Height="4" Fill="{StaticResource Brush_Text_Primary}" Margin="2,0"/>
                    <Ellipse Width="4" Height="4" Fill="{StaticResource Brush_Text_Primary}" Margin="2,0"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Background="Transparent" MouseLeftButtonDown="OnTitleBarDrag"/>

            <StackPanel Grid.Row="2" Orientation="Vertical" HorizontalAlignment="Center" Margin="0,2,0,2">
                <Button Style="{StaticResource Style_IconButton}" Width="32" Height="32" Margin="0,0,0,8" Click="OnHistoryClick" ToolTip="历史记录">
                    <Path Data="{StaticResource Icon_List}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform" Width="16" Height="16"/>
                </Button>
                <Button Style="{StaticResource Style_IconButton}" Width="32" Height="32" Margin="0,0,0,8" Click="OnSettingsClick" ToolTip="设置">
                    <Path Data="{StaticResource Icon_Settings}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform" Width="16" Height="16"/>
                </Button>
                <Button Style="{StaticResource Style_IconButton}" Width="32" Height="32" Margin="0,0,0,8" Click="OnPreviousClick" ToolTip="上一页">
                    <Path Data="{StaticResource Icon_Undo}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform" Width="16" Height="16"/>
                </Button>
                <Button Style="{StaticResource Style_IconButton}" Width="32" Height="32" Click="OnNextClick" ToolTip="下一页">
                    <Path Data="{StaticResource Icon_Redo}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform" Width="16" Height="16"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
