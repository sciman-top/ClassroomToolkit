<Window x:Class="ClassroomToolkit.App.LauncherBubbleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="60" Height="60"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False">
    
    <Grid>
        <!-- 悬浮球主体 -->
        <Border Width="48" Height="48" 
                CornerRadius="100"
                BorderThickness="1.5"
                BorderBrush="#80FFFFFF">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#4FACFE" Offset="0"/>
                    <GradientStop Color="#00F2FE" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <!-- 阴影让它浮起来 -->
                <DropShadowEffect Color="#204FACFE" BlurRadius="16" ShadowDepth="4" Opacity="0.6"/>
            </Border.Effect>
            
            <!-- 图标 -->
            <Path Data="{StaticResource Icon_Apps}" 
                  Fill="White" 
                  Stretch="Uniform" 
                  Width="22" Height="22"
                  HorizontalAlignment="Center" 
                  VerticalAlignment="Center">
                <Path.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="1" Opacity="0.2"/>
                </Path.Effect>
            </Path>
            
            <!-- 鼠标交互反馈 -->
            <Border.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Width" To="52" Duration="0:0:0.1"/>
                            <DoubleAnimation Storyboard.TargetProperty="Height" To="52" Duration="0:0:0.1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Width" To="48" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetProperty="Height" To="48" Duration="0:0:0.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
        </Border>
    </Grid>
</Window>