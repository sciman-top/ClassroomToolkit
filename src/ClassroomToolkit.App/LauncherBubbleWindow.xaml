<Window x:Class="ClassroomToolkit.App.LauncherBubbleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="60" Height="60"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False">
    
    <Grid Background="Transparent">
        <!-- 悬浮球主体 -->
        <Border Width="48" Height="48" 
                CornerRadius="24"
                BorderThickness="1"
                BorderBrush="{StaticResource Brush_Border}"
                Background="{StaticResource Brush_Background_L2}"
                TextElement.Foreground="{StaticResource Brush_Text_Primary}">
            <Border.Effect>
                <!-- 阴影让它浮起来 -->
                <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="4" Opacity="0.5"/>
            </Border.Effect>
            
            <!-- 图标 -->
            <Grid>
                 <Path Data="{StaticResource Icon_Apps}" 
                       Fill="{StaticResource Brush_Primary}" 
                       Stretch="Uniform" 
                       Width="20" Height="20"
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center">
                     <Path.Effect>
                         <DropShadowEffect Color="{StaticResource Color_Primary_Main}" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
                     </Path.Effect>
                 </Path>
            </Grid>
            
            <!-- 鼠标交互反馈 -->
            <Border.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Width" To="52" Duration="0:0:0.1"/>
                            <DoubleAnimation Storyboard.TargetProperty="Height" To="52" Duration="0:0:0.1"/>
                            <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="{StaticResource Color_Surface_Hover}" Duration="0:0:0.1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Width" To="48" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetProperty="Height" To="48" Duration="0:0:0.2"/>
                            <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="{StaticResource Color_Background_L2}" Duration="0:0:0.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
        </Border>
    </Grid>
</Window>