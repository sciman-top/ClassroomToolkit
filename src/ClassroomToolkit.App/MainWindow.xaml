<Window x:Class="ClassroomToolkit.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:ClassroomToolkit.App.Behaviors"
        Title="课堂工具箱"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <!-- 大磁贴按钮样式 - 精美渐变版 -->
        <Style x:Key="Style_TileButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Brush_Foreground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="76"/>
            <Setter Property="Height" Value="76"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- 背景卡片 -->
                            <Border x:Name="border"
                                    Background="#F8FAFC"
                                    CornerRadius="10">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.08"/>
                                </Border.Effect>
                            </Border>

                            <!-- 悬停时的渐变背景 -->
                            <Border x:Name="hoverBorder"
                                    Background="{StaticResource Gradient_Accent}"
                                    CornerRadius="10"
                                    Opacity="0"/>

                            <!-- 光泽效果 -->
                            <Border x:Name="glossBorder"
                                    CornerRadius="10"
                                    Opacity="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="White" Offset="0" StopColor="White"/>
                                        <GradientStop Color="Transparent" Offset="0.5"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <!-- 内容 -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Path x:Name="icon"
                                      Data="{TemplateBinding Tag}"
                                      Fill="{StaticResource Brush_Primary}"
                                      Stretch="Uniform"
                                      Width="32" Height="32"
                                      Margin="0,0,0,6"/>
                                <ContentPresenter x:Name="text"
                                                TextElement.FontWeight="SemiBold"
                                                TextElement.FontSize="13"/>
                            </StackPanel>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="hoverBorder" Property="Opacity" Value="0.1"/>
                                <Setter TargetName="glossBorder" Property="Opacity" Value="0.3"/>
                                <Setter TargetName="icon" Property="Fill" Value="{StaticResource Brush_Primary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="hoverBorder" Property="Opacity" Value="0.2"/>
                                <Setter TargetName="glossBorder" Property="Opacity" Value="0.5"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="1" Opacity="0.12"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="LauncherContainer"
            CornerRadius="14"
            Background="#F5F7FA"
            BorderBrush="#E8EEF8"
            BorderThickness="1"
            MouseLeftButtonDown="OnDragAreaMouseDown">
        <Border.Effect>
            <DropShadowEffect Color="#4A90E2" BlurRadius="30" ShadowDepth="6" Opacity="0.15"/>
        </Border.Effect>

        <Grid>
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 1. 核心功能区 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="PaintButton" Content="屏幕画笔"
                            Style="{StaticResource Style_TileButton}"
                            Tag="{StaticResource Icon_Pen}"
                            Click="OnPaintClick"
                            ToolTip="开启画笔 (长按设置)"
                            behaviors:LongPressBehavior.Command="{Binding OpenPaintSettingsCommand}" />

                    <Button x:Name="RollCallButton" Content="点名/计时"
                            Style="{StaticResource Style_TileButton}"
                            Tag="{StaticResource Icon_RollCall}"
                            Click="OnRollCallClick"
                            ToolTip="开启点名器 (长按设置)"
                            behaviors:LongPressBehavior.Command="{Binding OpenRollCallSettingsCommand}" />
                </StackPanel>

                <!-- 品牌色分割线 -->
                <Border Grid.Row="0" VerticalAlignment="Bottom" Margin="6,8,6,6"
                        Height="2" CornerRadius="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{StaticResource Color_Primary_Light}" Offset="0"/>
                            <GradientStop Color="{StaticResource Color_Primary_Main}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- 2. 底部工具栏 -->
                <Grid Grid.Row="1" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：最小化 -->
                    <Button x:Name="MinimizeButton" Grid.Column="0"
                            Style="{StaticResource Style_IconButton}"
                            Click="OnMinimizeClick" ToolTip="最小化">
                         <Path Data="M2,11 L14,11 L14,13 L2,13 Z" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="14" Height="14"/>
                    </Button>

                    <!-- 右侧：辅助功能 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="SettingsButton"
                                Style="{StaticResource Style_IconButton}"
                                Click="OnLauncherSettingsClick" ToolTip="全局设置">
                            <Path Data="{StaticResource Icon_Settings}" Fill="{StaticResource Brush_Foreground}" Stretch="Uniform" Width="18" Height="18"/>
                        </Button>

                        <Button x:Name="AboutButton"
                                Style="{StaticResource Style_IconButton}"
                                Click="OnAboutClick" ToolTip="关于软件">
                            <Path Data="{StaticResource Icon_Info}" Fill="{StaticResource Brush_Foreground}" Stretch="Uniform" Width="18" Height="18"/>
                        </Button>

                        <Button x:Name="ExitButton"
                                Style="{StaticResource Style_IconButton}"
                                Click="OnExitClick" ToolTip="退出程序">
                            <Path Data="{StaticResource Icon_Power}" Fill="{StaticResource Brush_Danger}" Stretch="Uniform" Width="18" Height="18"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>