<Window x:Class="ClassroomToolkit.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="课堂工具箱"
        Height="304" Width="318"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">

    <Border x:Name="MainContainer"
            Style="{StaticResource Style_WorkShellWindowBorder}"
            MouseLeftButtonDown="OnDragAreaMouseDown">
        <Border.Effect>
            <StaticResource ResourceKey="Shadow_Dialog"/>
        </Border.Effect>

        <Grid Margin="10,8,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Height="42" Style="{StaticResource Style_WorkShellTitleBar}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Style="{StaticResource Style_TitleIconBadge}" Margin="0,0,8,0">
                        <Path Data="{StaticResource Icon_Apps}"
                              Fill="{StaticResource Brush_Primary}"
                              Stretch="Uniform"/>
                    </Border>
                    <TextBlock Text="课堂工具箱"
                               FontSize="{StaticResource FontSize_Title_Management}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush_Primary_Hover}"
                               TextAlignment="Center"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,4,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        x:Name="PaintButton"
                        Style="{StaticResource Style_WorkShellHeroTileButton}"
                        Content="画笔"
                        Tag="{StaticResource Icon_Pen}"
                        Click="OnPaintClick"
                        ToolTip="画笔批注"/>

                <Button Grid.Column="1"
                        x:Name="RollCallButton"
                        Style="{StaticResource Style_WorkShellHeroTileButton}"
                        Content="点名计时"
                        Tag="{StaticResource Icon_RollCall}"
                        Click="OnRollCallClick"
                        ToolTip="点名与计时"/>
            </Grid>

            <Border Grid.Row="2"
                    Style="{StaticResource Style_WorkShellBottomBar}"
                    HorizontalAlignment="Center">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            x:Name="MinimizeButton"
                            Style="{StaticResource Style_WorkShellMiniButton}"
                            Tag="{StaticResource Icon_Minimize}"
                            Click="OnMinimizeClick"
                            ToolTip="最小化"/>

                    <Rectangle Grid.Column="1" Width="1" Height="14" Fill="{StaticResource Brush_Border_Strong}" Margin="4,0" Opacity="0.45"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="DiagnosticsButton"
                                Style="{StaticResource Style_WorkShellMiniButton}"
                                Tag="{StaticResource Icon_Apps}"
                                Click="OnDiagnosticsClick"
                                ToolTip="兼容诊断"/>

                        <Button x:Name="AboutButton"
                                Style="{StaticResource Style_WorkShellMiniButton}"
                                Tag="{StaticResource Icon_Info}"
                                Click="OnAboutClick"
                                ToolTip="关于软件"/>

                        <Button x:Name="SettingsButton"
                                Style="{StaticResource Style_WorkShellMiniButton}"
                                Tag="{StaticResource Icon_Settings}"
                                Click="OnLauncherMoreClick"
                                ToolTip="更多设置"/>

                        <Rectangle Width="1" Height="14" Fill="{StaticResource Brush_Border_Strong}" Margin="4,0" Opacity="0.45"/>

                        <Button x:Name="ExitButton"
                                Style="{StaticResource Style_WorkShellMiniDangerButton}"
                                Tag="{StaticResource Icon_Power}"
                                Click="OnExitClick"
                                ToolTip="退出"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
