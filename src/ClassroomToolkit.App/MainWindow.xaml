<Window x:Class="ClassroomToolkit.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:behaviors="clr-namespace:ClassroomToolkit.App.Behaviors"
        mc:Ignorable="d"
        Title="Classroom Toolkit" 
        Height="300" Width="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <!-- 主功能磁贴 (Hero Tile) - Compact & Modern -->
        <Style x:Key="Style_HeroTile" TargetType="Button">
            <Setter Property="Width" Value="72"/>
            <Setter Property="Height" Value="72"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Background" Value="{StaticResource Brush_Background_L2}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- 弥散光影底层 (仅悬停时显示) -->
                            <Border x:Name="glow" CornerRadius="16" Background="{StaticResource Brush_Primary}" Margin="10" Opacity="0">
                                <Border.Effect>
                                    <DropShadowEffect Color="{StaticResource Color_Primary}" BlurRadius="24" ShadowDepth="0" Opacity="0.5"/>
                                </Border.Effect>
                            </Border>

                            <!-- 主体卡片 -->
                            <Border x:Name="border" 
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="16"
                                    BorderBrush="{StaticResource Brush_Border}"
                                    BorderThickness="1"
                                    Margin="2">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                    </Grid.RowDefinitions>

                                    <!-- 图标底色 (Squircle) -->
                                    <Border x:Name="iconBg" 
                                            Grid.Row="0" 
                                            VerticalAlignment="Center" HorizontalAlignment="Center"
                                            Width="32" Height="32" CornerRadius="10"
                                            Background="{StaticResource Brush_Background_L3}">
                                        <!-- 图标 (Fill 模式) -->
                                        <Path x:Name="icon" 
                                              Data="{TemplateBinding Tag}" 
                                              Fill="{StaticResource Brush_Primary}"
                                              Stretch="Uniform" 
                                              Width="18" Height="18"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- 文字 -->
                                    <TextBlock Grid.Row="1" 
                                               Text="{TemplateBinding Content}" 
                                               HorizontalAlignment="Center"
                                               FontFamily="Microsoft YaHei UI"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush_Text_Secondary}"/>
                                </Grid>
                            </Border>
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="-2"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource Brush_Primary}"/>
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Brush_Surface_Hover}"/>
                                <Setter TargetName="glow" Property="Opacity" Value="0.6"/>
                                <!-- 悬停变色 -->
                                <Setter TargetName="iconBg" Property="Background" Value="{StaticResource Brush_Primary}"/>
                                <Setter TargetName="icon" Property="Fill" Value="#FAFAFA"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="glow" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 迷你工具按钮 -->
        <Style x:Key="Style_MiniTool" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="8" Background="{TemplateBinding Background}">
                            <Path x:Name="ico" Data="{TemplateBinding Tag}" 
                                  Fill="{StaticResource Brush_Text_Tertiary}"
                                  Stretch="Uniform" Width="15" Height="15" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush_Surface_Hover}"/>
                                <Setter TargetName="ico" Property="Fill" Value="{StaticResource Brush_Primary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush_Surface_Active}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Style_MiniDanger" TargetType="Button" BasedOn="{StaticResource Style_MiniTool}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="8" Background="{TemplateBinding Background}">
                            <Path x:Name="ico" Data="{TemplateBinding Tag}" 
                                  Fill="{StaticResource Brush_Text_Tertiary}"
                                  Stretch="Uniform" Width="15" Height="15" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush_Danger_Surface}"/>
                                <Setter TargetName="ico" Property="Fill" Value="{StaticResource Brush_Danger}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- 主布局容器 (Atmospheric Gradient) -->
    <Border x:Name="MainContainer"
            CornerRadius="20"
            Background="{StaticResource Brush_Window_Atmosphere}"
            BorderThickness="1"
            BorderBrush="{StaticResource Brush_Border}"
            MouseLeftButtonDown="OnDragAreaMouseDown">
        
        <Border.Effect>
            <!-- 柔和的环境光阴影 (Deep & Blur) -->
            <DropShadowEffect Color="#000000" BlurRadius="32" ShadowDepth="8" Opacity="0.6"/>
        </Border.Effect>

        <Grid Margin="6,4,6,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- 拖拽条 -->
                <RowDefinition Height="Auto"/> <!-- 功能区 -->
                <RowDefinition Height="Auto"/> <!-- 工具栏 -->
            </Grid.RowDefinitions>

            <!-- 1. 顶部装饰 (拖拽把手 - Pill) -->
            <Grid Grid.Row="0" Height="14" Background="Transparent" VerticalAlignment="Top">
                <Rectangle Width="28" Height="4" RadiusX="2" RadiusY="2" 
                           Fill="{StaticResource Brush_Border_Light}"
                           VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.5"/>
            </Grid>

            <!-- 2. 核心功能区 -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                <!-- 屏幕画笔 -->
                <Button x:Name="PaintButton" 
                        Style="{StaticResource Style_HeroTile}"
                        Content="屏幕画笔"
                        Tag="{StaticResource Icon_Pen}"
                        Click="OnPaintClick"
                        ToolTip="开启画笔 (长按设置)"
                        behaviors:LongPressBehavior.Command="{Binding OpenPaintSettingsCommand}"/>

                <!-- 点名/计时 -->
                <Button x:Name="RollCallButton" 
                        Style="{StaticResource Style_HeroTile}"
                        Content="课堂互动"
                        Tag="{StaticResource Icon_RollCall}"
                        Click="OnRollCallClick"
                        ToolTip="开启点名 (长按设置)"
                        behaviors:LongPressBehavior.Command="{Binding OpenRollCallSettingsCommand}"/>
            </StackPanel>

            <!-- 3. 底部工具栏 (Floating Capsule) -->
            <Border Grid.Row="2" 
                    Background="{StaticResource Brush_Background_L2}" 
                    CornerRadius="14" 
                    BorderBrush="{StaticResource Brush_Border_Light}"
                    BorderThickness="1"
                    Padding="8,4" 
                    Margin="8,0,8,4"
                    HorizontalAlignment="Center">
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 最小化 -->
                    <Button Grid.Column="0" x:Name="MinimizeButton"
                            Style="{StaticResource Style_MiniTool}"
                            Tag="{StaticResource Icon_Minimize}"
                            Click="OnMinimizeClick" ToolTip="最小化"/>

                    <!-- 分隔 -->
                    <Rectangle Grid.Column="1" Width="1" Height="14" Fill="{StaticResource Brush_Border_Light}" Margin="4,0" Opacity="0.5"/>

                    <!-- 右侧功能 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="SettingsButton"
                                Style="{StaticResource Style_MiniTool}"
                                Tag="{StaticResource Icon_Settings}"
                                Click="OnLauncherSettingsClick" ToolTip="全局设置"/>
                        
                        <Button x:Name="AboutButton"
                                Style="{StaticResource Style_MiniTool}"
                                Tag="{StaticResource Icon_Info}"
                                Click="OnAboutClick" ToolTip="关于软件"/>

                        <Rectangle Width="1" Height="14" Fill="{StaticResource Brush_Border_Light}" Margin="4,0" Opacity="0.5"/>
                        
                        <Button x:Name="ExitButton"
                                Style="{StaticResource Style_MiniDanger}"
                                Tag="{StaticResource Icon_Power}"
                                Click="OnExitClick" ToolTip="退出程序"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>