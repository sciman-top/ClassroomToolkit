<Window x:Class="ClassroomToolkit.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:behaviors="clr-namespace:ClassroomToolkit.App.Behaviors"
        mc:Ignorable="d"
        Title="sciman课堂工具箱"
        Height="300" Width="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">

    <Border x:Name="MainContainer"
            Style="{StaticResource Style_WorkShellWindowBorder}"
            MouseLeftButtonDown="OnDragAreaMouseDown">
        <Border.Effect>
            <StaticResource ResourceKey="Shadow_Dialog"/>
        </Border.Effect>

        <Grid Margin="10,8,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Height="46" Style="{StaticResource Style_WorkShellTitleBar}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="sciman课堂工具箱"
                               FontSize="17"
                               FontWeight="Bold"
                               Foreground="{StaticResource Brush_Primary_Hover}"
                               TextAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,4,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        x:Name="PaintButton"
                        Style="{StaticResource Style_WorkShellHeroTileButton}"
                        Content="画笔"
                        Tag="{StaticResource Icon_Pen}"
                        Click="OnPaintClick"
                        ToolTip="开启画笔（长按可调设置）"
                        behaviors:LongPressBehavior.Command="{Binding OpenPaintSettingsCommand}"/>

                <Button Grid.Column="1"
                        x:Name="RollCallButton"
                        Style="{StaticResource Style_WorkShellHeroTileButton}"
                        Content="点名 / 计时"
                        Tag="{StaticResource Icon_RollCall}"
                        Click="OnRollCallClick"
                        ToolTip="打开点名/倒计时（长按可调设置）"
                        behaviors:LongPressBehavior.Command="{Binding OpenRollCallSettingsCommand}"/>
            </Grid>

            <Border Grid.Row="2"
                    Style="{StaticResource Style_WorkShellBottomBar}"
                    HorizontalAlignment="Center">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            x:Name="MinimizeButton"
                            Style="{StaticResource Style_WorkShellMiniButton}"
                            Tag="{StaticResource Icon_Minimize}"
                            Click="OnMinimizeClick"
                            ToolTip="最小化"/>

                    <Rectangle Grid.Column="1" Width="1" Height="14" Fill="{StaticResource Brush_Border_Strong}" Margin="4,0" Opacity="0.45"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="DiagnosticsButton"
                                Style="{StaticResource Style_WorkShellMiniButton}"
                                Tag="{StaticResource Icon_Apps}"
                                Click="OnDiagnosticsClick"
                                ToolTip="打开系统兼容性诊断"/>

                        <Button x:Name="AboutButton"
                                Style="{StaticResource Style_WorkShellMiniButton}"
                                Tag="{StaticResource Icon_Info}"
                                Click="OnAboutClick"
                                ToolTip="查看产品信息"/>

                        <Button x:Name="SettingsButton"
                                Style="{StaticResource Style_WorkShellMiniButton}"
                                Tag="{StaticResource Icon_Settings}"
                                Click="OnLauncherSettingsClick"
                                ToolTip="打开全局设置"/>

                        <Rectangle Width="1" Height="14" Fill="{StaticResource Brush_Border_Strong}" Margin="4,0" Opacity="0.45"/>

                        <Button x:Name="ExitButton"
                                Style="{StaticResource Style_WorkShellMiniDangerButton}"
                                Tag="{StaticResource Icon_Power}"
                                Click="OnExitClick"
                                ToolTip="退出程序"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
