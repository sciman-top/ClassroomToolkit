<Window x:Class="ClassroomToolkit.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:ClassroomToolkit.App.Behaviors"
        Title="课堂工具箱"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">
    <Window.Resources>
        <Style x:Key="LauncherButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#E8EAED" />
            <Setter Property="Background" Value="#0CFFFFFF" />
            <Setter Property="BorderBrush" Value="#14FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#C24285F4" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FF4285F4" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF4285F4" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FF4285F4" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="LauncherContainer"
            CornerRadius="10"
            BorderThickness="1"
            BorderBrush="#32788296"
            MouseLeftButtonDown="OnDragAreaMouseDown">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FA2D2D37" Offset="0" />
                <GradientStop Color="#FA1E232D" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="PaintButton" Grid.Column="1" Content="画笔"
                        Style="{StaticResource LauncherButtonStyle}"
                        Click="OnPaintClick"
                        behaviors:LongPressBehavior.Command="{Binding OpenPaintSettingsCommand}" />
                <Button x:Name="RollCallButton" Grid.Column="3" Content="点名"
                        Style="{StaticResource LauncherButtonStyle}"
                        Click="OnRollCallClick"
                        behaviors:LongPressBehavior.Command="{Binding OpenRollCallSettingsCommand}" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button x:Name="MinimizeButton" Grid.Column="0" Content="缩小"
                        Style="{StaticResource LauncherButtonStyle}"
                        Click="OnMinimizeClick" />
                <Button x:Name="AboutButton" Grid.Column="2" Content="关于"
                        Style="{StaticResource LauncherButtonStyle}"
                        Click="OnAboutClick" Margin="0,0,3,0" />
                <Button x:Name="SettingsButton" Grid.Column="3" Content="设置"
                        Style="{StaticResource LauncherButtonStyle}"
                        Click="OnLauncherSettingsClick" Margin="0,0,3,0" />
                <Button x:Name="ExitButton" Grid.Column="4" Content="退出"
                        Style="{StaticResource LauncherButtonStyle}"
                        Click="OnExitClick" />
            </Grid>
        </Grid>
    </Border>
</Window>
