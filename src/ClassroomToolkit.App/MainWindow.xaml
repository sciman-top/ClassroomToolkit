<Window x:Class="ClassroomToolkit.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:ClassroomToolkit.App.Behaviors"
        Title="课堂工具箱"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">
    
    <Window.Resources>
        <!-- 大磁贴按钮样式 -->
        <Style x:Key="Style_TileButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Brush_Foreground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Path x:Name="icon" 
                                      Data="{TemplateBinding Tag}" 
                                      Fill="{StaticResource Brush_Primary}" 
                                      Stretch="Uniform" 
                                      Width="32" Height="32" 
                                      Margin="0,0,0,8"/>
                                <ContentPresenter TextElement.FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Brush_Accent}"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Brush_Pressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="LauncherContainer"
            CornerRadius="12"
            Background="White"
            MouseLeftButtonDown="OnDragAreaMouseDown">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="4" Opacity="0.15"/>
        </Border.Effect>
        
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 1. 核心功能区 -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="PaintButton" Content="屏幕画笔"
                        Style="{StaticResource Style_TileButton}"
                        Tag="{StaticResource Icon_Pen}"
                        Click="OnPaintClick"
                        ToolTip="开启画笔 (长按设置)"
                        behaviors:LongPressBehavior.Command="{Binding OpenPaintSettingsCommand}" />
                
                <Button x:Name="RollCallButton" Content="点名/计时"
                        Style="{StaticResource Style_TileButton}"
                        Tag="{StaticResource Icon_RollCall}"
                        Click="OnRollCallClick"
                        ToolTip="开启点名器 (长按设置)"
                        behaviors:LongPressBehavior.Command="{Binding OpenRollCallSettingsCommand}" />
            </StackPanel>

            <Separator Grid.Row="0" VerticalAlignment="Bottom" Margin="4,8,4,4" Background="#EEE"/>

            <!-- 2. 底部工具栏 -->
            <Grid Grid.Row="1" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <!-- 左侧：最小化 -->
                <Button x:Name="MinimizeButton" Grid.Column="0" 
                        Style="{StaticResource Style_IconButton}"
                        Click="OnMinimizeClick" ToolTip="收起菜单">
                     <Path Data="{StaticResource Icon_Close}" Fill="#999" Stretch="Uniform" Width="12" Height="12"/>
                     <!-- 其实是用 Close 图标代表收起，或者用 Menu 再次收起 -->
                </Button>

                <!-- 右侧：辅助功能 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="SettingsButton" 
                            Style="{StaticResource Style_IconButton}"
                            Click="OnLauncherSettingsClick" ToolTip="全局设置">
                        <Path Data="{StaticResource Icon_Settings}" Fill="{StaticResource Brush_Foreground}" Stretch="Uniform" Width="16" Height="16"/>
                    </Button>
                    
                    <Button x:Name="AboutButton" 
                            Style="{StaticResource Style_IconButton}"
                            Click="OnAboutClick" ToolTip="关于软件">
                        <Path Data="{StaticResource Icon_Info}" Fill="{StaticResource Brush_Foreground}" Stretch="Uniform" Width="16" Height="16"/>
                    </Button>
                    
                    <Button x:Name="ExitButton" 
                            Style="{StaticResource Style_IconButton}"
                            Click="OnExitClick" ToolTip="退出程序">
                        <Path Data="{StaticResource Icon_Power}" Fill="{StaticResource Brush_Danger}" Stretch="Uniform" Width="16" Height="16"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>