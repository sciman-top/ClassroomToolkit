<Window x:Class="ClassroomToolkit.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:ClassroomToolkit.App.Behaviors"
        Title="课堂工具箱"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <!-- 大磁贴按钮样式 - 现代升级版 -->
        <Style x:Key="Style_TileButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Brush_Foreground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="88"/>
            <Setter Property="Height" Value="88"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Path x:Name="icon"
                                      Data="{TemplateBinding Tag}"
                                      Fill="{StaticResource Brush_Primary}"
                                      Stretch="Uniform"
                                      Width="36" Height="36"
                                      Margin="0,0,0,8"/>
                                <ContentPresenter TextElement.FontWeight="SemiBold" TextElement.FontSize="14"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Brush_Surface_Tint}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Duration="0:0:0.2" To="1.05" Storyboard.TargetProperty="RenderTransform.ScaleX"/>
                                            <DoubleAnimation Duration="0:0:0.2" To="1.05" Storyboard.TargetProperty="RenderTransform.ScaleY"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Duration="0:0:0.2" To="1.0" Storyboard.TargetProperty="RenderTransform.ScaleX"/>
                                            <DoubleAnimation Duration="0:0:0.2" To="1.0" Storyboard.TargetProperty="RenderTransform.ScaleY"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Brush_Background_L3}"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="LauncherContainer"
            CornerRadius="14"
            Background="{StaticResource Gradient_Glass}"
            BorderBrush="{StaticResource Brush_Border}"
            BorderThickness="1"
            MouseLeftButtonDown="OnDragAreaMouseDown">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="25" ShadowDepth="5" Opacity="0.1"/>
        </Border.Effect>

        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 1. 核心功能区 -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="PaintButton" Content="屏幕画笔"
                        Style="{StaticResource Style_TileButton}"
                        Tag="{StaticResource Icon_Pen}"
                        Click="OnPaintClick"
                        ToolTip="开启画笔 (长按设置)"
                        behaviors:LongPressBehavior.Command="{Binding OpenPaintSettingsCommand}" />

                <Button x:Name="RollCallButton" Content="点名/计时"
                        Style="{StaticResource Style_TileButton}"
                        Tag="{StaticResource Icon_RollCall}"
                        Click="OnRollCallClick"
                        ToolTip="开启点名器 (长按设置)"
                        behaviors:LongPressBehavior.Command="{Binding OpenRollCallSettingsCommand}" />
            </StackPanel>

            <!-- 品牌色分割线 -->
            <Border Grid.Row="0" VerticalAlignment="Bottom" Margin="8,12,8,8"
                    Height="2" CornerRadius="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="{StaticResource Color_Primary_Light}" Offset="0"/>
                        <GradientStop Color="{StaticResource Color_Primary_Main}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- 2. 底部工具栏 -->
            <Grid Grid.Row="1" Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 左侧：最小化 -->
                <Button x:Name="MinimizeButton" Grid.Column="0"
                        Style="{StaticResource Style_IconButton}"
                        Click="OnMinimizeClick" ToolTip="最小化">
                     <Path Data="M2,11 L14,11 L14,13 L2,13 Z" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="14" Height="14"/>
                </Button>

                <!-- 右侧：辅助功能 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="SettingsButton"
                            Style="{StaticResource Style_IconButton}"
                            Click="OnLauncherSettingsClick" ToolTip="全局设置">
                        <Path Data="{StaticResource Icon_Settings}" Fill="{StaticResource Brush_Foreground}" Stretch="Uniform" Width="18" Height="18"/>
                    </Button>

                    <Button x:Name="AboutButton"
                            Style="{StaticResource Style_IconButton}"
                            Click="OnAboutClick" ToolTip="关于软件">
                        <Path Data="{StaticResource Icon_Info}" Fill="{StaticResource Brush_Foreground}" Stretch="Uniform" Width="18" Height="18"/>
                    </Button>

                    <Button x:Name="ExitButton"
                            Style="{StaticResource Style_IconButton}"
                            Click="OnExitClick" ToolTip="退出程序">
                        <Path Data="{StaticResource Icon_Power}" Fill="{StaticResource Brush_Danger}" Stretch="Uniform" Width="18" Height="18"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>