<Window x:Class="ClassroomToolkit.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:behaviors="clr-namespace:ClassroomToolkit.App.Behaviors"
        mc:Ignorable="d"
        Title="Classroom Toolkit" 
        Height="300" Width="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <!-- 主功能磁贴 (Hero Tile) - Soft Tech Style -->
        <Style x:Key="Style_HeroTile" TargetType="Button">
            <Setter Property="Width" Value="90"/>
            <Setter Property="Height" Value="90"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- 阴影层 (独立于Border以获得最佳性能) -->
                            <Border x:Name="shadow" CornerRadius="18" Background="White" Margin="4">
                                <Border.Effect>
                                    <DropShadowEffect Color="#B0BEC5" BlurRadius="15" ShadowDepth="5" Opacity="0.15"/>
                                </Border.Effect>
                            </Border>

                            <!-- 主体卡片 -->
                            <Border x:Name="border" 
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="16"
                                    BorderBrush="{StaticResource Brush_Border_Subtle}"
                                    BorderThickness="1"
                                    Margin="4">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="14"/>
                                    </Grid.RowDefinitions>

                                    <!-- 图标圆底 -->
                                    <Border x:Name="iconBg" 
                                            Grid.Row="0" 
                                            VerticalAlignment="Center" HorizontalAlignment="Center"
                                            Width="44" Height="44" CornerRadius="22"
                                            Background="{StaticResource Brush_Surface_Tint}">
                                        <!-- 图标 -->
                                        <Path x:Name="icon" 
                                              Data="{TemplateBinding Tag}" 
                                              Fill="{StaticResource Brush_Primary}" 
                                              Stretch="Uniform" 
                                              Width="22" Height="22"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- 文字 -->
                                    <TextBlock Grid.Row="1" 
                                               Text="{TemplateBinding Content}" 
                                               HorizontalAlignment="Center"
                                               FontFamily="Microsoft YaHei UI"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush_Text_Primary}"/>
                                </Grid>
                            </Border>
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="-2"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="shadow" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="{StaticResource Color_Primary_Main}" BlurRadius="20" ShadowDepth="8" Opacity="0.25"/>
                                    </Setter.Value>
                                </Setter>
                                <!-- 悬停变色 -->
                                <Setter TargetName="iconBg" Property="Background" Value="{StaticResource Brush_Primary}"/>
                                <Setter TargetName="icon" Property="Fill" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="shadow" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="{StaticResource Color_Primary_Main}" BlurRadius="5" ShadowDepth="2" Opacity="0.1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 迷你工具按钮 -->
        <Style x:Key="Style_MiniTool" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="8" Background="{TemplateBinding Background}">
                            <Path x:Name="ico" Data="{TemplateBinding Tag}" Fill="{StaticResource Brush_Text_Secondary}" 
                                  Stretch="Uniform" Width="16" Height="16" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush_Surface_Tint}"/>
                                <Setter TargetName="ico" Property="Fill" Value="{StaticResource Brush_Primary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush_Border_Medium}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Style_MiniDanger" TargetType="Button" BasedOn="{StaticResource Style_MiniTool}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="8" Background="{TemplateBinding Background}">
                            <Path x:Name="ico" Data="{TemplateBinding Tag}" Fill="{StaticResource Brush_Text_Secondary}" 
                                  Stretch="Uniform" Width="16" Height="16" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush_Danger_Light}"/>
                                <Setter TargetName="ico" Property="Fill" Value="#D32F2F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- 主布局容器 (半透明玻璃边框 + 柔光背景) -->
    <Border x:Name="MainContainer"
            CornerRadius="24"
            Background="{StaticResource Brush_Background_L2}"
            BorderThickness="1"
            BorderBrush="{StaticResource Brush_White_Translucent}"
            MouseLeftButtonDown="OnDragAreaMouseDown">
        
        <Border.Effect>
            <!-- 柔和的环境光阴影 -->
            <DropShadowEffect Color="#636E72" BlurRadius="40" ShadowDepth="15" Opacity="0.2"/>
        </Border.Effect>

        <Grid Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- 拖拽条 -->
                <RowDefinition Height="Auto"/> <!-- 功能区 -->
                <RowDefinition Height="Auto"/> <!-- 工具栏 -->
            </Grid.RowDefinitions>

            <!-- 1. 顶部装饰 (拖拽把手) -->
            <Grid Grid.Row="0" Height="16" Background="Transparent" VerticalAlignment="Top">
                <Rectangle Width="36" Height="4" RadiusX="2" RadiusY="2" 
                           Fill="{StaticResource Brush_Border_Medium}" 
                           Opacity="0.8" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Grid>

            <!-- 2. 核心功能区 -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,10">
                <!-- 屏幕画笔 -->
                <Button x:Name="PaintButton" 
                        Style="{StaticResource Style_HeroTile}"
                        Content="屏幕画笔"
                        Tag="{StaticResource Icon_Pen}"
                        Click="OnPaintClick"
                        ToolTip="开启画笔 (长按设置)"
                        behaviors:LongPressBehavior.Command="{Binding OpenPaintSettingsCommand}"/>

                <!-- 点名/计时 -->
                <Button x:Name="RollCallButton" 
                        Style="{StaticResource Style_HeroTile}"
                        Content="课堂互动"
                        Tag="{StaticResource Icon_RollCall}"
                        Click="OnRollCallClick"
                        ToolTip="开启点名 (长按设置)"
                        behaviors:LongPressBehavior.Command="{Binding OpenRollCallSettingsCommand}"/>
            </StackPanel>

            <!-- 3. 底部工具栏 -->
            <Border Grid.Row="2" 
                    Background="White" 
                    CornerRadius="14" 
                    Padding="6,4" 
                    Margin="10,0,10,6">
                <Border.Effect>
                    <DropShadowEffect Color="#B0BEC5" BlurRadius="5" ShadowDepth="1" Opacity="0.1"/>
                </Border.Effect>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 最小化 -->
                    <Button Grid.Column="0" x:Name="MinimizeButton"
                            Style="{StaticResource Style_MiniTool}"
                            Tag="{StaticResource Icon_Minimize}"
                            Click="OnMinimizeClick" ToolTip="最小化"/>

                    <!-- 分隔 -->
                    <Rectangle Grid.Column="1" Width="1" Height="14" Fill="{StaticResource Brush_Border}" Opacity="0.8" HorizontalAlignment="Center"/>

                    <!-- 右侧功能 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="SettingsButton"
                                Style="{StaticResource Style_MiniTool}"
                                Tag="{StaticResource Icon_Settings}"
                                Click="OnLauncherSettingsClick" ToolTip="全局设置"/>
                        
                        <Button x:Name="AboutButton"
                                Style="{StaticResource Style_MiniTool}"
                                Tag="{StaticResource Icon_Info}"
                                Click="OnAboutClick" ToolTip="关于软件"/>

                        <Rectangle Width="1" Height="14" Fill="{StaticResource Brush_Border}" Margin="4,0" Opacity="0.8"/>
                        
                        <Button x:Name="ExitButton"
                                Style="{StaticResource Style_MiniDanger}"
                                Tag="{StaticResource Icon_Power}"
                                Click="OnExitClick" ToolTip="退出程序"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>