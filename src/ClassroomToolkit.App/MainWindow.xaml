<Window x:Class="ClassroomToolkit.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:ClassroomToolkit.App.Behaviors"
        Title="课堂工具箱"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <!-- 核心功能大磁贴样式 -->
        <Style x:Key="Style_HeroTile" TargetType="Button">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="100"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- 卡片背景主体 -->
                            <Border x:Name="border" 
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="20"
                                    BorderBrush="{StaticResource Brush_Border_Subtle}"
                                    BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="#B0C4DE" BlurRadius="20" ShadowDepth="8" Opacity="0.2"/>
                                </Border.Effect>
                            </Border>
                            
                            <!-- 渐变装饰层 (悬停显示) -->
                            <Border x:Name="glow" CornerRadius="20" Opacity="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#104A90E2" Offset="0"/>
                                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <!-- 内容布局 -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <!-- 图标容器 (带圆形背景) -->
                                <Border x:Name="iconBg" Width="48" Height="48" CornerRadius="24" Background="{StaticResource Brush_Surface_Tint}" Margin="0,0,0,8">
                                    <Path x:Name="icon" Data="{TemplateBinding Tag}" Fill="{StaticResource Brush_Primary}" Stretch="Uniform" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                
                                <!-- 文本 -->
                                <TextBlock Text="{TemplateBinding Content}" 
                                           FontWeight="SemiBold" 
                                           FontSize="13" 
                                           Foreground="{StaticResource Brush_Text_Primary}"
                                           TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="{StaticResource Color_Primary_Main}" BlurRadius="25" ShadowDepth="10" Opacity="0.25"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="glow" Property="Opacity" Value="1"/>
                                <Setter TargetName="iconBg" Property="Background" Value="{StaticResource Brush_Primary}"/>
                                <Setter TargetName="icon" Property="Fill" Value="White"/>
                                <!-- 简单的缩放动画 -->
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05" CenterX="50" CenterY="50"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98" CenterX="50" CenterY="50"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 底部迷你工具按钮样式 -->
        <Style x:Key="Style_MiniToolButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="8" Background="{TemplateBinding Background}">
                            <Path x:Name="ico" Data="{TemplateBinding Tag}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush_Background_L4}"/>
                                <Setter TargetName="ico" Property="Fill" Value="{StaticResource Brush_Text_Primary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 红色危险按钮特化 -->
        <Style x:Key="Style_MiniDangerButton" TargetType="Button" BasedOn="{StaticResource Style_MiniToolButton}">
             <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="8" Background="{TemplateBinding Background}">
                            <Path x:Name="ico" Data="{TemplateBinding Tag}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#15EF4444"/>
                                <Setter TargetName="ico" Property="Fill" Value="{StaticResource Brush_Danger}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 主容器：采用卡片悬浮式设计 -->
    <Border x:Name="LauncherContainer"
            CornerRadius="24"
            Background="#FDFDFD"
            BorderBrush="{StaticResource Brush_White_Translucent}"
            BorderThickness="1"
            MouseLeftButtonDown="OnDragAreaMouseDown"
            Padding="6">
        <Border.Effect>
            <!-- 柔和的高级阴影 -->
            <DropShadowEffect Color="#8899AA" BlurRadius="40" ShadowDepth="12" Opacity="0.25"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- 标题/品牌 -->
                <RowDefinition Height="Auto"/> <!-- 核心功能区 -->
                <RowDefinition Height="Auto"/> <!-- 底部工具栏 -->
            </Grid.RowDefinitions>

            <!-- 1. 顶部装饰条 (可拖动区) -->
            <Grid Grid.Row="0" Margin="0,4,0,2">
                 <Rectangle Width="32" Height="4" RadiusX="2" RadiusY="2" Fill="{StaticResource Brush_Border_Medium}" Opacity="0.5" HorizontalAlignment="Center"/>
            </Grid>

            <!-- 2. 核心功能区 (水平排列) -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,4">
                
                <Button x:Name="PaintButton" Content="屏幕画笔"
                        Style="{StaticResource Style_HeroTile}"
                        Tag="{StaticResource Icon_Pen}"
                        Click="OnPaintClick"
                        ToolTip="开启画笔 (长按设置)"
                        behaviors:LongPressBehavior.Command="{Binding OpenPaintSettingsCommand}" />

                <Button x:Name="RollCallButton" Content="点名/计时"
                        Style="{StaticResource Style_HeroTile}"
                        Tag="{StaticResource Icon_RollCall}"
                        Click="OnRollCallClick"
                        ToolTip="开启点名器 (长按设置)"
                        behaviors:LongPressBehavior.Command="{Binding OpenRollCallSettingsCommand}" />
            </StackPanel>

            <!-- 3. 底部极简工具栏 -->
            <Border Grid.Row="2" Margin="12,4,12,8" Padding="4" Background="{StaticResource Brush_Surface_Tint}" CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：最小化 -->
                    <Button x:Name="MinimizeButton" Grid.Column="0"
                            Style="{StaticResource Style_MiniToolButton}"
                            Click="OnMinimizeClick" ToolTip="最小化">
                         <Button.Tag>
                             <Geometry>M2,11 L14,11 L14,13 L2,13 Z</Geometry>
                         </Button.Tag>
                    </Button>

                    <!-- 右侧：设置与退出 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="SettingsButton"
                                Style="{StaticResource Style_MiniToolButton}"
                                Tag="{StaticResource Icon_Settings}"
                                Click="OnLauncherSettingsClick" ToolTip="全局设置"/>

                        <Button x:Name="AboutButton"
                                Style="{StaticResource Style_MiniToolButton}"
                                Tag="{StaticResource Icon_Info}"
                                Click="OnAboutClick" ToolTip="关于软件"/>

                        <Rectangle Width="1" Height="16" Fill="{StaticResource Brush_Border_Medium}" Margin="2,0"/>

                        <Button x:Name="ExitButton"
                                Style="{StaticResource Style_MiniDangerButton}"
                                Tag="{StaticResource Icon_Power}"
                                Click="OnExitClick" ToolTip="退出程序"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>