<Window x:Class="ClassroomToolkit.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:behaviors="clr-namespace:ClassroomToolkit.App.Behaviors"
        mc:Ignorable="d"
        Title="sciman课堂工具箱" 
        Height="300" Width="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">

    <!-- 主布局容器 (Atmospheric Gradient) -->
    <Border x:Name="MainContainer"
            Style="{StaticResource Style_WorkShellWindowBorder}"
            MouseLeftButtonDown="OnDragAreaMouseDown">
        <Border.Effect>
            <StaticResource ResourceKey="Shadow_Dialog"/>
        </Border.Effect>

        <Grid Margin="10,6,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- 拖拽条 -->
                <RowDefinition Height="Auto"/> <!-- 功能区 -->
                <RowDefinition Height="Auto"/> <!-- 工具栏 -->
            </Grid.RowDefinitions>

            <!-- 1. 顶部装饰 (拖拽把手 - Pill) -->
            <Grid Grid.Row="0" Height="34" Style="{StaticResource Style_WorkShellTitleBar}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Rectangle Width="28" Height="4" RadiusX="2" RadiusY="2" 
                               Fill="{StaticResource Brush_Border_Strong}"
                               HorizontalAlignment="Center" Opacity="0.70"/>
                    <TextBlock Text="sciman课堂工具箱"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush_Text_Secondary}"
                               Opacity="0.92"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>

            <!-- 2. 核心功能区 -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <!-- 屏幕画笔 -->
                <Button x:Name="PaintButton" 
                        Style="{StaticResource Style_WorkShellHeroTileButton}"
                        Content="{Binding PaintButtonText}"
                        Tag="{StaticResource Icon_Pen}"
                        Click="OnPaintClick"
                        ToolTip="开启画笔（长按可调设置）"
                        behaviors:LongPressBehavior.Command="{Binding OpenPaintSettingsCommand}"/>

                <!-- 点名/计时 -->
                <Button x:Name="RollCallButton" 
                        Style="{StaticResource Style_WorkShellHeroTileButton}"
                        Content="{Binding RollCallButtonText}"
                        Tag="{StaticResource Icon_RollCall}"
                        Click="OnRollCallClick"
                        ToolTip="打开点名/倒计时（长按可调设置）"
                        behaviors:LongPressBehavior.Command="{Binding OpenRollCallSettingsCommand}"/>
            </StackPanel>

            <!-- 3. 底部工具栏 (Floating Capsule) -->
            <Border Grid.Row="2"
                    Style="{StaticResource Style_WorkShellBottomBar}"
                    HorizontalAlignment="Center">
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 最小化 -->
                    <Button Grid.Column="0" x:Name="MinimizeButton"
                            Style="{StaticResource Style_WorkShellMiniButton}"
                            Tag="{StaticResource Icon_Minimize}"
                            Click="OnMinimizeClick" ToolTip="最小化"/>

                    <!-- 分隔 -->
                    <Rectangle Grid.Column="1" Width="1" Height="14" Fill="{StaticResource Brush_Border_Strong}" Margin="4,0" Opacity="0.45"/>

                    <!-- 右侧功能 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="DiagnosticsButton"
                                Style="{StaticResource Style_WorkShellMiniButton}"
                                Tag="{StaticResource Icon_Apps}"
                                Click="OnDiagnosticsClick" ToolTip="打开系统兼容性诊断"/>

                        <Button x:Name="AboutButton"
                                Style="{StaticResource Style_WorkShellMiniButton}"
                                Tag="{StaticResource Icon_Info}"
                                Click="OnAboutClick" ToolTip="查看产品信息"/>

                        <Button x:Name="SettingsButton"
                                Style="{StaticResource Style_WorkShellMiniButton}"
                                Tag="{StaticResource Icon_Settings}"
                                Click="OnLauncherSettingsClick" ToolTip="打开全局设置"/>

                        <Rectangle Width="1" Height="14" Fill="{StaticResource Brush_Border_Strong}" Margin="4,0" Opacity="0.45"/>
                        
                        <Button x:Name="ExitButton"
                                Style="{StaticResource Style_WorkShellMiniDangerButton}"
                                Tag="{StaticResource Icon_Power}"
                                Click="OnExitClick" ToolTip="退出程序"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
