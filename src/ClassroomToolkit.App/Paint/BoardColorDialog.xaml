<Window x:Class="ClassroomToolkit.App.Paint.BoardColorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择颜色"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}">

    <Border Background="{StaticResource Brush_Window_Atmosphere}" CornerRadius="12" Margin="10" BorderBrush="{StaticResource Brush_Border}" BorderThickness="1"
            MouseLeftButtonDown="OnTitleBarDrag">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="5" Opacity="0.5"/>
        </Border.Effect>

        <StackPanel Margin="16">
            <TextBlock Text="选择画板颜色" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,12"/>
            <StackPanel x:Name="OptionsPanel" Orientation="Horizontal" />
        </StackPanel>
    </Border>
</Window>