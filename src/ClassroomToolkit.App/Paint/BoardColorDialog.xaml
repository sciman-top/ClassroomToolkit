<Window x:Class="ClassroomToolkit.App.Paint.BoardColorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="白板颜色"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}">

    <Border Background="{StaticResource Brush_Window_Atmosphere}" CornerRadius="12" Margin="10" BorderBrush="{StaticResource Brush_Border_Subtle}" BorderThickness="1"
            MouseLeftButtonDown="OnTitleBarDrag">
        <Border.Effect>
            <StaticResource ResourceKey="Shadow_Popup_Light"/>
        </Border.Effect>

        <StackPanel Margin="14">
            <Grid Margin="0,0,0,10">
                <TextBlock Text="颜色" FontSize="{StaticResource FontSize_Body_M}" FontWeight="SemiBold" Foreground="{StaticResource Brush_Text_Primary}" VerticalAlignment="Center"/>
                <Button Style="{StaticResource Style_IconButton}" Click="OnCancelFromButton" x:Name="CloseButton" HorizontalAlignment="Right" ToolTip="关闭">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform"
                          Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}"/>
                </Button>
            </Grid>
            <StackPanel x:Name="OptionsPanel" Orientation="Horizontal" />
        </StackPanel>
    </Border>
</Window>
