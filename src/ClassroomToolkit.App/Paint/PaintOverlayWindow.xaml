<Window x:Class="ClassroomToolkit.App.Paint.PaintOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="PaintOverlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="28" ResizeBorderThickness="6" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Border x:Name="PhotoWindowFrame" BorderBrush="{StaticResource Brush_Border}" BorderThickness="0" Background="Transparent">
        <Grid x:Name="OverlayRoot" Background="Transparent" ClipToBounds="True">
            <Canvas x:Name="NeighborPagesCanvas" IsHitTestVisible="False" Visibility="Collapsed"/>
            <Image x:Name="PhotoBackground" Stretch="None" SnapsToDevicePixels="True" HorizontalAlignment="Left" VerticalAlignment="Top" Visibility="Collapsed"/>
            <Image x:Name="RasterImage" Stretch="None" SnapsToDevicePixels="True" HorizontalAlignment="Left" VerticalAlignment="Top" />
            <Canvas x:Name="PreviewCanvas" IsHitTestVisible="False" />
            <Border x:Name="CustomDrawHost" Background="Transparent" IsHitTestVisible="False" />
            <Grid x:Name="PhotoControlLayer" Visibility="Collapsed" Background="{x:Null}" Panel.ZIndex="10">
                <!-- 顶部浮动标题栏 -->
                <Border x:Name="PhotoTitleBar" Height="48" Margin="0" VerticalAlignment="Top" 
                        MouseLeftButtonDown="OnPhotoTitleBarDrag">
                    <Border.Background>
                        <SolidColorBrush Color="{StaticResource Color_Bg_Overlay}"/>
                    </Border.Background>
                    <DockPanel Margin="12,0" VerticalAlignment="Top" Height="38">
                        <Border Background="{StaticResource Brush_Surface_Hover}" CornerRadius="19" Padding="16,0" Height="30" VerticalAlignment="Center" Margin="10,0,0,0">
                             <Border.Effect>
                                <StaticResource ResourceKey="Shadow_Card_Subtle"/>
                            </Border.Effect>
                            <TextBlock x:Name="PhotoTitleText" Text="图片应用" VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush_Text_Primary}" FontWeight="SemiBold" FontSize="13"/>
                        </Border>
                    </DockPanel>
                </Border>

                <!-- 顶右角关闭 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8,8,12,0">
                    <Button x:Name="PhotoCloseButton" Style="{StaticResource Style_FullscreenShellCloseButton}" Click="OnPhotoCloseClick"
                            Width="36" Height="36" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform"
                              Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}"/>
                    </Button>
                </StackPanel>

                <!-- 底部两侧浮动控制 -->
                <Button x:Name="PhotoCloseLeftButton" Style="{StaticResource Style_FullscreenShellCloseButton}" Click="OnPhotoCloseClick" Width="36" Height="36" ToolTip="关闭"
                        HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="16">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform"
                          Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}"/>
                </Button>
                <Button x:Name="PhotoCloseRightButton" Style="{StaticResource Style_FullscreenShellCloseButton}" Click="OnPhotoCloseClick" Width="36" Height="36" ToolTip="关闭"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="16">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform"
                          Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}"/>
                </Button>

                <!-- 左侧翻页 (Glassy Pill) -->
                <Border HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0,0,0" 
                        Style="{StaticResource Style_FullscreenShellSideRail}">
                    <StackPanel Orientation="Vertical">
                         <Button x:Name="PhotoPrevButtonLeft" Style="{StaticResource Style_IconButton}" Click="OnPhotoPrevClick" Width="40" Height="40" Margin="0,4,0,2" ToolTip="上一版">
                            <Path Data="{StaticResource Icon_ArrowUp}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform"
                                  Width="{StaticResource Size_Icon_Glyph_LG}" Height="{StaticResource Size_Icon_Glyph_LG}"/>
                        </Button>
                        <Button x:Name="PhotoNextButtonLeft" Style="{StaticResource Style_IconButton}" Click="OnPhotoNextClick" Width="40" Height="40" Margin="0,2,0,4" ToolTip="下一版">
                            <Path Data="{StaticResource Icon_ArrowDown}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform"
                                  Width="{StaticResource Size_Icon_Glyph_LG}" Height="{StaticResource Size_Icon_Glyph_LG}"/>
                        </Button>
                        <Button x:Name="PhotoFitButtonLeft" Style="{StaticResource Style_IconButton}" Click="OnPhotoFitWidthClick" Width="46" Height="40" Margin="0,2,0,2" ToolTip="宽度适配并居中">
                            <TextBlock Text="适宽" Foreground="{StaticResource Brush_Text_Primary}" FontSize="11" FontWeight="SemiBold"/>
                        </Button>
                        <Button x:Name="ExportInkButtonLeft" Style="{StaticResource Style_IconButton}" Click="OnExportInkClick" Width="46" Height="40" Margin="0,2,0,6" ToolTip="导出当前目录笔迹合成图片（含清理失效旧图）">
                            <TextBlock Text="导出" Foreground="{StaticResource Brush_Text_Primary}" FontSize="11" FontWeight="SemiBold"/>
                        </Button>
                    </StackPanel>
                </Border>
                
                <!-- 右侧翻页 (Glassy Pill) -->
                <Border HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0" 
                        Style="{StaticResource Style_FullscreenShellSideRail}">
                    <StackPanel Orientation="Vertical">
                        <Button x:Name="PhotoPrevButtonRight" Style="{StaticResource Style_IconButton}" Click="OnPhotoPrevClick" Width="40" Height="40" Margin="0,4,0,2" ToolTip="上一版">
                            <Path Data="{StaticResource Icon_ArrowUp}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform"
                                  Width="{StaticResource Size_Icon_Glyph_LG}" Height="{StaticResource Size_Icon_Glyph_LG}"/>
                        </Button>
                        <Button x:Name="PhotoNextButtonRight" Style="{StaticResource Style_IconButton}" Click="OnPhotoNextClick" Width="40" Height="40" Margin="0,2,0,4" ToolTip="下一版">
                            <Path Data="{StaticResource Icon_ArrowDown}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform"
                                  Width="{StaticResource Size_Icon_Glyph_LG}" Height="{StaticResource Size_Icon_Glyph_LG}"/>
                        </Button>
                        <Button x:Name="PhotoFitButtonRight" Style="{StaticResource Style_IconButton}" Click="OnPhotoFitWidthClick" Width="46" Height="40" Margin="0,2,0,2" ToolTip="宽度适配并居中"
                                Visibility="Collapsed">
                            <TextBlock Text="适宽" Foreground="{StaticResource Brush_Text_Primary}" FontSize="11" FontWeight="SemiBold"/>
                        </Button>
                        <Button x:Name="ExportInkButtonRight" Style="{StaticResource Style_IconButton}" Click="OnExportInkClick" Width="46" Height="40" Margin="0,2,0,6" ToolTip="导出当前目录笔迹合成图片（含清理失效旧图）"
                                Visibility="Collapsed">
                            <TextBlock Text="导出" Foreground="{StaticResource Brush_Text_Primary}" FontSize="11" FontWeight="SemiBold"/>
                        </Button>
                    </StackPanel>
                </Border>

                <Border HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,14"
                        Style="{StaticResource Style_FullscreenShellHintBadge}">
                    <TextBlock Text="左侧为主操作区 · 右侧为翻页快捷区"
                               Foreground="{StaticResource Brush_Text_Secondary}"
                               FontSize="11"/>
                </Border>
            </Grid>
            <Grid x:Name="PhotoLoadingOverlay" Visibility="Collapsed" Background="{StaticResource Brush_OverlayMask}" Panel.ZIndex="20">
                <Border Background="{StaticResource Brush_Surface_Primary}" BorderBrush="{StaticResource Brush_Border_Subtle}" BorderThickness="1"
                        CornerRadius="12" Padding="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="PhotoLoadingText" Text="正在加载..." Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>

