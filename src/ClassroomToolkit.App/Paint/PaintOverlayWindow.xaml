<Window x:Class="ClassroomToolkit.App.Paint.PaintOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="PaintOverlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="28" ResizeBorderThickness="6" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Border x:Name="PhotoWindowFrame" BorderBrush="{StaticResource Brush_Border}" BorderThickness="0" Background="Transparent">
        <Grid x:Name="OverlayRoot" Background="Transparent" ClipToBounds="True">
            <Canvas x:Name="NeighborPagesCanvas" IsHitTestVisible="False" Visibility="Collapsed"/>
            <Image x:Name="PhotoBackground" Stretch="None" SnapsToDevicePixels="True" HorizontalAlignment="Left" VerticalAlignment="Top" Visibility="Collapsed"/>
            <Image x:Name="RasterImage" Stretch="None" SnapsToDevicePixels="True" HorizontalAlignment="Left" VerticalAlignment="Top" />
            <Canvas x:Name="PreviewCanvas" IsHitTestVisible="False" />
            <Border x:Name="CustomDrawHost" Background="Transparent" IsHitTestVisible="False" />
            <Grid x:Name="PhotoControlLayer" Visibility="Collapsed" Background="{x:Null}" Panel.ZIndex="10">
                <!-- 顶部浮动标题栏 -->
                <Border x:Name="PhotoTitleBar" Height="48" Margin="0" VerticalAlignment="Top" 
                        MouseLeftButtonDown="OnPhotoTitleBarDrag">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#CC1A1A2E" Offset="0"/>
                            <GradientStop Color="#001A1A2E" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <DockPanel Margin="12,0" VerticalAlignment="Top" Height="38">
                        <Border Background="{StaticResource Brush_Surface_Hover}" CornerRadius="19" Padding="16,0" Height="30" VerticalAlignment="Center" Margin="10,0,0,0">
                             <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="1" Opacity="0.5"/>
                            </Border.Effect>
                            <TextBlock x:Name="PhotoTitleText" Text="图片应用" VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush_Text_Primary}" FontWeight="SemiBold" FontSize="13"/>
                        </Border>
                    </DockPanel>
                </Border>

                <!-- 顶右角关闭 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8,8,12,0">
                    <Button x:Name="PhotoCloseButton" Style="{StaticResource Style_IconButton}" Click="OnPhotoCloseClick"
                            Width="36" Height="36" shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Background="{StaticResource Brush_Background_L2}">
                        <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform" Width="14" Height="14"/>
                    </Button>
                </StackPanel>

                <!-- 底部两侧浮动控制 -->
                <Button x:Name="PhotoCloseLeftButton" Style="{StaticResource Style_IconButton}" Click="OnPhotoCloseClick" Width="36" Height="36" ToolTip="关闭"
                        HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="16">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform" Width="14" Height="14"/>
                </Button>
                <Button x:Name="PhotoCloseRightButton" Style="{StaticResource Style_IconButton}" Click="OnPhotoCloseClick" Width="36" Height="36" ToolTip="关闭"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="16">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform" Width="14" Height="14"/>
                </Button>

                <!-- 左侧翻页 (Glassy Pill) -->
                <Border HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0,0,0" 
                        Background="{StaticResource Brush_Background_L2}" CornerRadius="20" Opacity="0.8">
                    <StackPanel Orientation="Vertical">
                         <Button x:Name="PhotoPrevButtonLeft" Style="{StaticResource Style_IconButton}" Click="OnPhotoPrevClick" Width="40" Height="40" Margin="0,4,0,2" ToolTip="上一张">
                            <Path Data="{StaticResource Icon_ArrowUp}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform" Width="18" Height="18"/>
                        </Button>
                        <Button x:Name="PhotoNextButtonLeft" Style="{StaticResource Style_IconButton}" Click="OnPhotoNextClick" Width="40" Height="40" Margin="0,2,0,4" ToolTip="下一张">
                            <Path Data="{StaticResource Icon_ArrowDown}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform" Width="18" Height="18"/>
                        </Button>
                    </StackPanel>
                </Border>
                
                <!-- 右侧翻页 (Glassy Pill) -->
                <Border HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0" 
                        Background="{StaticResource Brush_Background_L2}" CornerRadius="20" Opacity="0.8">
                    <StackPanel Orientation="Vertical">
                        <Button x:Name="PhotoPrevButtonRight" Style="{StaticResource Style_IconButton}" Click="OnPhotoPrevClick" Width="40" Height="40" Margin="0,4,0,2" ToolTip="上一张">
                            <Path Data="{StaticResource Icon_ArrowUp}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform" Width="18" Height="18"/>
                        </Button>
                        <Button x:Name="PhotoNextButtonRight" Style="{StaticResource Style_IconButton}" Click="OnPhotoNextClick" Width="40" Height="40" Margin="0,2,0,4" ToolTip="下一张">
                            <Path Data="{StaticResource Icon_ArrowDown}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform" Width="18" Height="18"/>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
            <Grid x:Name="PhotoLoadingOverlay" Visibility="Collapsed" Background="#80000000" Panel.ZIndex="20">
                <Border Background="#CC1A1A2E" CornerRadius="12" Padding="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="PhotoLoadingText" Text="正在加载..." Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
