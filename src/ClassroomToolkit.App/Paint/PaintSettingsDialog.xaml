<Window x:Class="ClassroomToolkit.App.Paint.PaintSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="画笔设置" Height="560" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <GroupBox Header="基本画笔设置">
            <StackPanel Margin="8">
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                    <TextBlock Text="笔画粗细：" VerticalAlignment="Center" Width="80" />
                    <Slider x:Name="BrushSizeSlider" Minimum="1" Maximum="50" Width="200" ValueChanged="OnBrushSizeChanged" />
                    <TextBlock x:Name="BrushSizeValue" Width="60" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Text="笔画透明：" VerticalAlignment="Center" Width="80" />
                    <Slider x:Name="BrushOpacitySlider" Minimum="0" Maximum="100" Width="200" ValueChanged="OnBrushOpacityChanged" />
                    <TextBlock x:Name="BrushOpacityValue" Width="60" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Text="橡皮粗细：" VerticalAlignment="Center" Width="80" />
                    <Slider x:Name="EraserSizeSlider" Minimum="6" Maximum="60" Width="200" ValueChanged="OnEraserSizeChanged" />
                    <TextBlock x:Name="EraserSizeValue" Width="60" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Text="白板透明：" VerticalAlignment="Center" Width="80" />
                    <Slider x:Name="BoardOpacitySlider" Minimum="0" Maximum="100" Width="200" ValueChanged="OnBoardOpacityChanged" />
                    <TextBlock x:Name="BoardOpacityValue" Width="60" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="临时更换画笔的颜色：" Margin="0,10,0,4" />
                <UniformGrid Columns="4" Rows="2" Margin="0,0,0,4">
                    <Button Tag="#000000" Background="#000000" Foreground="White" Content="黑" Margin="2" Click="OnTempColorClick" />
                    <Button Tag="#FF0000" Background="#FF0000" Foreground="White" Content="红" Margin="2" Click="OnTempColorClick" />
                    <Button Tag="#1E90FF" Background="#1E90FF" Foreground="White" Content="蓝" Margin="2" Click="OnTempColorClick" />
                    <Button Tag="#24B47E" Background="#24B47E" Foreground="White" Content="绿" Margin="2" Click="OnTempColorClick" />
                    <Button Tag="#FFFF00" Background="#FFFF00" Foreground="Black" Content="黄" Margin="2" Click="OnTempColorClick" />
                    <Button Tag="#FFA500" Background="#FFA500" Foreground="Black" Content="橙" Margin="2" Click="OnTempColorClick" />
                    <Button Tag="#800080" Background="#800080" Foreground="White" Content="紫" Margin="2" Click="OnTempColorClick" />
                    <Button Tag="#FFFFFF" Background="#FFFFFF" Foreground="Black" Content="白" Margin="2" Click="OnTempColorClick" />
                </UniformGrid>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Text="画笔工具条的界面大小：" VerticalAlignment="Center" Width="140" />
                    <ComboBox x:Name="ToolbarScaleCombo" Width="120" />
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="图形工具" Grid.Row="1" Margin="0,12,0,0">
            <StackPanel Margin="8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="当前工具：" VerticalAlignment="Center" Width="80" />
                    <ComboBox x:Name="ShapeCombo" Width="200" />
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="WPS 兼容" Grid.Row="2" Margin="0,12,0,0">
            <StackPanel Margin="8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="兼容策略：" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox x:Name="WpsModeCombo" Width="200" />
                </StackPanel>
                <CheckBox x:Name="WpsWheelCheck" Content="滚轮映射为翻页键（解决双动画/无动画）"
                          Margin="0,8,0,0" />
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="确定" Width="70" Margin="0,0,8,0" Click="OnConfirm" />
            <Button Content="取消" Width="70" Click="OnCancel" />
        </StackPanel>
    </Grid>
</Window>
