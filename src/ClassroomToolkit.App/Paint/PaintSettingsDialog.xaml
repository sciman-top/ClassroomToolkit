<Window x:Class="ClassroomToolkit.App.Paint.PaintSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="画笔设置"
        Height="Auto" Width="620"
        MinHeight="560" MinWidth="560"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        Topmost="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48"
                            ResizeBorderThickness="8"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Style="{StaticResource Style_DialogShellWindowBorder}"
            Background="{StaticResource Brush_Window_Atmosphere}"
            Margin="10"
            Effect="{StaticResource Shadow_Dialog_Heavy}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title -->
                <RowDefinition Height="*"/> <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- 1. 标题栏 -->
            <Grid Grid.Row="0" Style="{StaticResource Style_DialogShellTitleBar}" MouseLeftButtonDown="OnTitleBarDrag">
                <TextBlock Text="画笔设置" Style="{StaticResource Style_DialogShellTitleText}"/>
                <Button Style="{StaticResource Style_DialogShellCloseButton}" Click="OnCancel" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform"
                          Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}"/>
                </Button>
            </Grid>
            <!-- 分隔线 -->
            <Border Grid.Row="0" Style="{StaticResource Style_DialogShellDivider}"/>

            <!-- 2. 内容 -->
            <ScrollViewer Grid.Row="1"
                          Margin="20,16,20,14"
                          Padding="0,0,12,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
                <Grid>
                    <TabControl x:Name="SettingsTabControl" Background="Transparent" BorderThickness="0">
                        <TabItem Header="笔触与预设">
                            <StackPanel Margin="0,12,0,0">
                <!-- 基础画笔参数 -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="笔触风格" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Medium"/>
                    <ComboBox Grid.Column="1" x:Name="BrushStyleCombo" Height="36" SelectionChanged="OnBrushStyleChanged"/>
                </Grid>
                
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="白板笔预设" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Medium"/>
                    <ComboBox Grid.Column="1" x:Name="WhiteboardPresetCombo" Height="36"/>
                </Grid>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="毛笔预设" VerticalAlignment="Top" Foreground="{StaticResource Brush_Text_Secondary}" Margin="0,6,0,0" FontWeight="Medium"/>
                    <StackPanel Grid.Column="1">
                        <ComboBox x:Name="CalligraphyPresetCombo" Height="36" Margin="0,0,0,8"/>
                        <Expander Header="毛笔高级（不建议调整）" IsExpanded="False" Foreground="{StaticResource Brush_Text_Primary}">
                            <Border Style="{StaticResource Style_SettingCardBorder}"
                                    Margin="0,8,0,0"
                                    Padding="10"
                                    Background="{StaticResource Brush_Surface_Secondary}"
                                    CornerRadius="8">
                                <StackPanel>
                                    <CheckBox x:Name="CalligraphyInkBloomCheck" Content="顿笔墨团（更润更厚）" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="CalligraphySealCheck" Content="空洞修复（填补白点）" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="CalligraphyOverlayThresholdLabel" Text="低不透明度弱化阈值" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="12" Margin="0,4,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="CalligraphyOverlayThresholdSlider" Minimum="0" Maximum="100" ValueChanged="OnCalligraphyOverlayThresholdChanged" Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="1" x:Name="CalligraphyOverlayThresholdValue" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Expander>
                    </StackPanel>
                </Grid>

                <Expander x:Name="WritingModeOverrideExpander" Header="书写模式覆盖（按需）" IsExpanded="False" Margin="0,0,0,16" Foreground="{StaticResource Brush_Text_Primary}">
                    <Border Style="{StaticResource Style_SettingCardBorder}"
                            Margin="0,8,0,0"
                            Padding="12"
                            Background="{StaticResource Brush_Surface_Secondary}">
                        <StackPanel>
                            <TextBlock Text="整体效果请优先在&quot;整套预设&quot;中选择；此处仅在需要时覆盖书写手感。"
                                       Foreground="{StaticResource Brush_Text_Secondary}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="书写模式" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Medium"/>
                                <ComboBox Grid.Column="1" x:Name="ClassroomWritingModeCombo" Height="34"/>
                            </Grid>
                            <TextBlock x:Name="ClassroomWritingModeHint" Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource Brush_Text_Secondary}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Expander>

                <Border Style="{StaticResource Style_SettingCardBorder}" Padding="12">
                    <StackPanel>
                        <TextBlock Text="整套预设" VerticalAlignment="Center" Margin="0,0,0,8" Foreground="{StaticResource Brush_Text_Secondary}"/>
                        <TextBlock Text="这里是总入口，会统一调整书写模式与场景参数。"
                                   Margin="0,0,0,8"
                                   FontSize="12"
                                   Foreground="{StaticResource Brush_Text_Secondary}"
                                   TextWrapping="Wrap"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="PresetSchemeCombo" Height="34" SelectionChanged="OnPresetSchemeChanged"/>
                            <Button Grid.Column="1"
                                    x:Name="ReapplyPresetButton"
                                    Content="应用所选"
                                    Margin="8,0,0,0"
                                    Padding="12,0"
                                    Height="34"
                                    MinWidth="72"
                                    Style="{StaticResource Style_SecondaryButton}"
                                    Click="OnReapplyPresetClick"/>
                            <Button Grid.Column="2"
                                    x:Name="RestoreCustomPresetButton"
                                    Content="恢复自定义"
                                    Margin="8,0,0,0"
                                    Padding="12,0"
                                    Height="34"
                                    MinWidth="92"
                                    Style="{StaticResource Style_SecondaryButton}"
                                    Click="OnRestoreCustomPresetClick"/>
                        </Grid>
                        <TextBlock x:Name="PresetSchemeHintText" Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource Brush_Text_Secondary}" TextWrapping="Wrap"/>
                        <TextBlock x:Name="PresetManagedHintText" Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource Brush_Text_Secondary}" TextWrapping="Wrap"/>
                        <Button x:Name="ConvertToCustomEditingButton"
                                Content="切换为自定义后编辑"
                                Margin="0,8,0,0"
                                Padding="12,0"
                                Height="30"
                                MinWidth="132"
                                HorizontalAlignment="Left"
                                Style="{StaticResource Style_SecondaryButton}"
                                Click="OnConvertToCustomEditingClick"/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="PresetSchemeRecommendationText"
                                       Foreground="{StaticResource Brush_Text_Secondary}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                            <Button Grid.Column="1"
                                    x:Name="ApplyRecommendedPresetButton"
                                    Content="套用推荐"
                                    Margin="12,0,0,0"
                                    Padding="12,0"
                                    Height="30"
                                    MinWidth="92"
                                    Style="{StaticResource Style_SecondaryButton}"
                                    Click="OnApplyRecommendedPresetClick"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="笔画粗细" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Medium"/>
                    <Slider Grid.Column="1" x:Name="BrushSizeSlider" Minimum="1" Maximum="50" ValueChanged="OnBrushSizeChanged" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="2" x:Name="BrushSizeValue" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}"/>
                </Grid>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="不透明度" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Medium"/>
                    <Slider Grid.Column="1" x:Name="BrushOpacitySlider" Minimum="0" Maximum="100" ValueChanged="OnBrushOpacityChanged" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="2" x:Name="BrushOpacityValue" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}"/>
                </Grid>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="橡皮粗细" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Medium"/>
                    <Slider Grid.Column="1" x:Name="EraserSizeSlider" Minimum="6" Maximum="60" ValueChanged="OnEraserSizeChanged" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="2" x:Name="EraserSizeValue" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}"/>
                </Grid>

                            </StackPanel>
                        </TabItem>

                        <TabItem Header="工具栏">
                            <StackPanel Margin="0,12,0,0">
                                <Border Style="{StaticResource Style_SettingCardBorder}" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="界面与工具" Foreground="{StaticResource Brush_Text_Secondary}" Margin="0,0,0,6"/>
                                        <TextBlock Text="这里只保留影响工具栏显示和切换方式的设置。"
                                                   Foreground="{StaticResource Brush_Text_Tertiary}"
                                                   FontSize="12"
                                                   Margin="0,0,0,12"/>
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="图形工具" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Medium"/>
                                            <ComboBox Grid.Column="1" x:Name="ShapeCombo" Height="36"/>
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="工具条缩放" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Medium"/>
                                            <ComboBox Grid.Column="1" x:Name="ToolbarScaleCombo" Height="36"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </TabItem>

                        <TabItem Header="场景与兼容">
                            <StackPanel Margin="0,12,0,0">
                <Grid x:Name="SceneCardsGrid" Margin="0,8,0,0" SizeChanged="OnSceneCardsGridSizeChanged">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- PDF、图片的设置 -->
                    <Border x:Name="PhotoPdfSettingsCard"
                            Grid.Row="0"
                            Grid.Column="0"
                            Style="{StaticResource Style_SettingCardBorder}"
                            Padding="16"
                            Margin="0,0,6,0">
                        <StackPanel>
                            <TextBlock Text="PDF/图片" FontWeight="Bold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,12" FontSize="13"/>
                            <CheckBox x:Name="InkSaveCheck" Content="保存笔迹" Foreground="{StaticResource Brush_Text_Primary}" FontSize="13" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="导出范围" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="13"/>
                                <ComboBox Grid.Column="1" x:Name="InkExportScopeCombo" Height="34" FontSize="13"/>
                            </Grid>
                            <CheckBox x:Name="PhotoCrossPageDisplayCheck" Content="连页显示" Foreground="{StaticResource Brush_Text_Primary}" FontSize="13" Margin="0,0,0,10"/>
                            <CheckBox x:Name="PhotoRememberTransformCheck" Content="记住缩放/平移位置" Foreground="{StaticResource Brush_Text_Primary}" FontSize="13" Margin="0,0,0,10"/>
                            <TextBlock Text="说明：默认推荐保持当前设置；仅在卡顿或翻页不同步时再调整下方高级参数。"
                                       Foreground="{StaticResource Brush_Text_Tertiary}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>

                            <Expander Header="高级参数（一般无需调整）" IsExpanded="False" Foreground="{StaticResource Brush_Text_Primary}">
                                <Border Margin="0,8,0,0" Padding="10" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource Brush_Border}" Background="{StaticResource Brush_Surface_Secondary}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="导出并行度" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="13"/>
                                            <ComboBox Grid.Column="1" x:Name="ExportParallelCombo" Height="34" FontSize="13"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="邻页预加载" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="13"/>
                                            <ComboBox Grid.Column="1" x:Name="NeighborPrefetchCombo" Height="34" FontSize="13"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="抬笔后延迟刷新" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="13"/>
                                            <ComboBox Grid.Column="1" x:Name="PostInputRefreshDelayCombo" Height="34" FontSize="13"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="滚轮缩放幅度" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="13"/>
                                            <ComboBox Grid.Column="1" x:Name="WheelZoomBaseCombo" Height="34" FontSize="13"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="手势缩放灵敏度" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="13"/>
                                            <ComboBox Grid.Column="1" x:Name="GestureSensitivityCombo" Height="34" FontSize="13"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="拖拽惯性预设" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="13"/>
                                            <ComboBox Grid.Column="1" x:Name="PhotoInertiaProfileCombo" Height="34" FontSize="13"/>
                                        </Grid>
                                        <CheckBox x:Name="PhotoInputTelemetryCheck" Content="输入日志（仅排障）" Foreground="{StaticResource Brush_Text_Primary}" FontSize="13"/>
                                    </StackPanel>
                                </Border>
                            </Expander>
                        </StackPanel>
                    </Border>

                    <!-- 演示文稿控制策略 -->
                    <Border x:Name="WpsSettingsCard"
                            Grid.Row="0"
                            Grid.Column="1"
                            Style="{StaticResource Style_SettingCardBorder}"
                            Padding="16"
                            Margin="6,0,0,0">
                        <StackPanel>
                            <TextBlock Text="放映控制策略" FontWeight="Bold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,12" FontSize="13"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="112"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Office PPT" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="13"/>
                                <ComboBox Grid.Column="1" x:Name="OfficeModeCombo" Height="34" FontSize="13"/>
                            </Grid>

                            <!-- WPS 策略 -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="112"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="WPS 演示文稿" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="13"/>
                                <ComboBox Grid.Column="1" x:Name="WpsModeCombo" Height="34" FontSize="13"/>
                            </Grid>
                            <CheckBox x:Name="WpsWheelCheck" Content="滚轮映射为翻页键" Foreground="{StaticResource Brush_Text_Primary}" FontSize="13" Margin="0,0,0,10"/>
                            <CheckBox x:Name="ForceForegroundCheck" Content="自动置顶（检测到全屏放映时）" Foreground="{StaticResource Brush_Text_Primary}" FontSize="13" Margin="0,0,0,10"/>
                            <TextBlock Text="说明：默认推荐保持当前设置；仅在兼容异常时再调整高级参数。"
                                       Foreground="{StaticResource Brush_Text_Tertiary}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>

                            <Expander Header="高级参数（一般无需调整）" IsExpanded="False" Foreground="{StaticResource Brush_Text_Primary}">
                                <Border Margin="0,8,0,0" Padding="10" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource Brush_Border}" Background="{StaticResource Brush_Surface_Secondary}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="去抖阈值" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="13"/>
                                            <ComboBox Grid.Column="1" x:Name="WpsDebounceCombo" Height="34" FontSize="13"/>
                                        </Grid>
                                        <CheckBox x:Name="LockStrategyOnDegradeCheck" Content="降级后固定兼容模式（更稳定）" Foreground="{StaticResource Brush_Text_Primary}" FontSize="13"/>
                                        <CheckBox x:Name="PresentationClassifierAutoLearnCheck" Content="自动学习放映窗口特征（实验功能）" Foreground="{StaticResource Brush_Text_Primary}" FontSize="13" Margin="0,10,0,0"/>
                                        <CheckBox x:Name="PresentationClassifierClearOverridesCheck" Content="清空演示识别规则覆盖（保存后生效）" Foreground="{StaticResource Brush_Text_Primary}" FontSize="13" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Expander>
                        </StackPanel>
                    </Border>
                </Grid>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </Grid>
            </ScrollViewer>

            <!-- 3. 按钮 -->
            <StackPanel Grid.Row="2" Style="{StaticResource Style_DialogShellActionBar}">
                <Button Content="仅重置当前页" Style="{StaticResource Style_DialogShellSecondaryActionButton_Wide}" Click="OnRestoreDefaultsClick"/>
                <Button Content="重置全部设置" Width="118" Style="{StaticResource Style_DialogShellSecondaryActionButton}" Click="OnRestoreAllDefaultsClick"/>
                <Button Content="取消" Style="{StaticResource Style_DialogShellSecondaryActionButton}" Click="OnCancel"/>
                <Button Content="确定" Style="{StaticResource Style_DialogShellPrimaryActionButton}" Click="OnConfirm"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>


