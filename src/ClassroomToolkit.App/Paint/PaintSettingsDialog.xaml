<Window x:Class="ClassroomToolkit.App.Paint.PaintSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="画笔设置"
        Height="Auto" Width="620"
        MinHeight="560" MinWidth="560"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        Topmost="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48"
                            ResizeBorderThickness="8"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Style="{StaticResource Style_DialogShellWindowBorder}"
            Background="{StaticResource Brush_Window_Atmosphere}"
            Margin="10"
            Effect="{StaticResource Shadow_Dialog_Heavy}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title -->
                <RowDefinition Height="*"/> <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Summary -->
                <RowDefinition Height="Auto"/> <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- 1. 标题栏 -->
            <Grid Grid.Row="0" Style="{StaticResource Style_DialogShellTitleBar}" MouseLeftButtonDown="OnTitleBarDrag">
                <TextBlock Text="画笔设置" Style="{StaticResource Style_DialogShellTitleText}"/>
                <Button Style="{StaticResource Style_DialogShellCloseButton}" Click="OnCancel" ToolTip="关闭" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform"
                          Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}"/>
                </Button>
            </Grid>
            <!-- 分隔线 -->
            <Border Grid.Row="0" Style="{StaticResource Style_DialogShellDivider}"/>

            <!-- 2. 内容 -->
            <ScrollViewer Grid.Row="1"
                          Margin="20,16,20,14"
                          Padding="0,0,12,0"
                          PanningMode="VerticalFirst"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
                <Grid>
                    <TabControl x:Name="SettingsTabControl" Background="Transparent" BorderThickness="0">
                        <TabItem Header="基础">
                            <StackPanel Margin="0,12,0,0">
                <TextBlock Text="先选预设，再调参数。"
                           Margin="0,0,0,12"
                           Foreground="{StaticResource Brush_Text_Tertiary}"
                           FontSize="{StaticResource FontSize_Body_S}"
                           TextWrapping="Wrap"/>
                <TextBlock Text="笔触与预设"
                           Margin="0,0,0,8"
                           Foreground="{StaticResource Brush_Text_Secondary}"
                           FontWeight="SemiBold"/>
                <!-- 基础画笔参数 -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="笔触风格" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Medium"/>
                    <ComboBox Grid.Column="1" x:Name="BrushStyleCombo" Height="{StaticResource Size_Button_Icon_Regular}" SelectionChanged="OnBrushStyleChanged"/>
                </Grid>
                
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="笔触预设" VerticalAlignment="Top" Foreground="{StaticResource Brush_Text_Secondary}" Margin="0,6,0,0" FontWeight="Medium"/>
                    <StackPanel Grid.Column="1">
                        <ComboBox x:Name="WhiteboardPresetCombo" Height="{StaticResource Size_Button_Icon_Regular}" Margin="0,0,0,8"/>
                        <ComboBox x:Name="CalligraphyPresetCombo" Height="{StaticResource Size_Button_Icon_Regular}" Margin="0,0,0,8"/>
                        <Expander x:Name="CalligraphyAdvancedExpander" Header="毛笔高级" IsExpanded="False" Foreground="{StaticResource Brush_Text_Primary}">
                            <Border Style="{StaticResource Style_SettingCardBorder}"
                                    Margin="0,8,0,0"
                                    Padding="10"
                                    Background="{StaticResource Brush_Surface_Secondary}"
                                    CornerRadius="8">
                                <StackPanel>
                                    <CheckBox x:Name="CalligraphyInkBloomCheck" Content="顿笔墨团" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="CalligraphySealCheck" Content="空洞修复" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="CalligraphyOverlayThresholdLabel" Text="低不透明度阈值" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="{StaticResource FontSize_Body_S}" Margin="0,4,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="CalligraphyOverlayThresholdSlider" Minimum="0" Maximum="100" ValueChanged="OnCalligraphyOverlayThresholdChanged" Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="1" x:Name="CalligraphyOverlayThresholdValue" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Expander>
                    </StackPanel>
                </Grid>

                <Border Style="{StaticResource Style_SettingCardBorder}" Padding="12">
                    <StackPanel>
                        <TextBlock Text="整套预设" VerticalAlignment="Center" Margin="0,0,0,8" Foreground="{StaticResource Brush_Text_Secondary}"/>
                        <TextBlock Text="统一管理预设、手感和场景。"
                                   Margin="0,0,0,8"
                                   FontSize="{StaticResource FontSize_Body_S}"
                                   Foreground="{StaticResource Brush_Text_Secondary}"
                                   TextWrapping="Wrap"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="PresetSchemeCombo" Height="{StaticResource Size_Button_Icon_Regular}" SelectionChanged="OnPresetSchemeChanged"/>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="书写模式" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Medium"/>
                            <ComboBox Grid.Column="1" x:Name="ClassroomWritingModeCombo" Height="{StaticResource Size_Button_Icon_Regular}"/>
                        </Grid>
                        <TextBlock x:Name="PresetSchemeHintText" Margin="0,8,0,0" FontSize="{StaticResource FontSize_Body_S}" Foreground="{StaticResource Brush_Text_Secondary}" TextWrapping="Wrap"/>
                        <TextBlock x:Name="PresetManagedHintText" Margin="0,6,0,0" FontSize="{StaticResource FontSize_Body_S}" Foreground="{StaticResource Brush_Text_Secondary}" TextWrapping="Wrap"/>
                        <TextBlock x:Name="ClassroomWritingModeHint" Margin="0,6,0,0" FontSize="{StaticResource FontSize_Body_S}" Foreground="{StaticResource Brush_Text_Secondary}" TextWrapping="Wrap"/>
                        <Button x:Name="ConvertToCustomEditingButton"
                                Content="切换为自定义"
                                Margin="0,8,0,0"
                                Padding="12,0"
                                Height="{StaticResource Size_Button_Action_Height_Compact}"
                                MinWidth="132"
                                HorizontalAlignment="Left"
                                Style="{StaticResource Style_SecondaryButton}"
                                Click="OnConvertToCustomEditingClick"/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="PresetSchemeRecommendationText"
                                       Foreground="{StaticResource Brush_Text_Secondary}"
                                       FontSize="{StaticResource FontSize_Body_S}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Text="基础微调"
                           Margin="0,16,0,8"
                           Foreground="{StaticResource Brush_Text_Secondary}"
                           FontWeight="SemiBold"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="笔画粗细" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Medium"/>
                    <Slider Grid.Column="1" x:Name="BrushSizeSlider" Minimum="1" Maximum="50" ValueChanged="OnBrushSizeChanged" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="2" x:Name="BrushSizeValue" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}"/>
                </Grid>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="橡皮粗细" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Medium"/>
                    <Slider Grid.Column="1" x:Name="EraserSizeSlider" Minimum="6" Maximum="60" ValueChanged="OnEraserSizeChanged" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="2" x:Name="EraserSizeValue" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}"/>
                </Grid>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="不透明度" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Medium"/>
                    <Slider Grid.Column="1" x:Name="BrushOpacitySlider" Minimum="0" Maximum="100" ValueChanged="OnBrushOpacityChanged" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="2" x:Name="BrushOpacityValue" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}"/>
                </Grid>

                            </StackPanel>
                        </TabItem>

                        <TabItem Header="工具栏">
                            <StackPanel Margin="0,12,0,0">
                                <Border Style="{StaticResource Style_SettingCardBorder}" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="界面与工具" Foreground="{StaticResource Brush_Text_Secondary}" Margin="0,0,0,6"/>
                                        <TextBlock Text="只调显示和切换。"
                                                   Foreground="{StaticResource Brush_Text_Tertiary}"
                                                   FontSize="{StaticResource FontSize_Body_S}"
                                                   Margin="0,0,0,12"/>
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="图形工具" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Medium"/>
                                            <ComboBox Grid.Column="1" x:Name="ShapeCombo" Height="{StaticResource Size_Button_Icon_Regular}"/>
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="工具条缩放" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Medium"/>
                                            <ComboBox Grid.Column="1" x:Name="ToolbarScaleCombo" Height="{StaticResource Size_Button_Icon_Regular}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </TabItem>

                        <TabItem Header="兼容">
                            <StackPanel Margin="0,12,0,0">
                <TextBlock Text="常用项优先，高级项按需开。"
                           Margin="0,0,0,12"
                           Foreground="{StaticResource Brush_Text_Tertiary}"
                           FontSize="{StaticResource FontSize_Body_S}"
                           TextWrapping="Wrap"/>
                <Border Style="{StaticResource Style_SettingCardBorder}" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="高级项默认收起。"
                                   Foreground="{StaticResource Brush_Text_Secondary}"
                                   FontSize="{StaticResource FontSize_Body_S}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8"/>
                        <CheckBox x:Name="AdvancedModeCheck"
                                  Content="显示高级项"
                                  Foreground="{StaticResource Brush_Text_Primary}"
                                  FontSize="{StaticResource FontSize_Body_M}"
                                  Checked="OnAdvancedModeCheckChanged"
                                  Unchecked="OnAdvancedModeCheckChanged"/>
                    </StackPanel>
                </Border>
                <Grid x:Name="SceneCardsGrid" Margin="0,8,0,0" SizeChanged="OnSceneCardsGridSizeChanged">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- PDF、图片的设置 -->
                    <Border x:Name="PhotoPdfSettingsCard"
                            Grid.Row="0"
                            Grid.Column="0"
                            Style="{StaticResource Style_SettingCardBorder}"
                            Padding="16"
                            Margin="0,0,6,0">
                        <StackPanel>
                            <TextBlock Text="PDF/图片" FontWeight="Bold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,12" FontSize="{StaticResource FontSize_Body_M}"/>
                            <CheckBox x:Name="InkSaveCheck" Content="保存笔迹" Foreground="{StaticResource Brush_Text_Primary}" FontSize="{StaticResource FontSize_Body_M}" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="导出范围" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="{StaticResource FontSize_Body_M}"/>
                                <ComboBox Grid.Column="1" x:Name="InkExportScopeCombo" Height="{StaticResource Size_Button_Icon_Regular}" FontSize="{StaticResource FontSize_Body_M}"/>
                            </Grid>
                            <CheckBox x:Name="PhotoCrossPageDisplayCheck" Content="跨页显示" Foreground="{StaticResource Brush_Text_Primary}" FontSize="{StaticResource FontSize_Body_M}" Margin="0,0,0,10"/>
                            <CheckBox x:Name="PhotoRememberTransformCheck" Content="记住缩放和平移" Foreground="{StaticResource Brush_Text_Primary}" FontSize="{StaticResource FontSize_Body_M}" Margin="0,0,0,10"/>
                            <TextBlock Text="排障时再调。"
                                       Foreground="{StaticResource Brush_Text_Tertiary}"
                                       FontSize="{StaticResource FontSize_Body_S}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>

                            <Expander x:Name="PhotoAdvancedExpander" Header="高级参数" IsExpanded="False" Foreground="{StaticResource Brush_Text_Primary}">
                                <Border Margin="0,8,0,0" Padding="10" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource Brush_Border}" Background="{StaticResource Brush_Surface_Secondary}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="导出并行度" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="{StaticResource FontSize_Body_M}"/>
                                            <ComboBox Grid.Column="1" x:Name="ExportParallelCombo" Height="{StaticResource Size_Button_Icon_Regular}" FontSize="{StaticResource FontSize_Body_M}"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="邻页预加载" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="{StaticResource FontSize_Body_M}"/>
                                            <ComboBox Grid.Column="1" x:Name="NeighborPrefetchCombo" Height="{StaticResource Size_Button_Icon_Regular}" FontSize="{StaticResource FontSize_Body_M}"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="抬笔后延迟刷新" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="{StaticResource FontSize_Body_M}"/>
                                            <ComboBox Grid.Column="1" x:Name="PostInputRefreshDelayCombo" Height="{StaticResource Size_Button_Icon_Regular}" FontSize="{StaticResource FontSize_Body_M}"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="滚轮缩放幅度" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="{StaticResource FontSize_Body_M}"/>
                                            <ComboBox Grid.Column="1" x:Name="WheelZoomBaseCombo" Height="{StaticResource Size_Button_Icon_Regular}" FontSize="{StaticResource FontSize_Body_M}"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="手势缩放灵敏度" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="{StaticResource FontSize_Body_M}"/>
                                            <ComboBox Grid.Column="1" x:Name="GestureSensitivityCombo" Height="{StaticResource Size_Button_Icon_Regular}" FontSize="{StaticResource FontSize_Body_M}"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="拖拽惯性预设" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="{StaticResource FontSize_Body_M}"/>
                                            <ComboBox Grid.Column="1" x:Name="PhotoInertiaProfileCombo" Height="{StaticResource Size_Button_Icon_Regular}" FontSize="{StaticResource FontSize_Body_M}"/>
                                        </Grid>
                                        <CheckBox x:Name="PhotoInputTelemetryCheck" Content="输入日志" Foreground="{StaticResource Brush_Text_Primary}" FontSize="{StaticResource FontSize_Body_M}"/>
                                    </StackPanel>
                                </Border>
                            </Expander>
                        </StackPanel>
                    </Border>

                    <!-- 演示文稿控制策略 -->
                    <Border x:Name="WpsSettingsCard"
                            Grid.Row="0"
                            Grid.Column="1"
                            Style="{StaticResource Style_SettingCardBorder}"
                            Padding="16"
                            Margin="6,0,0,0">
                        <StackPanel>
                            <TextBlock Text="放映控制策略" FontWeight="Bold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,12" FontSize="{StaticResource FontSize_Body_M}"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="112"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Office PPT" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="{StaticResource FontSize_Body_M}"/>
                                <ComboBox Grid.Column="1" x:Name="OfficeModeCombo" Height="{StaticResource Size_Button_Icon_Regular}" FontSize="{StaticResource FontSize_Body_M}"/>
                            </Grid>

                            <!-- WPS 策略 -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="112"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="WPS 演示文稿" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="{StaticResource FontSize_Body_M}"/>
                                <ComboBox Grid.Column="1" x:Name="WpsModeCombo" Height="{StaticResource Size_Button_Icon_Regular}" FontSize="{StaticResource FontSize_Body_M}"/>
                            </Grid>
                            <CheckBox x:Name="WpsWheelCheck" Content="滚轮翻页" Foreground="{StaticResource Brush_Text_Primary}" FontSize="{StaticResource FontSize_Body_M}" Margin="0,0,0,10"/>
                            <CheckBox x:Name="ForceForegroundCheck" Content="全屏置顶" Foreground="{StaticResource Brush_Text_Primary}" FontSize="{StaticResource FontSize_Body_M}" Margin="0,0,0,10"/>
                            <TextBlock Text="兼容异常时再调。"
                                       Foreground="{StaticResource Brush_Text_Tertiary}"
                                       FontSize="{StaticResource FontSize_Body_S}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>

                            <Expander x:Name="PresentationAdvancedExpander" Header="高级参数" IsExpanded="False" Foreground="{StaticResource Brush_Text_Primary}">
                                <Border Margin="0,8,0,0" Padding="10" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource Brush_Border}" Background="{StaticResource Brush_Surface_Secondary}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="去抖阈值" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="{StaticResource FontSize_Body_M}"/>
                                            <ComboBox Grid.Column="1" x:Name="WpsDebounceCombo" Height="{StaticResource Size_Button_Icon_Regular}" FontSize="{StaticResource FontSize_Body_M}"/>
                                        </Grid>
                                        <CheckBox x:Name="LockStrategyOnDegradeCheck" Content="降级后锁定兼容" Foreground="{StaticResource Brush_Text_Primary}" FontSize="{StaticResource FontSize_Body_M}"/>
                                        <Grid Margin="0,10,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="降级阈值" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="{StaticResource FontSize_Body_M}"/>
                                            <ComboBox Grid.Column="1" x:Name="FallbackFailureThresholdCombo" Height="{StaticResource Size_Button_Icon_Regular}" FontSize="{StaticResource FontSize_Body_M}"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="探活窗口" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="{StaticResource FontSize_Body_M}"/>
                                            <ComboBox Grid.Column="1" x:Name="FallbackProbeIntervalCombo" Height="{StaticResource Size_Button_Icon_Regular}" FontSize="{StaticResource FontSize_Body_M}"/>
                                        </Grid>
                                        <CheckBox x:Name="PresentationClassifierAutoLearnCheck" Content="自动学习特征" Foreground="{StaticResource Brush_Text_Primary}" FontSize="{StaticResource FontSize_Body_M}" Margin="0,10,0,0"/>
                                        <CheckBox x:Name="PresentationClassifierClearOverridesCheck" Content="清除覆盖" Foreground="{StaticResource Brush_Text_Primary}" FontSize="{StaticResource FontSize_Body_M}" Margin="0,8,0,0"/>
                                        <TextBlock Text="规则包"
                                                   Foreground="{StaticResource Brush_Text_Secondary}"
                                                   FontSize="{StaticResource FontSize_Body_M}"
                                                   Margin="0,12,0,8"/>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="ExportClassifierPackageButton"
                                                    Content="导出包"
                                                    Height="{StaticResource Size_Button_Action_Height_Compact}"
                                                    Margin="0,0,6,0"
                                                    Style="{StaticResource Style_SecondaryButton}"
                                                    Click="OnExportClassifierPackageClick"/>
                                            <Button Grid.Column="1"
                                                    x:Name="ImportClassifierPackageButton"
                                                    Content="导入包"
                                                    Height="{StaticResource Size_Button_Action_Height_Compact}"
                                                    Margin="6,0,0,0"
                                                    Style="{StaticResource Style_SecondaryButton}"
                                                    Click="OnImportClassifierPackageClick"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="CopyClassifierPackageButton"
                                                    Content="复制包"
                                                    Height="{StaticResource Size_Button_Action_Height_Compact}"
                                                    Margin="0,0,6,0"
                                                    Style="{StaticResource Style_SecondaryButton}"
                                                    Click="OnCopyClassifierPackageClick"/>
                                            <Button Grid.Column="1"
                                                    x:Name="ImportClassifierPackageFromClipboardButton"
                                                    Content="粘贴导入"
                                                    Height="{StaticResource Size_Button_Action_Height_Compact}"
                                                    Margin="6,0,0,0"
                                                    Style="{StaticResource Style_SecondaryButton}"
                                                    Click="OnImportClassifierPackageFromClipboardClick"/>
                                        </Grid>
                                        <Button x:Name="UndoClassifierPackageImportButton"
                                                Content="撤销导入"
                                                Height="{StaticResource Size_Button_Action_Height_Compact}"
                                                Margin="0,0,0,8"
                                                HorizontalAlignment="Left"
                                                MinWidth="132"
                                                Style="{StaticResource Style_SecondaryButton}"
                                                Click="OnUndoClassifierPackageImportClick"/>
                                       <TextBlock x:Name="PresentationClassifierPackageStatusText"
                                                   Text="规则包：未初始化。"
                                                   Foreground="{StaticResource Brush_Text_Tertiary}"
                                                   FontSize="{StaticResource FontSize_Body_S}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Expander>
                        </StackPanel>
                    </Border>
                </Grid>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </Grid>
            </ScrollViewer>

            <TextBlock x:Name="ChangeSummaryText"
                       Grid.Row="2"
                       Margin="24,0,24,8"
                       Foreground="{StaticResource Brush_Text_Tertiary}"
                       FontSize="{StaticResource FontSize_Body_S}"
                       TextWrapping="Wrap"/>

            <!-- 3. 按钮 -->
            <StackPanel Grid.Row="3" Style="{StaticResource Style_DialogShellActionBar}">
                <Button Content="重置本页" Style="{StaticResource Style_DialogShellSecondaryActionButton_Wide}" Click="OnRestoreDefaultsClick"/>
                <Button Content="全部重置" Style="{StaticResource Style_DialogShellSecondaryActionButton}" Click="OnRestoreAllDefaultsClick"/>
                <Button Content="取消" Style="{StaticResource Style_DialogShellSecondaryActionButton}" Click="OnCancel"/>
                <Button Content="确定" Style="{StaticResource Style_DialogShellPrimaryActionButton}" Click="OnConfirm"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

