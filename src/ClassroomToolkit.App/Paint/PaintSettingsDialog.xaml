<Window x:Class="ClassroomToolkit.App.Paint.PaintSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="画笔设置" Width="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <GroupBox Header="基本画笔设置">
            <StackPanel Margin="8">
                <Grid Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="60" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="笔画粗细：" VerticalAlignment="Center" />
                    <Slider Grid.Column="1" x:Name="BrushSizeSlider" Minimum="1" Maximum="50"
                            HorizontalAlignment="Stretch" ValueChanged="OnBrushSizeChanged" />
                    <TextBlock Grid.Column="2" x:Name="BrushSizeValue" Margin="8,0,0,0" VerticalAlignment="Center" />
                </Grid>
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="60" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="笔画透明度：" VerticalAlignment="Center" />
                    <Slider Grid.Column="1" x:Name="BrushOpacitySlider" Minimum="0" Maximum="100"
                            HorizontalAlignment="Stretch" ValueChanged="OnBrushOpacityChanged" />
                    <TextBlock Grid.Column="2" x:Name="BrushOpacityValue" Margin="8,0,0,0" VerticalAlignment="Center" />
                </Grid>
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="60" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="橡皮粗细：" VerticalAlignment="Center" />
                    <Slider Grid.Column="1" x:Name="EraserSizeSlider" Minimum="6" Maximum="60"
                            HorizontalAlignment="Stretch" ValueChanged="OnEraserSizeChanged" />
                    <TextBlock Grid.Column="2" x:Name="EraserSizeValue" Margin="8,0,0,0" VerticalAlignment="Center" />
                </Grid>
                <TextBlock Text="临时更换画笔的颜色：" Margin="0,10,0,4" />
                <UniformGrid Columns="4" Rows="2" Margin="0,0,0,4">
                    <Button Tag="#000000" Background="#000000" Foreground="White" Content="黑" Margin="2" Click="OnTempColorClick" />
                    <Button Tag="#FF0000" Background="#FF0000" Foreground="White" Content="红" Margin="2" Click="OnTempColorClick" />
                    <Button Tag="#1E90FF" Background="#1E90FF" Foreground="White" Content="蓝" Margin="2" Click="OnTempColorClick" />
                    <Button Tag="#24B47E" Background="#24B47E" Foreground="White" Content="绿" Margin="2" Click="OnTempColorClick" />
                    <Button Tag="#FFFF00" Background="#FFFF00" Foreground="Black" Content="黄" Margin="2" Click="OnTempColorClick" />
                    <Button Tag="#FFA500" Background="#FFA500" Foreground="Black" Content="橙" Margin="2" Click="OnTempColorClick" />
                    <Button Tag="#800080" Background="#800080" Foreground="White" Content="紫" Margin="2" Click="OnTempColorClick" />
                    <Button Tag="#FFFFFF" Background="#FFFFFF" Foreground="Black" Content="白" Margin="2" Click="OnTempColorClick" />
                </UniformGrid>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
            <TextBlock Text="画笔工具条的界面大小：" VerticalAlignment="Center" Width="140" />
            <ComboBox x:Name="ToolbarScaleCombo" Width="120" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
            <TextBlock Text="图形工具：" VerticalAlignment="Center" Width="80" />
            <ComboBox x:Name="ShapeCombo" Width="200" />
        </StackPanel>

        <GroupBox Header="WPS 兼容" Grid.Row="3" Margin="0,12,0,0">
            <StackPanel Margin="8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="兼容策略：" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox x:Name="WpsModeCombo" Width="200" />
                </StackPanel>
                <CheckBox x:Name="WpsWheelCheck" Content="滚轮映射为翻页键（解决双动画/无动画）"
                          Margin="0,8,0,0" />
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="确定" Width="60" Height="26" Margin="0,0,6,0" Click="OnConfirm" />
            <Button Content="取消" Width="60" Height="26" Click="OnCancel" />
        </StackPanel>
    </Grid>
</Window>
