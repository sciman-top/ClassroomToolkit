<Window x:Class="ClassroomToolkit.App.Paint.PaintSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="画笔设置"
        Height="Auto" Width="620"
        MinHeight="560" MinWidth="560"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        Topmost="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="52"
                            ResizeBorderThickness="8"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- 临时颜色按钮样式 (Updated) -->
        <Style x:Key="Style_TempColorButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                             <Border x:Name="border" CornerRadius="16" 
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="1" Opacity="0.5"/>
                                </Border.Effect>
                            </Border>
                            <!-- 选中/悬停高亮圈 -->
                             <Border x:Name="highlight" CornerRadius="18" BorderBrush="{StaticResource Brush_Primary}" BorderThickness="2" Margin="-4" Opacity="0" IsHitTestVisible="False"/>
                        </Grid>
                       
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform CenterX="16" CenterY="16" ScaleX="1.1" ScaleY="1.1"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="highlight" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource Brush_Window_Atmosphere}" CornerRadius="16" Margin="10" BorderBrush="{StaticResource Brush_Border}" BorderThickness="1"
            TextElement.Foreground="{StaticResource Brush_Text_Primary}">
        <Border.Effect>
            <!-- 统一的深浮层阴影 -->
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="12" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title -->
                <RowDefinition Height="*"/> <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- 1. 标题栏 -->
            <Grid Grid.Row="0" Height="52" Background="Transparent" MouseLeftButtonDown="OnTitleBarDrag">
                <TextBlock Text="画笔设置" FontWeight="Bold" Margin="24,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}" FontSize="18"/>
                <Button Style="{StaticResource Style_IconButton}"
                        Click="OnCancel"
                        HorizontalAlignment="Right"
                        Margin="0,0,16,0"
                        Width="36"
                        Height="36"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="14" Height="14"/>
                </Button>
            </Grid>
            <!-- 分隔线 -->
            <Rectangle Grid.Row="0" VerticalAlignment="Bottom" Height="1" Fill="{StaticResource Brush_Border}" Margin="24,0"/>

            <!-- 2. 内容 -->
            <ScrollViewer Grid.Row="1"
                          Margin="24,20,24,16"
                          Padding="0,0,12,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
                <Grid>
                    <StackPanel>

                <!-- 基础画笔参数 -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="笔触风格" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Medium"/>
                    <ComboBox Grid.Column="1" x:Name="BrushStyleCombo" Height="36" SelectionChanged="OnBrushStyleChanged"/>
                </Grid>
                
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="白板笔预设" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Medium"/>
                    <ComboBox Grid.Column="1" x:Name="WhiteboardPresetCombo" Height="36"/>
                </Grid>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="毛笔预设" VerticalAlignment="Top" Foreground="{StaticResource Brush_Text_Secondary}" Margin="0,6,0,0" FontWeight="Medium"/>
                    <StackPanel Grid.Column="1">
                        <ComboBox x:Name="CalligraphyPresetCombo" Height="36" Margin="0,0,0,8"/>
                        <Expander Header="毛笔高级（不建议调整）" IsExpanded="False" Foreground="{StaticResource Brush_Text_Primary}">
                            <Border Margin="0,8,0,0" Padding="10" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource Brush_Border}" Background="{StaticResource Brush_Background_L2}">
                                <StackPanel>
                                    <CheckBox x:Name="CalligraphyInkBloomCheck" Content="顿笔墨团（更润更厚）" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="CalligraphySealCheck" Content="空洞修复（填补白点）" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="CalligraphyOverlayThresholdLabel" Text="低不透明度弱化阈值" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="12" Margin="0,4,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="CalligraphyOverlayThresholdSlider" Minimum="0" Maximum="100" ValueChanged="OnCalligraphyOverlayThresholdChanged" Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="1" x:Name="CalligraphyOverlayThresholdValue" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Expander>
                    </StackPanel>
                </Grid>

                <Expander Header="书写模式（高级覆盖）" IsExpanded="False" Margin="0,0,0,16" Foreground="{StaticResource Brush_Text_Primary}">
                    <Border BorderThickness="1" BorderBrush="{StaticResource Brush_Border}" CornerRadius="10" Padding="12" Margin="0,8,0,0" Background="{StaticResource Brush_Background_L2}">
                        <StackPanel>
                            <TextBlock Text="预设方案会自动联动书写模式。仅在你需要手动覆盖时再修改。"
                                       Foreground="{StaticResource Brush_Text_Secondary}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="书写模式" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Medium"/>
                                <ComboBox Grid.Column="1" x:Name="ClassroomWritingModeCombo" Height="34"/>
                            </Grid>
                            <TextBlock x:Name="ClassroomWritingModeHint" Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource Brush_Text_Secondary}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Expander>

                <Border BorderThickness="1" BorderBrush="{StaticResource Brush_Border}" CornerRadius="12" Padding="12" Margin="0,0,0,16" Background="{StaticResource Brush_Background_L3}">
                    <StackPanel>
                        <TextBlock Text="预设方案" VerticalAlignment="Center" Margin="0,0,0,8" Foreground="{StaticResource Brush_Text_Secondary}"/>
                        <ComboBox x:Name="PresetSchemeCombo" Height="34" SelectionChanged="OnPresetSchemeChanged"/>
                        <TextBlock x:Name="PresetSchemeHintText" Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource Brush_Text_Secondary}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="笔画粗细" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Medium"/>
                    <Slider Grid.Column="1" x:Name="BrushSizeSlider" Minimum="1" Maximum="50" ValueChanged="OnBrushSizeChanged" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="2" x:Name="BrushSizeValue" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}"/>
                </Grid>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="不透明度" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Medium"/>
                    <Slider Grid.Column="1" x:Name="BrushOpacitySlider" Minimum="0" Maximum="100" ValueChanged="OnBrushOpacityChanged" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="2" x:Name="BrushOpacityValue" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}"/>
                </Grid>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="橡皮粗细" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Medium"/>
                    <Slider Grid.Column="1" x:Name="EraserSizeSlider" Minimum="6" Maximum="60" ValueChanged="OnEraserSizeChanged" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="2" x:Name="EraserSizeValue" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}"/>
                </Grid>

                <!-- 临时颜色 -->
                <TextBlock Text="临时换色" FontWeight="Bold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,4,0,12" FontSize="14"/>
                <WrapPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button Tag="#000000" Background="#000000" Style="{StaticResource Style_TempColorButton}" Click="OnTempColorClick" ToolTip="黑"/>
                    <Button Tag="#FF3B30" Background="#FF3B30" Style="{StaticResource Style_TempColorButton}" Click="OnTempColorClick" ToolTip="红"/>
                    <Button Tag="#007ACC" Background="#007ACC" Style="{StaticResource Style_TempColorButton}" Click="OnTempColorClick" ToolTip="蓝"/>
                    <Button Tag="#24B47E" Background="#24B47E" Style="{StaticResource Style_TempColorButton}" Click="OnTempColorClick" ToolTip="绿"/>
                    <Button Tag="#FFFF00" Background="#FFFF00" Style="{StaticResource Style_TempColorButton}" Click="OnTempColorClick" ToolTip="黄"/>
                    <Button Tag="#FFA500" Background="#FFA500" Style="{StaticResource Style_TempColorButton}" Click="OnTempColorClick" ToolTip="橙"/>
                    <Button Tag="#800080" Background="#800080" Style="{StaticResource Style_TempColorButton}" Click="OnTempColorClick" ToolTip="紫"/>
                    <Button Tag="#FFFFFF" Background="#FFFFFF" Style="{StaticResource Style_TempColorButton}" Click="OnTempColorClick" ToolTip="白"/>
                </WrapPanel>

                <!-- 其他设置 -->
                <TextBlock Text="界面与功能" FontWeight="Bold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,4,0,12" FontSize="14"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="图形工具" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Medium"/>
                    <ComboBox Grid.Column="1" x:Name="ShapeCombo" Height="36"/>
                </Grid>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="工具条缩放" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Medium"/>
                    <ComboBox Grid.Column="1" x:Name="ToolbarScaleCombo" Height="36"/>
                </Grid>

                <!-- PDF、图片的设置 -->
                <Border BorderThickness="1" BorderBrush="{StaticResource Brush_Border}" CornerRadius="12" Padding="16" Margin="0,8,0,0" Background="{StaticResource Brush_Background_L3}">
                     <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="4" ShadowDepth="1" Opacity="0.05"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="pdf、图片的设置" FontWeight="Bold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,12" FontSize="13"/>
                        <CheckBox x:Name="InkSaveCheck" Content="保存笔迹" Foreground="{StaticResource Brush_Text_Primary}" FontSize="13" Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="导出范围" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="13"/>
                            <ComboBox Grid.Column="1" x:Name="InkExportScopeCombo" Height="34" FontSize="13"/>
                        </Grid>
                        <CheckBox x:Name="PhotoCrossPageDisplayCheck" Content="连页显示" Foreground="{StaticResource Brush_Text_Primary}" FontSize="13" Margin="0,0,0,10"/>
                        <CheckBox x:Name="PhotoRememberTransformCheck" Content="记住缩放/平移位置" Foreground="{StaticResource Brush_Text_Primary}" FontSize="13" Margin="0,0,0,10"/>

                        <Expander Header="高级设置（不建议调整）" IsExpanded="False" Foreground="{StaticResource Brush_Text_Primary}">
                            <Border Margin="0,8,0,0" Padding="10" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource Brush_Border}" Background="{StaticResource Brush_Background_L2}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="导出并发" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="13"/>
                                        <ComboBox Grid.Column="1" x:Name="ExportParallelCombo" Height="34" FontSize="13"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="邻页预取" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="13"/>
                                        <ComboBox Grid.Column="1" x:Name="NeighborPrefetchCombo" Height="34" FontSize="13"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="抬笔后刷新" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="13"/>
                                        <ComboBox Grid.Column="1" x:Name="PostInputRefreshDelayCombo" Height="34" FontSize="13"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="滚轮缩放步进" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="13"/>
                                        <ComboBox Grid.Column="1" x:Name="WheelZoomBaseCombo" Height="34" FontSize="13"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="手势缩放灵敏" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="13"/>
                                        <ComboBox Grid.Column="1" x:Name="GestureSensitivityCombo" Height="34" FontSize="13"/>
                                    </Grid>
                                    <CheckBox x:Name="PhotoInputTelemetryCheck" Content="输入遥测日志（仅调试）" Foreground="{StaticResource Brush_Text_Primary}" FontSize="13"/>
                                </StackPanel>
                            </Border>
                        </Expander>
                    </StackPanel>
                </Border>

                <!-- WPS 演示文稿兼容性 -->
                <Border BorderThickness="1" BorderBrush="{StaticResource Brush_Border}" CornerRadius="12" Padding="16" Margin="0,8,0,0" Background="{StaticResource Brush_Background_L3}">
                     <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="4" ShadowDepth="1" Opacity="0.05"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="WPS 演示文稿兼容性" FontWeight="Bold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,12" FontSize="13"/>

                        <!-- WPS 兼容策略 -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="兼容策略" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="13"/>
                            <ComboBox Grid.Column="1" x:Name="WpsModeCombo" Height="34" FontSize="13"/>
                        </Grid>
                        <CheckBox x:Name="WpsWheelCheck" Content="滚轮映射为翻页键" Foreground="{StaticResource Brush_Text_Primary}" FontSize="13" Margin="0,0,0,10"/>
                        <CheckBox x:Name="ForceForegroundCheck" Content="自动置顶 (检测到全屏放映时)" Foreground="{StaticResource Brush_Text_Primary}" FontSize="13" Margin="0,0,0,10"/>

                        <Expander Header="高级设置（不建议调整）" IsExpanded="False" Foreground="{StaticResource Brush_Text_Primary}">
                            <Border Margin="0,8,0,0" Padding="10" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource Brush_Border}" Background="{StaticResource Brush_Background_L2}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="去抖阈值" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="13"/>
                                        <ComboBox Grid.Column="1" x:Name="WpsDebounceCombo" Height="34" FontSize="13"/>
                                    </Grid>
                                    <CheckBox x:Name="LockStrategyOnDegradeCheck" Content="降级后锁定消息模式（更稳）" Foreground="{StaticResource Brush_Text_Primary}" FontSize="13"/>
                                </StackPanel>
                            </Border>
                        </Expander>
                    </StackPanel>
                </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <!-- 3. 按钮 -->
            <Grid Grid.Row="2" Margin="24,0,24,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" Style="{StaticResource Style_SecondaryButton}" Width="96" Margin="0,0,12,0" Click="OnCancel"/>
                    <Button Content="确定" Style="{StaticResource Style_PrimaryButton}" Width="96" Click="OnConfirm"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
