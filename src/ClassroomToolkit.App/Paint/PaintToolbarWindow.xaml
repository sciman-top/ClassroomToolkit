<Window x:Class="ClassroomToolkit.App.Paint.PaintToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:ClassroomToolkit.App.Behaviors"
        Title="工具条"
        Height="Auto" Width="Auto"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}">

    <Window.Resources>
        <!-- 颜色选择按钮样式 (圆形) -->
        <Style x:Key="Style_ColorButton" TargetType="ToggleButton">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <!-- 选中时的外圈光环 -->
                            <Ellipse x:Name="Ring" Stroke="{TemplateBinding Background}" StrokeThickness="2" 
                                     Width="32" Height="32" Opacity="0">
                                <Ellipse.Effect>
                                    <BlurEffect Radius="2"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            
                            <!-- 颜色主体 -->
                            <Border x:Name="ColorDot" Width="20" Height="20" CornerRadius="10" 
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#30000000" BorderThickness="1">
                                <Border.RenderTransform>
                                    <ScaleTransform CenterX="10" CenterY="10" ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Ring" Property="Opacity" Value="1"/>
                                <Setter TargetName="ColorDot" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform CenterX="10" CenterY="10" ScaleX="1.2" ScaleY="1.2"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter TargetName="ColorDot" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform CenterX="10" CenterY="10" ScaleX="1.1" ScaleY="1.1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 分割线样式 -->
        <Style x:Key="Style_Separator" TargetType="Rectangle">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Fill" Value="#E0E0E0"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <!-- 主容器：胶囊形状，带阴影 -->
    <Border x:Name="ToolbarContainer" 
            Background="{StaticResource Brush_Background_Translucent}" 
            BorderBrush="{StaticResource Brush_Border}" 
            BorderThickness="1"
            CornerRadius="8" 
            Padding="6,4"
            MouseLeftButtonDown="OnToolbarDrag">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="10" ShadowDepth="2"/>
        </Border.Effect>

        <Grid x:Name="ToolbarRoot" Background="Transparent">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                
                <!-- 0. 拖动把手 (Drag Handle) -->
                <!-- 专门用于触屏拖动的区域，防止误触按钮 -->
                <Grid x:Name="DragHandle" Width="28" Background="Transparent" 
                      Margin="2,0,4,0" Cursor="SizeAll"
                      MouseLeftButtonDown="OnToolbarDrag"
                      ToolTip="按住此处拖动">
                    <Path Data="M4,6 L20,6 M4,10 L20,10 M4,14 L20,14" 
                          Stroke="#BBB" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>

                <!-- 1. 鼠标/选择 -->
                <ToggleButton x:Name="CursorButton" 
                              Style="{StaticResource Style_IconButton_Active}"
                              Checked="OnModeChecked" Unchecked="OnModeUnchecked"
                              ToolTip="鼠标模式 (选择)">
                    <Path Data="{StaticResource Icon_Cursor}" Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" Stretch="Uniform" Width="18" Height="18"/>
                </ToggleButton>

                <Rectangle Style="{StaticResource Style_Separator}"/>

                <!-- 2. 颜色/画笔区 -->
                <!-- 注意：颜色不仅是颜色，也是画笔模式的触发器 -->
                <ToggleButton x:Name="QuickColor1Button" Background="Black" Tag="0"
                              Style="{StaticResource Style_ColorButton}"
                              Click="OnColorClick"
                              ToolTip="黑色笔 (长按换色)"
                              behaviors:LongPressBehavior.Command="{Binding OpenQuickColor1Command}"/>
                
                <ToggleButton x:Name="QuickColor2Button" Background="#FF3B30" Tag="1"
                              Style="{StaticResource Style_ColorButton}"
                              Click="OnColorClick"
                              ToolTip="红色笔 (长按换色)"
                              behaviors:LongPressBehavior.Command="{Binding OpenQuickColor2Command}"/>
                
                <ToggleButton x:Name="QuickColor3Button" Background="#007ACC" Tag="2"
                              Style="{StaticResource Style_ColorButton}"
                              Click="OnColorClick"
                              ToolTip="蓝色笔 (长按换色)"
                              behaviors:LongPressBehavior.Command="{Binding OpenQuickColor3Command}"/>

                <Rectangle Style="{StaticResource Style_Separator}"/>

                <!-- 3. 擦除工具 -->
                <ToggleButton x:Name="EraserButton" 
                              Style="{StaticResource Style_IconButton_Active}"
                              Checked="OnModeChecked" Unchecked="OnModeUnchecked"
                              ToolTip="橡皮擦">
                    <Path Data="{StaticResource Icon_Eraser}" Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" Stretch="Uniform" Width="18" Height="18"/>
                </ToggleButton>

                <ToggleButton x:Name="RegionEraseButton" 
                              Style="{StaticResource Style_IconButton_Active}"
                              Checked="OnModeChecked" Unchecked="OnModeUnchecked"
                              ToolTip="区域删除 (框选)">
                    <Path Data="{StaticResource Icon_RegionErase}" Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" Stretch="Uniform" Width="18" Height="18"/>
                </ToggleButton>

                <Rectangle Style="{StaticResource Style_Separator}"/>

                <!-- 4. 操作与设置 -->
                <Button x:Name="ClearButton" Style="{StaticResource Style_IconButton}" Click="OnClearClick" ToolTip="一键清屏">
                    <Path Data="{StaticResource Icon_Trash}" Fill="{StaticResource Brush_Danger}" Stretch="Uniform" Width="18" Height="18"/>
                </Button>

                <Button x:Name="UndoButton" Style="{StaticResource Style_IconButton}" Click="OnUndoClick" ToolTip="撤销">
                    <Path Data="{StaticResource Icon_Undo}" Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Stretch="Uniform" Width="18" Height="18"/>
                </Button>

                <ToggleButton x:Name="BoardButton" 
                              Style="{StaticResource Style_IconButton_Active}"
                              Click="OnBoardClick"
                              ToolTip="白板 (单击开关 / 长按换色)"
                              behaviors:LongPressBehavior.Command="{Binding OpenBoardColorCommand}">
                     <Path Data="{StaticResource Icon_Board}" Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" Stretch="Uniform" Width="18" Height="18"/>
                </ToggleButton>

                <Button x:Name="SettingsButton" Style="{StaticResource Style_IconButton}" Click="OnSettingsClick" ToolTip="画笔设置">
                    <Path Data="{StaticResource Icon_Settings}" Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Stretch="Uniform" Width="18" Height="18"/>
                </Button>

            </StackPanel>
        </Grid>
    </Border>
</Window>