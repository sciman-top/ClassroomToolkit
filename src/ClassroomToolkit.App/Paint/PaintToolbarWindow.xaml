<Window x:Class="ClassroomToolkit.App.Paint.PaintToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:ClassroomToolkit.App.Behaviors"
        Title="工具条"
        Height="Auto" Width="Auto"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}">

    <Window.Resources>
        <!-- 颜色选择按钮样式 (圆形) - 现代升级版 -->
        <Style x:Key="Style_ColorButton" TargetType="ToggleButton">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <!-- 选中时的外圈光环 -->
                            <Ellipse x:Name="Ring" Stroke="{StaticResource Brush_Primary}" StrokeThickness="2.5"
                                     Width="32" Height="32" Opacity="0">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="{StaticResource Color_Primary_Main}" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                                </Ellipse.Effect>
                            </Ellipse>

                            <!-- 颜色主体 -->
                            <Border x:Name="ColorDot" Width="22" Height="22" CornerRadius="11"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#30FFFFFF" BorderThickness="1">
                                <Border.RenderTransform>
                                    <ScaleTransform CenterX="11" CenterY="11" ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.15"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Ring" Property="Opacity" Value="1"/>
                                <Setter TargetName="ColorDot" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform CenterX="11" CenterY="11" ScaleX="1.15" ScaleY="1.15"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ColorDot" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform CenterX="11" CenterY="11" ScaleX="1.1" ScaleY="1.1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 分割线样式 - 现代升级版 -->
        <Style x:Key="Style_Separator" TargetType="Rectangle">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Fill" Value="{StaticResource Brush_Border}"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="RadiusX" Value="0.5"/>
            <Setter Property="RadiusY" Value="0.5"/>
        </Style>
    </Window.Resources>

    <!-- 主容器：胶囊形状，玻璃态效果 + 品牌装饰 -->
    <Border x:Name="ToolbarContainer"
            Background="{StaticResource Gradient_Glass}"
            BorderBrush="{StaticResource Brush_Border}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="8,6"
            MouseLeftButtonDown="OnToolbarDrag">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.12" BlurRadius="15" ShadowDepth="3"/>
        </Border.Effect>

        <Grid>
            <!-- 顶部品牌色装饰线 -->
            <Border Height="2" VerticalAlignment="Top" CornerRadius="2,2,0,0" ClipToBounds="True" Margin="8,0,8,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="{StaticResource Color_Primary_Light}" Offset="0"/>
                        <GradientStop Color="{StaticResource Color_Primary_Main}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Grid x:Name="ToolbarRoot" Background="Transparent" Margin="0,2,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- 0. 拖动把手 (Drag Handle) - 点状设计 -->
                <Grid x:Name="DragHandle" Width="32" Background="Transparent"
                      Margin="2,0,5,0" Cursor="SizeAll"
                      MouseLeftButtonDown="OnToolbarDrag"
                      ToolTip="按住此处拖动">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Ellipse Width="3" Height="3" Fill="{StaticResource Brush_Text_Tertiary}" Margin="0,1"/>
                        <Ellipse Width="3" Height="3" Fill="{StaticResource Brush_Text_Tertiary}" Margin="0,1"/>
                        <Ellipse Width="3" Height="3" Fill="{StaticResource Brush_Text_Tertiary}" Margin="0,1"/>
                    </StackPanel>
                </Grid>

                <!-- 1. 鼠标/选择 -->
                <ToggleButton x:Name="CursorButton"
                              Style="{StaticResource Style_IconButton_Active}"
                              Checked="OnModeChecked" Unchecked="OnModeUnchecked"
                              ToolTip="鼠标模式 (选择)">
                    <Path Data="{StaticResource Icon_Cursor}" Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" Stretch="Uniform" Width="20" Height="20"/>
                </ToggleButton>

                <Rectangle Style="{StaticResource Style_Separator}"/>

                <!-- 2. 颜色/画笔区 -->
                <ToggleButton x:Name="QuickColor1Button" Background="Black" Tag="0"
                              Style="{StaticResource Style_ColorButton}"
                              Click="OnColorClick"
                              ToolTip="黑色笔 (长按换色)"
                              behaviors:LongPressBehavior.Command="{Binding OpenQuickColor1Command}"/>

                <ToggleButton x:Name="QuickColor2Button" Background="#FF3B30" Tag="1"
                              Style="{StaticResource Style_ColorButton}"
                              Click="OnColorClick"
                              ToolTip="红色笔 (长按换色)"
                              behaviors:LongPressBehavior.Command="{Binding OpenQuickColor2Command}"/>

                <ToggleButton x:Name="QuickColor3Button" Background="#007ACC" Tag="2"
                              Style="{StaticResource Style_ColorButton}"
                              Click="OnColorClick"
                              ToolTip="蓝色笔 (长按换色)"
                              behaviors:LongPressBehavior.Command="{Binding OpenQuickColor3Command}"/>

                <Rectangle Style="{StaticResource Style_Separator}"/>

                <!-- 3. 擦除工具 -->
                <ToggleButton x:Name="EraserButton"
                              Style="{StaticResource Style_IconButton_Active}"
                              Checked="OnModeChecked" Unchecked="OnModeUnchecked"
                              ToolTip="橡皮擦">
                    <Path Data="{StaticResource Icon_Eraser}" Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" Stretch="Uniform" Width="20" Height="20"/>
                </ToggleButton>

                <ToggleButton x:Name="RegionEraseButton"
                              Style="{StaticResource Style_IconButton_Active}"
                              Checked="OnModeChecked" Unchecked="OnModeUnchecked"
                              ToolTip="区域删除 (框选)">
                    <Path Data="{StaticResource Icon_RegionErase}" Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" Stretch="Uniform" Width="20" Height="20"/>
                </ToggleButton>

                <Rectangle Style="{StaticResource Style_Separator}"/>

                <!-- 4. 操作与设置 -->
                <Button x:Name="ClearButton" Style="{StaticResource Style_IconButton}" Click="OnClearClick" ToolTip="一键清屏">
                    <Path Data="{StaticResource Icon_Trash}" Fill="{StaticResource Brush_Danger}" Stretch="Uniform" Width="20" Height="20"/>
                </Button>

                <Button x:Name="UndoButton" Style="{StaticResource Style_IconButton}" Click="OnUndoClick" ToolTip="撤销">
                    <Path Data="{StaticResource Icon_Undo}" Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Stretch="Uniform" Width="20" Height="20"/>
                </Button>

                <ToggleButton x:Name="BoardButton"
                              Style="{StaticResource Style_IconButton_Active}"
                              Click="OnBoardClick"
                              ToolTip="白板 (单击开关 / 长按换色)"
                              behaviors:LongPressBehavior.Command="{Binding OpenBoardColorCommand}">
                     <Path Data="{StaticResource Icon_Board}" Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" Stretch="Uniform" Width="20" Height="20"/>
                </ToggleButton>

                <Button x:Name="SettingsButton" Style="{StaticResource Style_IconButton}" Click="OnSettingsClick" ToolTip="画笔设置">
                    <Path Data="{StaticResource Icon_Settings}" Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Stretch="Uniform" Width="20" Height="20"/>
                </Button>

            </StackPanel>
        </Grid>
        </Grid>
    </Border>
</Window>