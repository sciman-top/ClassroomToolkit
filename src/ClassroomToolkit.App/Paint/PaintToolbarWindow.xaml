<Window x:Class="ClassroomToolkit.App.Paint.PaintToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:ClassroomToolkit.App.Behaviors"
        Title="工具条"
        Height="200" Width="420"
        WindowStartupLocation="Manual"
        Topmost="True"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
            <ToggleButton x:Name="CursorButton" Content="指针" Width="60" Margin="4" Click="OnModeClick" />
            <ToggleButton x:Name="BrushButton" Content="画笔" Width="60" Margin="4" Click="OnModeClick"
                          behaviors:LongPressBehavior.Command="{Binding OpenBrushColorCommand}" />
            <ToggleButton x:Name="EraserButton" Content="橡皮" Width="60" Margin="4" Click="OnModeClick" />
            <ToggleButton x:Name="ShapeButton" Content="形状" Width="60" Margin="4" Click="OnModeClick" />
            <Button Content="撤销" Width="60" Margin="4" Click="OnUndoClick" />
            <Button Content="清空" Width="60" Margin="4" Click="OnClearClick" />
            <ToggleButton x:Name="BoardButton" Content="白板" Width="60" Margin="4" Click="OnBoardClick"
                          behaviors:LongPressBehavior.Command="{Binding OpenBoardColorCommand}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="画笔大小" VerticalAlignment="Center" Margin="0,0,8,0" />
            <Slider x:Name="BrushSizeSlider" Minimum="2" Maximum="40" Width="120" ValueChanged="OnBrushSizeChanged" />
            <TextBlock Text="橡皮大小" VerticalAlignment="Center" Margin="12,0,8,0" />
            <Slider x:Name="EraserSizeSlider" Minimum="6" Maximum="60" Width="120" ValueChanged="OnEraserSizeChanged" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
            <TextBlock Text="透明度" VerticalAlignment="Center" Margin="0,0,8,0" />
            <Slider x:Name="BrushOpacitySlider" Minimum="10" Maximum="255" Width="120" ValueChanged="OnBrushOpacityChanged" />
            <TextBlock Text="白板透明" VerticalAlignment="Center" Margin="12,0,8,0" />
            <Slider x:Name="BoardOpacitySlider" Minimum="0" Maximum="255" Width="120" ValueChanged="OnBoardOpacityChanged" />
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <ComboBox x:Name="ShapeCombo" Width="120" SelectionChanged="OnShapeChanged" Margin="0,0,8,0" />
            <Button x:Name="QuickColor1Button" Content="黑" Width="40" Margin="4" Click="OnColorClick" Tag="0"
                    behaviors:LongPressBehavior.Command="{Binding OpenQuickColor1Command}" />
            <Button x:Name="QuickColor2Button" Content="红" Width="40" Margin="4" Click="OnColorClick" Tag="1"
                    behaviors:LongPressBehavior.Command="{Binding OpenQuickColor2Command}" />
            <Button x:Name="QuickColor3Button" Content="蓝" Width="40" Margin="4" Click="OnColorClick" Tag="2"
                    behaviors:LongPressBehavior.Command="{Binding OpenQuickColor3Command}" />
            <ComboBox x:Name="WpsModeCombo" Width="120" Margin="8,0,0,0" SelectionChanged="OnWpsModeChanged" />
            <CheckBox x:Name="WpsWheelCheck" Content="滚轮翻页" Margin="8,0,0,0" Checked="OnWpsWheelChanged" Unchecked="OnWpsWheelChanged" />
        </StackPanel>
    </Grid>
</Window>
