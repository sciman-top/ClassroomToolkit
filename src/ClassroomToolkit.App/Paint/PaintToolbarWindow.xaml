<Window x:Class="ClassroomToolkit.App.Paint.PaintToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:ClassroomToolkit.App.Behaviors"
        Title="工具条"
        Height="Auto" Width="Auto"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}">

    <Window.Resources>
        <!-- 专用紧凑按钮样式 -->
        <Style x:Key="Style_PaintToolButton" TargetType="ToggleButton">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" CornerRadius="8" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Brush_Surface_Tint}"/>
                                <Setter Property="Foreground" Value="{StaticResource Brush_Primary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Brush_Background_L3}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 专用普通按钮样式 -->
        <Style x:Key="Style_PaintActionButton" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="8" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Brush_Background_L3}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Brush_Background_L4}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 颜色选择按钮样式 (圆形) -->
        <Style x:Key="Style_ColorBubble" TargetType="ToggleButton">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <!-- 选中时的光环 -->
                            <Ellipse x:Name="Ring" Stroke="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}" 
                                     StrokeThickness="2" Width="28" Height="28" Opacity="0"/>
                            
                            <!-- 颜色点 -->
                            <Border x:Name="Dot" Width="18" Height="18" CornerRadius="9"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource Brush_White_Translucent_Low}" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="1" Opacity="0.1"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Ring" Property="Opacity" Value="0.3"/>
                                <Setter TargetName="Dot" Property="Width" Value="22"/>
                                <Setter TargetName="Dot" Property="Height" Value="22"/>
                                <Setter TargetName="Dot" Property="CornerRadius" Value="11"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Dot" Property="Width" Value="20"/>
                                <Setter TargetName="Dot" Property="Height" Value="20"/>
                                <Setter TargetName="Dot" Property="CornerRadius" Value="10"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 悬浮胶囊容器 -->
    <Border x:Name="ToolbarContainer"
            Background="White"
            BorderBrush="{StaticResource Brush_Border_Subtle}"
            BorderThickness="1"
            CornerRadius="24"
            Height="48"
            Padding="8,4"
            MouseLeftButtonDown="OnToolbarDrag">
        <Border.Effect>
            <!-- 强阴影增强悬浮感 -->
            <DropShadowEffect Color="Black" Opacity="0.12" BlurRadius="25" ShadowDepth="6"/>
        </Border.Effect>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

            <!-- 1. 拖动区 -->
            <Grid Width="20" Background="Transparent" Cursor="SizeAll" Margin="0,0,2,0" ToolTip="按住拖动">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.4">
                    <Ellipse Width="3" Height="3" Fill="{StaticResource Brush_Text_Secondary}" Margin="0,1.5"/>
                    <Ellipse Width="3" Height="3" Fill="{StaticResource Brush_Text_Secondary}" Margin="0,1.5"/>
                    <Ellipse Width="3" Height="3" Fill="{StaticResource Brush_Text_Secondary}" Margin="0,1.5"/>
                </StackPanel>
            </Grid>

            <!-- 2. 指针模式 -->
            <ToggleButton x:Name="CursorButton"
                          Style="{StaticResource Style_PaintToolButton}"
                          Checked="OnModeChecked" Unchecked="OnModeUnchecked"
                          ToolTip="鼠标模式">
                <Path Data="{StaticResource Icon_Cursor}" Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" Stretch="Uniform" Width="16" Height="16"/>
            </ToggleButton>

            <!-- 间隔 -->
            <Rectangle Width="8" Fill="Transparent"/>

            <!-- 3. 颜色组 (浅色背景包裹) -->
            <Border Background="{StaticResource Brush_Background_L2}" CornerRadius="16" Padding="4,2">
                <StackPanel Orientation="Horizontal">
                    <ToggleButton x:Name="QuickColor1Button" Background="Black" Tag="0"
                                  Style="{StaticResource Style_ColorBubble}"
                                  Click="OnColorClick"
                                  ToolTip="黑色笔 (长按换色)"
                                  behaviors:LongPressBehavior.Command="{Binding OpenQuickColor1Command}"/>

                    <ToggleButton x:Name="QuickColor2Button" Background="{StaticResource Brush_Pen_Red}" Tag="1"
                                  Style="{StaticResource Style_ColorBubble}"
                                  Click="OnColorClick"
                                  ToolTip="红色笔 (长按换色)"
                                  behaviors:LongPressBehavior.Command="{Binding OpenQuickColor2Command}"/>

                    <ToggleButton x:Name="QuickColor3Button" Background="{StaticResource Brush_Pen_Blue}" Tag="2"
                                  Style="{StaticResource Style_ColorBubble}"
                                  Click="OnColorClick"
                                  ToolTip="蓝色笔 (长按换色)"
                                  behaviors:LongPressBehavior.Command="{Binding OpenQuickColor3Command}"/>
                </StackPanel>
            </Border>

            <!-- 间隔 -->
            <Rectangle Width="8" Fill="Transparent"/>

            <!-- 4. 擦除组 -->
            <ToggleButton x:Name="EraserButton"
                          Style="{StaticResource Style_PaintToolButton}"
                          Checked="OnModeChecked" Unchecked="OnModeUnchecked"
                          ToolTip="橡皮擦">
                <Path Data="{StaticResource Icon_Eraser}" Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" Stretch="Uniform" Width="18" Height="18"/>
            </ToggleButton>

            <ToggleButton x:Name="RegionEraseButton"
                          Style="{StaticResource Style_PaintToolButton}"
                          Checked="OnModeChecked" Unchecked="OnModeUnchecked"
                          ToolTip="区域删除">
                <Path Data="{StaticResource Icon_RegionErase}" Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" Stretch="Uniform" Width="18" Height="18"/>
            </ToggleButton>

            <!-- 细微分割线 -->
            <Rectangle Width="1" Height="20" Fill="{StaticResource Brush_Border_Medium}" Margin="6,0"/>

            <!-- 5. 常用操作 -->
            <Button x:Name="UndoButton" Style="{StaticResource Style_PaintActionButton}" Click="OnUndoClick" ToolTip="撤销">
                <Path Data="{StaticResource Icon_Undo}" Fill="{StaticResource Brush_Foreground}" Stretch="Uniform" Width="18" Height="18"/>
            </Button>
            
            <Button x:Name="ClearButton" Style="{StaticResource Style_PaintActionButton}" Click="OnClearClick" ToolTip="清屏">
                <Path Data="{StaticResource Icon_Trash}" Fill="{StaticResource Brush_Danger}" Stretch="Uniform" Width="18" Height="18"/>
            </Button>

            <!-- 细微分割线 -->
            <Rectangle Width="1" Height="20" Fill="{StaticResource Brush_Border_Medium}" Margin="6,0"/>

            <!-- 6. 白板与设置 -->
             <ToggleButton x:Name="BoardButton"
                          Style="{StaticResource Style_PaintToolButton}"
                          Click="OnBoardClick"
                          ToolTip="白板 (长按换色)"
                          behaviors:LongPressBehavior.Command="{Binding OpenBoardColorCommand}">
                 <Path Data="{StaticResource Icon_Board}" Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" Stretch="Uniform" Width="18" Height="18"/>
            </ToggleButton>

            <Button x:Name="SettingsButton" Style="{StaticResource Style_PaintActionButton}" Click="OnSettingsClick" ToolTip="设置">
                <Path Data="{StaticResource Icon_Settings}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="18" Height="18"/>
            </Button>

        </StackPanel>
    </Border>
</Window>