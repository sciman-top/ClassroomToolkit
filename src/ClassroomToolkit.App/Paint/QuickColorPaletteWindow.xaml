<Window x:Class="ClassroomToolkit.App.Paint.QuickColorPaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="颜色"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">
    <Border Background="{StaticResource Brush_Window_Atmosphere}" BorderBrush="{StaticResource Brush_Border_Subtle}" BorderThickness="1" CornerRadius="12" Padding="6,5"
            TextElement.Foreground="{StaticResource Brush_Text_Primary}">
        <Border.Effect>
            <StaticResource ResourceKey="Shadow_Popup_Light"/>
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="快捷颜色" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Brush_Text_Tertiary}" Margin="4,0,0,4"/>
            <Border Background="{StaticResource Brush_Background_L2}" CornerRadius="8" Padding="4" BorderBrush="{StaticResource Brush_Border_Subtle}" BorderThickness="1">
                <StackPanel x:Name="OptionsPanel" Orientation="Horizontal" />
            </Border>
        </StackPanel>
    </Border>
</Window>
