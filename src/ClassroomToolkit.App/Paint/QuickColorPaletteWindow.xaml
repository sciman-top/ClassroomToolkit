<Window x:Class="ClassroomToolkit.App.Paint.QuickColorPaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="颜色"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">
    <Border Background="#F9FAFB" BorderBrush="#C9D1D9" BorderThickness="1" CornerRadius="6" Padding="6,4">
        <StackPanel x:Name="OptionsPanel" Orientation="Horizontal" />
    </Border>
</Window>
