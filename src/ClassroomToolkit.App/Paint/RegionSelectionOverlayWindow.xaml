<Window x:Class="ClassroomToolkit.App.Paint.RegionSelectionOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="{StaticResource Brush_OverlayMask}"
        Focusable="True"
        Cursor="Cross"
        PreviewKeyDown="OnPreviewKeyDown"
        MouseLeftButtonDown="OnMouseLeftButtonDown"
        MouseMove="OnMouseMove"
        MouseLeftButtonUp="OnMouseLeftButtonUp"
        TouchDown="OnTouchDown"
        TouchMove="OnTouchMove"
        TouchUp="OnTouchUp">
    <Canvas x:Name="RootCanvas">
        <TextBlock x:Name="HintText"
                   Text="拖拽选择，Enter 确认，Esc 取消"
                   Foreground="White"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Canvas.Left="20"
                   Canvas.Top="20"/>
        <Rectangle x:Name="SelectionRect"
                   Visibility="Collapsed"
                   Stroke="{StaticResource Brush_Border_Focus}"
                   StrokeThickness="2"
                   Fill="{StaticResource Brush_White_Translucent}"/>
    </Canvas>
</Window>
