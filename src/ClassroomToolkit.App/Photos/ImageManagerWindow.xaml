<Window x:Class="ClassroomToolkit.App.Photos.ImageManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="图片管理"
        Width="900"
        Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Background="{StaticResource Brush_Background}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" MinWidth="180"/>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource Brush_Border_Subtle}" BorderThickness="1" Padding="12" Margin="12,12,3,12">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="收藏夹" FontWeight="SemiBold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Button Content="添加" Width="60" Height="26" Margin="0,0,6,0" Click="OnAddFavoriteClick"/>
                        <Button Content="移除" Width="60" Height="26" Click="OnRemoveFavoriteClick"/>
                    </StackPanel>
                    <ListBox x:Name="FavoritesList" Height="120" SelectionChanged="OnFavoritesSelectionChanged"/>

                    <TextBlock Text="最近目录" FontWeight="SemiBold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,12,0,6"/>
                    <ListBox x:Name="RecentsList" Height="120" SelectionChanged="OnRecentsSelectionChanged"/>

                    <TextBlock Text="此电脑" FontWeight="SemiBold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,12,0,6"/>
                    <TreeView x:Name="FolderTree" SelectedItemChanged="OnFolderTreeSelected"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{StaticResource Brush_Background_L2}"/>

        <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource Brush_Border_Subtle}" BorderThickness="1" Padding="12" Margin="3,12,12,12">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top">
                    <TextBlock x:Name="CurrentFolderText" Foreground="{StaticResource Brush_Text_Secondary}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Margin="0,0,0,8">
                        <ToggleButton x:Name="ThumbnailViewButton" Content="缩略图" Width="70" Height="26" Margin="0,0,6,0"
                                      Click="OnViewModeClick"/>
                        <ToggleButton x:Name="ListViewButton" Content="列表" Width="60" Height="26" Click="OnViewModeClick"/>
                    </StackPanel>
                </DockPanel>
                <TextBlock x:Name="EmptyHintText" DockPanel.Dock="Top" Text="请选择左侧文件夹查看图片"
                           Foreground="{StaticResource Brush_Text_Tertiary}" Margin="0,0,0,8"/>
                <ScrollViewer x:Name="ThumbnailScroll" VerticalScrollBarVisibility="Auto">
                    <ListView x:Name="ImageList" SelectionChanged="OnImageSelectionChanged" Background="Transparent" BorderThickness="0">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel IsItemsHost="True" />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Width="140" Margin="4">
                                    <Border BorderBrush="{StaticResource Brush_Border_Subtle}" BorderThickness="1" CornerRadius="6" Padding="4">
                                        <Grid>
                                            <Image Source="{Binding Thumbnail}" Width="120" Height="90" Stretch="UniformToFill"/>
                                            <Border Background="#99000000" CornerRadius="8" Padding="4,1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                    Margin="0,0,4,4" Visibility="{Binding PageBadgeVisibility}">
                                                <TextBlock Text="{Binding PageBadge}" Foreground="White" FontSize="10"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource Brush_Text_Secondary}"
                                               TextTrimming="CharacterEllipsis" FontSize="12" Margin="2,6,2,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </ScrollViewer>
                <ListView x:Name="ImageListView" SelectionChanged="OnImageSelectionChanged" Background="Transparent" BorderThickness="0" Visibility="Collapsed">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="名称" DisplayMemberBinding="{Binding Name}" Width="240"/>
                            <GridViewColumn Header="类型" DisplayMemberBinding="{Binding TypeLabel}" Width="80"/>
                            <GridViewColumn Header="页数" DisplayMemberBinding="{Binding PageLabel}" Width="80"/>
                            <GridViewColumn Header="修改时间" DisplayMemberBinding="{Binding ModifiedLabel}" Width="160"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Border>
    </Grid>
</Window>
