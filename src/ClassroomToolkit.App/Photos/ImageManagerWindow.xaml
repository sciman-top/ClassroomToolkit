<Window x:Class="ClassroomToolkit.App.Photos.ImageManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClassroomToolkit.App.Photos"
        xmlns:converters="clr-namespace:ClassroomToolkit.App.Converters"
        Title="PDF/图片管理"
        Width="1100"
        Height="700"
        MinWidth="960"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Topmost="True">
    <Window.Resources>
        <local:MultiplyConverter x:Key="ThumbnailSizeRatio" Factor="0.75"/>
        <converters:PdfForegroundConverter x:Key="PdfForegroundConverter"/>
        <converters:PdfFontWeightConverter x:Key="PdfFontWeightConverter"/>
        <local:FolderVisibilityConverter x:Key="FolderVisibilityConverter"/>
        <local:FileVisibilityConverter x:Key="FileVisibilityConverter"/>
        <local:PdfBackgroundConverter x:Key="PdfBackgroundConverter"/>
        <Style x:Key="ImageTileListViewItemStyle"
               TargetType="ListViewItem"
               BasedOn="{StaticResource Style_ListViewItem_SelectionUnified}">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush_Surface_Hover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush_Surface_Active}"/>
                                <Setter Property="Foreground" Value="{StaticResource Brush_Primary_Light}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Style="{StaticResource Style_ManagementShellWindowBorder}" Margin="12" CornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Style="{StaticResource Style_ManagementShellTitleBar}" MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <Path Data="{StaticResource Icon_Photo}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="PDF/图片管理" Style="{StaticResource Style_ManagementShellTitleText}" Margin="0"/>
                    <TextBlock Text="资源与名单管理视图" Style="{StaticResource Style_ManagementShellSubtitleText}" Margin="10,2,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Button x:Name="WindowStateToggleButton" Content="还原" Width="76" Height="30" Margin="0,0,8,0"
                            Style="{StaticResource Style_SecondaryButton}" Click="OnRestoreWindowClick"/>
                    <Button Content="关闭" Width="60" Height="30"
                            Style="{StaticResource Style_DangerButton}" Click="OnCloseWindowClick"/>
                </StackPanel>
            </Grid>
            <Border Grid.Row="0" Style="{StaticResource Style_ManagementShellDivider}"/>

            <Grid x:Name="RootGrid" Grid.Row="1" Margin="0,4,0,0" Background="{x:Null}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="LeftColumn" Width="2*" MinWidth="240"/>
                    <ColumnDefinition x:Name="SplitterColumn" Width="8"/>
                    <ColumnDefinition x:Name="RightColumn" Width="5*" MinWidth="560"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="FavoritesRow" Height="2.1*" MinHeight="140"/>
                        <RowDefinition x:Name="RecentsRow" Height="1.4*" MinHeight="120"/>
                        <RowDefinition x:Name="FolderTreeRow" Height="3.5*" MinHeight="240"/>
                    </Grid.RowDefinitions>

            <!-- 1. 收藏夹 -->
            <Border Grid.Row="0" Background="{StaticResource Brush_Surface_Secondary}" BorderBrush="{StaticResource Brush_Border}" 
                    BorderThickness="1" Padding="8,6" Margin="12,12,3,6" CornerRadius="8">
                <Expander Header="收藏夹" IsExpanded="True" Foreground="{StaticResource Brush_Text_Primary}">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="添加" Width="60" Height="26" Margin="0,0,6,0" Click="OnAddFavoriteClick" Style="{StaticResource Style_Button_Teal}" FontSize="12"/>
                            <Button Content="移除" Width="60" Height="26" Click="OnRemoveFavoriteClick" Style="{StaticResource Style_DangerButton}" FontSize="12"/>
                        </StackPanel>
                        <ListBox Grid.Row="1" x:Name="FavoritesList" SelectionChanged="OnFavoritesSelectionChanged"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Background="Transparent" BorderThickness="0" Foreground="{StaticResource Brush_Text_Primary}"/>
                    </Grid>
                </Expander>
            </Border>

            <!-- 2. 最近目录 -->
            <Border Grid.Row="1" Background="{StaticResource Brush_Surface_Secondary}" BorderBrush="{StaticResource Brush_Border}" 
                    BorderThickness="1" Padding="8,6" Margin="12,6,3,6" CornerRadius="8">
                <Expander Header="最近目录" IsExpanded="True" Foreground="{StaticResource Brush_Text_Primary}">
                    <ListBox x:Name="RecentsList" SelectionChanged="OnRecentsSelectionChanged"
                             Margin="0,8,0,0"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Background="Transparent" BorderThickness="0" Foreground="{StaticResource Brush_Text_Primary}"/>
                </Expander>
            </Border>

            <!-- 3. 此电脑 -->
            <Border Grid.Row="2" Background="{StaticResource Brush_Surface_Secondary}" BorderBrush="{StaticResource Brush_Border}" 
                    BorderThickness="1" Padding="8,6" Margin="12,6,3,12" CornerRadius="8">
                <Expander Header="此电脑" IsExpanded="True" Foreground="{StaticResource Brush_Text_Primary}">
                    <TreeView x:Name="FolderTree" SelectedItemChanged="OnFolderTreeSelected"
                              Margin="0,8,0,0"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
                              Background="Transparent" BorderThickness="0" Foreground="{StaticResource Brush_Text_Primary}">
                        <!-- Global TreeViewItem style applied automatically -->
                    </TreeView>
                </Expander>
            </Border>
                </Grid>

                <GridSplitter x:Name="MainColumnSplitter" Grid.Column="1" Width="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              Background="{StaticResource Brush_Border}" Opacity="0.55"
                              ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" Cursor="SizeWE"
                              ShowsPreview="False" DragDelta="OnMainColumnSplitterDragDelta" DragCompleted="OnMainColumnSplitterDragCompleted"/>

                <Border Grid.Column="2" Background="{StaticResource Brush_Surface_Secondary}" BorderBrush="{StaticResource Brush_Border}" BorderThickness="1" Padding="12,12,0,12" Margin="3,12,0,12" CornerRadius="8">
                    <DockPanel>
                <!-- 地址栏（独立在最上方） -->
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Border Background="{StaticResource Brush_InputBackground}" BorderBrush="{StaticResource Brush_Border}"
                            BorderThickness="1" CornerRadius="4" Padding="8,6" Height="36">
                        <TextBlock x:Name="CurrentFolderText" Foreground="{StaticResource Brush_Text_Primary}"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    </Border>
                </DockPanel>

                <!-- 工具栏 -->
                <DockPanel DockPanel.Dock="Top" Margin="0,0,12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button x:Name="BackButton" ToolTip="后退" Width="36" Height="30" Margin="0,0,6,0"
                                    Click="OnBackClick" IsEnabled="{Binding IsBackButtonEnabled}" Style="{StaticResource Style_SecondaryButton}" Padding="0">
                                <Path Data="{StaticResource Icon_Back}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform" Width="14" Height="14"/>
                            </Button>
                            <Button x:Name="ForwardButton" ToolTip="前进" Width="36" Height="30" Margin="0,0,6,0"
                                    Click="OnForwardClick" IsEnabled="{Binding IsForwardButtonEnabled}" Style="{StaticResource Style_SecondaryButton}" Padding="0">
                                <Path Data="{StaticResource Icon_Forward}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform" Width="14" Height="14"/>
                            </Button>
                            <Button x:Name="UpButton" ToolTip="向上" Width="36" Height="30" Margin="0,0,10,0"
                                    Click="OnUpClick" Style="{StaticResource Style_SecondaryButton}" Padding="0">
                                <Path Data="{StaticResource Icon_ArrowUp}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform" Width="16" Height="16"/>
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                            <ToggleButton x:Name="ListViewButton" ToolTip="列表视图" Width="36" Height="30" Margin="0,0,6,0"
                                          Click="OnViewModeClick" Style="{StaticResource Style_ToggleButton}" Padding="0">
                                <Path Data="{StaticResource Icon_ViewList}" Fill="{x:Null}" Stroke="{StaticResource Brush_Text_Primary}" StrokeThickness="1.5" Stretch="Uniform" Width="16" Height="16"/>
                            </ToggleButton>
                            <ToggleButton x:Name="ThumbnailViewButton" ToolTip="缩略图视图" Width="36" Height="30" Margin="0,0,10,0"
                                          Click="OnViewModeClick" Style="{StaticResource Style_ToggleButton}" Padding="0">
                                <Path Data="{StaticResource Icon_ViewGrid}" Fill="{x:Null}" Stroke="{StaticResource Brush_Text_Primary}" StrokeThickness="1.5" Stretch="Uniform" Width="16" Height="16"/>
                            </ToggleButton>
                            <TextBlock Text="缩略图大小" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <Slider x:Name="ThumbnailSizeSlider" Width="120" Minimum="90" Maximum="420" Value="120"
                                    ValueChanged="OnThumbnailSizeChanged" IsEnabled="{Binding IsThumbnailSizeSliderEnabled}"/>
                            <CheckBox x:Name="ShowInkCheckBox" Content="显示笔迹" Margin="12,0,0,0"
                                      Foreground="{StaticResource Brush_Text_Secondary}" FontSize="13"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding ShowInkOverlay, Mode=TwoWay}"
                                      Checked="OnShowInkChanged" Unchecked="OnShowInkChanged"/>
                        </StackPanel>
                    </Grid>
                </DockPanel>

                <TextBlock x:Name="EmptyHintText" DockPanel.Dock="Top" Text="未选择目录或目录为空，请在左侧选择文件夹后查看。"
                           Foreground="{StaticResource Brush_Text_Tertiary}" Margin="0,0,12,8"/>
                <Grid HorizontalAlignment="Stretch">
                    <ListView x:Name="ImageList" SelectionChanged="OnImageSelectionChanged" MouseDoubleClick="OnImageListDoubleClick"
                              Background="Transparent" BorderThickness="0" 
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              Foreground="{StaticResource Brush_Text_Primary}"
                              ItemContainerStyle="{StaticResource ImageTileListViewItemStyle}">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel IsItemsHost="True" />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="6" Width="{Binding ElementName=ThumbnailSizeSlider, Path=Value}">
                                    <Border BorderBrush="{StaticResource Brush_Border}" BorderThickness="1" CornerRadius="6" Padding="4"
                                            Background="{StaticResource Brush_InputBackground}"
                                            Height="{Binding ElementName=ThumbnailSizeSlider, Path=Value, Converter={StaticResource ThumbnailSizeRatio}}">
                                        <Grid>
                                            <!-- 文件夹图标：固定大小，居中，不随 Slider 缩放 -->
                                            <Path Data="{StaticResource Icon_Folder}" Fill="{StaticResource Brush_Primary}" 
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" Width="48" Height="48"
                                                  Stretch="Uniform"
                                                  Visibility="{Binding IsFolder, Converter={StaticResource FolderVisibilityConverter}}"/>
                                            
                                            <!-- 图片/PDF：填满容器 -->
                                            <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                                                   Visibility="{Binding IsFolder, Converter={StaticResource FileVisibilityConverter}}"/>
                                            
                                            <Border Background="{StaticResource Brush_OverlayMask}" CornerRadius="4" Padding="4,1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                    Margin="0,0,2,2" Visibility="{Binding PageBadgeVisibility}">
                                                <TextBlock Text="{Binding PageBadge}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis" FontSize="12" Margin="2,6,2,0"
                                               Foreground="{Binding IsPdf, Converter={StaticResource PdfForegroundConverter}}"
                                               FontWeight="{Binding IsPdf, Converter={StaticResource PdfFontWeightConverter}}"
                                               HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <ListView x:Name="ImageListView" SelectionChanged="OnImageSelectionChanged" MouseDoubleClick="OnImageListDoubleClick"
                              Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Visibility="Collapsed"
                              Foreground="{StaticResource Brush_Text_Primary}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="名称" Width="240">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                                                       Foreground="{Binding IsPdf, Converter={StaticResource PdfForegroundConverter}}"
                                                       FontWeight="{Binding IsPdf, Converter={StaticResource PdfFontWeightConverter}}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="类型" DisplayMemberBinding="{Binding TypeLabel}" Width="80"/>
                                <GridViewColumn Header="页数" DisplayMemberBinding="{Binding PageLabel}" Width="80"/>
                                <GridViewColumn Header="修改时间" DisplayMemberBinding="{Binding ModifiedLabel}" Width="160"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
                    </DockPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource Style_ManagementShellFooterBorder}" CornerRadius="0">
                <Grid>
                    <TextBlock Text="统一管理壳层：头部、内容区与底部信息栏已对齐。"
                               Style="{StaticResource Style_ManagementShellFooterText}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

