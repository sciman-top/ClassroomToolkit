<Window x:Class="ClassroomToolkit.App.Photos.ImageManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClassroomToolkit.App.Photos"
        xmlns:converters="clr-namespace:ClassroomToolkit.App.Converters"
        Title="PDF/图片管理"
        Width="1100"
        Height="700"
        MinWidth="960"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Topmost="True">
    <Window.Resources>
        <local:MultiplyConverter x:Key="ThumbnailSizeRatio" Factor="0.75"/>
        <converters:PdfForegroundConverter x:Key="PdfForegroundConverter"/>
        <converters:PdfFontWeightConverter x:Key="PdfFontWeightConverter"/>
        <local:FolderVisibilityConverter x:Key="FolderVisibilityConverter"/>
        <local:FileVisibilityConverter x:Key="FileVisibilityConverter"/>
        <local:PdfBackgroundConverter x:Key="PdfBackgroundConverter"/>

        <Style x:Key="Style_ImageManagerToolbarButton" TargetType="Button" BasedOn="{StaticResource Style_SecondaryButton}">
            <Setter Property="Height" Value="{StaticResource Size_Touch_Target_Min}"/>
            <Setter Property="MinWidth" Value="72"/>
        </Style>

        <Style x:Key="Style_ImageManagerToolbarDangerButton" TargetType="Button" BasedOn="{StaticResource Style_DangerButton}">
            <Setter Property="Height" Value="{StaticResource Size_Touch_Target_Min}"/>
            <Setter Property="MinWidth" Value="72"/>
        </Style>

        <Style x:Key="Style_ImageManagerToolbarToggleButton" TargetType="ToggleButton" BasedOn="{StaticResource Style_ToggleButton}">
            <Setter Property="Height" Value="{StaticResource Size_Touch_Target_Min}"/>
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="Style_ImageManagerToolbarIconButton" TargetType="Button" BasedOn="{StaticResource Style_IconButton}">
            <Setter Property="Width" Value="{StaticResource Size_Button_Icon_Regular}"/>
            <Setter Property="Height" Value="{StaticResource Size_Button_Icon_Regular}"/>
        </Style>

    </Window.Resources>

    <Border Style="{StaticResource Style_ManagementShellWindowBorder}" Margin="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Style="{StaticResource Style_ManagementShellTitleBar}" MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <Path Data="{StaticResource Icon_Photo}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform"
                          Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="PDF/图片管理" Style="{StaticResource Style_ManagementShellTitleText}" Margin="0"/>
                    <TextBlock Text="文件夹、PDF、图片" Style="{StaticResource Style_ManagementShellSubtitleText}" Margin="10,2,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Button x:Name="WindowStateToggleButton" Content="还原" Width="72" Margin="0,0,8,0"
                            Style="{StaticResource Style_ImageManagerToolbarButton}" Click="OnRestoreWindowClick"/>
                    <Button Content="关闭" Width="72"
                            Style="{StaticResource Style_ImageManagerToolbarDangerButton}" Click="OnCloseWindowClick"/>
                </StackPanel>
            </Grid>
            <Border Grid.Row="0" Style="{StaticResource Style_ManagementShellDivider}"/>

            <Grid x:Name="RootGrid" Grid.Row="1" Margin="0,4,0,0" Background="{x:Null}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="LeftColumn" Width="2*" MinWidth="240"/>
                    <ColumnDefinition x:Name="SplitterColumn" Width="8"/>
                    <ColumnDefinition x:Name="RightColumn" Width="5*" MinWidth="560"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="CommonFoldersRow" Height="3.3*" MinHeight="250"/>
                        <RowDefinition x:Name="FolderTreeRow" Height="3.5*" MinHeight="240"/>
                    </Grid.RowDefinitions>

            <!-- 1. 常用目录（收藏 + 最近） -->
            <Border Grid.Row="0" Background="{StaticResource Brush_Surface_Secondary}" BorderBrush="{StaticResource Brush_Border}" 
                    BorderThickness="1" Padding="8,6" Margin="12,12,3,6" CornerRadius="8">
                <Expander Header="常用目录" IsExpanded="True" Foreground="{StaticResource Brush_Text_Primary}">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <UniformGrid Grid.Row="0" Margin="0,0,0,6" Columns="3">
                            <Button
                                    Content="添加收藏"
                                    Margin="0,0,4,0"
                                    VerticalContentAlignment="Center"
                                    Click="OnAddFavoriteClick"
                                    Style="{StaticResource Style_ImageManagerToolbarButton}"
                                    Background="{StaticResource Gradient_Success}"
                                    BorderBrush="{StaticResource Brush_Teaching}"
                                    Foreground="{StaticResource Brush_Text_Black}"
                                    FontSize="{StaticResource FontSize_Body_S}"
                                    HorizontalAlignment="Stretch"/>
                            <Button
                                    Content="取消收藏"
                                    Margin="0,0,4,0"
                                    VerticalContentAlignment="Center"
                                    Click="OnRemoveFavoriteClick"
                                    Style="{StaticResource Style_ImageManagerToolbarDangerButton}"
                                    FontSize="{StaticResource FontSize_Body_S}"
                                    HorizontalAlignment="Stretch"/>
                            <Button
                                    Content="清空最近"
                                    VerticalContentAlignment="Center"
                                    Click="OnClearRecentsClick"
                                    Style="{StaticResource Style_ImageManagerToolbarButton}"
                                    FontSize="{StaticResource FontSize_Body_S}"
                                    HorizontalAlignment="Stretch"/>
                        </UniformGrid>
                        <TextBlock Grid.Row="1" Text="收藏" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="{StaticResource FontSize_Body_S}" Margin="0,0,0,4"/>
                        <ListBox Grid.Row="2" x:Name="FavoritesList" SelectionChanged="OnFavoritesSelectionChanged"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.PanningMode="VerticalFirst"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 Background="Transparent" BorderThickness="0" Foreground="{StaticResource Brush_Text_Primary}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Width="28" Height="28" Margin="0,0,6,0"
                                                Padding="0" ToolTip="取消收藏（保留最近）"
                                                MinWidth="32" MinHeight="32"
                                                Foreground="{StaticResource Brush_Text_Primary}"
                                                Click="OnFavoriteStarToggleClick"
                                                Tag="{Binding Path}"
                                                Style="{StaticResource Style_IconButton}">
                                            <Path Data="{StaticResource Icon_Star}"
                                                  Fill="{StaticResource Brush_Warning}"
                                                  Width="{StaticResource Size_Icon_Glyph_MD}"
                                                  Height="{StaticResource Size_Icon_Glyph_MD}"
                                                  Stretch="Uniform"/>
                                        </Button>
                                        <TextBlock Grid.Column="1" Text="{Binding Path}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource Brush_Text_Primary}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Expander Grid.Row="3" Header="最近" IsExpanded="False" Foreground="{StaticResource Brush_Text_Secondary}" Margin="0,6,0,0">
                            <ListBox x:Name="RecentsList" SelectionChanged="OnRecentsSelectionChanged"
                                     Margin="0,8,0,0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.PanningMode="VerticalFirst"
                                     ScrollViewer.CanContentScroll="True"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     Background="Transparent" BorderThickness="0" Foreground="{StaticResource Brush_Text_Primary}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Width="28" Height="28" Margin="0,0,6,0"
                                                    Padding="0" ToolTip="加入收藏"
                                                    MinWidth="32" MinHeight="32"
                                                    Foreground="{StaticResource Brush_Text_Primary}"
                                                    Click="OnRecentStarToggleClick"
                                                    Tag="{Binding Path}"
                                                    Style="{StaticResource Style_IconButton}">
                                                <Path Data="{StaticResource Icon_StarOutline}"
                                                      Fill="{StaticResource Brush_Text_Secondary}"
                                                      Width="{StaticResource Size_Icon_Glyph_MD}"
                                                      Height="{StaticResource Size_Icon_Glyph_MD}"
                                                      Stretch="Uniform"/>
                                            </Button>
                                            <TextBlock Grid.Column="1" Text="{Binding Path}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource Brush_Text_Primary}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Expander>
                    </Grid>
                </Expander>
            </Border>

            <!-- 3. 此电脑 -->
            <Border Grid.Row="1" Background="{StaticResource Brush_Surface_Secondary}" BorderBrush="{StaticResource Brush_Border}" 
                    BorderThickness="1" Padding="8,6" Margin="12,6,3,12" CornerRadius="8">
                <Expander Header="文件夹" IsExpanded="True" Foreground="{StaticResource Brush_Text_Primary}">
                    <TreeView x:Name="FolderTree" SelectedItemChanged="OnFolderTreeSelected"
                              Margin="0,8,0,0"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.PanningMode="VerticalFirst"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              Background="Transparent" BorderThickness="0" Foreground="{StaticResource Brush_Text_Primary}">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="{x:Type TreeViewItem}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <Setter Property="FontSize" Value="{StaticResource FontSize_Body_M}"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Expander>
            </Border>
                </Grid>

                <GridSplitter x:Name="MainColumnSplitter" Grid.Column="1" Width="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              Background="{StaticResource Brush_Border}" Opacity="0.55"
                              ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" Cursor="SizeWE"
                              ShowsPreview="False" DragDelta="OnMainColumnSplitterDragDelta" DragCompleted="OnMainColumnSplitterDragCompleted"/>

                <Border Grid.Column="2" Background="{StaticResource Brush_Surface_Secondary}" BorderBrush="{StaticResource Brush_Border}" BorderThickness="1" Padding="12,12,0,12" Margin="3,12,0,12" CornerRadius="8">
                    <DockPanel>
                <!-- 地址栏（独立在最上方） -->
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Border Background="{StaticResource Brush_InputBackground}" BorderBrush="{StaticResource Brush_Border}"
                            BorderThickness="1" CornerRadius="4" Padding="10,4" Height="40">
                        <TextBox x:Name="CurrentFolderText"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource Brush_Text_Primary}"
                                 FontSize="{StaticResource FontSize_Body_M}"
                                 VerticalContentAlignment="Center"
                                 KeyDown="OnCurrentFolderTextKeyDown"
                                 ToolTip="输入后回车"/>
                    </Border>
                </DockPanel>

                <!-- 工具栏 -->
                <DockPanel DockPanel.Dock="Top" Margin="0,0,12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button x:Name="BackButton" ToolTip="后退" Margin="0,0,6,0"
                                    Click="OnBackClick" IsEnabled="{Binding IsBackButtonEnabled}" Style="{StaticResource Style_ImageManagerToolbarIconButton}">
                                <Path Data="{StaticResource Icon_Back}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform" Width="14" Height="14"/>
                            </Button>
                            <Button x:Name="ForwardButton" ToolTip="前进" Margin="0,0,6,0"
                                    Click="OnForwardClick" IsEnabled="{Binding IsForwardButtonEnabled}" Style="{StaticResource Style_ImageManagerToolbarIconButton}">
                                <Path Data="{StaticResource Icon_Forward}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform" Width="14" Height="14"/>
                            </Button>
                            <Button x:Name="UpButton" ToolTip="上一级" Margin="0,0,10,0"
                                    Click="OnUpClick" Style="{StaticResource Style_ImageManagerToolbarIconButton}">
                                <Path Data="{StaticResource Icon_ArrowUp}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform"
                                      Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}"/>
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                            <ToggleButton x:Name="ListViewButton" ToolTip="列表" Width="72" Margin="0,0,6,0"
                                          Click="OnViewModeClick" Style="{StaticResource Style_ImageManagerToolbarToggleButton}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Data="{StaticResource Icon_ViewList}" Fill="{x:Null}" Stroke="{StaticResource Brush_Text_Primary}" StrokeThickness="1.5" Stretch="Uniform"
                                          Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}"/>
                                    <TextBlock Text="列表" Margin="6,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}" FontSize="{StaticResource FontSize_Body_S}"/>
                                </StackPanel>
                            </ToggleButton>
                            <ToggleButton x:Name="ThumbnailViewButton" ToolTip="缩略图" Width="84" Margin="0,0,10,0"
                                          Click="OnViewModeClick" Style="{StaticResource Style_ImageManagerToolbarToggleButton}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Data="{StaticResource Icon_ViewGrid}" Fill="{x:Null}" Stroke="{StaticResource Brush_Text_Primary}" StrokeThickness="1.5" Stretch="Uniform"
                                          Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}"/>
                                    <TextBlock Text="缩略图" Margin="6,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}" FontSize="{StaticResource FontSize_Body_S}"/>
                                </StackPanel>
                            </ToggleButton>
                            <TextBlock Text="缩略图" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="{StaticResource FontSize_Body_M}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <Slider x:Name="ThumbnailSizeSlider" Width="120" Minimum="90" Maximum="420" Value="120"
                                    ValueChanged="OnThumbnailSizeChanged" IsEnabled="{Binding IsThumbnailSizeSliderEnabled}"/>
                            <CheckBox x:Name="ShowInkCheckBox" Content="显示笔迹" Margin="12,0,0,0"
                                      Foreground="{StaticResource Brush_Text_Secondary}" FontSize="{StaticResource FontSize_Body_M}"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding ShowInkOverlay, Mode=TwoWay}"
                                      Checked="OnShowInkChanged" Unchecked="OnShowInkChanged"/>
                            <Button x:Name="EnterSelectionModeButton" Content="多选" Margin="12,0,0,0"
                                    Style="{StaticResource Style_ImageManagerToolbarButton}"
                                    Click="OnEnterSelectionModeClick"/>
                            <Button x:Name="DeleteFilesButton" Content="删除" Margin="12,0,0,0"
                                    MinWidth="86"
                                    Style="{StaticResource Style_ImageManagerToolbarDangerButton}" IsEnabled="False" Visibility="Collapsed"
                                    Click="OnDeleteSelectedFilesClick"/>
                            <Button x:Name="SelectAllFilesButton" Content="全选" Margin="6,0,0,0"
                                    Style="{StaticResource Style_ImageManagerToolbarButton}" Visibility="Collapsed"
                                    Click="OnSelectAllFilesClick"/>
                            <Button x:Name="ExitSelectionModeButton" Content="取消多选" Margin="6,0,0,0"
                                    MinWidth="86"
                                    Style="{StaticResource Style_ImageManagerToolbarButton}" Visibility="Collapsed"
                                    Click="OnExitSelectionModeClick"/>
                        </StackPanel>
                    </Grid>
                </DockPanel>

                    <TextBlock x:Name="EmptyHintText" DockPanel.Dock="Top"
                           Text="先选左侧文件夹"
                           Foreground="{StaticResource Brush_Text_Tertiary}" Margin="0,0,12,8"/>
                <Grid HorizontalAlignment="Stretch">
                    <ListView x:Name="ImageList" SelectionChanged="OnImageSelectionChanged"
                              SelectionMode="Single"
                              PreviewMouseLeftButtonDown="OnImageListPointerDown"
                              PreviewMouseMove="OnImageListPointerMove"
                              PreviewMouseLeftButtonUp="OnImageListPointerUp"
                              MouseDoubleClick="OnImageListMouseDoubleClick"
                              MouseLeave="OnImageListPointerLeave"
                              Background="Transparent" BorderThickness="0" 
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.PanningMode="VerticalFirst"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.ScrollChanged="OnImageListScrollChanged"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Standard"
                              Foreground="{StaticResource Brush_Text_Primary}"
                              ItemContainerStyle="{StaticResource Style_ManagementThumbnailListViewItem}">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <local:VirtualizingWrapPanel/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="6" Width="{Binding ElementName=ThumbnailSizeSlider, Path=Value}">
                                    <Border BorderBrush="{StaticResource Brush_Border}" BorderThickness="1" CornerRadius="6" Padding="4"
                                            Background="{StaticResource Brush_InputBackground}"
                                            Height="{Binding ElementName=ThumbnailSizeSlider, Path=Value, Converter={StaticResource ThumbnailSizeRatio}}">
                                        <Grid>
                                            <!-- 文件夹图标：固定大小，居中，不随 Slider 缩放 -->
                                            <Path Data="{StaticResource Icon_Folder}" Fill="{StaticResource Brush_Primary}" 
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" Width="48" Height="48"
                                                  Stretch="Uniform"
                                                  Visibility="{Binding IsFolder, Converter={StaticResource FolderVisibilityConverter}}"/>
                                            
                                            <!-- 图片/PDF：填满容器 -->
                                            <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                                                   Visibility="{Binding IsFolder, Converter={StaticResource FileVisibilityConverter}}"/>
                                            
                                            <Border Background="{StaticResource Brush_OverlayMask}" CornerRadius="4" Padding="4,1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                    Margin="0,0,2,2" Visibility="{Binding PageBadgeVisibility}">
                                                <TextBlock Text="{Binding PageBadge}" Foreground="White" FontSize="{StaticResource FontSize_Body_S}" FontWeight="SemiBold"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis" FontSize="{StaticResource FontSize_Body_S}" Margin="2,6,2,0"
                                               Foreground="{Binding IsPdf, Converter={StaticResource PdfForegroundConverter}}"
                                               FontWeight="{Binding IsPdf, Converter={StaticResource PdfFontWeightConverter}}"
                                               HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <ListView x:Name="ImageListView" SelectionChanged="OnImageSelectionChanged"
                              SelectionMode="Single"
                              PreviewMouseLeftButtonDown="OnImageListPointerDown"
                              PreviewMouseMove="OnImageListPointerMove"
                              PreviewMouseLeftButtonUp="OnImageListPointerUp"
                              MouseDoubleClick="OnImageListMouseDoubleClick"
                              MouseLeave="OnImageListPointerLeave"
                              Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Visibility="Collapsed"
                              ScrollViewer.PanningMode="VerticalFirst"
                              ScrollViewer.CanContentScroll="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              Foreground="{StaticResource Brush_Text_Primary}"
                              ItemContainerStyle="{StaticResource Style_ManagementFileListViewItem}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="名称" Width="240">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                                                       Foreground="{Binding IsPdf, Converter={StaticResource PdfForegroundConverter}}"
                                                       FontWeight="{Binding IsPdf, Converter={StaticResource PdfFontWeightConverter}}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="类型" DisplayMemberBinding="{Binding TypeLabel}" Width="80"/>
                                <GridViewColumn Header="页数" DisplayMemberBinding="{Binding PageLabel}" Width="80"/>
                                <GridViewColumn Header="修改时间" DisplayMemberBinding="{Binding ModifiedLabel}" Width="160"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
                    </DockPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource Style_ManagementShellFooterBorder}" CornerRadius="0">
                <Grid>
                    <TextBlock Text="管理 PDF、图片与笔迹。"
                               Style="{StaticResource Style_ManagementShellFooterText}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
