<Window x:Class="ClassroomToolkit.App.Photos.ImageManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClassroomToolkit.App.Photos"
        xmlns:converters="clr-namespace:ClassroomToolkit.App.Converters"
        Title="PDF/图片管理"
        Width="1100"
        Height="700"
        MinWidth="960"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    <Window.Resources>
        <local:MultiplyConverter x:Key="ThumbnailSizeRatio" Factor="0.75"/>
        <converters:PdfForegroundConverter x:Key="PdfForegroundConverter"/>
        <converters:PdfFontWeightConverter x:Key="PdfFontWeightConverter"/>
        <local:FolderVisibilityConverter x:Key="FolderVisibilityConverter"/>
        <local:FileVisibilityConverter x:Key="FileVisibilityConverter"/>
        <local:PdfBackgroundConverter x:Key="PdfBackgroundConverter"/>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="{StaticResource Brush_Window_Atmosphere}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LeftColumn" Width="2*" MinWidth="220" MaxWidth="520"/>
            <ColumnDefinition x:Name="SplitterColumn" Width="6"/>
            <ColumnDefinition x:Name="RightColumn" Width="5*" MinWidth="560"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="FavoritesRow" Height="1*" MinHeight="120"/>
                <RowDefinition x:Name="RecentsRow" Height="1*" MinHeight="120"/>
                <RowDefinition x:Name="FolderTreeRow" Height="2*" MinHeight="180"/>
            </Grid.RowDefinitions>

            <!-- 1. 收藏夹 -->
            <Border Grid.Row="0" Background="{StaticResource Brush_Background_L2}" BorderBrush="{StaticResource Brush_Border}" 
                    BorderThickness="1" Padding="12" Margin="12,12,3,6" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="收藏夹" FontWeight="SemiBold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,6"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                        <Button Content="添加" Width="60" Height="26" Margin="0,0,6,0" Click="OnAddFavoriteClick" Style="{StaticResource Style_Button_Teal}" FontSize="12"/>
                        <Button Content="移除" Width="60" Height="26" Click="OnRemoveFavoriteClick" Style="{StaticResource Style_DangerButton}" FontSize="12"/>
                    </StackPanel>
                    <ListBox Grid.Row="2" x:Name="FavoritesList" SelectionChanged="OnFavoritesSelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Background="Transparent" BorderThickness="0" Foreground="{StaticResource Brush_Text_Primary}"/>
                </Grid>
            </Border>

            <!-- 2. 最近目录 -->
            <Border Grid.Row="1" Background="{StaticResource Brush_Background_L2}" BorderBrush="{StaticResource Brush_Border}" 
                    BorderThickness="1" Padding="12" Margin="12,6,3,6" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="最近目录" FontWeight="SemiBold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,6"/>
                    <ListBox Grid.Row="1" x:Name="RecentsList" SelectionChanged="OnRecentsSelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Background="Transparent" BorderThickness="0" Foreground="{StaticResource Brush_Text_Primary}"/>
                </Grid>
            </Border>

            <!-- 3. 此电脑 -->
            <Border Grid.Row="2" Background="{StaticResource Brush_Background_L2}" BorderBrush="{StaticResource Brush_Border}" 
                    BorderThickness="1" Padding="12" Margin="12,6,3,12" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="此电脑" FontWeight="SemiBold" Foreground="{StaticResource Brush_Text_Primary}" Margin="0,0,0,6"/>
                    <TreeView Grid.Row="1" x:Name="FolderTree" SelectedItemChanged="OnFolderTreeSelected"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
                              Background="Transparent" BorderThickness="0" Foreground="{StaticResource Brush_Text_Primary}">
                        <!-- Global TreeViewItem style applied automatically -->
                    </TreeView>
                </Grid>
            </Border>
        </Grid>

        <GridSplitter x:Name="MainColumnSplitter" Grid.Column="1" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent"
                      ShowsPreview="True" DragCompleted="OnMainColumnSplitterDragCompleted"/>

        <Border Grid.Column="2" Background="{StaticResource Brush_Background_L2}" BorderBrush="{StaticResource Brush_Border}" BorderThickness="1" Padding="12,12,0,12" Margin="3,12,0,12" CornerRadius="8">
            <DockPanel>
                <!-- 地址栏（独立在最上方） -->
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Border Background="{StaticResource Brush_Background_L3}" BorderBrush="{StaticResource Brush_Border}"
                            BorderThickness="1" CornerRadius="4" Padding="8,6" Height="36">
                        <TextBlock x:Name="CurrentFolderText" Foreground="{StaticResource Brush_Text_Primary}"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    </Border>
                </DockPanel>

                <!-- 工具栏 -->
                <DockPanel DockPanel.Dock="Top" Margin="0,0,12,8">
                    <WrapPanel x:Name="ToolbarWrapPanel" Orientation="Horizontal" ItemHeight="30">
                        <!-- 增加高度到 30，统一字体 13 -->
                        <Button x:Name="BackButton" Content="后退" Width="60" Height="30" Margin="0,0,6,0"
                                Click="OnBackClick" IsEnabled="{Binding IsBackButtonEnabled}" Style="{StaticResource Style_SecondaryButton}" FontSize="13" Padding="0"/>
                        <Button x:Name="ForwardButton" Content="前进" Width="60" Height="30" Margin="0,0,6,0"
                                Click="OnForwardClick" IsEnabled="{Binding IsForwardButtonEnabled}" Style="{StaticResource Style_SecondaryButton}" FontSize="13" Padding="0"/>
                        <Button x:Name="UpButton" Content="向上" Width="60" Height="30" Margin="0,0,12,0"
                                Click="OnUpClick" Style="{StaticResource Style_SecondaryButton}" FontSize="13" Padding="0"/>
                        <ToggleButton x:Name="ListViewButton" Content="列表" Width="60" Height="30" Margin="0,0,6,0"
                                      Click="OnViewModeClick" Style="{StaticResource Style_ToggleButton}" FontSize="13" Padding="0"/>
                        <ToggleButton x:Name="ThumbnailViewButton" Content="缩略图" Width="70" Height="30" Margin="0,0,12,0"
                                      Click="OnViewModeClick" Style="{StaticResource Style_ToggleButton}" FontSize="13" Padding="0"/>
                        <TextBlock Text="缩略图大小" Foreground="{StaticResource Brush_Text_Secondary}" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Slider x:Name="ThumbnailSizeSlider" Width="120" Minimum="90" Maximum="420" Value="120"
                                ValueChanged="OnThumbnailSizeChanged" IsEnabled="{Binding IsThumbnailSizeSliderEnabled}"/>
                        <CheckBox x:Name="ShowInkCheckBox" Content="显示笔迹" Margin="12,0,0,0"
                                  Foreground="{StaticResource Brush_Text_Secondary}" FontSize="13"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding ShowInkOverlay, Mode=TwoWay}"
                                  Checked="OnShowInkChanged" Unchecked="OnShowInkChanged"/>
                    </WrapPanel>
                </DockPanel>

                <TextBlock x:Name="EmptyHintText" DockPanel.Dock="Top" Text="请选择左侧文件夹查看图片"
                           Foreground="{StaticResource Brush_Text_Tertiary}" Margin="0,0,12,8"/>
                <Grid HorizontalAlignment="Stretch">
                    <ListView x:Name="ImageList" SelectionChanged="OnImageSelectionChanged" MouseDoubleClick="OnImageListDoubleClick"
                              Background="Transparent" BorderThickness="0" 
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              Foreground="{StaticResource Brush_Text_Primary}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,1"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="bd"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush_Surface_Hover}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush_Surface_Active}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Brush_Primary_Light}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel IsItemsHost="True" />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="6" Width="{Binding ElementName=ThumbnailSizeSlider, Path=Value}">
                                    <Border BorderBrush="{StaticResource Brush_Border}" BorderThickness="1" CornerRadius="6" Padding="4"
                                            Background="{StaticResource Brush_Background_L3}"
                                            Height="{Binding ElementName=ThumbnailSizeSlider, Path=Value, Converter={StaticResource ThumbnailSizeRatio}}">
                                        <Grid>
                                            <!-- 文件夹图标：固定大小，居中，不随 Slider 缩放 -->
                                            <TextBlock Text="📁" FontSize="48" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Visibility="{Binding IsFolder, Converter={StaticResource FolderVisibilityConverter}}"
                                                       Foreground="{StaticResource Brush_Primary}"/> <!-- 给个主题色更好看 -->
                                            
                                            <!-- 图片/PDF：填满容器 -->
                                            <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                                                   Visibility="{Binding IsFolder, Converter={StaticResource FileVisibilityConverter}}"/>
                                            
                                            <Border Background="#CC000000" CornerRadius="4" Padding="4,1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                    Margin="0,0,2,2" Visibility="{Binding PageBadgeVisibility}">
                                                <TextBlock Text="{Binding PageBadge}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis" FontSize="12" Margin="2,6,2,0"
                                               Foreground="{Binding IsPdf, Converter={StaticResource PdfForegroundConverter}}"
                                               FontWeight="{Binding IsPdf, Converter={StaticResource PdfFontWeightConverter}}"
                                               HorizontalAlignment="Center" TextAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <ListView x:Name="ImageListView" SelectionChanged="OnImageSelectionChanged" MouseDoubleClick="OnImageListDoubleClick"
                              Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Visibility="Collapsed"
                              Foreground="{StaticResource Brush_Text_Primary}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="名称" Width="240">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                                                       Foreground="{Binding IsPdf, Converter={StaticResource PdfForegroundConverter}}"
                                                       FontWeight="{Binding IsPdf, Converter={StaticResource PdfFontWeightConverter}}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="类型" DisplayMemberBinding="{Binding TypeLabel}" Width="80"/>
                                <GridViewColumn Header="页数" DisplayMemberBinding="{Binding PageLabel}" Width="80"/>
                                <GridViewColumn Header="修改时间" DisplayMemberBinding="{Binding ModifiedLabel}" Width="160"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</Window>
