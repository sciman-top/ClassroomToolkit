<Window x:Class="ClassroomToolkit.App.Photos.PhotoOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize">
    <Grid>
        <Border x:Name="PhotoBorder" Background="Transparent">
            <Grid>
                <Image x:Name="PhotoImage" Stretch="Uniform" />
                <TextBlock x:Name="NameText"
                           Foreground="#F0F2F5"
                           FontSize="48"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           Margin="20,24,20,0" />
                <Button x:Name="CloseButton"
                        Content="X"
                        Width="24"
                        Height="24"
                        FontSize="12"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="8"
                        Click="OnCloseClick" />
            </Grid>
        </Border>
    </Grid>
</Window>
