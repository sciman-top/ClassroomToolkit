<Window x:Class="ClassroomToolkit.App.Photos.PhotoOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize">
    <Grid>
        <Border x:Name="PhotoBorder" Background="Transparent">
            <Grid>
                <Image x:Name="PhotoImage" Stretch="Uniform" />
                <TextBlock x:Name="NameText"
                           Foreground="#F0F2F5"
                           FontSize="48"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           Margin="20,24,20,0" />
                <Grid VerticalAlignment="Bottom" Margin="20,0,20,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="CloseButtonLeft"
                            Grid.Column="0"
                            Content="关闭"
                            Width="60"
                            Height="26"
                            Click="OnCloseClick" />
                    <Button x:Name="CloseButtonRight"
                            Grid.Column="2"
                            Content="关闭"
                            Width="60"
                            Height="26"
                            Click="OnCloseClick" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
