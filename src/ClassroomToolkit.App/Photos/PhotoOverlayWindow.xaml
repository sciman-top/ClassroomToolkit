<Window x:Class="ClassroomToolkit.App.Photos.PhotoOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">
    
    <Canvas x:Name="RootCanvas" SizeChanged="OnCanvasSizeChanged">
        <Rectangle x:Name="BackgroundRect" Fill="Transparent" MouseLeftButtonDown="OnCloseClick"/>

        <Image x:Name="PhotoImage"
               Stretch="Uniform"
               StretchDirection="DownOnly"
               MouseLeftButtonDown="OnCloseClick"
               Cursor="Hand"
               SizeChanged="OnPhotoSizeChanged">
            <Image.Effect>
                <StaticResource ResourceKey="Shadow_Card_Subtle"/>
            </Image.Effect>
        </Image>

        <Border x:Name="LoadingMask" Background="{StaticResource Brush_OverlayMask}" Visibility="Collapsed" Panel.ZIndex="8" IsHitTestVisible="False"/>

        <Border x:Name="NameBadge"
                Style="{StaticResource Style_FullscreenShellHintBadge}"
                Padding="{StaticResource Spacing_Control_OverlayHintBadge}"
                Visibility="Collapsed"
                BorderThickness="1"
                Background="{StaticResource Brush_GlassSurface}"
                Opacity="1"
                Panel.ZIndex="120">
            <TextBlock x:Name="NameText"
                       MaxWidth="720"
                       Foreground="{StaticResource Brush_Text_Primary}"
                       FontFamily="KaiTi, STKaiti, KaiTi_GB2312, Microsoft YaHei UI"
                       FontSize="42"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

        <Button x:Name="CloseButtonLeft"
                Style="{StaticResource Style_FullscreenShellCloseButton}"
                Click="OnCloseClick"
                Opacity="0.64"
                ToolTip="关闭">
            <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform"
                  Width="{StaticResource Size_Icon_Glyph_LG}" Height="{StaticResource Size_Icon_Glyph_LG}"/>
        </Button>
        <Button x:Name="CloseButtonRight"
                Style="{StaticResource Style_FullscreenShellCloseButton}"
                Click="OnCloseClick"
                Opacity="0.64"
                ToolTip="关闭">
            <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform"
                  Width="{StaticResource Size_Icon_Glyph_LG}" Height="{StaticResource Size_Icon_Glyph_LG}"/>
        </Button>
        <Button x:Name="CloseButtonCenter"
                Style="{StaticResource Style_FullscreenShellCloseButton}"
                Click="OnCloseClick"
                Opacity="0.64"
                ToolTip="关闭">
            <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Primary}" Stretch="Uniform"
                  Width="{StaticResource Size_Icon_Glyph_LG}" Height="{StaticResource Size_Icon_Glyph_LG}"/>
        </Button>

        <Border x:Name="CloseHintText" Style="{StaticResource Style_FullscreenShellHintBadge}" Padding="{StaticResource Spacing_Control_OverlayHintBadge}" Panel.ZIndex="10">
            <Border.Effect>
                <StaticResource ResourceKey="Shadow_Floating"/>
            </Border.Effect>
            <TextBlock Text="点击空白处关闭" FontSize="{StaticResource FontSize_Body_M}" Foreground="{StaticResource Brush_Text_Primary}" Opacity="0.9"/>
        </Border>
    </Canvas>
</Window>
