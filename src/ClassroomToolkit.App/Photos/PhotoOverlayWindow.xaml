<Window x:Class="ClassroomToolkit.App.Photos.PhotoOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        ShowInTaskbar="False"
        Topmost="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">
    
    <Canvas x:Name="RootCanvas" SizeChanged="OnCanvasSizeChanged">
        <Rectangle x:Name="BackgroundRect" Fill="Transparent"/>

        <Image x:Name="PhotoImage"
               Stretch="Uniform"
               StretchDirection="DownOnly"
               SizeChanged="OnPhotoSizeChanged"
               MouseLeftButtonDown="OnPhotoImageMouseLeftButtonDown">
            <Image.Effect>
                <StaticResource ResourceKey="Shadow_Card_Subtle"/>
            </Image.Effect>
        </Image>

        <Border x:Name="LoadingMask" Background="{StaticResource Brush_OverlayMask}" Visibility="Collapsed" Panel.ZIndex="8" IsHitTestVisible="False"/>

        <Border x:Name="NameBadge"
                Style="{StaticResource Style_FullscreenShellHintBadge}"
                Padding="{StaticResource Spacing_Control_OverlayHintBadge}"
                Visibility="Collapsed"
                BorderThickness="1"
                Background="{StaticResource Brush_GlassSurface}"
                Opacity="1"
                Panel.ZIndex="120">
            <TextBlock x:Name="NameText"
                       MaxWidth="560"
                       Foreground="{StaticResource Brush_Text_Primary}"
                       FontFamily="KaiTi, STKaiti, KaiTi_GB2312, Microsoft YaHei UI"
                       FontSize="34"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

    </Canvas>
</Window>
