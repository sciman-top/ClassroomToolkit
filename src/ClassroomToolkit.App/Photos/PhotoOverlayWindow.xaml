<Window x:Class="ClassroomToolkit.App.Photos.PhotoOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        ShowInTaskbar="False"
        Topmost="True"
        WindowState="Maximized"
        ResizeMode="NoResize">
    
    <Canvas x:Name="RootCanvas" SizeChanged="OnCanvasSizeChanged">
        <!-- 透明背景，点击关闭 -->
        <Rectangle x:Name="BackgroundRect" Fill="Transparent" MouseLeftButtonDown="OnCloseClick"/>

        <!-- 照片：只缩小不放大，居中显示 -->
        <Image x:Name="PhotoImage" 
               Stretch="Uniform" 
               StretchDirection="DownOnly"
               SizeChanged="OnPhotoSizeChanged"/>

        <!-- 遮挡层：用于在切换照片时隐藏旧照片 -->
        <Border x:Name="LoadingMask" Background="Transparent" Visibility="Collapsed" Panel.ZIndex="100"/>

        <!-- 学生姓名：动态定位到照片顶部 -->
        <TextBlock x:Name="NameText" 
                   Foreground="White" 
                   FontSize="56" 
                   FontWeight="Black"
                   TextAlignment="Center"
                   TextWrapping="NoWrap"
                   TextTrimming="CharacterEllipsis"
                   Panel.ZIndex="10">
            <TextBlock.Effect>
                <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.7"/>
            </TextBlock.Effect>
        </TextBlock>

        <!-- 底部关闭按钮 -->
        <Button x:Name="CloseButtonLeft" 
                Style="{StaticResource Style_FullscreenShellCloseButton}" 
                Click="OnCloseClick" 
                Opacity="0.3"
                Width="56"
                Height="56"
                Visibility="Collapsed"/>
        <Button x:Name="CloseButtonRight" 
                Style="{StaticResource Style_FullscreenShellCloseButton}" 
                Click="OnCloseClick" 
                Opacity="0.45"
                Width="56"
                Height="56"/>

        <TextBlock x:Name="CloseHintText"
                   Text="单击背景或右下角关闭"
                   FontSize="16"
                   Foreground="#E6FFFFFF"
                   Panel.ZIndex="10">
            <TextBlock.Effect>
                <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="1" Opacity="0.6"/>
            </TextBlock.Effect>
        </TextBlock>
    </Canvas>
</Window>
