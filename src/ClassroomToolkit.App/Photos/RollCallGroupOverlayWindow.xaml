<Window x:Class="ClassroomToolkit.App.Photos.RollCallGroupOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RollCallGroupOverlayWindow"
        Height="80" Width="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        IsHitTestVisible="False">

    <Window.Resources>
        <Storyboard x:Key="FadeStoryboard">
            <DoubleAnimation Storyboard.TargetName="OverlayBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="OverlayBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.5"
                             BeginTime="0:0:2.0"/>
        </Storyboard>
    </Window.Resources>

    <Grid Margin="5">
        <Border x:Name="OverlayBorder" 
                CornerRadius="10" 
                Padding="14,6"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Opacity="0"
                IsHitTestVisible="False"
                Background="{StaticResource Brush_Surface_Primary}">

            <TextBlock x:Name="GroupNameText" 
                       Foreground="{StaticResource Brush_Text_Primary}"
                       FontSize="18" 
                       FontWeight="SemiBold" 
                       VerticalAlignment="Center"
                       Text="全部"/>
        </Border>
    </Grid>
</Window>
