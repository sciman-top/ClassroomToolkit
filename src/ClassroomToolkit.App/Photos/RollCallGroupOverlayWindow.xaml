<Window x:Class="ClassroomToolkit.App.Photos.RollCallGroupOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="分组提示"
        Height="72" Width="240"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        IsHitTestVisible="False">

    <Window.Resources>
        <Storyboard x:Key="FadeStoryboard">
            <DoubleAnimation Storyboard.TargetName="OverlayBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="OverlayBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.5"
                             BeginTime="0:0:2.0"/>
        </Storyboard>
    </Window.Resources>

    <Grid Margin="5">
        <Border x:Name="OverlayBorder" 
                Style="{StaticResource Style_BubbleShellRoot}"
                Padding="12,6"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Opacity="0"
                IsHitTestVisible="False"
                MinWidth="80">

            <TextBlock x:Name="GroupNameText"
                       Foreground="{StaticResource Brush_Text_Primary}"
                       FontSize="{StaticResource FontSize_Title_Management}"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Text="全部"/>
        </Border>
    </Grid>
</Window>
