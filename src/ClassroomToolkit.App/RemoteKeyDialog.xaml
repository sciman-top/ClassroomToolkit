<Window x:Class="ClassroomToolkit.App.RemoteKeyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="遥控键位" Height="Auto" Width="376"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}">

    <Border Style="{StaticResource Style_DialogShellWindowBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Style="{StaticResource Style_DialogShellTitleBar}" MouseLeftButtonDown="OnTitleBarDrag">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                    <Border Style="{StaticResource Style_TitleIconBadge}" Margin="0,0,8,0">
                        <Path Data="{StaticResource Icon_Settings}" Fill="{StaticResource Brush_Teaching}" Stretch="Uniform"/>
                    </Border>
                    <TextBlock Text="遥控键位" Style="{StaticResource Style_DialogShellTitleText}" Margin="0"/>
                </StackPanel>
                <Button Style="{StaticResource Style_DialogShellCloseButton}" Click="OnCancel" ToolTip="关闭">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform"
                          Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}"/>
                </Button>
            </Grid>
            <Border Grid.Row="0" Style="{StaticResource Style_DialogShellDivider}"/>

            <Border Grid.Row="1" Margin="20,16,20,20" Style="{StaticResource Style_SettingCardBorder}" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="78" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="预设键位" VerticalAlignment="Center" Margin="0,0,12,14" Foreground="{StaticResource Brush_Text_Secondary}"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="PresetCombo" Margin="0,0,0,14" SelectionChanged="OnPresetChanged" Height="{StaticResource Size_Button_Icon_Regular}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="自定义" VerticalAlignment="Center" Margin="0,0,12,14" Foreground="{StaticResource Brush_Text_Secondary}"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="CustomBox" Margin="0,0,0,14" Height="{StaticResource Size_Button_Icon_Regular}" VerticalContentAlignment="Center"/>

                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource Style_DialogShellActionBar}" Margin="0,2,0,0">
                        <Button Content="取消" Style="{StaticResource Style_DialogShellSecondaryActionButton}" Click="OnCancel" />
                        <Button Content="确定" Style="{StaticResource Style_DialogShellPrimaryActionButton}" Click="OnConfirm" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
