<Window x:Class="ClassroomToolkit.App.RemoteKeyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="遥控键设置" Height="Auto" Width="360" 
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}">

    <Border Style="{StaticResource Style_DialogShellWindowBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Style="{StaticResource Style_DialogShellTitleBar}">
                <TextBlock Text="遥控键设置" Style="{StaticResource Style_DialogShellTitleText}"/>
            </Grid>
            <Border Grid.Row="0" Style="{StaticResource Style_DialogShellDivider}"/>

            <Grid Grid.Row="1" Margin="20,16,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="预设：" VerticalAlignment="Center" Margin="0,0,12,16" Foreground="{StaticResource Brush_Text_Secondary}"/>
                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="PresetCombo" Margin="0,0,0,16" SelectionChanged="OnPresetChanged" Height="34"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="自定义：" VerticalAlignment="Center" Margin="0,0,12,16" Foreground="{StaticResource Brush_Text_Secondary}"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="CustomBox" Margin="0,0,0,16" Height="34" VerticalContentAlignment="Center"/>

                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource Style_DialogShellActionBar}" Margin="0,4,0,0">
                    <Button Content="取消" Style="{StaticResource Style_DialogShellSecondaryActionButton}" Click="OnCancel" />
                    <Button Content="确定" Style="{StaticResource Style_DialogShellPrimaryActionButton}" Click="OnConfirm" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
