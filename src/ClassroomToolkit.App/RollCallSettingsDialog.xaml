<Window x:Class="ClassroomToolkit.App.RollCallSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="点名设置"
        Width="460"
        MinWidth="420"
        MaxWidth="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Topmost="True">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl x:Name="SettingsTabs" Grid.Row="0">
            <TabItem Header="显示/照片">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="学生信息:" Margin="0,0,8,8" VerticalAlignment="Center" />
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox x:Name="ShowIdCheck" Content="学号" Margin="0,0,12,0" />
                        <CheckBox x:Name="ShowNameCheck" Content="姓名" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="照片显示:" Margin="0,0,8,8" VerticalAlignment="Center" />
                    <CheckBox x:Name="ShowPhotoCheck" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"
                              Checked="OnShowPhotoChanged" Unchecked="OnShowPhotoChanged" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="照片显示时间:" Margin="0,0,8,8" VerticalAlignment="Center" />
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <Slider x:Name="PhotoDurationSlider" Width="180" Minimum="0" Maximum="10"
                                ValueChanged="OnPhotoDurationChanged" />
                        <TextBlock x:Name="PhotoDurationLabel" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="照片文件夹" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <ComboBox x:Name="PhotoSharedCombo" Grid.Row="3" Grid.Column="1" IsEditable="False" />
                </Grid>
            </TabItem>

            <TabItem Header="语音播报">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="启用语音播报:" Margin="0,0,8,8" VerticalAlignment="Center" />
                    <CheckBox x:Name="SpeechCheck" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="语音引擎:" Margin="0,0,8,8" VerticalAlignment="Center" />
                    <ComboBox x:Name="SpeechEngineCombo" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"
                              SelectionChanged="OnSpeechEngineChanged" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="发音人:" Margin="0,0,8,8" VerticalAlignment="Center" />
                    <ComboBox x:Name="SpeechVoiceCombo" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="输出设备:" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <ComboBox x:Name="SpeechOutputCombo" Grid.Row="3" Grid.Column="1" />
                </Grid>
            </TabItem>

            <TabItem Header="倒计时提示">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="启用结束提示音:" Margin="0,0,8,8" VerticalAlignment="Center" />
                    <CheckBox x:Name="TimerSoundCheck" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"
                              Checked="OnTimerControlChanged" Unchecked="OnTimerControlChanged" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="结束提示音样式:" Margin="0,0,8,8" VerticalAlignment="Center" />
                    <ComboBox x:Name="TimerSoundCombo" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="启用中途提示音:" Margin="0,0,8,8" VerticalAlignment="Center" />
                    <CheckBox x:Name="ReminderSoundCheck" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"
                              Checked="OnTimerControlChanged" Unchecked="OnTimerControlChanged" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="中途提示音样式:" Margin="0,0,8,8" VerticalAlignment="Center" />
                    <ComboBox x:Name="ReminderSoundCombo" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="中途提示间隔:" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                        <Slider x:Name="ReminderIntervalSlider" Width="180" Minimum="1" Maximum="20"
                                ValueChanged="OnReminderIntervalChanged" />
                        <TextBlock x:Name="ReminderIntervalLabel" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="遥控点名">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="启用翻页笔遥控点名:" Margin="0,0,8,8" VerticalAlignment="Center" />
                    <CheckBox x:Name="RemoteEnabledCheck" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"
                              Checked="OnRemoteEnabledChanged" Unchecked="OnRemoteEnabledChanged" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="翻页笔按键:" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <ComboBox x:Name="RemoteKeyCombo" Grid.Row="1" Grid.Column="1" IsEditable="True" />
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="DiagnosticButton" Grid.Column="0" Content="系统兼容性诊断"
                    Width="140" Height="32" Click="OnDiagnosticClick" />
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="确定" Width="80" Height="32" Margin="0,0,8,0" Click="OnConfirm" />
                <Button Content="取消" Width="80" Height="32" Click="OnCancel" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
