<Window x:Class="ClassroomToolkit.App.RollCallSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="点名设置"
        Height="Auto" Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        Topmost="True">
    
    <Border Background="White" CornerRadius="8" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="4" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title -->
                <RowDefinition Height="Auto"/> <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- 1. 标题栏 -->
            <Grid Grid.Row="0" Height="40" Background="Transparent" MouseLeftButtonDown="OnTitleBarDrag">
                <TextBlock Text="点名设置" FontWeight="Bold" Margin="16,0" VerticalAlignment="Center" Foreground="#333"/>
                <Button Style="{StaticResource Style_IconButton}" Click="OnCancel" HorizontalAlignment="Right" Margin="0,0,8,0">
                    <Path Data="{StaticResource Icon_Close}" Fill="#888" Stretch="Uniform" Width="10" Height="10"/>
                </Button>
            </Grid>
            <Border Grid.Row="0" VerticalAlignment="Bottom" Height="1" Background="#F0F0F0"/>

            <!-- 2. 内容 (TabControl) -->
            <TabControl x:Name="SettingsTabs" Grid.Row="1" Margin="12" BorderThickness="0" Background="Transparent">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Padding" Value="12,6"/>
                        <Setter Property="HeaderTemplate">
                            <Setter.Value>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="13"/>
                                </DataTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- 标签页 1: 显示/照片 -->
                <TabItem Header="显示/照片">
                    <Grid Margin="4,12,4,4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="学生信息:" Margin="0,0,12,12" VerticalAlignment="Center" Foreground="#666"/>
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                            <CheckBox x:Name="ShowIdCheck" Content="学号" Margin="0,0,16,0" />
                            <CheckBox x:Name="ShowNameCheck" Content="姓名" />
                        </StackPanel>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="照片显示:" Margin="0,0,12,12" VerticalAlignment="Center" Foreground="#666"/>
                        <CheckBox x:Name="ShowPhotoCheck" Grid.Row="1" Grid.Column="1" Margin="0,0,0,12"
                                  Checked="OnShowPhotoChanged" Unchecked="OnShowPhotoChanged" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="照片时长:" Margin="0,0,12,12" VerticalAlignment="Center" Foreground="#666"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                            <Slider x:Name="PhotoDurationSlider" Width="140" Minimum="0" Maximum="10"
                                    ValueChanged="OnPhotoDurationChanged" VerticalAlignment="Center"/>
                            <TextBlock x:Name="PhotoDurationLabel" Margin="8,0,0,0" VerticalAlignment="Center" Width="30"/>
                        </StackPanel>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="照片文件夹:" Margin="0,0,12,0" VerticalAlignment="Center" Foreground="#666"/>
                        <ComboBox x:Name="PhotoSharedCombo" Grid.Row="3" Grid.Column="1" IsEditable="False" Height="28"/>
                    </Grid>
                </TabItem>

                <!-- 标签页 2: 语音播报 -->
                <TabItem Header="语音播报">
                    <Grid Margin="4,12,4,4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="启用语音:" Margin="0,0,12,12" VerticalAlignment="Center" Foreground="#666"/>
                        <CheckBox x:Name="SpeechCheck" Grid.Row="0" Grid.Column="1" Margin="0,0,0,12" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="语音引擎:" Margin="0,0,12,12" VerticalAlignment="Center" Foreground="#666"/>
                        <ComboBox x:Name="SpeechEngineCombo" Grid.Row="1" Grid.Column="1" Margin="0,0,0,12" Height="28"
                                  SelectionChanged="OnSpeechEngineChanged" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="发音人:" Margin="0,0,12,12" VerticalAlignment="Center" Foreground="#666"/>
                        <ComboBox x:Name="SpeechVoiceCombo" Grid.Row="2" Grid.Column="1" Margin="0,0,0,12" Height="28"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="输出设备:" Margin="0,0,12,0" VerticalAlignment="Center" Foreground="#666"/>
                        <ComboBox x:Name="SpeechOutputCombo" Grid.Row="3" Grid.Column="1" Height="28"/>
                    </Grid>
                </TabItem>

                <!-- 标签页 3: 遥控点名 -->
                <TabItem Header="遥控点名">
                    <Grid Margin="4,12,4,4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="启用遥控:" Margin="0,0,12,12" VerticalAlignment="Center" Foreground="#666"/>
                        <CheckBox x:Name="RemoteEnabledCheck" Grid.Row="0" Grid.Column="1" Margin="0,0,0,12"
                                  Checked="OnRemoteEnabledChanged" Unchecked="OnRemoteEnabledChanged" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="翻页笔按键:" Margin="0,0,12,0" VerticalAlignment="Center" Foreground="#666"/>
                        <ComboBox x:Name="RemoteKeyCombo" Grid.Row="1" Grid.Column="1" IsEditable="False" Height="28"/>
                    </Grid>
                </TabItem>

                <!-- 标签页 4: 倒计时提示 -->
                <TabItem Header="倒计时">
                    <Grid Margin="4,12,4,4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="结束提示:" Margin="0,0,12,12" VerticalAlignment="Center" Foreground="#666"/>
                        <CheckBox x:Name="TimerSoundCheck" Grid.Row="0" Grid.Column="1" Margin="0,0,0,12"
                                  Checked="OnTimerControlChanged" Unchecked="OnTimerControlChanged" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="提示音效:" Margin="0,0,12,12" VerticalAlignment="Center" Foreground="#666"/>
                        <ComboBox x:Name="TimerSoundCombo" Grid.Row="1" Grid.Column="1" Margin="0,0,0,12" Height="28"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="中途提示:" Margin="0,0,12,12" VerticalAlignment="Center" Foreground="#666"/>
                        <CheckBox x:Name="ReminderSoundCheck" Grid.Row="2" Grid.Column="1" Margin="0,0,0,12"
                                  Checked="OnTimerControlChanged" Unchecked="OnTimerControlChanged" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="中途音效:" Margin="0,0,12,12" VerticalAlignment="Center" Foreground="#666"/>
                        <ComboBox x:Name="ReminderSoundCombo" Grid.Row="3" Grid.Column="1" Margin="0,0,0,12" Height="28"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="提示间隔:" Margin="0,0,12,0" VerticalAlignment="Center" Foreground="#666"/>
                        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                            <Slider x:Name="ReminderIntervalSlider" Width="140" Minimum="1" Maximum="20"
                                    ValueChanged="OnReminderIntervalChanged" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ReminderIntervalLabel" Margin="8,0,0,0" VerticalAlignment="Center" Width="30"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- 3. 底部按钮 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,0,16,16">
                <Button Content="取消" Style="{StaticResource Style_SecondaryButton}" Width="80" Margin="0,0,10,0" Click="OnCancel"/>
                <Button Content="确定" Style="{StaticResource Style_PrimaryButton}" Width="80" Click="OnConfirm"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
