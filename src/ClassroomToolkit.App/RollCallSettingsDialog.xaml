<Window x:Class="ClassroomToolkit.App.RollCallSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="点名设置"
        Height="Auto" Width="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        Topmost="True">

    <Border Style="{StaticResource Style_DialogShellWindowBorder}"
            Background="{StaticResource Brush_Window_Atmosphere}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title -->
                <RowDefinition Height="Auto"/> <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- 1. 标题栏 -->
            <Grid Grid.Row="0" Style="{StaticResource Style_DialogShellTitleBar}" MouseLeftButtonDown="OnTitleBarDrag">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <Path Data="{StaticResource Icon_Settings}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform"
                          Width="{StaticResource Size_Icon_Glyph_SM}" Height="{StaticResource Size_Icon_Glyph_SM}" Margin="0,0,8,0"/>
                    <TextBlock Text="点名设置" Style="{StaticResource Style_DialogShellTitleText}"/>
                </StackPanel>
                <Button Style="{StaticResource Style_DialogShellCloseButton}" Click="OnCancel" ToolTip="关闭点名设置">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform"
                          Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}"/>
                </Button>
            </Grid>
            <Border Grid.Row="0" Style="{StaticResource Style_DialogShellDivider}"/>

            <!-- 2. 内容 (TabControl) -->
            <TabControl x:Name="SettingsTabs" Grid.Row="1" Margin="20,16,20,16" BorderThickness="0" Background="Transparent">
                <!-- Global TabControl style applied automatically -->

                <!-- 标签页 1: 显示/照片 -->
                <TabItem Header="显示与照片">
                    <StackPanel Margin="4,12,4,8">
                        <Border Style="{StaticResource Style_SettingCardBorder}" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="学生信息" Margin="0,0,16,16" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}"/>
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,16">
                                    <CheckBox x:Name="ShowIdCheck" Content="显示学号" Foreground="{StaticResource Brush_Text_Primary}" VerticalAlignment="Center" Margin="0,0,24,0"/>
                                    <CheckBox x:Name="ShowNameCheck" Content="显示姓名" Foreground="{StaticResource Brush_Text_Primary}" VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="照片显示" Margin="0,0,16,16" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}"/>
                                <CheckBox x:Name="ShowPhotoCheck" Grid.Row="1" Grid.Column="1" Margin="0,0,0,16" Foreground="{StaticResource Brush_Text_Primary}" VerticalAlignment="Center"
                                          Content="启用学生照片显示"
                                          Checked="OnShowPhotoChanged" Unchecked="OnShowPhotoChanged" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="照片时长" Margin="0,0,16,16" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,16">
                                    <Slider x:Name="PhotoDurationSlider" Width="160" Minimum="0" Maximum="10"
                                            ValueChanged="OnPhotoDurationChanged" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="PhotoDurationLabel" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}"/>
                                </StackPanel>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="照片来源" Margin="0,0,16,0" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}"/>
                                <ComboBox x:Name="PhotoSharedCombo" Grid.Row="3" Grid.Column="1" IsEditable="False" Height="34"/>
                            </Grid>
                        </Border>
                        <TextBlock Text="说明：一般保持默认即可；需要突出学生信息或照片时再调整。"
                                   Margin="4,8,4,0"
                                   Foreground="{StaticResource Brush_Text_Tertiary}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </TabItem>

                <!-- 标签页 2: 语音播报 -->
                <TabItem Header="语音播报">
                    <StackPanel Margin="4,12,4,8">
                        <Border Style="{StaticResource Style_SettingCardBorder}" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="语音播报" Margin="0,0,16,16" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}"/>
                            <CheckBox x:Name="SpeechCheck" Grid.Row="0" Grid.Column="1" Margin="0,0,0,16" Content="点名时朗读姓名" Foreground="{StaticResource Brush_Text_Primary}" VerticalAlignment="Center"
                                      Checked="OnSpeechToggleChanged" Unchecked="OnSpeechToggleChanged"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="播报引擎" Margin="0,0,16,16" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}"/>
                            <ComboBox x:Name="SpeechEngineCombo" Grid.Row="1" Grid.Column="1" Margin="0,0,0,16" Height="34"
                                      SelectionChanged="OnSpeechEngineChanged" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="发音人" Margin="0,0,16,16" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}"/>
                            <ComboBox x:Name="SpeechVoiceCombo" Grid.Row="2" Grid.Column="1" Margin="0,0,0,16" Height="34"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="播报设备（暂不可选）" Margin="0,0,16,0" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}"/>
                            <ComboBox x:Name="SpeechOutputCombo" Grid.Row="3" Grid.Column="1" Height="34"/>
                        </Grid>
                        </Border>
                        <TextBlock Text="说明：一般保持默认即可；当前版本使用系统默认播报设备。"
                                   Margin="4,8,4,0"
                                   Foreground="{StaticResource Brush_Text_Tertiary}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </TabItem>

                <!-- 标签页 3: 遥控控制 -->
                <TabItem Header="遥控按键">
                    <StackPanel Margin="4,12,4,8">
                        <Border Style="{StaticResource Style_SettingCardBorder}" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- 点名按键 -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="遥控点名" Margin="0,0,16,16" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}"/>
                            <CheckBox x:Name="RemoteEnabledCheck" Grid.Row="0" Grid.Column="1" Margin="0,0,0,16" Content="使用翻页笔进行点名" Foreground="{StaticResource Brush_Text_Primary}" VerticalAlignment="Center"
                                      Checked="OnRemoteEnabledChanged" Unchecked="OnRemoteEnabledChanged" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="点名按键" Margin="0,0,16,16" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}"/>
                            <ComboBox x:Name="RemoteKeyCombo" Grid.Row="1" Grid.Column="1" IsEditable="False" Height="34" Margin="0,0,0,16"/>

                            <!-- 分组切换 -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="分组切换" Margin="0,0,16,16" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}"/>
                            <CheckBox x:Name="RemoteGroupSwitchCheck" Grid.Row="2" Grid.Column="1" Margin="0,0,0,16" Content="使用翻页笔切换分组" Foreground="{StaticResource Brush_Text_Primary}" VerticalAlignment="Center"
                                      Checked="OnRemoteGroupSwitchChanged" Unchecked="OnRemoteGroupSwitchChanged" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="分组按键" Margin="0,0,16,0" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}"/>
                            <ComboBox x:Name="RemoteGroupSwitchKeyCombo" Grid.Row="3" Grid.Column="1" IsEditable="False" Height="34"/>
                        </Grid>
                        </Border>
                        <TextBlock Text="说明：如同时启用两个按键，请确保不相同。"
                                   Margin="4,8,4,0"
                                   Foreground="{StaticResource Brush_Text_Tertiary}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </TabItem>

                <!-- 标签页 4: 倒计时提示 -->
                <TabItem Header="倒计时提醒">
                    <StackPanel Margin="4,12,4,8">
                        <Border Style="{StaticResource Style_SettingCardBorder}" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="结束提示" Margin="0,0,16,16" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}"/>
                            <CheckBox x:Name="TimerSoundCheck" Grid.Row="0" Grid.Column="1" Margin="0,0,0,16" Content="计时结束播放音效" Foreground="{StaticResource Brush_Text_Primary}" VerticalAlignment="Center"
                                      Checked="OnTimerControlChanged" Unchecked="OnTimerControlChanged" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="结束音效" Margin="0,0,16,16" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}"/>
                            <ComboBox x:Name="TimerSoundCombo" Grid.Row="1" Grid.Column="1" Margin="0,0,0,16" Height="34"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="中途提示" Margin="0,0,16,16" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}"/>
                            <CheckBox x:Name="ReminderSoundCheck" Grid.Row="2" Grid.Column="1" Margin="0,0,0,16" Content="定时语音提醒" Foreground="{StaticResource Brush_Text_Primary}" VerticalAlignment="Center"
                                      Checked="OnTimerControlChanged" Unchecked="OnTimerControlChanged" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="提醒音效" Margin="0,0,16,16" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}"/>
                            <ComboBox x:Name="ReminderSoundCombo" Grid.Row="3" Grid.Column="1" Margin="0,0,0,16" Height="34"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="提示间隔" Margin="0,0,16,0" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Secondary}"/>
                            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                                <Slider x:Name="ReminderIntervalSlider" Width="160" Minimum="1" Maximum="20"
                                        ValueChanged="OnReminderIntervalChanged" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ReminderIntervalLabel" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}"/>
                            </StackPanel>
                        </Grid>
                        </Border>
                        <TextBlock Text="说明：默认建议关闭“定时语音提醒”；开启后会按设定间隔播报。"
                                   Margin="4,8,4,0"
                                   Foreground="{StaticResource Brush_Text_Tertiary}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </TabItem>
            </TabControl>

            <!-- 3. 底部按钮 -->
            <StackPanel Grid.Row="2" Style="{StaticResource Style_DialogShellActionBar}">
                <Button Content="仅重置当前页" Style="{StaticResource Style_DialogShellSecondaryActionButton_Wide}" Click="OnRestoreDefaultsClick"/>
                <Button Content="重置全部设置" Width="118" Style="{StaticResource Style_DialogShellSecondaryActionButton}" Click="OnRestoreAllDefaultsClick"/>
                <Button Content="取消" Style="{StaticResource Style_DialogShellSecondaryActionButton}" Click="OnCancel"/>
                <Button Content="确定" Style="{StaticResource Style_DialogShellPrimaryActionButton}" Click="OnConfirm"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

