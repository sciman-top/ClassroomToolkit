<Window x:Class="ClassroomToolkit.App.RollCallSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="点名设置" Height="320" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <GroupBox Header="显示">
            <StackPanel Margin="8">
                <CheckBox x:Name="ShowIdCheck" Content="显示学号" Margin="0,4,0,0" />
                <CheckBox x:Name="ShowNameCheck" Content="显示姓名" Margin="0,4,0,0" />
            </StackPanel>
        </GroupBox>

        <GroupBox Header="遥控点名" Grid.Row="1" Margin="0,12,0,0">
            <StackPanel Margin="8">
                <CheckBox x:Name="RemoteEnabledCheck" Content="启用翻页笔遥控点名"
                          Checked="OnRemoteEnabledChanged" Unchecked="OnRemoteEnabledChanged" />
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="按键：" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox x:Name="RemoteKeyCombo" Width="180" IsEditable="True" />
                </StackPanel>
                <TextBlock Text="示例：tab 或 shift+b" Foreground="#666666" FontSize="11" Margin="0,4,0,0" />
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="确定" Width="70" Margin="0,0,8,0" Click="OnConfirm" />
            <Button Content="取消" Width="70" Click="OnCancel" />
        </StackPanel>
    </Grid>
</Window>
