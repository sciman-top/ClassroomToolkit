<Window x:Class="ClassroomToolkit.App.RollCallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClassroomToolkit.App.Converters"
        x:Name="NameWindow"
        Title="点名与计时"
        Height="420" Width="640"
        MinWidth="320" MinHeight="240"
        WindowStartupLocation="Manual"
        Topmost="True"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />

        <Style x:Key="Style_RollCallBottomBarTextButton" TargetType="Button" BasedOn="{StaticResource Style_SecondaryButton}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

        <Style x:Key="Style_RollCallBottomBarAccentButton" TargetType="Button" BasedOn="{StaticResource Style_Button_Amber}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

        <Style x:Key="Style_RollCallGroupButton" TargetType="Button" BasedOn="{StaticResource Style_RollCallBottomBarTextButton}">
            <Setter Property="MinWidth" Value="48"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>
    </Window.Resources>

    <!-- 1. 主容器：圆角+深邃阴影 -->
    <Border Style="{StaticResource Style_WorkShellWindowBorder}"
            TextElement.Foreground="{StaticResource Brush_Text_Primary}">
        <Border.Effect>
            <StaticResource ResourceKey="Shadow_Dialog"/>
        </Border.Effect>

        <Grid x:Name="RootGrid" MouseLeftButtonDown="OnBackgroundDrag" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 2. 顶部标题栏 -->
            <Grid x:Name="TitleBarRoot" Grid.Row="0" Style="{StaticResource Style_WorkShellTitleBar}" MouseLeftButtonDown="OnTitleBarDrag">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：模式切换与班级 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="18,0,0,0">
                    <!-- 模式切换按钮 (胶囊型) -->
                    <Button Style="{StaticResource Style_SecondaryButton}"
                            Click="OnToggleModeClick"
                            Padding="12,5"
                            Margin="0,0,8,0"
                            Height="{StaticResource Size_Button_Action_Height_Compact}"
                            MinWidth="102"
                            ToolTip="切换模式"
                            Background="{StaticResource Brush_InputBackground}"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Path Fill="{StaticResource Brush_Primary}" Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}" Stretch="Uniform" Margin="0,0,7,0">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Data" Value="{StaticResource Icon_RollCall}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRollCallMode}" Value="False">
                                                <Setter Property="Data" Value="{StaticResource Icon_Clock}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                            <TextBlock Text="{Binding ModeToggleLabel}" FontWeight="SemiBold" FontSize="{StaticResource FontSize_Body_S}" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}"/>
                        </StackPanel>
                    </Button>

                    <!-- 班级选择 -->
                    <Button Style="{StaticResource Style_SecondaryButton}"
                            Click="OnClassSelectClick"
                            Padding="12,5"
                            Height="{StaticResource Size_Button_Action_Height_Compact}"
                            MinWidth="108"
                            Background="{StaticResource Brush_InputBackground}"
                            BorderThickness="1"
                            Visibility="{Binding IsRollCallMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding ClassButtonLabel}"
                                   FontWeight="SemiBold"
                                   FontSize="{StaticResource FontSize_Body_S}"
                                   Foreground="{StaticResource Brush_Text_Primary}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="144"/>
                    </Button>
                </StackPanel>

                <!-- 右侧：窗口控制 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,14,0">
                    <Button Style="{StaticResource Style_IconButton}" Click="OnSettingsClick" ToolTip="点名设置">
                        <Path Data="{StaticResource Icon_Settings}" Fill="{StaticResource Brush_Teaching}" Stretch="Uniform"
                              Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}"/>
                    </Button>

                    <Button Style="{StaticResource Style_IconButton}" Click="OnMinimizeClick" ToolTip="最小化并继续" Margin="4,0,0,0">
                        <Path Data="{StaticResource Icon_Minimize}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform"
                              Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}"/>
                    </Button>
                    
                    <Button Style="{StaticResource Style_IconButton}" Click="OnCloseClick" ToolTip="关闭" Margin="4,0,0,0">
                        <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform"
                              Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 3. 内容展示区 -->
            <Grid Grid.Row="1" Style="{StaticResource Style_WorkShellContentHost}">
                <!-- A. 点名视图 -->
                <Grid Visibility="{Binding IsRollCallMode, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：名字卡片 (重点展示) -->
                    <Border x:Name="RollNameCard" Grid.Column="0" 
                            CornerRadius="{StaticResource Radius_Shell_Work}"
                            BorderBrush="{StaticResource Brush_Border_Strong}"
                            BorderThickness="1"
                            MouseLeftButtonUp="OnRollClick"
                            Cursor="Hand"
                            Margin="0,0,8,0">
                        <Border.Background>
                           <StaticResource ResourceKey="Gradient_RollCall_Card"/>
                        </Border.Background>
                        <Border.Effect>
                            <StaticResource ResourceKey="Shadow_Glow_Teaching"/>
                        </Border.Effect>

                        <!-- 名字展示 -->
                        <Viewbox Stretch="Uniform" Margin="10">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <!-- 主体字 (姓名) -->
                                <TextBlock x:Name="BigNameText"
                                           Text="{Binding CurrentStudentName}"
                                           Visibility="{Binding ShowName, Converter={StaticResource BoolToVis}}"
                                           FontSize="68"
                                           FontWeight="Heavy"
                                           FontFamily="Microsoft YaHei UI"
                                           FontStretch="Expanded"
                                           Foreground="{StaticResource Brush_Text_Primary}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0">
                                    <TextBlock.Effect>
                                        <StaticResource ResourceKey="Shadow_Card_Subtle"/>
                                    </TextBlock.Effect>
                                </TextBlock>

                                <!-- 学号 -->
                                <TextBlock Text="{Binding CurrentStudentId}"
                                           Visibility="{Binding ShowId, Converter={StaticResource BoolToVis}}"
                                           FontSize="{StaticResource FontSize_Title_Management}"
                                           Foreground="{StaticResource Brush_Text_Secondary}"
                                           FontWeight="Bold"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"
                               Margin="0,-4,0,0"/>
                            </StackPanel>
                        </Viewbox>
                    </Border>

                    <!-- 右侧：照片展示 -->
                    <Grid Grid.Column="1" Width="176" Height="228"
                          VerticalAlignment="Center"
                          Visibility="{Binding CurrentStudentPhotoPath, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                        <!-- 照片容器 -->
                        <Border CornerRadius="{StaticResource Radius_Shell_WorkBottomBar}" ClipToBounds="True" Background="{StaticResource Brush_Surface_Primary}" BorderBrush="{StaticResource Brush_Border_Subtle}" BorderThickness="1">
                            <Border.Effect>
                                <StaticResource ResourceKey="Shadow_Card"/>
                            </Border.Effect>
                            <Image Source="{Binding CurrentStudentPhotoPath}" Stretch="UniformToFill"/>
                        </Border>
                        
                        <!-- 姓名覆盖 (底部渐变遮罩) -->
                        <Border VerticalAlignment="Bottom" Height="54" CornerRadius="0,0,14,14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="{StaticResource Color_Bg_Overlay}" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="{Binding CurrentStudentName}"
                                       FontSize="{StaticResource FontSize_Title_Management}"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,8,0,0"/>
                        </Border>
                    </Grid>
                </Grid>

                <!-- B. 计时视图 -->
                <Grid Visibility="{Binding IsRollCallMode, Converter={StaticResource InverseBoolToVis}}">
                    <Border x:Name="TimerCard" 
                            Background="{StaticResource Brush_Surface_Primary}" 
                            CornerRadius="{StaticResource Radius_Shell_Work}"
                            BorderBrush="{StaticResource Brush_Border_Focus}" BorderThickness="1">
                        <Border.Effect>
                            <StaticResource ResourceKey="Shadow_Glow_Primary"/>
                        </Border.Effect>
                        <Grid>
                            <!-- 装饰线条 -->
                            <Border BorderBrush="{StaticResource Brush_Border_Strong}" BorderThickness="1" Margin="10" CornerRadius="8" Opacity="0.18"/>
                            
                            <Viewbox Margin="20" Stretch="Uniform">
                                <TextBlock Text="{Binding TimeDisplay}"
                                           Foreground="{StaticResource Gradient_Timer_Display}"
                                           FontFamily="Consolas, Courier New"
                                           FontWeight="Black">
                                     <TextBlock.Effect>
                                         <StaticResource ResourceKey="Shadow_Glow_Primary"/>
                                     </TextBlock.Effect>
                                </TextBlock>
                            </Viewbox>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- 4. 底部操作栏 -->
            <Border x:Name="BottomBarRoot" Grid.Row="2" Style="{StaticResource Style_WorkShellBottomBar}">
                <Border.Effect>
                    <StaticResource ResourceKey="Shadow_Floating"/>
                </Border.Effect>
                <Grid>
                    <Border BorderBrush="{StaticResource Brush_Border_Subtle}" BorderThickness="1" CornerRadius="{StaticResource Radius_Shell_WorkBottomBar}" Margin="-1"/>

                    <Grid>
                    <!-- 点名操作 -->
                    <StackPanel x:Name="RollCallActionsPanel" Orientation="Horizontal" HorizontalAlignment="Left" Visibility="{Binding IsRollCallMode, Converter={StaticResource BoolToVis}}">
                        <ItemsControl x:Name="GroupButtonsControl" ItemsSource="{Binding GroupButtons}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Label}"
                                            Click="OnGroupEntryClick">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource Style_RollCallGroupButton}">
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsReset}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource Brush_Primary}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource Brush_Text_Black}"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource Brush_Primary}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Rectangle Width="1" Height="16" Fill="{StaticResource Brush_Border_Strong}" Margin="10,0" Opacity="1"/>

                        <Button Style="{StaticResource Style_RollCallBottomBarAccentButton}" Click="OnResetClick">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource Icon_Reset}" Fill="{StaticResource Brush_Text_Black}"
                                      Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}" Margin="0,0,6,0" Stretch="Uniform"/>
                                <TextBlock Text="重置" FontWeight="SemiBold" FontSize="{StaticResource FontSize_Body_S}" Foreground="{StaticResource Brush_Text_Black}"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource Style_RollCallBottomBarTextButton}" Click="OnListClick">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource Icon_List}" Fill="{StaticResource Brush_Text_Secondary}"
                                      Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}" Margin="0,0,6,0" Stretch="Uniform"/>
                                <TextBlock Text="名单" FontWeight="SemiBold" FontSize="{StaticResource FontSize_Body_S}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- 计时操作 -->
                    <StackPanel x:Name="TimerActionsPanel" Orientation="Horizontal" HorizontalAlignment="Center" Visibility="{Binding IsRollCallMode, Converter={StaticResource InverseBoolToVis}}">
                        <Button Style="{StaticResource Style_RollCallBottomBarTextButton}" Click="OnTimerModeClick" MinWidth="64">
                             <TextBlock Text="{Binding TimerModeLabel}" FontWeight="SemiBold" FontSize="{StaticResource FontSize_Body_S}"/>
                        </Button>

                        <!-- 播放/暂停按钮 -->
                        <Button Style="{StaticResource Style_Button_Teal}" Margin="10,0" MinWidth="54" Height="{StaticResource Size_Button_Icon_Regular}" Click="OnTimerStartPauseClick" ToolTip="开始/暂停">
                            <Path Fill="{StaticResource Brush_Text_Black}" Width="{StaticResource Size_Icon_Glyph_LG}" Height="{StaticResource Size_Icon_Glyph_LG}" Stretch="Uniform">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Data" Value="{StaticResource Icon_Play}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TimerRunning}" Value="True">
                                                <Setter Property="Data" Value="{StaticResource Icon_Pause}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                        </Button>

                        <Button Style="{StaticResource Style_RollCallBottomBarAccentButton}" Click="OnTimerResetClick" MinWidth="64">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource Icon_Reset}" Fill="{StaticResource Brush_Text_Black}"
                                      Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}" Margin="0,0,6,0" Stretch="Uniform"/>
                                <TextBlock Text="重置" FontWeight="SemiBold" FontSize="{StaticResource FontSize_Body_S}" Foreground="{StaticResource Brush_Text_Black}"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource Style_RollCallBottomBarTextButton}" Click="OnTimerSetClick" MinWidth="64"
                                Background="{StaticResource Brush_Surface_Secondary}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource Icon_Settings}" Fill="{StaticResource Brush_Text_Secondary}"
                                      Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}" Margin="0,0,6,0" Stretch="Uniform"/>
                                <TextBlock Text="时长" FontWeight="SemiBold" FontSize="{StaticResource FontSize_Body_S}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
                </Grid>
            </Border>

            <!-- 5. 加载占位（旋转圆弧指示器） -->
            <Grid Grid.RowSpan="3"
                  Panel.ZIndex="100"
                  Background="{StaticResource Brush_OverlayMask}"
                  Visibility="{Binding IsDataLoaded, ElementName=NameWindow, Converter={StaticResource InverseBoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- 旋转圆弧 -->
                    <Border Width="48" Height="48" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <RotateTransform x:Name="LoadingRotate" Angle="0"/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="LoadingRotate"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" To="360" Duration="0:0:1.0"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        <Ellipse Width="48" Height="48"
                                 Stroke="{StaticResource Brush_Primary}"
                                 StrokeThickness="3"
                                 StrokeDashArray="20 10"
                                 Opacity="0.85"/>
                    </Border>
                    <TextBlock Text="加载名单..."
                               FontSize="{StaticResource FontSize_Body_M}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush_Text_Secondary}"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
