<Window x:Class="ClassroomToolkit.App.RollCallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClassroomToolkit.App.Converters"
        x:Name="NameWindow"
        Title="Classroom Toolkit"
        Height="420" Width="640"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="Manual"
        Topmost="True"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
    </Window.Resources>

    <!-- 1. 主容器：圆角+柔光阴影 -->
    <Border Background="{StaticResource Brush_Background}" 
            CornerRadius="20" 
            BorderBrush="{StaticResource Brush_Border}" 
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#8899AA" BlurRadius="35" ShadowDepth="10" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/> <!-- 标题栏加高，更舒适 -->
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 2. 顶部标题栏 -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="OnTitleBarDrag">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：模式切换与班级 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="20,0,0,0">
                    <!-- 模式切换按钮：使用次要按钮样式，更精致 -->
                    <Button Style="{StaticResource Style_SecondaryButton}" 
                            Click="OnToggleModeClick" 
                            Padding="12,6" 
                            Margin="0,0,12,0" 
                            Height="36">
                        <StackPanel Orientation="Horizontal">
                            <Path Fill="{StaticResource Brush_Primary}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Data" Value="{StaticResource Icon_RollCall}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRollCallMode}" Value="False">
                                                <Setter Property="Data" Value="{StaticResource Icon_Clock}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                            <TextBlock Text="{Binding ModeToggleLabel}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- 班级选择 -->
                    <ComboBox Width="130" Height="36" 
                              ItemsSource="{Binding AvailableClasses}" 
                              SelectedItem="{Binding ActiveClassName, Mode=OneWay}"
                              Visibility="{Binding IsRollCallMode, Converter={StaticResource BoolToVis}}" 
                              SelectionChanged="OnClassSelectionChanged"
                              VerticalContentAlignment="Center" FontSize="14"/>
                </StackPanel>

                <!-- 右侧：窗口控制 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,16,0">
                    <Button Style="{StaticResource Style_IconButton}" Click="OnSettingsClick" ToolTip="设置">
                        <Path Data="{StaticResource Icon_Settings}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="20" Height="20"/>
                    </Button>
                    
                    <Rectangle Width="1" Height="20" Fill="{StaticResource Brush_Border_Medium}" Margin="8,0" Opacity="0.6"/>
                    
                    <Button Style="{StaticResource Style_IconButton}" Click="OnMinimizeClick" ToolTip="最小化">
                        <Rectangle Width="14" Height="2" Fill="{StaticResource Brush_Text_Secondary}" RadiusX="1" RadiusY="1"/>
                    </Button>
                    <Button Style="{StaticResource Style_IconButton}" Click="OnCloseClick" ToolTip="关闭">
                        <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="14" Height="14"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 3. 内容展示区 -->
            <Grid Grid.Row="1" Margin="24,8">
                <!-- A. 点名视图 -->
                <Grid Visibility="{Binding IsRollCallMode, Converter={StaticResource BoolToVis}}">
                    <!-- 卡片容器 -->
                    <Border Background="{StaticResource Brush_Background_L2}" 
                            CornerRadius="24" 
                            BorderBrush="{StaticResource Brush_Border_Subtle}" 
                            BorderThickness="1" 
                            MouseLeftButtonUp="OnRollClick"
                            Cursor="Hand">
                        <Border.Effect>
                            <!-- 内部发光感 -->
                            <DropShadowEffect Color="{StaticResource Color_Primary_Main}" BlurRadius="30" ShadowDepth="0" Opacity="0.05"/>
                        </Border.Effect>
                        
                        <Grid Margin="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- 名字展示 -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding CurrentStudentId}" 
                                           Visibility="{Binding ShowId, Converter={StaticResource BoolToVis}}"
                                           FontSize="28" 
                                           Foreground="{StaticResource Brush_Text_Tertiary}" 
                                           FontWeight="Light" 
                                           HorizontalAlignment="Center" 
                                           Margin="0,0,0,12"/>
                                
                                <TextBlock x:Name="BigNameText" 
                                           Text="{Binding CurrentStudentName}" 
                                           FontSize="88" 
                                           FontWeight="Heavy" 
                                           Foreground="{StaticResource Brush_Text_Primary}" 
                                           HorizontalAlignment="Center" 
                                           TextAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="1" Opacity="0.1"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </StackPanel>
                            
                            <!-- 照片展示 (带边框和阴影) -->
                            <Border Grid.Column="1" Width="180" Height="240" Margin="30,0,0,0" 
                                    CornerRadius="16" 
                                    Background="White" 
                                    BorderThickness="4" 
                                    BorderBrush="White"
                                    Visibility="{Binding CurrentStudentPhotoPath, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                                <Border.Effect>
                                    <DropShadowEffect Color="#8899AA" BlurRadius="20" ShadowDepth="8" Opacity="0.2"/>
                                </Border.Effect>
                                <Border CornerRadius="12" ClipToBounds="True">
                                    <Image Source="{Binding CurrentStudentPhotoPath}" Stretch="UniformToFill"/>
                                </Border>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- B. 计时视图 -->
                <Grid Visibility="{Binding IsRollCallMode, Converter={StaticResource InverseBoolToVis}}">
                    <Border Background="{StaticResource Brush_Background_Dark}" CornerRadius="24">
                         <Border.Effect>
                            <DropShadowEffect Color="{StaticResource Color_Timer_Neon}" BlurRadius="50" ShadowDepth="0" Opacity="0.2"/>
                        </Border.Effect>
                        <Grid>
                            <Viewbox Margin="50">
                                <TextBlock Text="{Binding TimeDisplay}" 
                                           Foreground="{StaticResource Brush_Timer_Neon}" 
                                           FontFamily="Consolas, Courier New" 
                                           FontWeight="Bold">
                                     <TextBlock.Effect>
                                         <DropShadowEffect Color="{StaticResource Color_Timer_Neon}" BlurRadius="30" ShadowDepth="0" Opacity="0.8"/>
                                     </TextBlock.Effect>
                                </TextBlock>
                            </Viewbox>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- 4. 底部操作栏 -->
            <Grid Grid.Row="2" Margin="24,12,24,24">
                <!-- 点名操作 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Visibility="{Binding IsRollCallMode, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding GroupButtons}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Label}" 
                                        Style="{StaticResource Style_SecondaryButton}"
                                        Margin="6,0" Padding="16,10" MinWidth="80" 
                                        Click="OnGroupEntryClick">
                                    <!-- 触发器隐藏Reset按钮 (如果需要) -->
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource Style_SecondaryButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsReset}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <Rectangle Width="1" Height="28" Fill="{StaticResource Brush_Border}" Margin="12,0"/>
                    
                    <Button Style="{StaticResource Style_SecondaryButton}" Click="OnResetClick" Margin="6,0" Padding="16,10">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_Reset}" Fill="{StaticResource Brush_Text_Primary}" Width="16" Height="16" Margin="0,0,8,0" Stretch="Uniform"/>
                            <TextBlock Text="重置" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource Style_SecondaryButton}" Click="OnListClick" Margin="6,0" Padding="16,10">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_List}" Fill="{StaticResource Brush_Text_Primary}" Width="16" Height="16" Margin="0,0,8,0" Stretch="Uniform"/>
                            <TextBlock Text="名单" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 计时操作 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Visibility="{Binding IsRollCallMode, Converter={StaticResource InverseBoolToVis}}">
                    <Button Style="{StaticResource Style_SecondaryButton}" Margin="8,0" Click="OnTimerModeClick" Padding="20,10" MinWidth="100">
                         <TextBlock Text="{Binding TimerModeLabel}" FontWeight="Bold"/>
                    </Button>
                    
                    <!-- 播放/暂停按钮：主色调 -->
                    <Button Style="{StaticResource Style_PrimaryButton}" Margin="8,0" Width="90" Height="50" Click="OnTimerStartPauseClick">
                        <Path Fill="White" Width="24" Height="24" Stretch="Uniform">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Data" Value="{StaticResource Icon_Play}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TimerRunning}" Value="True">
                                            <Setter Property="Data" Value="{StaticResource Icon_Pause}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Button>
                    
                    <Button Style="{StaticResource Style_SecondaryButton}" Margin="8,0" Click="OnTimerResetClick" Padding="20,10" MinWidth="100">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_Reset}" Fill="{StaticResource Brush_Text_Primary}" Width="16" Height="16" Margin="0,0,8,0" Stretch="Uniform"/>
                            <TextBlock Text="重置" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource Style_SecondaryButton}" Margin="8,0" Click="OnTimerSetClick" Padding="20,10" MinWidth="100">
                        <TextBlock Text="设定" FontWeight="Bold"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>