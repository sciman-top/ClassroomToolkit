<Window x:Class="ClassroomToolkit.App.RollCallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClassroomToolkit.App.Converters"
        x:Name="NameWindow"
        Title="Classroom Toolkit"
        Height="400" Width="600"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="Manual"
        Topmost="True"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
        
        <!-- 动画资源 -->
        <Storyboard x:Key="Anim_PopIn">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0.8"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="1.0">
                     <EasingDoubleKeyFrame.EasingFunction>
                        <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="5"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0.8"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="1.0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="5"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>

    <Border Background="White" CornerRadius="8" BorderBrush="#DDDDDD" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.15"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/> <!-- Toolbar -->
                <RowDefinition Height="*"/>  <!-- Main Content -->
                <RowDefinition Height="Auto"/> <!-- Bottom Controls (Groups/TimerControls) -->
            </Grid.RowDefinitions>

            <!-- 1. 顶部工具栏 -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="OnTitleBarDrag">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Left: Controls -->
                    <ColumnDefinition Width="*"/>    <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/> <!-- Right: System -->
                </Grid.ColumnDefinitions>

                <!-- 左侧功能区 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0">
                    <!-- 模式切换 -->
                    <Button Style="{StaticResource Style_SecondaryButton}" 
                            Click="OnToggleModeClick" Padding="12,6" Margin="0,0,8,0" MinWidth="120">
                        <StackPanel Orientation="Horizontal">
                            <Path Fill="#555" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Data" Value="{StaticResource Icon_RollCall}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRollCallMode}" Value="False">
                                                <Setter Property="Data" Value="{StaticResource Icon_Clock}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                            <TextBlock Text="{Binding ModeToggleLabel}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <!-- 班级选择 (仅点名模式) -->
                    <ComboBox Width="100" Height="32"
                              ItemsSource="{Binding AvailableClasses}"
                              SelectedItem="{Binding ActiveClassName, Mode=OneWay}"
                              Visibility="{Binding IsRollCallMode, Converter={StaticResource BoolToVis}}"
                              SelectionChanged="OnClassSelectionChanged"
                              VerticalContentAlignment="Center"
                              ToolTip="切换班级"/>
                </StackPanel>

                <!-- 右侧：系统按钮 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,12,0">
                    <Button Style="{StaticResource Style_IconButton}" Click="OnSettingsClick" ToolTip="设置">
                        <Path Data="{StaticResource Icon_Settings}" Fill="{StaticResource Brush_Foreground}" Stretch="Uniform" Width="16" Height="16"/>
                    </Button>
                    
                    <Rectangle Width="1" Height="20" Fill="#EEE" Margin="6,0"/>
                    
                    <Button Style="{StaticResource Style_IconButton}" Click="OnMinimizeClick" ToolTip="最小化">
                        <Rectangle Width="12" Height="2" Fill="{StaticResource Brush_Foreground}"/>
                    </Button>
                    <Button Style="{StaticResource Style_IconButton}" Click="OnCloseClick" ToolTip="关闭">
                        <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Foreground}" Stretch="Uniform" Width="10" Height="10"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 2. 内容区 -->
            
            <!-- A. 点名展示 -->
            <Grid Grid.Row="1" Visibility="{Binding IsRollCallMode, Converter={StaticResource BoolToVis}}">
                <!-- 优化：VerticalAlignment="Center" 让卡片高度根据文字自适应，不再强制拉伸 -->
                <Border Background="White" CornerRadius="12" 
                        VerticalAlignment="Center"
                        Margin="40,10"
                        MouseLeftButtonUp="OnRollClick">
                    <!-- 卡片阴影 -->
                    <Border.Effect>
                        <DropShadowEffect Color="#007ACC" BlurRadius="30" ShadowDepth="0" Opacity="0.15"/>
                    </Border.Effect>
                    
                    <!-- 核心名字展示 -->
                    <Grid x:Name="NameCardBody" Margin="40,20"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          SnapsToDevicePixels="True" UseLayoutRounding="True"
                          SizeChanged="OnNameCardSizeChanged">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    x:Name="NameContainer" RenderTransformOrigin="0.5,0.5">
                            <StackPanel.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </StackPanel.RenderTransform>

                            <!-- 学号 (可选显示) -->
                            <TextBlock x:Name="IdText" Text="{Binding CurrentStudentId}" 
                                       Visibility="{Binding ShowId, Converter={StaticResource BoolToVis}}"
                                       Foreground="#888" Margin="0,0,20,0" FontWeight="Light"
                                       TextOptions.TextFormattingMode="Display"
                                       TextOptions.TextRenderingMode="ClearType"/>
                            
                            <!-- 姓名 -->
                            <TextBlock x:Name="BigNameText" Text="{Binding CurrentStudentName}" 
                                       Visibility="{Binding ShowName, Converter={StaticResource BoolToVis}}"
                                       Foreground="#333" FontWeight="Bold"
                                       TextOptions.TextFormattingMode="Display"
                                       TextOptions.TextRenderingMode="ClearType">
                                <!-- 这里的 Effect 会在代码中动态控制 (Blur) -->
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- B. 计时展示 -->
            <Grid Grid.Row="1" Visibility="{Binding IsRollCallMode, Converter={StaticResource InverseBoolToVis}}" Margin="20,0,20,10">
                <Border Background="#2B2B2B" CornerRadius="12">
                     <Viewbox Stretch="Uniform" Margin="20">
                        <TextBlock Text="{Binding TimeDisplay}" 
                                   Foreground="#00FF99" 
                                   FontFamily="Consolas" 
                                   FontWeight="Bold">
                             <TextBlock.Effect>
                                 <DropShadowEffect Color="#00FF99" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                             </TextBlock.Effect>
                        </TextBlock>
                    </Viewbox>
                </Border>
            </Grid>

            <!-- 3. 底部控件 -->
            <Grid Grid.Row="2" Margin="0,0,0,16">
                <!-- 点名模式下的底部栏 -->
                <WrapPanel Visibility="{Binding IsRollCallMode, Converter={StaticResource BoolToVis}}"
                           HorizontalAlignment="Center" VerticalAlignment="Center">
                    
                    <!-- 分组按钮列表 -->
                    <ItemsControl ItemsSource="{Binding GroupButtons}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Label}" 
                                        Margin="4" 
                                        Click="OnGroupEntryClick">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource Style_SecondaryButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsReset}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 重置按钮 (改为与分组按钮同风格) -->
                    <Button Style="{StaticResource Style_SecondaryButton}" Click="OnResetClick" ToolTip="重置当前分组" Margin="4" Padding="10,6">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_Reset}" Fill="#333" Stretch="Uniform" Width="14" Height="14" Margin="0,0,6,0"/>
                            <TextBlock Text="重置"/>
                        </StackPanel>
                    </Button>

                    <!-- 名单管理按钮 (改为与分组按钮同风格) -->
                    <Button Style="{StaticResource Style_SecondaryButton}" Click="OnListClick" ToolTip="查看名单" Margin="4" Padding="10,6">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_List}" Fill="#333" Stretch="Uniform" Width="14" Height="14" Margin="0,0,6,0"/>
                            <TextBlock Text="名单"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>

                <!-- 计时控制 (计时模式) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" 
                            Visibility="{Binding IsRollCallMode, Converter={StaticResource InverseBoolToVis}}">
                    
                    <Button Style="{StaticResource Style_SecondaryButton}" Margin="6" Click="OnTimerModeClick">
                         <TextBlock Text="{Binding TimerModeLabel}"/>
                    </Button>
                    
                    <Button Style="{StaticResource Style_PrimaryButton}" Margin="6" Width="64" Height="48" Click="OnTimerStartPauseClick">
                        <Path Fill="White" Width="16" Height="16" Stretch="Uniform">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Data" Value="{StaticResource Icon_Play}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TimerRunning}" Value="True">
                                            <Setter Property="Data" Value="{StaticResource Icon_Pause}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Button>
                    
                    <Button Style="{StaticResource Style_SecondaryButton}" Margin="6" Click="OnTimerResetClick" ToolTip="重置">
                        <Path Data="{StaticResource Icon_Reset}" Fill="#333" Width="16" Height="16" Stretch="Uniform"/>
                    </Button>

                    <Button Style="{StaticResource Style_SecondaryButton}" Margin="6" Click="OnTimerSetClick" Content="设定"/>
                </StackPanel>
            </Grid>

        </Grid>
    </Border>
</Window>
