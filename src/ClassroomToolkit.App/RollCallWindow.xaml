<Window x:Class="ClassroomToolkit.App.RollCallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClassroomToolkit.App.Converters"
        x:Name="NameWindow"
        Title="Classroom Toolkit"
        Height="420" Width="640"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="Manual"
        Topmost="True"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
    </Window.Resources>

    <!-- 1. 主容器：圆角+深邃阴影 -->
    <Border Background="{StaticResource Brush_Background_L2}"
            CornerRadius="28"
            BorderBrush="{StaticResource Brush_White_Translucent}"
            BorderThickness="1">
        <Border.Effect>
            <!-- 强烈的悬浮阴影 -->
            <DropShadowEffect Color="#455A64" BlurRadius="50" ShadowDepth="12" Opacity="0.25"/>
        </Border.Effect>

        <Grid PreviewMouseLeftButtonDown="OnBackgroundDrag">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 2. 顶部标题栏 -->
            <Grid Grid.Row="0" MouseLeftButtonDown="OnTitleBarDrag">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 透明拖动层 -->
                <Rectangle Fill="Transparent" Grid.ColumnSpan="3"/>

                <!-- 左侧：模式切换与班级 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="24,0,0,0">
                    <!-- 模式切换按钮 (胶囊型) -->
                    <Button Style="{StaticResource Style_SecondaryButton}"
                            Click="OnToggleModeClick"
                            Padding="12,6"
                            Margin="0,0,12,0"
                            Height="36"
                            Background="White"
                            BorderThickness="0">
                        <Button.Effect>
                            <DropShadowEffect Color="#B0BEC5" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                        </Button.Effect>
                        <StackPanel Orientation="Horizontal">
                            <Path Fill="{StaticResource Brush_Primary}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Data" Value="{StaticResource Icon_RollCall}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRollCallMode}" Value="False">
                                                <Setter Property="Data" Value="{StaticResource Icon_Clock}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                            <TextBlock Text="{Binding ModeToggleLabel}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" Foreground="{StaticResource Brush_Text_Primary}"/>
                        </StackPanel>
                    </Button>

                    <!-- 班级选择 -->
                    <ComboBox x:Name="ClassCombo" Width="110" Height="36"
                              ItemsSource="{Binding AvailableClasses}"
                              Visibility="{Binding IsRollCallMode, Converter={StaticResource BoolToVis}}"
                              SelectionChanged="OnClassSelectionChanged"
                              DropDownOpened="OnClassDropDownOpened"
                              DropDownClosed="OnClassDropDownClosed"
                              VerticalContentAlignment="Center" FontSize="13"
                              Style="{StaticResource {x:Type ComboBox}}"/>
                </StackPanel>

                <!-- 右侧：窗口控制 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,18,0">
                    <Button Style="{StaticResource Style_IconButton}" Click="OnSettingsClick" ToolTip="设置" Width="36" Height="36">
                        <Path Data="{StaticResource Icon_Settings}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="20" Height="20"/>
                    </Button>
                    
                    <Button Style="{StaticResource Style_IconButton}" Click="OnCloseClick" ToolTip="关闭" Width="36" Height="36" Margin="4,0,0,0">
                        <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="14" Height="14"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 3. 内容展示区 -->
            <Grid Grid.Row="1" Margin="24,8">
                <!-- A. 点名视图 -->
                <Grid Visibility="{Binding IsRollCallMode, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：名字卡片 (重点展示) -->
                    <Border x:Name="RollNameCard" Grid.Column="0" 
                            Background="{StaticResource Gradient_RollCall_Name}"
                            CornerRadius="24"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            MouseLeftButtonUp="OnRollClick"
                            Cursor="Hand"
                            Margin="0,0,16,0">
                        <Border.Effect>
                            <!-- 柔和的漫反射阴影 -->
                            <DropShadowEffect Color="{StaticResource Color_Primary_Main}" BlurRadius="40" ShadowDepth="0" Opacity="0.12"/>
                        </Border.Effect>

                        <!-- 名字展示 -->
                        <Viewbox Stretch="Uniform" Margin="10">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <!-- 主体字 (姓名) -->
                                <TextBlock x:Name="BigNameText"
                                           Text="{Binding CurrentStudentName}"
                                           Visibility="{Binding ShowName, Converter={StaticResource BoolToVis}}"
                                           FontSize="100"
                                           FontWeight="Heavy"
                                           Foreground="{StaticResource Brush_Text_Primary}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#B0BEC5" BlurRadius="2" ShadowDepth="2" Opacity="0.3"/>
                                    </TextBlock.Effect>
                                </TextBlock>

                                <!-- 学号 -->
                                <TextBlock Text="{Binding CurrentStudentId}"
                                           Visibility="{Binding ShowId, Converter={StaticResource BoolToVis}}"
                                           FontSize="46"
                                           Foreground="{StaticResource Brush_Text_Primary}"
                                           FontWeight="Bold"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Margin="0,-5,0,0"/> <!-- 微量负边距进一步拉近距离 -->
                            </StackPanel>
                        </Viewbox>
                    </Border>

                    <!-- 右侧：照片展示 -->
                    <Grid Grid.Column="1" Width="200" Height="260"
                          VerticalAlignment="Center"
                          Visibility="{Binding CurrentStudentPhotoPath, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                        <!-- 照片容器 -->
                        <Border CornerRadius="18" ClipToBounds="True" Background="White">
                            <Border.Effect>
                                <DropShadowEffect Color="#263238" BlurRadius="20" ShadowDepth="5" Opacity="0.2"/>
                            </Border.Effect>
                            <Image Source="{Binding CurrentStudentPhotoPath}" Stretch="UniformToFill"/>
                        </Border>
                        
                        <!-- 姓名覆盖 (底部渐变遮罩) -->
                        <Border VerticalAlignment="Bottom" Height="60" CornerRadius="0,0,18,18">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="#A6000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="{Binding CurrentStudentName}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,8,0,0"/>
                        </Border>
                    </Grid>
                </Grid>

                <!-- B. 计时视图 -->
                <Grid Visibility="{Binding IsRollCallMode, Converter={StaticResource InverseBoolToVis}}">
                    <Border x:Name="TimerCard" 
                            Background="{StaticResource Brush_Background_Dark}" 
                            CornerRadius="24" 
                            BorderBrush="{StaticResource Brush_Border_Subtle}" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect Color="{StaticResource Color_Timer_Neon}" BlurRadius="60" ShadowDepth="0" Opacity="0.25"/>
                        </Border.Effect>
                        <Grid>
                            <!-- 装饰线条 -->
                            <Border BorderBrush="{StaticResource Brush_Timer_Neon}" BorderThickness="1" Margin="10" CornerRadius="16" Opacity="0.1"/>
                            
                            <Viewbox Margin="15" Stretch="Uniform">
                                <TextBlock Text="{Binding TimeDisplay}"
                                           Foreground="{StaticResource Brush_Timer_Neon}"
                                           FontFamily="Consolas, Courier New"
                                           FontWeight="Bold">
                                     <TextBlock.Effect>
                                         <DropShadowEffect Color="{StaticResource Color_Timer_Neon}" BlurRadius="25" ShadowDepth="0" Opacity="0.8"/>
                                     </TextBlock.Effect>
                                </TextBlock>
                            </Viewbox>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- 4. 底部操作栏 -->
            <Border Grid.Row="2" Background="White" CornerRadius="18" Margin="24,0,24,20" Padding="8,6">
                <Border.Effect>
                    <DropShadowEffect Color="#CFD8DC" BlurRadius="15" ShadowDepth="5" Opacity="0.2"/>
                </Border.Effect>

                <Grid>
                    <!-- 点名操作 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Visibility="{Binding IsRollCallMode, Converter={StaticResource BoolToVis}}">
                        <ItemsControl ItemsSource="{Binding GroupButtons}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Label}"
                                            Margin="4,0" Padding="12,6" MinWidth="50"
                                            Click="OnGroupEntryClick">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource Style_SecondaryButton}">
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsReset}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource Gradient_Primary}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Rectangle Width="1" Height="20" Fill="{StaticResource Brush_Border}" Margin="12,0" Opacity="0.6"/>

                        <Button Style="{StaticResource Style_SecondaryButton}" Click="OnResetClick" Margin="4,0" Padding="12,6">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource Icon_Reset}" Fill="{StaticResource Brush_Text_Secondary}" Width="14" Height="14" Margin="0,0,6,0" Stretch="Uniform"/>
                                <TextBlock Text="重置" FontWeight="SemiBold" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource Style_SecondaryButton}" Click="OnListClick" Margin="4,0" Padding="12,6">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource Icon_List}" Fill="{StaticResource Brush_Text_Secondary}" Width="14" Height="14" Margin="0,0,6,0" Stretch="Uniform"/>
                                <TextBlock Text="名单" FontWeight="SemiBold" FontSize="13"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- 计时操作 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Visibility="{Binding IsRollCallMode, Converter={StaticResource InverseBoolToVis}}">
                        <Button Style="{StaticResource Style_SecondaryButton}" Margin="4,0" Click="OnTimerModeClick" Padding="12,6" MinWidth="80">
                             <TextBlock Text="{Binding TimerModeLabel}" FontWeight="SemiBold" FontSize="13"/>
                        </Button>

                        <!-- 播放/暂停按钮：主色调 -->
                        <Button Style="{StaticResource Style_PrimaryButton}" Margin="12,0" Width="64" Height="40" Click="OnTimerStartPauseClick">
                            <Path Fill="White" Width="20" Height="20" Stretch="Uniform">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Data" Value="{StaticResource Icon_Play}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TimerRunning}" Value="True">
                                                <Setter Property="Data" Value="{StaticResource Icon_Pause}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                        </Button>

                        <Button Style="{StaticResource Style_SecondaryButton}" Margin="4,0" Click="OnTimerResetClick" Padding="12,6" MinWidth="80">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource Icon_Reset}" Fill="{StaticResource Brush_Text_Secondary}" Width="14" Height="14" Margin="0,0,6,0" Stretch="Uniform"/>
                                <TextBlock Text="重置" FontWeight="SemiBold" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource Style_SecondaryButton}" Margin="4,0" Click="OnTimerSetClick" Padding="12,6" MinWidth="80">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource Icon_Settings}" Fill="{StaticResource Brush_Text_Secondary}" Width="14" Height="14" Margin="0,0,6,0" Stretch="Uniform"/>
                                <TextBlock Text="设定" FontWeight="SemiBold" FontSize="13"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
