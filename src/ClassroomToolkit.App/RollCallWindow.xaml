<Window x:Class="ClassroomToolkit.App.RollCallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClassroomToolkit.App.Converters"
        x:Name="NameWindow"
        Title="Classroom Toolkit"
        Height="420" Width="640"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="Manual"
        Topmost="True"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
    </Window.Resources>

    <!-- 1. 主容器：圆角+柔光阴影 -->
    <Border Background="{StaticResource Brush_Background}"
            CornerRadius="24"
            BorderBrush="{StaticResource Brush_Border_Subtle}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#4A90E2" BlurRadius="40" ShadowDepth="8" Opacity="0.15"/>
        </Border.Effect>

        <Grid PreviewMouseLeftButtonDown="OnBackgroundDrag">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 2. 顶部标题栏 - 渐变装饰 -->
            <Grid Grid.Row="0" MouseLeftButtonDown="OnTitleBarDrag">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 透明拖动区域 - 覆盖整个标题栏 -->
                <Rectangle Fill="Transparent" Grid.ColumnSpan="3"/>

                <!-- 左侧：模式切换与班级 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="20,0,0,0">
                    <!-- 模式切换按钮 -->
                    <Button Style="{StaticResource Style_SecondaryButton}"
                            Click="OnToggleModeClick"
                            Padding="10,5"
                            Margin="0,0,10,0"
                            Height="32">
                        <StackPanel Orientation="Horizontal">
                            <Path Fill="{StaticResource Brush_Primary}" Width="15" Height="15" Stretch="Uniform" Margin="0,0,6,0">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Data" Value="{StaticResource Icon_RollCall}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRollCallMode}" Value="False">
                                                <Setter Property="Data" Value="{StaticResource Icon_Clock}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                            <TextBlock Text="{Binding ModeToggleLabel}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- 班级选择 -->
                    <ComboBox Width="95" Height="32"
                              ItemsSource="{Binding AvailableClasses}"
                              SelectedItem="{Binding ActiveClassName, Mode=OneWay}"
                              Visibility="{Binding IsRollCallMode, Converter={StaticResource BoolToVis}}"
                              SelectionChanged="OnClassSelectionChanged"
                              VerticalContentAlignment="Center" FontSize="12"/>
                </StackPanel>

                <!-- 右侧：窗口控制 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,14,0">
                    <Button Style="{StaticResource Style_IconButton}" Click="OnSettingsClick" ToolTip="设置" Width="34" Height="34">
                        <Path Data="{StaticResource Icon_Settings}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="18" Height="18"/>
                    </Button>

                    <Rectangle Width="1" Height="18" Fill="{StaticResource Brush_Border_Medium}" Margin="6,0" Opacity="0.5"/>
                    
                    <Button Style="{StaticResource Style_IconButton}" Click="OnCloseClick" ToolTip="关闭" Width="34" Height="34">
                        <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="12" Height="12"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 3. 内容展示区 -->
            <Grid Grid.Row="1" Margin="20,6">
                <!-- A. 点名视图 -->
                <Grid Visibility="{Binding IsRollCallMode, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：名字卡片 -->
                    <Border x:Name="RollNameCard" Grid.Column="0" Background="{StaticResource Gradient_RollCall_Name}"
                            CornerRadius="24"
                            BorderBrush="{StaticResource Brush_Border_Subtle}"
                            BorderThickness="1"
                            MouseLeftButtonUp="OnRollClick"
                            Cursor="Hand"
                            Margin="0,0,14,0">
                        <Border.Effect>
                            <DropShadowEffect Color="#0EA5E9" BlurRadius="30" ShadowDepth="0" Opacity="0.15"/>
                        </Border.Effect>

                        <!-- 名字展示 - 充满空间 -->
                        <Viewbox Stretch="Fill" Margin="6">
                            <Grid>
                                <TextBlock x:Name="BigNameText"
                                           Text="{Binding CurrentStudentName}"
                                           FontSize="100"
                                           FontWeight="Heavy"
                                           Foreground="{StaticResource Brush_Text_Primary}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="20">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#0284C7" BlurRadius="5" ShadowDepth="2" Opacity="0.2"/>
                                    </TextBlock.Effect>
                                </TextBlock>

                                <TextBlock Text="{Binding CurrentStudentId}"
                                           Visibility="{Binding ShowId, Converter={StaticResource BoolToVis}}"
                                           FontSize="30"
                                           Foreground="{StaticResource Brush_Text_Primary}"
                                           FontWeight="Medium"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Bottom"
                                           Margin="0,0,0,20"
                                           Opacity="0.7"/>
                            </Grid>
                        </Viewbox>
                    </Border>

                    <!-- 右侧：照片展示（无背景，姓名在照片内） -->
                    <Grid Grid.Column="1" Width="195" Height="255"
                          VerticalAlignment="Center"
                          Visibility="{Binding CurrentStudentPhotoPath, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                        <!-- 照片 -->
                        <Border CornerRadius="14" ClipToBounds="True">
                            <Image Source="{Binding CurrentStudentPhotoPath}" Stretch="UniformToFill"/>
                        </Border>
                        
                        <!-- 姓名覆盖在照片顶部 -->
                        <TextBlock Text="{Binding CurrentStudentName}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Top"
                                   Margin="0,12,0,0">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="4" ShadowDepth="2" Opacity="0.6"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Grid>
                </Grid>

                <!-- B. 计时视图 -->
                <Grid Visibility="{Binding IsRollCallMode, Converter={StaticResource InverseBoolToVis}}">
                    <Border x:Name="TimerCard" Background="{StaticResource Brush_Background_Dark}" CornerRadius="24" BorderBrush="Transparent">
                        <Border.Effect>
                            <DropShadowEffect Color="{StaticResource Color_Timer_Neon}" BlurRadius="50" ShadowDepth="0" Opacity="0.2"/>
                        </Border.Effect>
                        <Grid>
                            <Viewbox Margin="45">
                                <TextBlock Text="{Binding TimeDisplay}"
                                           Foreground="{StaticResource Brush_Timer_Neon}"
                                           FontFamily="Consolas, Courier New"
                                           FontWeight="Bold">
                                     <TextBlock.Effect>
                                         <DropShadowEffect Color="{StaticResource Color_Timer_Neon}" BlurRadius="30" ShadowDepth="0" Opacity="0.8"/>
                                     </TextBlock.Effect>
                                </TextBlock>
                            </Viewbox>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- 4. 底部操作栏 - 添加装饰背景 -->
            <Border Grid.Row="2" Background="{StaticResource Brush_Background_L2}">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="-2" Opacity="0.03"/>
                </Border.Effect>

                <Grid Margin="16,8,16,18">
                    <!-- 点名操作 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Visibility="{Binding IsRollCallMode, Converter={StaticResource BoolToVis}}">
                        <ItemsControl ItemsSource="{Binding GroupButtons}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Label}"
                                            Margin="2,0" Padding="8,4" MinWidth="50"
                                            Click="OnGroupEntryClick">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource Style_SecondaryButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsReset}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Rectangle Width="1" Height="24" Fill="{StaticResource Brush_Border}" Margin="6,0" Opacity="0.5"/>

                        <Button Style="{StaticResource Style_SecondaryButton}" Click="OnResetClick" Margin="2,0" Padding="8,4" MinWidth="56">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource Icon_Reset}" Fill="{StaticResource Brush_Text_Primary}" Width="13" Height="13" Margin="0,0,3,0" Stretch="Uniform"/>
                                <TextBlock Text="重置" FontWeight="SemiBold" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource Style_SecondaryButton}" Click="OnListClick" Margin="2,0" Padding="8,4" MinWidth="56">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource Icon_List}" Fill="{StaticResource Brush_Text_Primary}" Width="13" Height="13" Margin="0,0,3,0" Stretch="Uniform"/>
                                <TextBlock Text="名单" FontWeight="SemiBold" FontSize="13"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- 计时操作 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Visibility="{Binding IsRollCallMode, Converter={StaticResource InverseBoolToVis}}">
                        <Button Style="{StaticResource Style_SecondaryButton}" Margin="2,0" Click="OnTimerModeClick" Padding="8,5" MinWidth="70">
                             <TextBlock Text="{Binding TimerModeLabel}" FontWeight="SemiBold" FontSize="13"/>
                        </Button>

                        <!-- 播放/暂停按钮：主色调 -->
                        <Button Style="{StaticResource Style_PrimaryButton}" Margin="3,0" Width="64" Height="38" Click="OnTimerStartPauseClick">
                            <Path Fill="White" Width="18" Height="18" Stretch="Uniform">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Data" Value="{StaticResource Icon_Play}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TimerRunning}" Value="True">
                                                <Setter Property="Data" Value="{StaticResource Icon_Pause}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                        </Button>

                        <Button Style="{StaticResource Style_SecondaryButton}" Margin="2,0" Click="OnTimerResetClick" Padding="8,5" MinWidth="70">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource Icon_Reset}" Fill="{StaticResource Brush_Text_Primary}" Width="13" Height="13" Margin="0,0,3,0" Stretch="Uniform"/>
                                <TextBlock Text="重置" FontWeight="SemiBold" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource Style_SecondaryButton}" Margin="2,0" Click="OnTimerSetClick" Padding="8,5" MinWidth="70">
                            <TextBlock Text="设定" FontWeight="SemiBold" FontSize="13"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
