<Window x:Class="ClassroomToolkit.App.RollCallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClassroomToolkit.App.Converters"
        x:Name="NameWindow"
        Title="Classroom Toolkit"
        Height="400" Width="600"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="Manual"
        Topmost="True"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
        
        <!-- 动画资源 -->
        <Storyboard x:Key="Anim_PopIn">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0.8"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="1.0">
                     <EasingDoubleKeyFrame.EasingFunction>
                        <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="5"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0.8"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="1.1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="1.0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="5"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>

    <Border Background="White" CornerRadius="12" BorderBrush="{StaticResource Brush_Border}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="25" ShadowDepth="6" Opacity="0.1"/>
        </Border.Effect>

        <Grid>
            <!-- 顶部品牌色装饰条 -->
            <Border Height="3" VerticalAlignment="Top" CornerRadius="3,3,0,0" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="{StaticResource Color_Primary_Light}" Offset="0"/>
                        <GradientStop Color="{StaticResource Color_Primary_Main}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Grid Margin="0,3,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="56"/> <!-- Toolbar -->
                    <RowDefinition Height="*"/>  <!-- Main Content -->
                    <RowDefinition Height="Auto"/> <!-- Bottom Controls (Groups/TimerControls) -->
                </Grid.RowDefinitions>

                <!-- 1. 顶部工具栏 - 现代升级版 -->
                <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="OnTitleBarDrag">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/> <!-- Left: Controls -->
                        <ColumnDefinition Width="*"/>    <!-- Spacer -->
                        <ColumnDefinition Width="Auto"/> <!-- Right: System -->
                    </Grid.ColumnDefinitions>

                    <!-- 左侧功能区 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0,0,0">
                        <!-- 模式切换 -->
                        <Button Style="{StaticResource Style_SecondaryButton}"
                                Click="OnToggleModeClick" Padding="14,8" Margin="0,0,10,0" MinWidth="120">
                            <StackPanel Orientation="Horizontal">
                                <Path Fill="{StaticResource Brush_Foreground}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,8,0">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Data" Value="{StaticResource Icon_RollCall}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRollCallMode}" Value="False">
                                                    <Setter Property="Data" Value="{StaticResource Icon_Clock}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <TextBlock Text="{Binding ModeToggleLabel}" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                        <!-- 班级选择 (仅点名模式) -->
                        <ComboBox Width="110" Height="36"
                                  ItemsSource="{Binding AvailableClasses}"
                                  SelectedItem="{Binding ActiveClassName, Mode=OneWay}"
                                  Visibility="{Binding IsRollCallMode, Converter={StaticResource BoolToVis}}"
                                  SelectionChanged="OnClassSelectionChanged"
                                  VerticalContentAlignment="Center"
                                  ToolTip="切换班级"/>
                    </StackPanel>

                    <!-- 右侧：系统按钮 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,14,0">
                        <Button Style="{StaticResource Style_IconButton}" Click="OnSettingsClick" ToolTip="设置">
                            <Path Data="{StaticResource Icon_Settings}" Fill="{StaticResource Brush_Foreground}" Stretch="Uniform" Width="18" Height="18"/>
                        </Button>

                        <Rectangle Width="1" Height="22" Fill="{StaticResource Brush_Border}" Margin="8,0"/>

                        <Button Style="{StaticResource Style_IconButton}" Click="OnMinimizeClick" ToolTip="最小化">
                            <Rectangle Width="14" Height="2.5" Fill="{StaticResource Brush_Foreground}"/>
                        </Button>
                        <Button Style="{StaticResource Style_IconButton}" Click="OnCloseClick" ToolTip="关闭">
                            <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Foreground}" Stretch="Uniform" Width="12" Height="12"/>
                        </Button>
                    </StackPanel>
                </Grid>

            <!-- 2. 内容区 -->

            <!-- A. 点名展示 - 现代升级版 -->
            <Grid Grid.Row="1" Visibility="{Binding IsRollCallMode, Converter={StaticResource BoolToVis}}">
                <Border Background="{StaticResource Brush_Background_L2}" CornerRadius="16"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch"
                        Margin="40,16"
                        BorderBrush="{StaticResource Brush_Border}"
                        BorderThickness="1"
                        MouseLeftButtonUp="OnRollClick">
                    <!-- 卡片阴影 - 品牌色光晕 -->
                    <Border.Effect>
                        <DropShadowEffect Color="{StaticResource Color_Primary_Main}" BlurRadius="35" ShadowDepth="0" Opacity="0.18"/>
                    </Border.Effect>

                    <!-- 核心名字展示 -->
                    <Grid x:Name="NameCardBody" Margin="48,24"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          SnapsToDevicePixels="True" UseLayoutRounding="True"
                          SizeChanged="OnNameCardSizeChanged">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    x:Name="NameContainer" RenderTransformOrigin="0.5,0.5">
                            <StackPanel.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </StackPanel.RenderTransform>

                            <!-- 学号 (可选显示) -->
                            <TextBlock x:Name="IdText" Text="{Binding CurrentStudentId}"
                                       Visibility="{Binding ShowId, Converter={StaticResource BoolToVis}}"
                                       Foreground="{StaticResource Brush_Text_Secondary}" Margin="0,0,24,0" FontWeight="Light"
                                       TextOptions.TextFormattingMode="Display"
                                       TextOptions.TextRenderingMode="ClearType"/>

                            <!-- 姓名 -->
                            <TextBlock x:Name="BigNameText" Text="{Binding CurrentStudentName}"
                                       Visibility="{Binding ShowName, Converter={StaticResource BoolToVis}}"
                                       Foreground="{StaticResource Brush_Foreground}" FontWeight="Bold"
                                       TextAlignment="Center"
                                       TextTrimming="None"
                                       TextWrapping="NoWrap"
                                       TextOptions.TextFormattingMode="Display"
                                       TextOptions.TextRenderingMode="ClearType">
                                <!-- 这里的 Effect 会在代码中动态控制 (Blur) -->
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- B. 计时展示 - 现代升级版 -->
            <Grid Grid.Row="1" Visibility="{Binding IsRollCallMode, Converter={StaticResource InverseBoolToVis}}" Margin="24,0,24,16">
                <Border Background="#1A1F2C" CornerRadius="16">
                    <Border.Effect>
                        <DropShadowEffect Color="#00C896" BlurRadius="25" ShadowDepth="0" Opacity="0.2"/>
                    </Border.Effect>
                     <Viewbox Stretch="Uniform" Margin="24">
                        <TextBlock Text="{Binding TimeDisplay}"
                                   Foreground="#00FFAA"
                                   FontFamily="Consolas"
                                   FontWeight="Bold">
                             <TextBlock.Effect>
                                 <DropShadowEffect Color="#00FFAA" BlurRadius="25" ShadowDepth="0" Opacity="0.6"/>
                             </TextBlock.Effect>
                        </TextBlock>
                    </Viewbox>
                </Border>
            </Grid>

            <!-- 3. 底部控件 - 现代升级版 -->
            <Grid Grid.Row="2" Margin="0,0,0,20">
                <!-- 点名模式下的底部栏 - 现代升级版 -->
                <WrapPanel Visibility="{Binding IsRollCallMode, Converter={StaticResource BoolToVis}}"
                           HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!-- 分组按钮列表 -->
                    <ItemsControl ItemsSource="{Binding GroupButtons}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Label}"
                                        Margin="6"
                                        Padding="16,10"
                                        MinWidth="70"
                                        Click="OnGroupEntryClick">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource Style_SecondaryButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsReset}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 重置按钮 -->
                    <Button Style="{StaticResource Style_SecondaryButton}" Click="OnResetClick" ToolTip="重置当前分组" Margin="6" Padding="16,10" MinWidth="75">
                        <StackPanel Orientation="Horizontal" Margin="6,0">
                            <Path Data="{StaticResource Icon_Reset}" Fill="{StaticResource Brush_Foreground}" Stretch="Uniform" Width="18" Height="18" Margin="0,0,6,0"/>
                            <TextBlock Text="重置" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>

                    <!-- 名单管理按钮 -->
                    <Button Style="{StaticResource Style_SecondaryButton}" Click="OnListClick" ToolTip="查看名单" Margin="6" Padding="16,10" MinWidth="75">
                        <StackPanel Orientation="Horizontal" Margin="6,0">
                            <Path Data="{StaticResource Icon_List}" Fill="{StaticResource Brush_Foreground}" Stretch="Uniform" Width="18" Height="18" Margin="0,0,6,0"/>
                            <TextBlock Text="名单" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>

                <!-- 计时控制 (计时模式) - 现代升级版 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            Visibility="{Binding IsRollCallMode, Converter={StaticResource InverseBoolToVis}}">

                    <Button Style="{StaticResource Style_SecondaryButton}" Margin="8" Click="OnTimerModeClick" Padding="18,10" MinWidth="80">
                         <TextBlock Text="{Binding TimerModeLabel}" FontWeight="Medium"/>
                    </Button>

                    <Button Style="{StaticResource Style_PrimaryButton}" Margin="8" Width="72" Height="56" Click="OnTimerStartPauseClick">
                        <Path Fill="White" Width="20" Height="20" Stretch="Uniform">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Data" Value="{StaticResource Icon_Play}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TimerRunning}" Value="True">
                                            <Setter Property="Data" Value="{StaticResource Icon_Pause}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Button>

                    <Button Style="{StaticResource Style_SecondaryButton}" Margin="8" Click="OnTimerResetClick" ToolTip="重置" Padding="16,10" MinWidth="70">
                        <StackPanel Orientation="Horizontal" Margin="6,0">
                            <Path Data="{StaticResource Icon_Reset}" Fill="{StaticResource Brush_Foreground}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,6,0"/>
                            <TextBlock Text="重置" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource Style_SecondaryButton}" Margin="8" Click="OnTimerSetClick" Content="设定" Padding="18,10" MinWidth="70" FontWeight="Medium"/>
                </StackPanel>
            </Grid>

            </Grid>
        </Grid>
    </Border>
</Window>
