<Window x:Class="ClassroomToolkit.App.RollCallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClassroomToolkit.App.Converters"
        x:Name="NameWindow"
        Title="Classroom Toolkit"
        Height="420" Width="640"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="Manual"
        Topmost="True"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
    </Window.Resources>

    <Border Background="White" CornerRadius="16" BorderBrush="{StaticResource Brush_Border}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="8" Opacity="0.12"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="54"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. 顶部工具栏 -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="OnTitleBarDrag">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0,0,0">
                    <Button Style="{StaticResource Style_SecondaryButton}" Click="OnToggleModeClick" Padding="14,6" Margin="0,0,10,0" Height="34" MinWidth="120">
                        <StackPanel Orientation="Horizontal">
                            <Path Fill="{StaticResource Brush_Primary}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Data" Value="{StaticResource Icon_RollCall}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRollCallMode}" Value="False">
                                                <Setter Property="Data" Value="{StaticResource Icon_Clock}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                            <TextBlock Text="{Binding ModeToggleLabel}" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <ComboBox Width="120" Height="34" ItemsSource="{Binding AvailableClasses}" SelectedItem="{Binding ActiveClassName, Mode=OneWay}"
                              Visibility="{Binding IsRollCallMode, Converter={StaticResource BoolToVis}}" SelectionChanged="OnClassSelectionChanged"
                              VerticalContentAlignment="Center" FontSize="13"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,12,0">
                    <Button Style="{StaticResource Style_IconButton}" Click="OnSettingsClick" ToolTip="设置">
                        <Path Data="{StaticResource Icon_Settings}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="18" Height="18"/>
                    </Button>
                    <Rectangle Width="1" Height="24" Fill="{StaticResource Brush_Border}" Margin="8,0"/>
                    <Button Style="{StaticResource Style_IconButton}" Click="OnMinimizeClick" ToolTip="最小化">
                        <Rectangle Width="14" Height="2" Fill="{StaticResource Brush_Text_Secondary}"/>
                    </Button>
                    <Button Style="{StaticResource Style_IconButton}" Click="OnCloseClick" ToolTip="关闭">
                        <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="14" Height="14"/>
                    </Button>
                </StackPanel>
                
                <Border Grid.ColumnSpan="3" VerticalAlignment="Bottom" Height="1" Background="{StaticResource Brush_Border}" Margin="16,0"/>
            </Grid>

            <!-- 2. 内容区 -->
            <Grid Grid.Row="1" Margin="20,10">
                <!-- A. 点名视图 -->
                <Grid Visibility="{Binding IsRollCallMode, Converter={StaticResource BoolToVis}}">
                    <Border Background="{StaticResource Brush_Background_L2}" CornerRadius="20" BorderBrush="{StaticResource Brush_Border}" BorderThickness="1" MouseLeftButtonUp="OnRollClick">
                        <Border.Effect>
                            <DropShadowEffect Color="{StaticResource Color_Primary_Main}" BlurRadius="20" ShadowDepth="0" Opacity="0.08"/>
                        </Border.Effect>
                        <Grid Margin="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding CurrentStudentId}" Visibility="{Binding ShowId, Converter={StaticResource BoolToVis}}"
                                           FontSize="24" Foreground="{StaticResource Brush_Text_Secondary}" FontWeight="Light" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock x:Name="BigNameText" Text="{Binding CurrentStudentName}" FontSize="82" FontWeight="Black" Foreground="{StaticResource Brush_Text_Primary}" HorizontalAlignment="Center" TextAlignment="Center"/>
                            </StackPanel>
                            <Border Grid.Column="1" Width="180" Height="240" Margin="20,0,0,0" CornerRadius="12" Background="White" BorderThickness="1" BorderBrush="{StaticResource Brush_Border}"
                                    Visibility="{Binding CurrentStudentPhotoPath, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="4" Opacity="0.1"/>
                                </Border.Effect>
                                <Image Source="{Binding CurrentStudentPhotoPath}" Stretch="UniformToFill" Margin="2" />
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- B. 计时视图 -->
                <Grid Visibility="{Binding IsRollCallMode, Converter={StaticResource InverseBoolToVis}}">
                    <Border Background="{StaticResource Brush_Background_Dark}" CornerRadius="20">
                         <Border.Effect>
                            <DropShadowEffect Color="{StaticResource Color_Timer_Neon}" BlurRadius="40" ShadowDepth="0" Opacity="0.15"/>
                        </Border.Effect>
                        <Grid>
                            <!-- 仅显示数字，并垂直水平居中 -->
                            <Viewbox Margin="40">
                                <TextBlock Text="{Binding TimeDisplay}" Foreground="{StaticResource Brush_Timer_Neon}" FontFamily="Consolas" FontWeight="Bold">
                                     <TextBlock.Effect>
                                         <DropShadowEffect Color="{StaticResource Color_Timer_Neon}" BlurRadius="30" ShadowDepth="0" Opacity="0.8"/>
                                     </TextBlock.Effect>
                                </TextBlock>
                            </Viewbox>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- 3. 底部操作栏 -->
            <Grid Grid.Row="2" Margin="16,0,16,20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Visibility="{Binding IsRollCallMode, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding GroupButtons}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Label}" Margin="4,0" Padding="14,8" MinWidth="70" Click="OnGroupEntryClick">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource Style_SecondaryButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsReset}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Rectangle Width="1" Height="24" Fill="{StaticResource Brush_Border}" Margin="10,0"/>
                    <Button Style="{StaticResource Style_SecondaryButton}" Click="OnResetClick" Margin="4,0" Padding="14,8">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_Reset}" Fill="{StaticResource Brush_Text_Primary}" Width="14" Height="14" Margin="0,0,6,0" Stretch="Uniform"/>
                            <TextBlock Text="重置" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource Style_SecondaryButton}" Click="OnListClick" Margin="4,0" Padding="14,8">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_List}" Fill="{StaticResource Brush_Text_Primary}" Width="14" Height="14" Margin="0,0,6,0" Stretch="Uniform"/>
                            <TextBlock Text="名单" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Visibility="{Binding IsRollCallMode, Converter={StaticResource InverseBoolToVis}}">
                    <Button Style="{StaticResource Style_SecondaryButton}" Margin="6,0" Click="OnTimerModeClick" Padding="16,10" MinWidth="90">
                         <TextBlock Text="{Binding TimerModeLabel}" FontWeight="Bold"/>
                    </Button>
                    <Button Style="{StaticResource Style_PrimaryButton}" Margin="6,0" Width="80" Height="48" Click="OnTimerStartPauseClick">
                        <Path Fill="White" Width="20" Height="20" Stretch="Uniform">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Data" Value="{StaticResource Icon_Play}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TimerRunning}" Value="True">
                                            <Setter Property="Data" Value="{StaticResource Icon_Pause}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Button>
                    <Button Style="{StaticResource Style_SecondaryButton}" Margin="6,0" Click="OnTimerResetClick" Padding="16,10" MinWidth="90">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_Reset}" Fill="{StaticResource Brush_Text_Primary}" Width="14" Height="14" Margin="0,0,6,0" Stretch="Uniform"/>
                            <TextBlock Text="重置" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource Style_SecondaryButton}" Margin="6,0" Click="OnTimerSetClick" Padding="16,10" MinWidth="90">
                        <TextBlock Text="设定时间" FontWeight="Bold"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>