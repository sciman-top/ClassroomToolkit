<Window x:Class="ClassroomToolkit.App.StudentListDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:ClassroomToolkit.App.Models"
        Title="班级名单"
        Width="1120"
        Height="640"
        MinWidth="980"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}">

    <Window.Resources>
        <SolidColorBrush x:Key="Brush_Student_Waiting" Color="{StaticResource Color_Accent_Primary}"/>
        <SolidColorBrush x:Key="Brush_Student_Called" Color="{StaticResource Color_Text_Tertiary}"/>
    </Window.Resources>

    <!-- 主窗口容器 -->
    <Border Style="{StaticResource Style_ManagementShellWindowBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title -->
                <RowDefinition Height="*"/>    <!-- List -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- 1. 标题栏 -->
            <Grid Grid.Row="0" Style="{StaticResource Style_ManagementShellTitleBar}" MouseLeftButtonDown="OnTitleBarDrag">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <Border Background="{StaticResource Brush_InputBackground}" CornerRadius="6" Padding="6" BorderBrush="Transparent">
                        <Path Data="{StaticResource Icon_List}" Fill="{StaticResource Brush_Primary}"
                              Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}" Stretch="Uniform"/>
                    </Border>
                    <TextBlock Text="班级名单" Style="{StaticResource Style_ManagementShellTitleText}" Margin="10,0,0,0"/>
                    <TextBlock Text="点击姓名切换状态" Style="{StaticResource Style_ManagementShellSubtitleText}" Margin="8,2,0,0"/>
                </StackPanel>
                
                <Button Style="{StaticResource Style_ManagementShellCloseButton}" Click="OnCloseClick" ToolTip="关闭">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform"
                          Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}"/>
                </Button>
                
                <Border Style="{StaticResource Style_ManagementShellDivider}"/>
            </Grid>

            <Border Grid.Row="1" Style="{StaticResource Style_ManagementShellContentBorder}">
                <ScrollViewer x:Name="ListScrollViewer" Margin="6"
                              PanningMode="VerticalFirst"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="StudentItems">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="10"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:StudentListItem}">
                                <!-- 学生卡片模板：已点名添加 ✓ 角标 -->
                                <Button Style="{StaticResource Style_StudentCardButton}" Click="OnStudentClick" ToolTip="{Binding DisplayText}">
                                    <Grid Margin="6,4">
                                        <!-- 主内容 -->
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding StudentName}" 
                                                       FontSize="{StaticResource FontSize_Body_S}" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       MaxWidth="88">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource Brush_Student_Waiting}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Called}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource Brush_Student_Called}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            
                                            <TextBlock Text="{Binding StudentId}" 
                                                       FontSize="{StaticResource FontSize_Body_S}"
                                                       Foreground="{StaticResource Brush_Text_Tertiary}"
                                                       Margin="0,0,0,0"
                                                       TextAlignment="Center"
                                                       HorizontalAlignment="Center"/>

                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Called}" Value="True">
                                                            <Setter Property="Opacity" Value="0.72"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- 3. 底部统计与操作 -->
            <Border Grid.Row="2" Style="{StaticResource Style_ManagementShellFooterBorder}">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4Z" Fill="{StaticResource Brush_Primary}" Stretch="Uniform" Width="{StaticResource Size_Icon_Glyph_SM}" Height="{StaticResource Size_Icon_Glyph_SM}" Margin="0,0,8,0"/>
                        <TextBlock Text="亮色：待点名" FontSize="{StaticResource FontSize_Body_S}" Foreground="{StaticResource Brush_Text_Secondary}" Margin="0,0,16,0"/>
                        
                        <Path Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2Z" Fill="{StaticResource Brush_Text_Tertiary}" Stretch="Uniform" Width="{StaticResource Size_Icon_Glyph_SM}" Height="{StaticResource Size_Icon_Glyph_SM}" Margin="0,0,8,0"/>
                        <TextBlock Text="灰色：已点名" FontSize="{StaticResource FontSize_Body_S}" Foreground="{StaticResource Brush_Text_Secondary}"/>
                    </StackPanel>
                    
                    <Button Content="关闭"
                            Style="{StaticResource Style_ManagementShellFooterActionButton}"
                            HorizontalAlignment="Right" 
                            Click="OnCloseClick"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
