<Window x:Class="ClassroomToolkit.App.StudentListDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:ClassroomToolkit.App.Models"
        xmlns:local="clr-namespace:ClassroomToolkit.App.Converters"
        Title="学生名单"
        Width="1120"
        Height="640"
        MinWidth="600"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
        
        <!-- 本地专用：学生卡片 - Modern Adaptation -->
        <Style x:Key="Style_StudentCard_Modern" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Brush_Background_L2}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush_Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush_Surface_Hover}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Brush_Primary}"/>
                                <Setter TargetName="bd" Property="Effect" Value="{StaticResource Shadow_Card}"/>
                                <!-- 微上浮 -->
                                <Setter TargetName="bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="-1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush_Surface_Active}"/>
                                <Setter TargetName="bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 主窗口容器 -->
    <Border Background="{StaticResource Brush_Window_Atmosphere}" CornerRadius="16" BorderBrush="{StaticResource Brush_Border}" BorderThickness="1" Margin="10">
        <Border.Effect>
            <!-- 统一使用浮层阴影 -->
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="12" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>   <!-- Title (Compact) -->
                <RowDefinition Height="*"/>    <!-- List -->
                <RowDefinition Height="50"/>   <!-- Footer (Compact) -->
            </Grid.RowDefinitions>

            <!-- 1. 标题栏 -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="OnTitleBarDrag">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <Border Background="{StaticResource Brush_Background_L3}" CornerRadius="6" Padding="6" BorderBrush="Transparent">
                        <Path Data="{StaticResource Icon_List}" Fill="{StaticResource Brush_Primary}" Width="14" Height="14" Stretch="Uniform"/>
                    </Border>
                    <TextBlock Text="班级名单" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Brush_Text_Primary}" Margin="10,0,0,0"/>
                    <TextBlock Text="(点击名字切换状态)" FontSize="12" Foreground="{StaticResource Brush_Text_Tertiary}" VerticalAlignment="Center" Margin="8,2,0,0"/>
                </StackPanel>
                
                <Button Style="{StaticResource Style_IconButton}" Click="OnCloseClick" HorizontalAlignment="Right" Margin="0,0,12,0">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="12" Height="12"/>
                </Button>
                
                <Border VerticalAlignment="Bottom" Height="1" Background="{StaticResource Brush_Border}"/>
            </Grid>

            <ScrollViewer x:Name="ListScrollViewer" Grid.Row="1" Margin="12,8" 
                          HorizontalScrollBarVisibility="Disabled" 
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="StudentItems">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <!-- 紧凑型布局：一行 10 人 (ItemWidth 105 -> 100) -->
                            <WrapPanel ItemWidth="100" ItemHeight="52" Orientation="Horizontal" HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:StudentListItem}">
                            <Button Style="{StaticResource Style_StudentCard_Modern}" Click="OnStudentClick" ToolTip="{Binding DisplayText}">
                                <Grid Margin="6,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/> <!-- 图标 -->
                                        <ColumnDefinition Width="*"/>    <!-- 文本 -->
                                    </Grid.ColumnDefinitions>

                                    <!-- 状态指示器 - 缩小尺寸 -->
                                    <Grid Grid.Column="0" Margin="0,0,6,0" VerticalAlignment="Center">
                                        <Border Width="20" Height="20" CornerRadius="8" Background="{StaticResource Brush_Background_L3}"
                                                Visibility="{Binding Called, Converter={StaticResource BoolToVis}}" BorderBrush="Transparent">
                                            <Path Data="{StaticResource Icon_RollCall}" Fill="{StaticResource Brush_Disabled}" 
                                                  Width="10" Height="10" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        
                                        <Border Width="20" Height="20" CornerRadius="8" Background="{StaticResource Brush_Surface_Tint}"
                                                Visibility="{Binding Called, Converter={StaticResource InverseBoolToVis}}" BorderBrush="Transparent">
                                            <Path Data="{StaticResource Icon_RollCall}" Fill="{StaticResource Brush_Primary}" 
                                                  Width="10" Height="10" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>

                                    <!-- 信息文本 - 缩小字体 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StudentName}" 
                                                   FontSize="12" FontWeight="SemiBold" 
                                                   Foreground="{StaticResource Brush_Text_Primary}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        
                                        <TextBlock Text="{Binding StudentId}" 
                                                   FontSize="10" 
                                                   Foreground="{StaticResource Brush_Text_Tertiary}"
                                                   Margin="0,0,0,0"/>
                                        
                                        <!-- 整体变灰 (如果已点名) -->
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Called}" Value="True">
                                                        <Setter Property="Opacity" Value="0.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 3. 底部统计与操作 -->
            <Border Grid.Row="2" Background="{StaticResource Brush_Background_L2}" CornerRadius="0,0,16,16" Padding="20,0" BorderThickness="0,1,0,0" BorderBrush="{StaticResource Brush_Border}">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource Brush_Primary}" Margin="0,0,8,0" BorderBrush="Transparent"/>
                        <TextBlock Text="亮色待点" FontSize="12" Foreground="{StaticResource Brush_Text_Secondary}" Margin="0,0,16,0"/>
                        
                        <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource Brush_Disabled}" Margin="0,0,8,0" BorderBrush="Transparent"/>
                        <TextBlock Text="灰色已点" FontSize="12" Foreground="{StaticResource Brush_Text_Secondary}"/>
                    </StackPanel>
                    
                    <Button Content="关闭" 
                            Style="{StaticResource Style_SecondaryButton}" 
                            HorizontalAlignment="Right" 
                            Padding="16,4"
                            Height="32"
                            Width="72"
                            Click="OnCloseClick"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>