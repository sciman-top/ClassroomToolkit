<Window x:Class="ClassroomToolkit.App.StudentListDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClassroomToolkit.App.Converters"
            Title="学生名单"
            Width="1200"
            MinWidth="1100"
            WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        SizeToContent="Manual">

    <Window.Resources>
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />

        <!-- 学生卡片样式 -->
        <Style x:Key="Style_StudentCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#EEE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <!-- 鼠标悬停 -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F8FF"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Brush_Primary}"/>
                </Trigger>
                <!-- 已点名状态 (Called=True) -->
                <!-- 注意：这里需要通过 DataTrigger 绑定 DataContext.Called，稍后在 ItemTemplate 里实现 -->
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="8" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="4" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title -->
                <RowDefinition Height="*"/>    <!-- List -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- 1. 标题栏 -->
            <Grid x:Name="TitleBarGrid" Grid.Row="0" Height="40" Background="Transparent" MouseLeftButtonDown="OnTitleBarDrag">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <Path Data="{StaticResource Icon_List}" Fill="{StaticResource Brush_Primary}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"/>
                    <TextBlock Text="学生名单" FontWeight="Bold" Foreground="#333"/>
                </StackPanel>
                
                <Button Style="{StaticResource Style_IconButton}" Click="OnCloseClick" HorizontalAlignment="Right" Margin="0,0,8,0">
                    <Path Data="{StaticResource Icon_Close}" Fill="#888" Stretch="Uniform" Width="10" Height="10"/>
                </Button>
            </Grid>
            <Border Grid.Row="0" VerticalAlignment="Bottom" Height="1" Background="#F0F0F0"/>

            <!-- 2. 名单区域 -->
            <ScrollViewer x:Name="ListScrollViewer" Grid.Row="1" Margin="16" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="StudentItems">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel ItemWidth="108" ItemHeight="44" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border MouseLeftButtonUp="OnStudentClick" ToolTip="{Binding DisplayText}">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource Style_StudentCard}">
                                        <Style.Triggers>
                                            <!-- 已点名：灰色背景 -->
                                            <DataTrigger Binding="{Binding Called}" Value="True">
                                                <Setter Property="Background" Value="#F5F5F5"/>
                                                <Setter Property="Opacity" Value="0.6"/>
                                            </DataTrigger>
                                            <!-- 未点名：白色背景 -->
                                            <DataTrigger Binding="{Binding Called}" Value="False">
                                                <Setter Property="Background" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#DDD"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="1.0"/>
                                                <Setter Property="Background" Value="{StaticResource Brush_Accent}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource Brush_Primary}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 名字: 一行10人，紧凑布局 -->
                                    <TextBlock Text="{Binding DisplayText}"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="#333"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>

                                    <!-- 未点名标记 (红点): 垂直居中 -->
                                    <Ellipse Grid.Column="1" Width="5" Height="5" Fill="{StaticResource Brush_Danger}"
                                             Visibility="{Binding Called, Converter={StaticResource InverseBoolToVis}}"
                                             VerticalAlignment="Center" HorizontalAlignment="Right"
                                             Margin="3,0,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 3. 底部 -->
            <Grid x:Name="FooterGrid" Grid.Row="2" Margin="16,0,16,16">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource Brush_Danger}" Margin="0,0,6,0"/>
                    <TextBlock Text="红点标记表示本轮未被点名" FontSize="12" Foreground="#888"/>
                </StackPanel>
                
                <Button Content="关闭" 
                        Style="{StaticResource Style_PrimaryButton}" 
                        HorizontalAlignment="Right" 
                        Width="80" 
                        Click="OnCloseClick"/>
            </Grid>
        </Grid>
    </Border>
</Window>
