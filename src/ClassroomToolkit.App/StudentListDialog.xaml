<Window x:Class="ClassroomToolkit.App.StudentListDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClassroomToolkit.App.Converters"
        Title="学生名单"
        Width="640"
        Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
    </Window.Resources>
    <Grid Margin="10" x:Name="Root">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="StudentItems">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="10" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Click="OnStudentClick"
                                Width="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=StudentButtonWidth}"
                                Height="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=StudentButtonHeight}"
                                Margin="3"
                                Padding="8,0"
                                VerticalContentAlignment="Center">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="ToolTip" Value="本轮已点名" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Called}" Value="False">
                                            <Setter Property="ToolTip" Value="本轮未点名" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding DisplayText}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           TextTrimming="CharacterEllipsis" />
                                <Ellipse Grid.Column="1" Width="10" Height="10" Fill="#d93025"
                                         HorizontalAlignment="Right" VerticalAlignment="Center"
                                         Visibility="{Binding Called, Converter={StaticResource InverseBoolToVis}}" />
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <TextBlock x:Name="HintText" Grid.Row="1" Text="红点标记本轮未点名（无标记即已点名）" Foreground="#4a525a"
                   Margin="0,6,0,0" />

        <StackPanel x:Name="FooterPanel" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
            <Button Content="关闭" Width="80" Height="30" Click="OnCloseClick" />
        </StackPanel>
    </Grid>
</Window>
