<Window x:Class="ClassroomToolkit.App.StudentListDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:ClassroomToolkit.App.Models"
        Title="学生名单"
        Width="1080"
        Height="640"
        MinWidth="800"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- 本地专用：学生卡片 -->
        <Style x:Key="Style_StudentCard_Modern" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Brush_Background_L2}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush_Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="White"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Brush_Primary}"/>
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="{StaticResource Color_Primary_Main}" BlurRadius="12" ShadowDepth="4" Opacity="0.15"/>
                                    </Setter.Value>
                                </Setter>
                                <!-- 微上浮 -->
                                <Setter TargetName="bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="-1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush_Surface_Tint}"/>
                                <Setter TargetName="bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 主窗口容器 -->
    <Border Background="#FAFAFA" CornerRadius="16" BorderBrush="{StaticResource Brush_Border}" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="#8899AA" BlurRadius="30" ShadowDepth="10" Opacity="0.25"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>   <!-- Title -->
                <RowDefinition Height="*"/>    <!-- List -->
                <RowDefinition Height="50"/>   <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- 1. 标题栏 -->
            <Grid Grid.Row="0" Background="White" MouseLeftButtonDown="OnTitleBarDrag">
                <Border CornerRadius="16,16,0,0" Background="White"/>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0">
                    <Border Background="{StaticResource Brush_Surface_Tint}" CornerRadius="8" Padding="6">
                        <Path Data="{StaticResource Icon_List}" Fill="{StaticResource Brush_Primary}" Width="16" Height="16" Stretch="Uniform"/>
                    </Border>
                    <TextBlock Text="班级名单" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Brush_Text_Primary}" Margin="12,0,0,0"/>
                    <TextBlock Text="(点击名字切换状态)" FontSize="13" Foreground="{StaticResource Brush_Text_Tertiary}" VerticalAlignment="Center" Margin="8,2,0,0"/>
                </StackPanel>
                
                <Button Style="{StaticResource Style_IconButton}" Click="OnCloseClick" HorizontalAlignment="Right" Margin="0,0,16,0">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="14" Height="14"/>
                </Button>
                
                <Border VerticalAlignment="Bottom" Height="1" Background="{StaticResource Brush_Border_Subtle}"/>
            </Grid>

            <!-- 2. 名单滚动区 -->
            <ScrollViewer x:Name="ListScrollViewer" Grid.Row="1" Margin="16" 
                          HorizontalScrollBarVisibility="Disabled" 
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="StudentItems">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <!-- 稍微加宽卡片，提升容纳力 -->
                            <WrapPanel ItemWidth="160" ItemHeight="64" Orientation="Horizontal" HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:StudentListItem}">
                            <Button Style="{StaticResource Style_StudentCard_Modern}" Click="OnStudentClick" ToolTip="{Binding DisplayText}">
                                <Grid Margin="12,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/> <!-- 图标 -->
                                        <ColumnDefinition Width="*"/>    <!-- 文本 -->
                                    </Grid.ColumnDefinitions>

                                    <!-- 状态指示器 -->
                                    <Grid Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center">
                                        <!-- 已点名 (Called=True)：灰色圆圈 -->
                                        <Border Width="32" Height="32" CornerRadius="16" Background="{StaticResource Brush_Background_L3}"
                                                Visibility="{Binding Called, Converter={StaticResource BoolToVis}}">
                                            <Path Data="{StaticResource Icon_RollCall}" Fill="{StaticResource Brush_Disabled}" 
                                                  Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        
                                        <!-- 未点名 (Called=False)：彩色圆圈 -->
                                        <Border Width="32" Height="32" CornerRadius="16" Background="{StaticResource Brush_Surface_Tint}"
                                                Visibility="{Binding Called, Converter={StaticResource InverseBoolToVis}}">
                                            <Path Data="{StaticResource Icon_RollCall}" Fill="{StaticResource Brush_Primary}" 
                                                  Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>

                                    <!-- 信息文本 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StudentName}" 
                                                   FontSize="15" FontWeight="SemiBold" 
                                                   Foreground="{StaticResource Brush_Text_Primary}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        
                                        <TextBlock Text="{Binding StudentId}" 
                                                   FontSize="12" 
                                                   Foreground="{StaticResource Brush_Text_Tertiary}"
                                                   Margin="0,2,0,0"/>
                                        
                                        <!-- 整体变灰 (如果已点名) -->
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Called}" Value="True">
                                                        <Setter Property="Opacity" Value="0.6"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 3. 底部统计与操作 -->
            <Border Grid.Row="2" Background="White" CornerRadius="0,0,16,16" Padding="24,0" BorderThickness="0,1,0,0" BorderBrush="{StaticResource Brush_Border_Subtle}">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource Brush_Primary}" Margin="0,0,8,0"/>
                        <TextBlock Text="亮色表示待点名" FontSize="13" Foreground="{StaticResource Brush_Text_Secondary}" Margin="0,0,16,0"/>
                        
                        <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource Brush_Disabled}" Margin="0,0,8,0"/>
                        <TextBlock Text="灰色表示已完成" FontSize="13" Foreground="{StaticResource Brush_Text_Secondary}"/>
                    </StackPanel>
                    
                    <Button Content="关闭窗口" 
                            Style="{StaticResource Style_SecondaryButton}" 
                            HorizontalAlignment="Right" 
                            Padding="20,6"
                            Height="36"
                            Click="OnCloseClick"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>