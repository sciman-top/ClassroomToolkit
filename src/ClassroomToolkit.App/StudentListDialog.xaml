<Window x:Class="ClassroomToolkit.App.StudentListDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:ClassroomToolkit.App.Models"
        Title="学生名单" Height="600" Width="400" MinWidth="320" MinHeight="400"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border Background="White" CornerRadius="12" BorderBrush="{StaticResource Brush_Border}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="25" ShadowDepth="4" Opacity="0.1"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- 标题栏 -->
            <Grid Grid.Row="0" Background="{StaticResource Brush_Background_L2}" MouseLeftButtonDown="OnTitleBarDrag">
                <TextBlock Text="学生名单" VerticalAlignment="Center" HorizontalAlignment="Center"
                           FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Brush_Text_Primary}"/>
                <Button Style="{StaticResource Style_IconButton}" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Width="48" Height="48" Margin="0" Click="OnCloseClick" ToolTip="关闭">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="12" Height="12"/>
                </Button>
                <Border VerticalAlignment="Bottom" Height="1" Background="{StaticResource Brush_Border}"/>
            </Grid>

            <!-- 学生列表 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Students}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" Margin="10"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:StudentListItem}">
                            <Button Style="{StaticResource Style_StudentCard}" Click="OnStudentClick">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 已完成标记 -->
                                    <Path Grid.Column="0" Data="{StaticResource Icon_RollCall}" Fill="{StaticResource Brush_Success}"
                                          Width="20" Height="20" Margin="10,0" VerticalAlignment="Center">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                    
                                    <Path Grid.Column="0" Data="{StaticResource Icon_User}" Fill="{StaticResource Brush_Text_Secondary}"
                                          Width="16" Height="16" Margin="12,0" VerticalAlignment="Center" Opacity="0.5">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>

                                    <!-- 姓名与学号 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Brush_Text_Primary}"/>
                                        <TextBlock Text="{Binding Id}" FontSize="12" Foreground="{StaticResource Brush_Text_Secondary}"/>
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <!-- 底部说明 -->
            <Border Grid.Row="2" Background="{StaticResource Brush_Background_L3}" CornerRadius="0,0,12,12"
                    Padding="12" BorderThickness="0,1,0,0" BorderBrush="{StaticResource Brush_Border}">
                <TextBlock Text="点击选择一个学生作为下一个点名对象" HorizontalAlignment="Center" FontSize="12" Foreground="{StaticResource Brush_Text_Tertiary}"/>
            </Border>
        </Grid>
    </Border>
</Window>