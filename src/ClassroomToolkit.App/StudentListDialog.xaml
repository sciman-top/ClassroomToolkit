<Window x:Class="ClassroomToolkit.App.StudentListDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:ClassroomToolkit.App.Models"
        Title="学生名单"
        Width="1100"
        MinWidth="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}"
        SizeToContent="Manual">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <!-- 学生卡片样式 -->
        <Style x:Key="Style_StudentCard_Modern" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Brush_Background_L2}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush_Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush_Surface_Tint}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Brush_Primary}"/>
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="{StaticResource Color_Primary_Main}" BlurRadius="8" ShadowDepth="0" Opacity="0.2"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource Brush_Background}" CornerRadius="12" Margin="15">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.15"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>   <!-- Title -->
                <RowDefinition Height="*"/>    <!-- List -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- 1. 标题栏 -->
            <Grid Grid.Row="0" Background="{StaticResource Brush_Background_L2}">
                <Border CornerRadius="12,12,0,0" Background="{StaticResource Brush_Background_L2}"/>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <Path Data="{StaticResource Icon_List}" Fill="{StaticResource Brush_Primary}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0"/>
                    <TextBlock Text="学生名单" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Brush_Text_Primary}"/>
                </StackPanel>
                
                <Button Style="{StaticResource Style_IconButton}" Click="OnCloseClick" HorizontalAlignment="Right" Margin="0,0,10,0" Width="40" Height="40">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform" Width="12" Height="12"/>
                </Button>
                
                <Border VerticalAlignment="Bottom" Height="1" Background="{StaticResource Brush_Border}"/>
            </Grid>

            <!-- 2. 名单区域 -->
            <ScrollViewer x:Name="ListScrollViewer" Grid.Row="1" Margin="10" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="StudentItems">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <!-- 增加宽度至 150，防止名字被截断 -->
                            <WrapPanel ItemWidth="150" ItemHeight="60" Orientation="Horizontal" HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:StudentListItem}">
                            <Button Style="{StaticResource Style_StudentCard_Modern}" Click="OnStudentClick" ToolTip="{Binding DisplayText}">
                                <Grid Margin="10,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/> <!-- 图标 -->
                                        <ColumnDefinition Width="*"/>    <!-- 文本 -->
                                    </Grid.ColumnDefinitions>

                                    <!-- 状态图标 -->
                                    <Grid Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center">
                                        <!-- 已点名：灰色打勾 -->
                                        <Path Data="{StaticResource Icon_RollCall}" Fill="{StaticResource Brush_Disabled}" 
                                              Width="20" Height="20" Stretch="Uniform"
                                              Visibility="{Binding Called, Converter={StaticResource BoolToVis}}"/>
                                        
                                        <!-- 未点名：高亮用户图标 -->
                                        <Path Data="{StaticResource Icon_RollCall}" Fill="{StaticResource Brush_Primary}" 
                                              Width="20" Height="20" Stretch="Uniform">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Called}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                    </Grid>

                                    <!-- 文本信息 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <!-- 姓名：加粗，防止过长截断 -->
                                        <TextBlock Text="{Binding StudentName}" 
                                                   FontSize="14" FontWeight="SemiBold" 
                                                   Foreground="{StaticResource Brush_Text_Primary}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        
                                        <!-- 学号：小字体，灰色 -->
                                        <TextBlock Text="{Binding StudentId}" 
                                                   FontSize="11" 
                                                   Foreground="{StaticResource Brush_Text_Tertiary}"
                                                   Margin="0,2,0,0"/>
                                        
                                        <!-- 已点名时的样式覆盖 -->
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Called}" Value="True">
                                                        <Setter Property="Opacity" Value="0.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 3. 底部 -->
            <Border Grid.Row="2" Background="{StaticResource Brush_Background_L2}" CornerRadius="0,0,12,12" Padding="15,10" BorderThickness="0,1,0,0" BorderBrush="{StaticResource Brush_Border}">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="{StaticResource Icon_RollCall}" Fill="{StaticResource Brush_Primary}" Width="12" Height="12" Margin="0,0,6,0"/>
                        <TextBlock Text="蓝色图标表示本轮未被点名" FontSize="12" Foreground="{StaticResource Brush_Text_Secondary}"/>
                    </StackPanel>
                    
                    <Button Content="关闭" 
                            Style="{StaticResource Style_SecondaryButton}" 
                            HorizontalAlignment="Right" 
                            Width="80" Height="32"
                            Click="OnCloseClick"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>