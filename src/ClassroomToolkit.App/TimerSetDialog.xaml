<Window x:Class="ClassroomToolkit.App.TimerSetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="倒计时设置"
        Height="Auto" Width="396"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}">

    <Border Style="{StaticResource Style_DialogShellWindowBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Style="{StaticResource Style_DialogShellTitleBar}" MouseLeftButtonDown="OnTitleBarDrag">
                <TextBlock Text="倒计时设置" Style="{StaticResource Style_DialogShellTitleText}"/>
                <Button Style="{StaticResource Style_DialogShellCloseButton}" Click="OnCancel" ToolTip="关闭倒计时设置">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform"
                          Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}"/>
                </Button>
            </Grid>
            <Border Grid.Row="0" Style="{StaticResource Style_DialogShellDivider}"/>

            <Border Grid.Row="1" Style="{StaticResource Style_SettingCardBorder}" Margin="20,16,20,10" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="分钟" FontSize="13" Foreground="{StaticResource Brush_Text_Secondary}" VerticalAlignment="Center"
                                   ToolTip="可输入 0-150，滑杆范围为 0-25。"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="MinutesDownButton" Content="−" Width="30" Height="30" Margin="0,0,2,0"
                                    FontSize="16" FontWeight="Bold" Foreground="{StaticResource Brush_Primary}"
                                    Style="{StaticResource Style_SecondaryButton}"
                                    Padding="0"
                                    Cursor="Hand" Click="OnMinutesDownClick"
                                    PreviewMouseLeftButtonDown="OnMinutesDownMouseDown" PreviewMouseLeftButtonUp="OnMinutesMouseUp" MouseLeave="OnMinutesMouseLeave"/>
                            <TextBox x:Name="MinutesBox" Width="68" Height="30" TextAlignment="Center" FontWeight="Bold" FontSize="16"
                                     Foreground="{StaticResource Brush_Primary}" TextChanged="OnMinutesTextChanged"
                                     VerticalContentAlignment="Center"/>
                            <Button x:Name="MinutesUpButton" Content="+" Width="30" Height="30" Margin="2,0,0,0"
                                    FontSize="16" FontWeight="Bold" Foreground="{StaticResource Brush_Primary}"
                                    Style="{StaticResource Style_SecondaryButton}"
                                    Padding="0"
                                    Cursor="Hand" Click="OnMinutesUpClick"
                                    PreviewMouseLeftButtonDown="OnMinutesUpMouseDown" PreviewMouseLeftButtonUp="OnMinutesMouseUp" MouseLeave="OnMinutesMouseLeave"/>
                        </StackPanel>
                    </Grid>

                    <Slider Grid.Row="1" x:Name="MinutesSlider" Minimum="0" Maximum="25"
                            ValueChanged="OnMinutesSliderChanged"
                            IsSnapToTickEnabled="True" TickFrequency="1"/>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource Style_SettingCardBorder}" Margin="20,0,20,8" Padding="14,12">
                <StackPanel>
                    <TextBlock Text="常用时长" FontSize="13" Foreground="{StaticResource Brush_Text_Secondary}" Margin="0,0,0,8"/>
                    <UniformGrid Columns="3">
                        <Button Content="3 分钟" Tag="3" Height="30" Margin="0,0,8,8" Style="{StaticResource Style_SecondaryButton}" Click="OnPresetMinutesClick"/>
                        <Button Content="5 分钟" Tag="5" Height="30" Margin="0,0,8,8" Style="{StaticResource Style_SecondaryButton}" Click="OnPresetMinutesClick"/>
                        <Button Content="10 分钟" Tag="10" Height="30" Margin="0,0,8,8" Style="{StaticResource Style_SecondaryButton}" Click="OnPresetMinutesClick"/>
                        <Button Content="20 分钟" Tag="20" Height="30" Margin="0,0,8,8" Style="{StaticResource Style_SecondaryButton}" Click="OnPresetMinutesClick"/>
                        <Button Content="30 分钟" Tag="30" Height="30" Margin="0,0,8,8" Style="{StaticResource Style_SecondaryButton}" Click="OnPresetMinutesClick"/>
                        <Button Content="40 分钟" Tag="40" Height="30" Margin="0,0,8,8" Style="{StaticResource Style_SecondaryButton}" Click="OnPresetMinutesClick"/>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource Style_SettingCardBorder}" Margin="20,8,20,18" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="秒" FontSize="13" Foreground="{StaticResource Brush_Text_Secondary}" VerticalAlignment="Center"/>
                        <TextBox x:Name="SecondsBox" Width="60" HorizontalAlignment="Right" TextAlignment="Center" FontWeight="Bold" Foreground="{StaticResource Brush_Primary}" TextChanged="OnSecondsTextChanged"/>
                    </Grid>

                    <Slider Grid.Row="1" x:Name="SecondsSlider" Minimum="0" Maximum="59"
                            ValueChanged="OnSecondsSliderChanged"
                            IsSnapToTickEnabled="True" TickFrequency="5"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="4" Style="{StaticResource Style_DialogShellActionBar}">
                <Button Content="取消" Style="{StaticResource Style_DialogShellSecondaryActionButton}" Click="OnCancel"/>
                <Button Content="确定" Style="{StaticResource Style_DialogShellPrimaryActionButton}" Click="OnConfirm"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
