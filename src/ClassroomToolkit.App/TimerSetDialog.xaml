<Window x:Class="ClassroomToolkit.App.TimerSetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置倒计时"
        Height="Auto" Width="380"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}">

    <Border Background="{StaticResource Brush_Window_Atmosphere}" CornerRadius="16" Margin="12" BorderBrush="{StaticResource Brush_Border}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="12" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title -->
                <RowDefinition Height="Auto"/> <!-- Mins -->
                <RowDefinition Height="Auto"/> <!-- Secs -->
                <RowDefinition Height="Auto"/> <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- 1. 标题 -->
            <Grid Grid.Row="0" Margin="0,0,0,0" Height="48" Background="Transparent" MouseLeftButtonDown="OnTitleBarDrag">
                <TextBlock Text="设定时间" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Brush_Text_Primary}" VerticalAlignment="Center" Margin="24,0,0,0"/>
            </Grid>
            <Border Grid.Row="0" VerticalAlignment="Bottom" Height="1" Background="{StaticResource Brush_Border}"/>

            <!-- 2. 分钟设置 -->
            <Grid Grid.Row="1" Margin="24,20,24,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="分钟" FontSize="14" Foreground="{StaticResource Brush_Text_Secondary}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="MinutesDownButton" Content="−" Width="28" Height="28" Margin="0,0,2,0"
                                FontSize="16" FontWeight="Bold" Foreground="{StaticResource Brush_Primary}"
                                Background="Transparent" BorderBrush="{StaticResource Brush_Border}" BorderThickness="1"
                                Cursor="Hand" Click="OnMinutesDownClick"
                                PreviewMouseLeftButtonDown="OnMinutesDownMouseDown" PreviewMouseLeftButtonUp="OnMinutesMouseUp" MouseLeave="OnMinutesMouseLeave">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4"
                                            Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <TextBox x:Name="MinutesBox" Width="60" TextAlignment="Center" FontWeight="Bold"
                                Foreground="{StaticResource Brush_Primary}" TextChanged="OnMinutesTextChanged"/>
                        <Button x:Name="MinutesUpButton" Content="+" Width="28" Height="28" Margin="2,0,0,0"
                                FontSize="16" FontWeight="Bold" Foreground="{StaticResource Brush_Primary}"
                                Background="Transparent" BorderBrush="{StaticResource Brush_Border}" BorderThickness="1"
                                Cursor="Hand" Click="OnMinutesUpClick"
                                PreviewMouseLeftButtonDown="OnMinutesUpMouseDown" PreviewMouseLeftButtonUp="OnMinutesMouseUp" MouseLeave="OnMinutesMouseLeave">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4"
                                            Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
                
                <Slider Grid.Row="1" x:Name="MinutesSlider" Minimum="0" Maximum="25"
                        ValueChanged="OnMinutesSliderChanged" 
                        IsSnapToTickEnabled="True" TickFrequency="1"/>
            </Grid>

            <!-- 3. 秒钟设置 -->
            <Grid Grid.Row="2" Margin="24,10,24,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="秒钟" FontSize="14" Foreground="{StaticResource Brush_Text_Secondary}" VerticalAlignment="Center"/>
                    <TextBox x:Name="SecondsBox" Width="60" HorizontalAlignment="Right" TextAlignment="Center" FontWeight="Bold" Foreground="{StaticResource Brush_Primary}" TextChanged="OnSecondsTextChanged"/>
                </Grid>

                <Slider Grid.Row="1" x:Name="SecondsSlider" Minimum="0" Maximum="59"
                        ValueChanged="OnSecondsSliderChanged"
                        IsSnapToTickEnabled="True" TickFrequency="5"/>
            </Grid>

            <!-- 4. 按钮 -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,0,24,24">
                <Button Content="取消" Style="{StaticResource Style_SecondaryButton}" Width="90" Margin="0,0,12,0" Click="OnCancel"/>
                <Button Content="确定" Style="{StaticResource Style_PrimaryButton}" Width="90" Click="OnConfirm"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>