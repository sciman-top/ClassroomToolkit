<Window x:Class="ClassroomToolkit.App.TimerSetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="倒计时"
        Height="Auto" Width="396"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}">

    <Window.Resources>
        <Style x:Key="Style_TimerCompactStepperButton" TargetType="Button" BasedOn="{StaticResource Style_IconButton}">
            <Setter Property="Width" Value="{StaticResource Size_Button_Icon_Compact}"/>
            <Setter Property="Height" Value="{StaticResource Size_Button_Icon_Compact}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource Brush_Primary}"/>
        </Style>

        <Style x:Key="Style_TimerValueTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="{StaticResource Size_Touch_Target_Min}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource Brush_Primary}"/>
        </Style>

        <Style x:Key="Style_TimerPresetButton" TargetType="Button" BasedOn="{StaticResource Style_SecondaryButton}">
            <Setter Property="MinHeight" Value="{StaticResource Size_Touch_Target_Min}"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>
    </Window.Resources>

    <Border Style="{StaticResource Style_DialogShellWindowBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Style="{StaticResource Style_DialogShellTitleBar}" MouseLeftButtonDown="OnTitleBarDrag">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                    <Border Style="{StaticResource Style_TitleIconBadge}" Margin="0,0,8,0">
                        <Path Data="{StaticResource Icon_Clock}" Fill="{StaticResource Brush_Primary}" Stretch="Uniform"/>
                    </Border>
                    <TextBlock Text="倒计时" Style="{StaticResource Style_DialogShellTitleText}" Margin="0"/>
                </StackPanel>
                <Button Style="{StaticResource Style_DialogShellCloseButton}" Click="OnCancel" ToolTip="关闭">
                    <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource Brush_Text_Secondary}" Stretch="Uniform"
                          Width="{StaticResource Size_Icon_Glyph_MD}" Height="{StaticResource Size_Icon_Glyph_MD}"/>
                </Button>
            </Grid>
            <Border Grid.Row="0" Style="{StaticResource Style_DialogShellDivider}"/>

            <Border Grid.Row="1" Style="{StaticResource Style_SettingCardBorder}" Margin="20,16,20,10" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="分钟" Style="{StaticResource Style_FieldLabelText}"
                                   ToolTip="输入 0-150；滑杆 0-25。"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="MinutesDownButton" Content="−" Margin="0,0,2,0"
                                    Style="{StaticResource Style_TimerCompactStepperButton}"
                                    Cursor="Hand" Click="OnMinutesDownClick"
                                    PreviewMouseLeftButtonDown="OnMinutesDownMouseDown" PreviewMouseLeftButtonUp="OnMinutesMouseUp" MouseLeave="OnMinutesMouseLeave"
                                    PreviewTouchDown="OnMinutesDownTouchDown" PreviewTouchUp="OnMinutesTouchUpOrLostCapture" LostTouchCapture="OnMinutesTouchUpOrLostCapture"/>
                            <TextBox x:Name="MinutesBox" Width="68" TextAlignment="Center" FontSize="16"
                                     Style="{StaticResource Style_TimerValueTextBox}" TextChanged="OnMinutesTextChanged"/>
                            <Button x:Name="MinutesUpButton" Content="+" Margin="2,0,0,0"
                                    Style="{StaticResource Style_TimerCompactStepperButton}"
                                    Cursor="Hand" Click="OnMinutesUpClick"
                                    PreviewMouseLeftButtonDown="OnMinutesUpMouseDown" PreviewMouseLeftButtonUp="OnMinutesMouseUp" MouseLeave="OnMinutesMouseLeave"
                                    PreviewTouchDown="OnMinutesUpTouchDown" PreviewTouchUp="OnMinutesTouchUpOrLostCapture" LostTouchCapture="OnMinutesTouchUpOrLostCapture"/>
                        </StackPanel>
                    </Grid>

                    <Slider Grid.Row="1" x:Name="MinutesSlider" Minimum="0" Maximum="25"
                            ValueChanged="OnMinutesSliderChanged"
                            IsSnapToTickEnabled="True" TickFrequency="1"/>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource Style_SettingCardBorder}" Margin="20,0,20,8" Padding="14,12">
                <StackPanel>
                    <TextBlock Text="常用时长" Style="{StaticResource Style_SectionHeaderText}" Margin="0,0,0,8"/>
                    <UniformGrid Columns="3">
                        <Button Content="3 分" Tag="3" Style="{StaticResource Style_TimerPresetButton}" Click="OnPresetMinutesClick"/>
                        <Button Content="5 分" Tag="5" Style="{StaticResource Style_TimerPresetButton}" Click="OnPresetMinutesClick"/>
                        <Button Content="10 分" Tag="10" Style="{StaticResource Style_TimerPresetButton}" Click="OnPresetMinutesClick"/>
                        <Button Content="20 分" Tag="20" Style="{StaticResource Style_TimerPresetButton}" Click="OnPresetMinutesClick"/>
                        <Button Content="30 分" Tag="30" Style="{StaticResource Style_TimerPresetButton}" Click="OnPresetMinutesClick"/>
                        <Button Content="40 分" Tag="40" Style="{StaticResource Style_TimerPresetButton}" Click="OnPresetMinutesClick"/>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource Style_SettingCardBorder}" Margin="20,8,20,18" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="秒" Style="{StaticResource Style_FieldLabelText}"/>
                        <TextBox x:Name="SecondsBox" Width="60" HorizontalAlignment="Right" TextAlignment="Center"
                                 Style="{StaticResource Style_TimerValueTextBox}" TextChanged="OnSecondsTextChanged"/>
                    </Grid>

                    <Slider Grid.Row="1" x:Name="SecondsSlider" Minimum="0" Maximum="59"
                            ValueChanged="OnSecondsSliderChanged"
                            IsSnapToTickEnabled="True" TickFrequency="5"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="4" Style="{StaticResource Style_DialogShellActionBar}">
                <Button Content="取消" Style="{StaticResource Style_DialogShellSecondaryActionButton}" Click="OnCancel"/>
                <Button Content="确定" Style="{StaticResource Style_DialogShellPrimaryActionButton}" Click="OnConfirm"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
