<Window x:Class="ClassroomToolkit.App.TimerSetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置倒计时"
        Height="Auto" Width="380"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{x:Null}">

    <Border Style="{StaticResource Style_DialogShellWindowBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title -->
                <RowDefinition Height="Auto"/> <!-- Mins -->
                <RowDefinition Height="Auto"/> <!-- Quick presets -->
                <RowDefinition Height="Auto"/> <!-- Secs -->
                <RowDefinition Height="Auto"/> <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- 1. 标题 -->
            <Grid Grid.Row="0" Style="{StaticResource Style_DialogShellTitleBar}" MouseLeftButtonDown="OnTitleBarDrag">
                <TextBlock Text="设定时间" Style="{StaticResource Style_DialogShellTitleText}"/>
            </Grid>
            <Border Grid.Row="0" Style="{StaticResource Style_DialogShellDivider}"/>

            <!-- 2. 分钟设置 -->
            <Grid Grid.Row="1" Margin="20,16,20,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="分钟 (0-150，滑杆 0-25)" FontSize="14" Foreground="{StaticResource Brush_Text_Secondary}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="MinutesDownButton" Content="−" Width="28" Height="28" Margin="0,0,2,0"
                                FontSize="16" FontWeight="Bold" Foreground="{StaticResource Brush_Primary}"
                                Style="{StaticResource Style_SecondaryButton}"
                                Padding="0"
                                Cursor="Hand" Click="OnMinutesDownClick"
                                PreviewMouseLeftButtonDown="OnMinutesDownMouseDown" PreviewMouseLeftButtonUp="OnMinutesMouseUp" MouseLeave="OnMinutesMouseLeave">
                        </Button>
                        <TextBox x:Name="MinutesBox" Width="60" TextAlignment="Center" FontWeight="Bold"
                                Foreground="{StaticResource Brush_Primary}" TextChanged="OnMinutesTextChanged"/>
                        <Button x:Name="MinutesUpButton" Content="+" Width="28" Height="28" Margin="2,0,0,0"
                                FontSize="16" FontWeight="Bold" Foreground="{StaticResource Brush_Primary}"
                                Style="{StaticResource Style_SecondaryButton}"
                                Padding="0"
                                Cursor="Hand" Click="OnMinutesUpClick"
                                PreviewMouseLeftButtonDown="OnMinutesUpMouseDown" PreviewMouseLeftButtonUp="OnMinutesMouseUp" MouseLeave="OnMinutesMouseLeave">
                        </Button>
                    </StackPanel>
                </Grid>
                
                <Slider Grid.Row="1" x:Name="MinutesSlider" Minimum="0" Maximum="25"
                        ValueChanged="OnMinutesSliderChanged"
                        IsSnapToTickEnabled="True" TickFrequency="1"/>
            </Grid>

            <!-- 3. 常用时长 -->
            <StackPanel Grid.Row="2" Margin="20,0,20,8">
                <TextBlock Text="常用预设" FontSize="13" Foreground="{StaticResource Brush_Text_Secondary}" Margin="0,0,0,8"/>
                <WrapPanel Orientation="Horizontal" ItemHeight="28">
                    <Button Content="3 分钟" Tag="3" Width="72" Height="28" Margin="0,0,8,8" Style="{StaticResource Style_SecondaryButton}" Click="OnPresetMinutesClick"/>
                    <Button Content="5 分钟" Tag="5" Width="72" Height="28" Margin="0,0,8,8" Style="{StaticResource Style_SecondaryButton}" Click="OnPresetMinutesClick"/>
                    <Button Content="10 分钟" Tag="10" Width="72" Height="28" Margin="0,0,8,8" Style="{StaticResource Style_SecondaryButton}" Click="OnPresetMinutesClick"/>
                    <Button Content="20 分钟" Tag="20" Width="72" Height="28" Margin="0,0,8,8" Style="{StaticResource Style_SecondaryButton}" Click="OnPresetMinutesClick"/>
                    <Button Content="30 分钟" Tag="30" Width="72" Height="28" Margin="0,0,8,8" Style="{StaticResource Style_SecondaryButton}" Click="OnPresetMinutesClick"/>
                    <Button Content="40 分钟" Tag="40" Width="72" Height="28" Margin="0,0,8,8" Style="{StaticResource Style_SecondaryButton}" Click="OnPresetMinutesClick"/>
                </WrapPanel>
            </StackPanel>

            <!-- 4. 秒钟设置 -->
            <Grid Grid.Row="3" Margin="20,8,20,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="秒钟" FontSize="14" Foreground="{StaticResource Brush_Text_Secondary}" VerticalAlignment="Center"/>
                    <TextBox x:Name="SecondsBox" Width="60" HorizontalAlignment="Right" TextAlignment="Center" FontWeight="Bold" Foreground="{StaticResource Brush_Primary}" TextChanged="OnSecondsTextChanged"/>
                </Grid>

                <Slider Grid.Row="1" x:Name="SecondsSlider" Minimum="0" Maximum="59"
                        ValueChanged="OnSecondsSliderChanged"
                        IsSnapToTickEnabled="True" TickFrequency="5"/>
            </Grid>

            <!-- 5. 按钮 -->
            <StackPanel Grid.Row="4" Style="{StaticResource Style_DialogShellActionBar}">
                <Button Content="取消" Style="{StaticResource Style_DialogShellSecondaryActionButton}" Click="OnCancel"/>
                <Button Content="确定" Style="{StaticResource Style_DialogShellPrimaryActionButton}" Click="OnConfirm"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
